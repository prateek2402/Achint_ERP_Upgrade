# =============================================================================
# AchintERP - example .env
# Copy to ".env" (which is gitignored) and fill in real values for your machine.
# Every variable below has a sensible default; nothing here is required to boot.
# =============================================================================

# ----- Application -----
APP_ENV=development                 # development | production
ENABLE_API_DOCS=                    # 1 to force-enable /docs in production; default off in production

# ----- HTTP server (read by `python main.py`) -----
HOST=0.0.0.0                        # 0.0.0.0 = LAN access; 127.0.0.1 = this PC only
PORT=3000                           # firewall (Admin): .\scripts\windows\enable-network-firewall.cmd

# ----- Database -----
APP_DATABASE_URL=sqlite:///./erp_database.sqlite

# ----- Legacy one-time import (from previous AchintERP SQLite export) -----
# Place your export as old_erp.sqlite in the project root, then run:
#   .\\venv\\Scripts\\python.exe migrate_sqlite.py
# Set LEGACY_AUTO_IMPORT=1 only for an intentional one-time replace import on startup.
LEGACY_DB_PATH=old_erp.sqlite
LEGACY_AUTO_IMPORT=0

# ----- Backups & restore drill -----
DB_BACKUP_DIR=db_backups
DB_BACKUP_INTERVAL_SECONDS=86400    # 24 h
KEEP_BACKUPS_DAYS=30                # rotate older auto-backups; 0 disables rotation
DRILL_USER=                         # optional: enables auth checks in restore_drill.py
DRILL_PASSWORD=

# ----- Auth & security -----
JWT_SECRET_KEY=                     # leave blank for ephemeral; SET for stable sessions
PASSWORD_PBKDF2_ROUNDS=210000
JWT_EXPIRY_HOURS=24                 # how long an issued JWT stays valid

# ----- Bootstrap admin (created on first boot if no matching user exists) -----
BOOTSTRAP_ADMIN_USERNAME=
BOOTSTRAP_ADMIN_PASSWORD=

# ----- Rate limiting -----
LOGIN_RATE_LIMIT_WINDOW_SECONDS=300
LOGIN_RATE_LIMIT_MAX_FAILURES=10
UPLOAD_RATE_LIMIT_WINDOW_SECONDS=60
UPLOAD_RATE_LIMIT_MAX_REQUESTS=10
MAX_UPLOAD_FILES_PER_REQUEST=5
MAX_UPLOAD_FILE_SIZE_BYTES=10485760 # 10 MB

# ----- CORS -----
CORS_ALLOW_ORIGINS=                 # comma-separated; empty falls back to local dev origins

# ----- Gemini (PDF extraction) -----
GEMINI_API_KEY=
GEMINI_INVOICE_MODEL=gemini-2.5-flash
GEMINI_PO_MODEL=gemini-2.5-flash
GEMINI_INVOICE_MAX_CONCURRENCY=3
GEMINI_INVOICE_JSON_RETRIES=1

# ----- Logging -----
LOG_LEVEL=INFO                      # DEBUG | INFO | WARNING | ERROR
LOG_JSON=0                          # 1 to emit single-line JSON logs (production); 0 for human-friendly
