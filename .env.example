JWT_SECRET_KEY=replace_with_a_long_random_secret
GEMINI_API_KEY=replace_with_gemini_key

# Optional bootstrap admin (created once on startup if user does not already exist)
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=change_me

# Optional hardening / tuning knobs
PASSWORD_PBKDF2_ROUNDS=210000
UPLOAD_RATE_LIMIT_WINDOW_SECONDS=60
UPLOAD_RATE_LIMIT_MAX_REQUESTS=10
MAX_UPLOAD_FILES_PER_REQUEST=5
MAX_UPLOAD_FILE_SIZE_BYTES=10485760
