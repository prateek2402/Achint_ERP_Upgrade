        async function setSummaryMaterialType(poNoEnc, descEnc, uomEnc, materialType) {
            const poNo = decodeURIComponent(String(poNoEnc || ''));
            const desc = decodeURIComponent(String(descEnc || ''));
            const uom = decodeURIComponent(String(uomEnc || 'Nos')) || 'Nos';
            if (!poNo || !desc) return;
            if (!appData[currentClient].poTerms[poNo]) appData[currentClient].poTerms[poNo] = { baselineItems: [] };
            const items = appData[currentClient].poTerms[poNo].baselineItems || [];
            const norm = normalizeDispatchDesc(desc);
            let idx = items.findIndex(i => normalizeDispatchDesc(i.description || '') === norm && String(i.uom || 'Nos').trim().toUpperCase() === String(uom).trim().toUpperCase());
            if (idx < 0) {
                items.push({ description: desc, ordered_qty: 0, inspected_qty: 0, uom: uom || 'Nos', material_type: null, dispatch_alias: null, dispatch_rate: 0 });
                idx = items.length - 1;
            }
            const updatedItems = items.map(it => ({ ...it }));
            const mt = (materialType || '').trim();
            updatedItems[idx].material_type = (mt === 'brick' || mt === 'castable_mortar') ? mt : null;
            appData[currentClient].poTerms[poNo].baselineItems = updatedItems;
            try {
                await persistSummaryBaseline(poNo, updatedItems);
            } catch (err) {
                return customApplet({ title: "Database Error", message: err.message || "Failed to set material type." });
            }
            await refreshCurrentDispatchContext();
        }

        async function setSummaryDispatchAlias(poNoEnc, descEnc, uomEnc, currentAliasEnc) {
            const poNo = decodeURIComponent(String(poNoEnc || ''));
            const desc = decodeURIComponent(String(descEnc || ''));
            const uom = decodeURIComponent(String(uomEnc || 'Nos')) || 'Nos';
            const currentAlias = decodeURIComponent(String(currentAliasEnc || ''));
            if (!poNo || !desc) return;
            const aliasRaw = await customApplet({
                title: "Set Material Alias",
                message: `Set invoice-upload alias for "${desc}" in PO ${poNo}. Leave blank to clear alias.`,
                type: "prompt",
                placeholder: currentAlias || ''
            });
            if (aliasRaw === null) return;
            const nextAlias = String(aliasRaw || '').trim();
            if (!appData[currentClient].poTerms[poNo]) appData[currentClient].poTerms[poNo] = { baselineItems: [] };
            const items = appData[currentClient].poTerms[poNo].baselineItems || [];
            const norm = normalizeDispatchDesc(desc);
            let idx = items.findIndex(i => normalizeDispatchDesc(i.description || '') === norm && String(i.uom || 'Nos').trim().toUpperCase() === String(uom).trim().toUpperCase());
            if (idx < 0) {
                items.push({ description: desc, ordered_qty: 0, inspected_qty: 0, uom: uom || 'Nos', material_type: null, dispatch_alias: null, dispatch_rate: 0 });
                idx = items.length - 1;
            }
            const updatedItems = items.map(it => ({ ...it }));
            updatedItems[idx].dispatch_alias = nextAlias || null;
            appData[currentClient].poTerms[poNo].baselineItems = updatedItems;
            try {
                await persistSummaryBaseline(poNo, updatedItems);
            } catch (err) {
                return customApplet({ title: "Database Error", message: err.message || "Failed to set dispatch alias." });
            }
            await refreshCurrentDispatchContext();
        }

        function setSummaryMaterialTypeFromSelect(selectEl) {
            if (!selectEl) return;
            const poNo = selectEl.getAttribute('data-po-no') || '';
            const desc = selectEl.getAttribute('data-description') || '';
            const uom = selectEl.getAttribute('data-uom') || 'Nos';
            return setSummaryMaterialType(
                encodeURIComponent(poNo),
                encodeURIComponent(desc),
                encodeURIComponent(uom),
                selectEl.value
            );
        }

        function setSummaryDispatchAliasFromButton(btn) {
            if (!btn) return;
            const poNo = btn.getAttribute('data-po-no') || '';
            const desc = btn.getAttribute('data-description') || '';
            const uom = btn.getAttribute('data-uom') || 'Nos';
            const alias = btn.getAttribute('data-alias') || '';
            return setSummaryDispatchAlias(
                encodeURIComponent(poNo),
                encodeURIComponent(desc),
                encodeURIComponent(uom),
                encodeURIComponent(alias)
            );
        }

        async function deleteSummaryColumn(poNoEnc, descEnc, uomEnc) {
            const poNo = decodeURIComponent(String(poNoEnc || ''));
            const description = decodeURIComponent(String(descEnc || ''));
            const uom = decodeURIComponent(String(uomEnc || ''));
            if (!poNo || !description) return;
            const ok = await customApplet({ title: "Delete Column", message: `Delete material column from PO ${poNo}?\n\n${description}`, type: "confirm" });
            if (!ok) return;
            const token = sessionStorage.getItem('erp_token');
            const response = await fetch('/api/dispatch-columns/delete', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
                body: JSON.stringify({ po_no: poNo, client_id: appData[currentClient]?.sql_id || null, description, uom: uom || null })
            });
            const result = await response.json().catch(() => ({}));
            if (!response.ok) return customApplet({ title: "Database Error", message: result.detail || "Failed to delete dispatch column." });
            await silentDataRefresh();
            renderDispatchReconciliation();
        }

        function deleteSummaryColumnFromButton(btn) {
            if (!btn) return;
            const poNo = btn.getAttribute('data-po-no') || '';
            const desc = btn.getAttribute('data-description') || '';
            const uom = btn.getAttribute('data-uom') || 'Nos';
            return deleteSummaryColumn(
                encodeURIComponent(poNo),
                encodeURIComponent(desc),
                encodeURIComponent(uom)
            );
        }

        async function deleteDispatchMatrixRow(invoiceNoEnc) {
            const invoiceNo = decodeURIComponent(String(invoiceNoEnc || ''));
            if (!invoiceNo) return;
            const ok = await customApplet({ title: "Delete Row", message: `Delete all dispatch entries for invoice ${invoiceNo}?`, type: "confirm" });
            if (!ok) return;
            const token = sessionStorage.getItem('erp_token');
            const response = await fetch(`/api/dispatch-row/${encodeURIComponent(invoiceNo)}`, {
                method: 'DELETE',
                headers: { 'Authorization': 'Bearer ' + token }
            });
            const result = await response.json().catch(() => ({}));
            if (!response.ok) return customApplet({ title: "Database Error", message: result.detail || "Failed to delete dispatch row." });
            await silentDataRefresh();
            renderDispatchReconciliation();
        }

        async function editSummaryOrderedCell(poNo, currentDesc, currentOrdered, currentUom) {
            return withInFlight(`editSummaryOrdered:${poNo}:${currentDesc}`, async () => {
                if (!poNo) return;
                if (!appData[currentClient].poTerms[poNo]) appData[currentClient].poTerms[poNo] = { baselineItems: [] };
                const items = appData[currentClient].poTerms[poNo].baselineItems || [];
                const oldNorm = normalizeDispatchDesc(currentDesc);
                const targetUom = String(currentUom || 'Nos').trim() || 'Nos';
                let idx = items.findIndex(i => normalizeDispatchDesc(i.description || '') === oldNorm && String(i.uom || 'Nos').trim().toUpperCase() === targetUom.toUpperCase());
                // If this material exists only in dispatch rows (not baseline), create baseline placeholder first.
                if (idx < 0) {
                    items.push({
                        description: currentDesc,
                        ordered_qty: 0,
                        inspected_qty: 0,
                        uom: targetUom,
                        material_type: null,
                        dispatch_alias: null,
                        dispatch_rate: 0
                    });
                    idx = items.length - 1;
                }

                const nextOrderedRaw = await customApplet({
                    title: "Edit Ordered Quantity",
                    message: `Enter ordered quantity for:\n\n${currentDesc}`,
                    type: "prompt",
                    placeholder: String(currentOrdered || 0)
                });
                if (nextOrderedRaw === null) return;
                const nextOrdered = parseFloat(nextOrderedRaw);
                if (!Number.isFinite(nextOrdered) || nextOrdered < 0) return await customApplet({ title: "Validation Error", message: "Please enter a valid non-negative ordered quantity." });

                const updatedItems = items.map(it => ({ ...it }));
                updatedItems[idx].ordered_qty = nextOrdered;
                appData[currentClient].poTerms[poNo].baselineItems = updatedItems;
                try {
                    await persistSummaryBaseline(poNo, updatedItems);
                } catch (err) {
                    return customApplet({ title: "Database Error", message: err.message || "Failed to update ordered quantity." });
                }
                await silentDataRefresh();
                renderDispatchReconciliation();
            });
        }

        function editDispatchEntryEncoded(invoiceNoEnc, dispatchItemId, descEnc, qty, inspectedQty, uomEnc) {
            const invoiceNo = decodeURIComponent(String(invoiceNoEnc || ''));
            const description = decodeURIComponent(String(descEnc || ''));
            const uom = decodeURIComponent(String(uomEnc || 'Nos'));
            return editDispatchEntry(invoiceNo, dispatchItemId, description, Number(qty || 0), Number(inspectedQty || 0), uom);
        }

        async function editDispatchEntry(invoiceNo, dispatchItemId, currentDesc, currentQty, currentInspectedQty, currentUom) {
            return withInFlight(`editDispatchEntry:${dispatchItemId}`, async () => {
                if (!dispatchItemId) return await customApplet({ title: "Not Available", message: "This dispatch row cannot be edited because it has no database id." });
                const nextDesc = await customApplet({
                    title: "Edit Dispatch Description",
                    message: `Update material description for invoice ${invoiceNo}:`,
                    type: "prompt",
                    placeholder: currentDesc || ''
                });
                if (nextDesc === null) return;
                const desc = String(nextDesc || '').trim();
                if (!desc) return await customApplet({ title: "Validation Error", message: "Description is required." });

                const nextQtyRaw = await customApplet({
                    title: "Edit Dispatched Quantity",
                    message: `Enter dispatched quantity for:\n\n${desc}`,
                    type: "prompt",
                    placeholder: String(currentQty || 0)
                });
                if (nextQtyRaw === null) return;
                const nextQty = parseFloat(nextQtyRaw);
                if (!Number.isFinite(nextQty) || nextQty < 0) return await customApplet({ title: "Validation Error", message: "Please enter a valid non-negative dispatched quantity." });

                const nextInspectedRaw = await customApplet({
                    title: "Edit Inspected Quantity",
                    message: `Enter inspected quantity for:\n\n${desc}`,
                    type: "prompt",
                    placeholder: String(currentInspectedQty || 0)
                });
                if (nextInspectedRaw === null) return;
                const nextInspected = parseFloat(nextInspectedRaw);
                if (!Number.isFinite(nextInspected) || nextInspected < 0) return await customApplet({ title: "Validation Error", message: "Please enter a valid non-negative inspected quantity." });

                const nextUomRaw = await customApplet({
                    title: "Edit Unit Of Measure",
                    message: `Enter UOM for:\n\n${desc}`,
                    type: "prompt",
                    placeholder: String(currentUom || 'Nos')
                });
                if (nextUomRaw === null) return;
                const nextUom = String(nextUomRaw || '').trim() || 'Nos';

                const token = sessionStorage.getItem('erp_token');
                const response = await fetch(`/api/dispatch-items/${dispatchItemId}`, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
                    body: JSON.stringify({
                        description: desc,
                        qty: nextQty,
                        inspected_qty: nextInspected,
                        uom: nextUom,
                        merge_on_match: true
                    })
                });
                const result = await response.json().catch(() => ({}));
                if (!response.ok) {
                    return await customApplet({ title: "Database Error", message: result.detail || "Failed to update dispatch entry." });
                }

                await silentDataRefresh();
                renderDispatchReconciliation();
                if (result.merged) {
                    await customApplet({ title: "Merged Successfully", message: "Edited description matched another dispatch entry. Rows were merged automatically." });
                }
            });
        }

        async function updateInspectedQty(poNo, materialDesc, currentInspected, uom) {
            let val = await customApplet({
                title: "Log Bulk Inspection",
                message: `Enter total cleared/inspected quantity for PO: ${poNo}<br><br><b>${materialDesc}</b>:`,
                type: "prompt",
                placeholder: currentInspected.toString()
            });

            if (val !== null && !isNaN(parseFloat(val))) {
                if (!appData[currentClient].poTerms[poNo]) appData[currentClient].poTerms[poNo] = { baselineItems: [] };

                let items = appData[currentClient].poTerms[poNo].baselineItems;
                let baseItem = items.find(i => i.description.trim().toUpperCase() === materialDesc.trim().toUpperCase());

                if (baseItem) {
                    baseItem.inspected_qty = parseFloat(val);
                } else {
                    // If material was dispatched but not yet explicitly added to PO baseline, add it now
                    items.push({ description: materialDesc, ordered_qty: 0, inspected_qty: parseFloat(val), uom: uom, material_type: null, dispatch_alias: null, dispatch_rate: 0 });
                }

                // Immediately Sync PO baseline to SQL
                const poData = appData[currentClient].poTerms[poNo];
                const token = sessionStorage.getItem('erp_token');

                const response = await fetch('/api/purchase-orders', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
                    body: JSON.stringify({
                        client_id: appData[currentClient].sql_id, po_no: poNo,
                        project_name: poData.projectName || null, contact_person: poData.contactPerson || null,
                        adv_pct: poData.adv || 0, ret_pct: poData.ret || 0, ret_base: poData.base || 'basic',
                        tds_enabled: poData.tdsEnabled || false, tds_rate: poData.tdsRate || 0, tds_threshold: poData.tdsThreshold || 0,
                        baseline_items: items
                    })
                });
                if (!response.ok) {
                    const result = await response.json().catch(() => ({}));
                    return customApplet({ title: "Database Error", message: result.detail || "Failed to update inspected quantity." });
                }

                renderDispatchReconciliation();
            }
        }

        function updateInspectedQtyEncoded(poNoEnc, materialDescEnc, currentInspected, uomEnc) {
            const poNo = decodeURIComponent(String(poNoEnc || ''));
            const materialDesc = decodeURIComponent(String(materialDescEnc || ''));
            const uom = decodeURIComponent(String(uomEnc || ''));
            return updateInspectedQty(poNo, materialDesc, currentInspected, uom);
        }

        async function updateOrderedQty(poNo, materialDesc, currentOrdered, uom) {
            return withInFlight(`updateOrderedQty:${poNo}:${materialDesc}`, async () => {
                let val = await customApplet({
                    title: "Update Ordered Quantity",
                    message: `Enter ordered quantity for PO: ${poNo}\n\n${materialDesc}:`,
                    type: "prompt",
                    placeholder: currentOrdered.toString()
                });

                if (val !== null && !isNaN(parseFloat(val))) {
                    const orderedVal = Math.max(0, parseFloat(val));
                    if (!appData[currentClient].poTerms[poNo]) appData[currentClient].poTerms[poNo] = { baselineItems: [] };

                    let items = appData[currentClient].poTerms[poNo].baselineItems;
                    let baseItem = items.find(i => i.description.trim().toUpperCase() === materialDesc.trim().toUpperCase());

                    if (baseItem) {
                        baseItem.ordered_qty = orderedVal;
                    } else {
                        items.push({ description: materialDesc, ordered_qty: orderedVal, inspected_qty: 0, uom: uom || 'Nos', material_type: null, dispatch_alias: null, dispatch_rate: 0 });
                    }

                    const poData = appData[currentClient].poTerms[poNo];
                    const token = sessionStorage.getItem('erp_token');

                    const response = await fetch('/api/purchase-orders', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
                        body: JSON.stringify({
                            client_id: appData[currentClient].sql_id, po_no: poNo,
                            project_name: poData.projectName || null, contact_person: poData.contactPerson || null,
                            adv_pct: poData.adv || 0, ret_pct: poData.ret || 0, ret_base: poData.base || 'basic',
                            tds_enabled: poData.tdsEnabled || false, tds_rate: poData.tdsRate || 0, tds_threshold: poData.tdsThreshold || 0,
                            baseline_items: items
                        })
                    });
                    if (!response.ok) {
                        const result = await response.json().catch(() => ({}));
                        return customApplet({ title: "Database Error", message: result.detail || "Failed to update ordered quantity." });
                    }

                    renderDispatchReconciliation();
                }
            });
        }

        function updateOrderedQtyEncoded(poNoEnc, materialDescEnc, currentOrdered, uomEnc) {
            const poNo = decodeURIComponent(String(poNoEnc || ''));
            const materialDesc = decodeURIComponent(String(materialDescEnc || ''));
            const uom = decodeURIComponent(String(uomEnc || ''));
            return updateOrderedQty(poNo, materialDesc, currentOrdered, uom);
        }

        async function addManualBaselineItem() {
            const poNo = document.getElementById('dispatchPoSelect').value;
            if (!poNo) return customApplet({ title: "Error", message: "Select a PO first." });

            let desc = await customApplet({ title: "Manual PO Item", message: "Enter Material Description:", type: "prompt" });
            if (!desc) return;
            let qty = await customApplet({ title: "Manual PO Item", message: `Enter Ordered Quantity for ${desc}:`, type: "prompt" });
            if (!qty || isNaN(parseFloat(qty))) return;
            let uom = await customApplet({ title: "Manual PO Item", message: `Enter Unit of Measure (e.g., MT, Nos):`, type: "prompt" });

            if (!appData[currentClient].poTerms[poNo].baselineItems) appData[currentClient].poTerms[poNo].baselineItems = [];
            appData[currentClient].poTerms[poNo].baselineItems.push({ description: desc, ordered_qty: parseFloat(qty), inspected_qty: 0, uom: uom || 'Nos', material_type: null, dispatch_alias: null, dispatch_rate: 0 });

            // Sync PO to SQL
            const clientObj = appData[currentClient];
            const poData = appData[currentClient].poTerms[poNo];
            const token = sessionStorage.getItem('erp_token');

            await fetch('/api/purchase-orders', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
                body: JSON.stringify({
                    client_id: clientObj.sql_id, po_no: poNo, adv_pct: poData.adv, ret_pct: poData.ret, ret_base: poData.base,
                    project_name: poData.projectName || null, contact_person: poData.contactPerson || null,
                    tds_enabled: poData.tdsEnabled, tds_rate: poData.tdsRate, tds_threshold: poData.tdsThreshold,
                    baseline_items: poData.baselineItems
                })
            });

            renderDispatchReconciliation();
        }

        async function addDispatchAgainstInvoiceManual() {
            return withInFlight('addDispatchAgainstInvoiceManual', async () => {
                const poNo = (document.getElementById('dispatchPoSelect')?.value || '').trim();
                if (!poNo) return customApplet({ title: "Select PO", message: "Select a PO first." });
                const defaults = {
                    invoice_no: '',
                    description: '',
                    qty: '0',
                    inspected_qty: '0',
                    uom: 'Nos'
                };
                const formData = await openDispatchEntryFormModal({
                    title: "Add Dispatch Against Invoice",
                    subtitle: `PO ${poNo}`,
                    fields: [
                        { key: 'invoice_no', label: 'Invoice Number', required: true, placeholder: 'INV-0001' },
                        { key: 'description', label: 'Material Description', required: true, placeholder: 'Material description' },
                        { key: 'qty', label: 'Dispatched Quantity', required: true, type: 'number', min: 0, step: '0.01' },
                        { key: 'inspected_qty', label: 'Inspected Quantity', required: false, type: 'number', min: 0, step: '0.01' },
                        { key: 'uom', label: 'UOM', required: false, placeholder: 'Nos' }
                    ],
                    defaults
                });
                if (!formData) return;
                const invoiceNo = String(formData.invoice_no || '').trim();
                const description = String(formData.description || '').trim();
                const qty = Number(parseFloat(String(formData.qty || '').replace(/,/g, '')));
                const inspectedQty = Number(parseFloat(String(formData.inspected_qty || '0').replace(/,/g, ''))) || 0;
                const uom = String(formData.uom || 'Nos').trim() || 'Nos';
                if (!invoiceNo) return customApplet({ title: "Validation Error", message: "Invoice number is required." });
                if (!description) return customApplet({ title: "Validation Error", message: "Material description is required." });
                if (!Number.isFinite(qty) || qty < 0) return customApplet({ title: "Validation Error", message: "Enter a valid non-negative dispatched quantity." });
                if (!Number.isFinite(inspectedQty) || inspectedQty < 0) return customApplet({ title: "Validation Error", message: "Enter a valid non-negative inspected quantity." });

                const targetInv = (appData[currentClient]?.invoices || []).find(i => String(i.id || '').trim().toUpperCase() === invoiceNo.toUpperCase() && i.poNo === poNo);
                if (!targetInv) {
                    return customApplet({ title: "Invoice Not Found", message: `Invoice ${invoiceNo} was not found under PO ${poNo}. Use "Add New Dispatch Entry" to create a new row.` });
                }

                const token = sessionStorage.getItem('erp_token');
                const response = await fetch('/api/dispatch-items/upsert-cell', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
                    body: JSON.stringify({
                        invoice_no: targetInv.id,
                        description,
                        uom,
                        qty: Number(qty.toFixed(2))
                    })
                });
                const result = await response.json().catch(() => ({}));
                if (!response.ok) return customApplet({ title: "Database Error", message: result.detail || "Failed to add dispatch against invoice." });

                if (inspectedQty > 0) {
                    const normDesc = normalizeDispatchDesc(description);
                    const terms = appData[currentClient]?.poTerms?.[poNo] || {};
                    const baseItems = Array.isArray(terms.baselineItems) ? terms.baselineItems : [];
                    let idx = baseItems.findIndex(i => normalizeDispatchDesc(i.description || '') === normDesc && String(i.uom || 'Nos').trim().toUpperCase() === uom.toUpperCase());
                    if (idx < 0) {
                        baseItems.push({ description, ordered_qty: 0, inspected_qty: Number(inspectedQty.toFixed(2)), uom, material_type: null, dispatch_alias: null, dispatch_rate: 0 });
                    } else {
                        baseItems[idx].inspected_qty = Number(inspectedQty.toFixed(2));
                    }
                    appData[currentClient].poTerms[poNo].baselineItems = baseItems;
                    try {
                        await persistSummaryBaseline(poNo, baseItems);
                    } catch (_) {}
                }

                await silentDataRefresh();
                renderDispatchReconciliation();
            });
        }

        async function addManualDispatchNewEntry() {
            return withInFlight('addManualDispatchNewEntry', async () => {
                const poNo = (document.getElementById('dispatchPoSelect')?.value || '').trim();
                if (!poNo) return customApplet({ title: "Select PO", message: "Select a PO first." });
                const defaults = {
                    invoice_no: '',
                    inv_date: new Date().toISOString().slice(0, 10),
                    lr_no: '',
                    total: '0',
                    description: '',
                    qty: '0',
                    inspected_qty: '0',
                    uom: 'Nos'
                };
                const formData = await openDispatchEntryFormModal({
                    title: "Add New Dispatch Entry",
                    subtitle: `PO ${poNo}`,
                    fields: [
                        { key: 'invoice_no', label: 'Invoice Number', required: true, placeholder: 'INV-NEW-001' },
                        { key: 'inv_date', label: 'Invoice Date', required: false, placeholder: 'YYYY-MM-DD' },
                        { key: 'lr_no', label: 'LR Number', required: false, placeholder: '-' },
                        { key: 'total', label: 'Bill Value (Gross)', required: true, type: 'number', min: 0, step: '0.01' },
                        { key: 'description', label: 'Material Description', required: true, placeholder: 'Material description' },
                        { key: 'qty', label: 'Dispatched Quantity', required: true, type: 'number', min: 0, step: '0.01' },
                        { key: 'inspected_qty', label: 'Inspected Quantity', required: false, type: 'number', min: 0, step: '0.01' },
                        { key: 'uom', label: 'UOM', required: false, placeholder: 'Nos' }
                    ],
                    defaults
                });
                if (!formData) return;
                const invoiceNo = String(formData.invoice_no || '').trim();
                const invDate = String(formData.inv_date || '').trim();
                const lrNo = String(formData.lr_no || '').trim();
                const total = Number(parseFloat(String(formData.total || '').replace(/,/g, '')));
                const description = String(formData.description || '').trim();
                const qty = Number(parseFloat(String(formData.qty || '').replace(/,/g, '')));
                const inspectedQty = Number(parseFloat(String(formData.inspected_qty || '0').replace(/,/g, ''))) || 0;
                const uom = String(formData.uom || 'Nos').trim() || 'Nos';
                if (!invoiceNo) return customApplet({ title: "Validation Error", message: "Invoice number is required." });
                if (invDate && !/^\d{4}-\d{2}-\d{2}$/.test(invDate)) return customApplet({ title: "Validation Error", message: "Date must be in YYYY-MM-DD format." });
                if (!Number.isFinite(total) || total < 0) return customApplet({ title: "Validation Error", message: "Enter a valid non-negative bill value." });
                if (!description) return customApplet({ title: "Validation Error", message: "Material description is required." });
                if (!Number.isFinite(qty) || qty < 0) return customApplet({ title: "Validation Error", message: "Enter a valid non-negative dispatched quantity." });
                if (!Number.isFinite(inspectedQty) || inspectedQty < 0) return customApplet({ title: "Validation Error", message: "Enter a valid non-negative inspected quantity." });

                const token = sessionStorage.getItem('erp_token');
                const existingInv = (appData[currentClient]?.invoices || []).find(i => String(i.id || '').trim().toUpperCase() === invoiceNo.toUpperCase());
                if (existingInv) {
                    return customApplet({ title: "Duplicate Invoice", message: `Invoice ${invoiceNo} already exists. Use "Add Dispatch Against Invoice" instead.` });
                }

                const res = await fetch('/api/invoices', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
                    body: JSON.stringify({
                        client_id: appData[currentClient].sql_id,
                        po_no: poNo,
                        invoice_no: invoiceNo,
                        sub_entity: null,
                        lr_no: lrNo || null,
                        inv_date: invDate || null,
                        due_date: invDate || null,
                        basic: total,
                        gst: 0,
                        total: total,
                        advance_adj: 0,
                        tds_ded: 0,
                        retention_held: 0,
                        net_payable: total,
                        paid: 0,
                        balance: total,
                        is_note: false,
                        note_type: null,
                        note_reason: null,
                        dispatch_items: [{
                            description,
                            qty: Number(qty.toFixed(2)),
                            inspected_qty: Number(inspectedQty.toFixed(2)),
                            uom
                        }]
                    })
                });
                const result = await res.json().catch(() => ({}));
                if (!res.ok) return customApplet({ title: "Database Error", message: result.detail || "Failed to create new dispatch entry." });

                await silentDataRefresh();
                renderDispatchReconciliation();
                return customApplet({ title: "Added", message: `New dispatch entry created for invoice ${invoiceNo}.` });
            });
        }

        function openDispatchEntryFormModal({ title, subtitle = '', fields = [], defaults = {} }) {
            return new Promise((resolve) => {
                const overlay = document.createElement('div');
                overlay.className = 'modal-overlay';
                overlay.style.zIndex = '10010';
                overlay.style.display = 'flex';
                const formHtml = fields.map((f) => `
                    <div class="form-group" style="margin-bottom:10px;">
                        <label style="font-size:0.78rem; font-weight:700; margin-bottom:4px; display:block;">${escHtml(f.label || f.key)}${f.required ? ' *' : ''}</label>
                        <input
                            type="${f.type === 'number' ? 'number' : 'text'}"
                            data-dispatch-form-key="${escHtml(f.key)}"
                            placeholder="${escHtml(f.placeholder || '')}"
                            value="${escHtml(defaults[f.key] ?? '')}"
                            ${f.min !== undefined ? `min="${escHtml(String(f.min))}"` : ''}
                            ${f.step !== undefined ? `step="${escHtml(String(f.step))}"` : ''}
                            style="width:100%;"
                        />
                    </div>
                `).join('');
                overlay.innerHTML = `
                    <div class="modal-content" style="width: 620px; max-width: 96vw;">
                        <div class="modal-header">
                            <h3>${escHtml(title || 'Form')}</h3>
                            <button class="close-btn" data-dispatch-form-cancel>×</button>
                        </div>
                        <div class="modal-body">
                            ${subtitle ? `<div style="font-size:0.8rem; color:var(--text-muted); margin-bottom:10px;">${escHtml(subtitle)}</div>` : ''}
                            ${formHtml}
                        </div>
                        <div style="padding: 20px 24px; display:flex; justify-content:flex-end; gap:12px; background:#f8fafc; border-top:1px solid var(--border); margin-top: 10px;">
                            <button class="btn-outline" data-dispatch-form-cancel>Cancel</button>
                            <button class="btn-primary" data-dispatch-form-submit>Submit</button>
                        </div>
                    </div>
                `;
                document.body.appendChild(overlay);

                const cleanup = (result) => {
                    try { overlay.remove(); } catch (_) {}
                    resolve(result);
                };

                const submit = () => {
                    const data = {};
                    let missingRequired = null;
                    fields.forEach((f) => {
                        const el = overlay.querySelector(`[data-dispatch-form-key="${f.key}"]`);
                        const val = String(el?.value ?? '').trim();
                        data[f.key] = val;
                        if (!missingRequired && f.required && !val) missingRequired = f.label || f.key;
                    });
                    if (missingRequired) {
                        customApplet({ title: "Validation Error", message: `${missingRequired} is required.` });
                        return;
                    }
                    cleanup(data);
                };

                overlay.querySelectorAll('[data-dispatch-form-cancel]').forEach((btn) => {
                    btn.onclick = () => cleanup(null);
                });
                const submitBtn = overlay.querySelector('[data-dispatch-form-submit]');
                submitBtn.onclick = submit;
                overlay.querySelectorAll('input[data-dispatch-form-key]').forEach((inp) => {
                    inp.addEventListener('keydown', (event) => {
                        if (event.key === 'Enter') {
                            event.preventDefault();
                            submit();
                        } else if (event.key === 'Escape') {
                            event.preventDefault();
                            cleanup(null);
                        }
                    });
                });

                const firstInput = overlay.querySelector('input[data-dispatch-form-key]');
                if (firstInput) setTimeout(() => firstInput.focus(), 30);
            });
        }

        async function handleDispatchInvoiceUpload(event) {
            const files = Array.from(event.target.files || []);
            event.target.value = '';
            if (!files.length) return;
            if (!currentClient || !appData[currentClient]) {
                return customApplet({ title: "Unavailable", message: "Client dispatch context is not loaded yet." });
            }
            const selectedPo = (document.getElementById('dispatchPoSelect')?.value || '').trim();
            const token = sessionStorage.getItem('erp_token');
            if (!token) return;

            const formData = new FormData();
            files.forEach(file => formData.append('invoice_pdf', file));

            try {
                const extractRes = await fetch('/api/upload-invoice', {
                    method: 'POST',
                    headers: { 'Authorization': 'Bearer ' + token },
                    body: formData
                });
                const extractData = await extractRes.json().catch(() => ({}));
                if (!extractRes.ok) {
                    return customApplet({ title: "AI Extraction Error", message: extractData.detail || "Failed to extract invoice data." });
                }

                const parsed = [];
                const failed = [];
                (extractData.results || []).forEach((result) => {
                    if (!result || !result.success || !result.raw_data) {
                        failed.push(result?.filename || 'unknown-file');
                        return;
                    }
                    try {
                        const cleanJson = result.raw_data.replace(/```json/g, '').replace(/```/g, '').trim();
                        const data = JSON.parse(cleanJson);
                        parsed.push({ filename: result.filename, data });
                    } catch (e) {
                        failed.push(result.filename || 'unknown-file');
                    }
                });

                if (!parsed.length) {
                    return customApplet({ title: "AI Parse Error", message: "No valid invoice payload could be extracted." });
                }

                let successCount = 0;
                let duplicateCount = 0;
                let failedCount = 0;
                const routedClients = new Set();
                const routedSummary = {};
                for (const p of parsed) {
                    const inv = p.data || {};
                    const invNo = String(inv.invNo || '').trim();
                    if (!invNo) {
                        failedCount += 1;
                        continue;
                    }
                    // Auto-route by extracted clientName when it cleanly matches another known client.
                    const extractedClient = String(inv.clientName || inv.client_name || '').trim();
                    const autoMatched = autoMatchClientByExtractedName(extractedClient);
                    const targetClient = (autoMatched && appData[autoMatched]) ? autoMatched : currentClient;
                    if (!targetClient || !appData[targetClient] || !appData[targetClient].sql_id) {
                        failedCount += 1;
                        continue;
                    }
                    const poFromMatch = autoMatchPoForClient(targetClient, inv.poNo);
                    const poNo = poFromMatch || String(inv.poNo || (targetClient === currentClient ? selectedPo : '') || 'UNASSIGNED').trim() || 'UNASSIGNED';
                    const basic = parseFloat(inv.basic || 0) || 0;
                    const gst = basic > 0 ? basic * 0.18 : 0;
                    const total = basic + gst;
                    const dispatchItems = canonicalizeExtractedDispatchItems(
                        (inv.items || []).map(i => ({
                            description: i.desc || i.description || '',
                            qty: parseFloat(i.qty) || 0,
                            inspected_qty: 0,
                            uom: i.uom || 'Nos',
                            rate_per_uom: parseFloat(i.rate_per_uom ?? i.rate ?? i.unitRate ?? 0) || 0
                        })),
                        targetClient,
                        poNo
                    );
                    const payload = {
                        client_id: appData[targetClient].sql_id,
                        po_no: poNo,
                        invoice_no: invNo,
                        sub_entity: inv.subEntity || '',
                        lr_no: inv.lrNo || '',
                        inv_date: inv.date || null,
                        due_date: null,
                        basic,
                        gst,
                        total,
                        advance_adj: 0,
                        tds_ded: 0,
                        retention_held: 0,
                        net_payable: 0,
                        paid: 0,
                        balance: 0,
                        is_note: false,
                        dispatch_items: dispatchItems
                    };
                    const saveRes = await fetch('/api/invoices', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
                        body: JSON.stringify(payload)
                    });
                    if (saveRes.ok) {
                        successCount += 1;
                        routedClients.add(targetClient);
                        routedSummary[targetClient] = (routedSummary[targetClient] || 0) + 1;
                        continue;
                    }
                    const saveErr = await saveRes.json().catch(() => ({}));
                    if (String(saveErr.detail || '').toLowerCase().includes('already exists')) duplicateCount += 1;
                    else failedCount += 1;
                }

                await openLogisticsDispatchWorkspace(currentClient, selectedPo);
                let msg = `AI processed ${parsed.length} invoice(s).\nSaved: ${successCount}`;
                if (duplicateCount) msg += `\nDuplicates skipped: ${duplicateCount}`;
                if (failedCount || failed.length) msg += `\nFailed: ${failedCount + failed.length}`;
                if (Object.keys(routedSummary).length > 1 || (routedSummary[currentClient] !== successCount && successCount > 0)) {
                    msg += `\n\nAuto-routed by client:`;
                    Object.entries(routedSummary).forEach(([c, n]) => { msg += `\n  • ${c}: ${n}`; });
                }
                await customApplet({ title: "Dispatch Invoice Import Complete", message: msg });
            } catch (error) {
                await customApplet({ title: "Upload Error", message: "Failed to process invoice upload." });
            }
        }

        async function handlePOUpload(event) {
            const file = event.target.files[0];
            if (!file) return;
            const poNo = document.getElementById('dispatchPoSelect').value;
            if (!poNo) return customApplet({ title: "Error", message: "Please select a PO from the dropdown first before uploading its PDF." });

            const formData = new FormData();
            formData.append('po_pdf', file);

            const token = sessionStorage.getItem('erp_token');
            document.getElementById('dispatchUnifiedBody').innerHTML = '<tr><td colspan="6" style="text-align: center; padding: 30px;">AI is reading the Purchase Order PDF...</td></tr>';

            try {
                const response = await fetch('/api/upload-po', {
                    method: 'POST',
                    headers: { 'Authorization': 'Bearer ' + token },
                    body: formData
                });
                const data = await response.json();

                if (data.results && data.results[0].success) {
                    let parsed = JSON.parse(data.results[0].raw_data.replace(/```json/g, '').replace(/```/g, ''));

                    // Attach items to local PO Terms
                    let items = parsed.items.map(i => ({ description: i.desc, ordered_qty: i.qty, uom: i.uom }));
                    appData[currentClient].poTerms[poNo].baselineItems = items;

                    // Push update to SQL
                    const clientObj = appData[currentClient];
                    const poData = appData[currentClient].poTerms[poNo];
                    await fetch('/api/purchase-orders', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
                        body: JSON.stringify({
                            client_id: clientObj.sql_id, po_no: poNo, adv_pct: poData.adv, ret_pct: poData.ret, ret_base: poData.base,
                            project_name: poData.projectName || null, contact_person: poData.contactPerson || null,
                            tds_enabled: poData.tdsEnabled, tds_rate: poData.tdsRate, tds_threshold: poData.tdsThreshold,
                            baseline_items: items
                        })
                    });

                    renderDispatchReconciliation();
                    customApplet({ title: "Success", message: "Purchase Order line items digitized successfully!" });
                }
            } catch (e) {
                renderDispatchReconciliation();
                customApplet({ title: "Extraction Error", message: "Failed to read the PO." });
            }
            event.target.value = '';
        }


    </script>
</body>
<script>
    // Register PWA Service Worker
    if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
            fetch('./sw.js', { method: 'HEAD' })
                .then((res) => {
                    if (!res.ok) return null;
                    return navigator.serviceWorker.register('./sw.js');
                })
                .then((reg) => {
                    if (reg) console.log('Service Worker registered successfully.', reg);
                })
                .catch(err => console.error('Service Worker registration failed:', err));
        });
    }
</script>
</body>

</html>