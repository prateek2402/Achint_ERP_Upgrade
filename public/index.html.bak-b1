        /* Admin screen: identity form + roster split */
        #adminView .split-layout {
            grid-template-columns: minmax(340px, 0.9fr) minmax(640px, 1.5fr);
            gap: 14px;
            align-items: start;
        }

        #adminView .split-layout > .card:first-child {
            position: sticky;
            top: 10px;
        }

        #adminView .table-wrapper {
            max-height: 62vh;
        }

        /* Reports: compact operator control strip */
        #reportsView .portfolio-header {
            border: 1px solid #c7ced8;
            padding: 14px 16px;
        }

        @media (max-width: 1200px) {
            #clientView #dataEntrySection,
            #adminView .split-layout {
                grid-template-columns: 1fr;
            }

            #clientView #invoiceFormCard,
            #adminView .split-layout > .card:first-child {
                position: static;
            }
        }

        /* =========================================================
           Phase-3 Role Emphasis (UI-only, no backend changes)
           ========================================================= */
        body[data-role="admin"] #clientView #dataEntrySection {
            grid-template-columns: minmax(380px, 1fr) minmax(520px, 1.5fr);
        }

        body[data-role="admin"] #clientView #dataEntrySection > .card:first-child {
            order: 2;
        }

        body[data-role="admin"] #clientView #dataEntrySection > .card:nth-child(2) {
            order: 1;
            border: 1px solid #86efac;
            box-shadow: 0 10px 24px rgba(22, 163, 74, 0.12);
        }

        body[data-role="admin"] #clientView #dataEntrySection > .card:nth-child(2) .section-title {
            color: #166534;
        }

        body[data-role="logistics"] #dispatchView .dispatch-toolbar {
            border-color: #93c5fd;
            box-shadow: 0 10px 24px rgba(30, 64, 175, 0.14);
        }

        body[data-role="logistics"] #dispatchView .dispatch-snapshot .dispatch-stat:first-child,
        body[data-role="logistics"] #dispatchView .dispatch-snapshot .dispatch-stat:nth-child(2),
        body[data-role="logistics"] #dispatchView .dispatch-snapshot .dispatch-stat:nth-child(3) {
            border: 1px solid #bfdbfe;
            background: linear-gradient(180deg, #f8fbff 0%, #eff6ff 100%);
            }
    </style>
</head>
<body data-role="user">

    <div class="modal-overlay" id="customAppletOverlay" style="z-index: 10000;">
        <div class="modal-content" style="width: 380px; max-width: 90vw;">
            <div class="modal-header">
                <h3 id="appletTitle">Message</h3>
                <button class="close-btn" id="appletCloseBtn">×</button>
            </div>
            <div class="modal-body" style="padding-bottom: 0;">
                <p id="appletMessage" style="margin-top: 0; font-size: 0.9rem; line-height: 1.5; color: var(--text-main);"></p>
                <div class="form-group" id="appletInputContainer" style="display: none; margin-top: 16px;">
                    <input type="text" id="appletInput" onkeypress="if(event.key === 'Enter') document.getElementById('appletConfirm').click();">
                </div>
            </div>
            <div style="padding: 20px 24px; display: flex; justify-content: flex-end; gap: 12px; background: #f8fafc; border-top: 1px solid var(--border); margin-top: 20px;">
                <button class="btn-outline" id="appletCancel">Cancel</button>
                <button class="btn-primary" id="appletConfirm">OK</button>
            </div>
        </div>
    </div>

    <div class="modal-overlay" id="poBalancesModal">
        <div class="modal-content" style="width: 600px; max-width: 95vw;">
            <div class="modal-header">
                <h3>Active PO Advance Balances</h3>
                <button class="close-btn" onclick="document.getElementById('poBalancesModal').style.display='none'">×</button>
            </div>
            <div class="modal-body" style="padding: 0;">
                <table style="min-width: 100%;">
                    <thead style="position: sticky; top: 0; z-index: 20; background: #f8fafc;">
                        <tr>
                            <th style="text-align: left; padding: 12px 16px; border-bottom: 2px solid var(--border-dark);">PO Number</th>
                            <th style="text-align: right; padding: 12px 16px; border-bottom: 2px solid var(--border-dark);">Available Balance</th>
                            <th style="text-align: center; padding: 12px 16px; border-bottom: 2px solid var(--border-dark);">Action</th>
                        </tr>
                    </thead>
                    <tbody id="poBalancesTableBody"></tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="modal-overlay" id="paymentHistoryModal">
        <div class="modal-content" style="width: 800px; max-width: 95vw;">
            <div class="modal-header">
                <h3>Transaction Ledger</h3>
                <button class="close-btn" onclick="document.getElementById('paymentHistoryModal').style.display='none'">×</button>
            </div>
            <div class="modal-body" style="padding: 0;">
                <div class="table-wrapper" style="border: none; border-radius: 0; box-shadow: none; max-height: 500px;">
                    <table style="min-width: 100%;">
                        <thead style="position: sticky; top: 0; z-index: 20;">
                            <tr>
                                <th style="text-align: left; padding: 12px 16px;">Date</th>
                                <th style="text-align: left; padding: 12px 16px;">Type</th>
                                <th style="text-align: right; padding: 12px 16px;">Amount</th>
                                <th style="text-align: left; padding: 12px 16px;">Allocation Details</th>
                                <th style="text-align: center; padding: 12px 16px;">Action</th>
                            </tr>
                        </thead>
                        <tbody id="paymentHistoryTableBody"></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="modal-overlay" id="poExcessAppletModal">
        <div class="modal-content" style="width: 900px; max-width: 96vw;">
            <div class="modal-header">
                <h3>PO Excess Payment Applet</h3>
                <button class="close-btn" onclick="document.getElementById('poExcessAppletModal').style.display='none'">×</button>
            </div>
            <div class="modal-body" style="padding: 0;">
                <div style="display:flex; gap:10px; align-items:center; padding:12px 16px; border-bottom:1px solid var(--border); background:#f8fafc;">
                    <span style="font-size:0.78rem; font-weight:700; color:var(--text-muted);">PO Filter</span>
                    <select id="poExcessFilter" style="min-width:220px;" onchange="renderExcessPoAppletRows()">
                        <option value="">All PO Excess Entries</option>
                    </select>
                    <span id="poExcessAppletHint" style="font-size:0.75rem; color:var(--text-muted); margin-left:auto;">Shows PO-excess receipts and history. You can delete the source payment record directly.</span>
                </div>
                <div class="table-wrapper" style="border: none; border-radius: 0; box-shadow: none; max-height: 500px;">
                    <table style="min-width: 100%;">
                        <thead style="position: sticky; top: 0; z-index: 20;">
                            <tr>
                                <th style="text-align: left; padding: 12px 16px;">Date</th>
                                <th style="text-align: left; padding: 12px 16px;">PO</th>
                                <th style="text-align: left; padding: 12px 16px;">Type</th>
                                <th style="text-align: right; padding: 12px 16px;">Amount</th>
                                <th style="text-align: left; padding: 12px 16px;">Details</th>
                                <th style="text-align: center; padding: 12px 16px;">Action</th>
                            </tr>
                        </thead>
                        <tbody id="poExcessAppletBody"></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="modal-overlay" id="poTermsModal">
        <div class="modal-content" style="width: 700px; max-width: 95vw;">
            <div class="modal-header">
                <h3>PO Payment Terms Configurator</h3>
                <button class="close-btn" onclick="document.getElementById('poTermsModal').style.display='none'">×</button>
            </div>
            <div class="modal-body" style="padding: 24px;">
                <div style="background: #f8fafc; padding: 16px; border-radius: var(--radius-md); border: 1px solid var(--border); margin-bottom: 24px;">
                    <h4 style="margin: 0 0 12px 0; font-size: 0.85rem; color: var(--text-dark);">+ Add/Update Terms for a PO</h4>

                    <div style="display:flex; gap:10px; align-items: center; margin-bottom: 12px;">
                        <input type="text" id="newTermPo" placeholder="PO Number" style="flex:2;">
                        <input type="text" id="newTermProjectName" placeholder="Project Name" style="flex:2;">
                        <input type="text" id="newTermContactPerson" placeholder="Contact Person" style="flex:1.6;">
                        <input type="number" id="newTermAdv" placeholder="Adv %" style="flex:1;" title="Advance Percentage">
                        <input type="number" id="newTermRet" placeholder="Ret %" style="flex:1;" title="Retention Percentage">
                        <select id="newTermBase" style="flex:1.5;" title="Retention Base">
                            <option value="total">Ret. on Gross</option>
                            <option value="basic">Ret. on Basic</option>
                        </select>
                    </div>

                    <div style="border-top: 1px dashed var(--border-dark); padding-top: 12px; margin-top: 12px;">
                        <label style="display:flex; align-items:center; gap:8px; font-weight:bold; margin-bottom: 10px; cursor:pointer;">
                            <input type="checkbox" id="newTermTdsEnabled" checked style="width:16px; height:16px; accent-color: var(--brand-primary);" onchange="document.getElementById('tdsConfigGrid').style.opacity = this.checked ? '1' : '0.4'; document.getElementById('tdsConfigGrid').style.pointerEvents = this.checked ? 'auto' : 'none';">
                            Enable Dynamic TDS Calculation for this PO
                        </label>
                        <div id="tdsConfigGrid" style="display:grid; grid-template-columns: 1fr 1fr 1fr; gap:10px; transition: 0.2s;">
                            <input type="number" id="newTermTdsRate" placeholder="TDS Rate (%)" value="0.1" title="TDS Percentage (e.g., 0.1 for 0.1%)">
                            <select id="newTermTdsBase" title="Base Value to calculate TDS on">
                                <option value="basic">TDS on Basic</option>
                                <option value="total">TDS on Gross</option>
                            </select>
                            <input type="number" id="newTermTdsThreshold" placeholder="Threshold (₹)" value="5000000" title="Billing threshold before TDS applies">
                            <input type="number" id="newTermPoBasic" placeholder="Expected PO Total Value (₹)" style="grid-column: span 3;" title="The total expected value of this PO to calculate proportional TDS">
                        </div>

                        <button class="btn-primary" style="width: 100%; margin-top: 12px;" onclick="addPoTerm()">Save Settings</button>
                    </div>


                </div>
            </div>
            <div class="table-wrapper" style="box-shadow: none; border: 1px solid var(--border); border-radius: var(--radius-md); max-height: 300px;">
                <table style="min-width: 100%;">
                    <thead style="position: sticky; top: 0; z-index: 20;">
                        <tr>
                            <th style="text-align: left; padding: 12px 16px;">PO Number</th>
                            <th style="text-align: left; padding: 12px 16px;">Project / Contact</th>
                            <th style="text-align: center; padding: 12px 16px;">Adv / Ret %</th>
                            <th style="text-align: center; padding: 12px 16px;">TDS Logic</th>
                            <th style="text-align: center; padding: 12px 16px;">Action</th>
                        </tr>
                    </thead>
                    <tbody id="poTermsTableBody"></tbody>
                </table>
            </div>
        </div>
    </div>
    </div>

    <div class="modal-overlay" id="bulkReviewModal">
        <div class="modal-content" style="width: 1000px; max-width: 95vw;">
            <div class="modal-header">
                <h3 style="font-size:1.1rem;">Bulk Invoice Review</h3>
                <button class="close-btn" onclick="document.getElementById('bulkReviewModal').style.display='none'">×</button>
            </div>
            <div class="modal-body" style="padding: 0; max-height: 60vh; overflow-y: auto;">
                <table style="min-width: 100%;">
                    <thead style="position: sticky; top: 0; z-index: 20;">
                        <tr>
                            <th style="text-align:left;">Document</th>
                            <th style="text-align:left;">Invoice No</th>
                            <th style="text-align:left;">Sub-Entity</th>
                            <th style="text-align:left;">PO No</th>
                            <th style="text-align:left;">LR No</th>
                            <th style="text-align:left;">Date</th>
                            <th style="text-align:right;">Basic (₹)</th>
                            <th style="text-align:center;">GST</th>
                            <th style="text-align:center;">TDS</th>
                        </tr>
                    </thead>
                    <tbody id="bulkReviewTableBody"></tbody>
                </table>
            </div>
            <div style="padding: 16px 24px; border-top: 1px solid var(--border); background: #f8fafc; display: flex; justify-content: space-between; align-items: center;">
                <span id="bulkReviewStatus" style="font-size: 0.8rem; font-weight: 600; color: var(--text-muted);">Please review extracted values.</span>
                <div style="display:flex; gap:12px;">
                    <button class="btn-outline" onclick="document.getElementById('bulkReviewModal').style.display='none'">Discard Batch</button>
                    <button class="btn-success" onclick="commitBulkInvoices()">Commit & Save Files</button>
                </div>
            </div>
        </div>
    </div>

    <div class="modal-overlay" id="bulkEditModal">
        <div class="modal-content" style="width: 580px;">
            <div class="modal-header">
                <h3>Bulk Edit Selected Records</h3>
                <button class="close-btn" onclick="document.getElementById('bulkEditModal').style.display='none'">×</button>
            </div>
            <div class="modal-body">
                <p style="font-size: 0.75rem; color: var(--text-muted); margin-top: 0; margin-bottom: 16px;">Leave a field completely blank to keep its existing values.</p>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 24px;">
                    <div class="form-group" style="margin-bottom: 0;">
                        <label>New PO Number</label>
                        <input type="text" id="bulkPoNo" placeholder="Leave blank to skip...">
                    </div>
                    <div class="form-group" style="margin-bottom: 0;">
                        <label>New Sub-Entity</label>
                        <input type="text" id="bulkSubEntity" placeholder="Leave blank to skip...">
                    </div>

                    <div class="form-group" style="margin-bottom: 0;">
                        <label>New Invoice Date</label>
                        <input type="date" id="bulkInvDate">
                    </div>
                    <div class="form-group" style="margin-bottom: 0;">
                        <label>New Due Date</label>
                        <input type="date" id="bulkDueDate">
                    </div>

                    <div class="form-group" style="grid-column: span 2; margin-bottom: 0;">
                        <label>New LR Number</label>
                        <input type="text" id="bulkLrNo" placeholder="Leave blank to skip...">
                    </div>

                    <div class="form-group" style="margin-bottom: 0; padding-top: 12px; border-top: 1px dashed var(--border);">
                        <label>New Basic Value (₹)</label>
                        <input type="number" id="bulkBasic" placeholder="Leave blank...">
                    </div>
                    <div class="form-group" style="margin-bottom: 0; padding-top: 12px; border-top: 1px dashed var(--border);">
                        <label>New Advance Adj. (₹)</label>
                        <input type="number" id="bulkAdvance" placeholder="Leave blank...">
                    </div>

                    <div class="form-group" style="margin-bottom: 0;">
                        <label>New TDS Ded. (₹)</label>
                        <input type="number" id="bulkTds" placeholder="Leave blank...">
                    </div>
                    <div class="form-group" style="margin-bottom: 0;">
                        <label>New Retention (₹)</label>
                        <input type="number" id="bulkRet" placeholder="Leave blank...">
                    </div>
                </div>

                <button class="btn-primary" style="width: 100%;" onclick="executeBulkEdit()">Apply Changes to Selected</button>
            </div>
        </div>
    </div>

    <div class="modal-overlay" id="transferModal">
        <div class="modal-content" style="width: 400px;">
            <div class="modal-header">
                <h3>Transfer Records</h3>
                <button class="close-btn" onclick="document.getElementById('transferModal').style.display='none'">×</button>
            </div>
            <div class="modal-body">
                <p style="font-size: 0.75rem; color: var(--danger); font-weight: bold; margin-top: 0;">Notice: Transferring will wipe payment allocations from the moved/copied invoice to protect ledger pools.</p>
                <div class="form-group" style="margin-bottom: 16px;">
                    <label>Action</label>
                    <select id="transferAction">
                        <option value="move">Move (Remove from current client)</option>
                        <option value="copy">Copy (Duplicate into target client)</option>
                    </select>
                </div>
                <div class="form-group" style="margin-bottom: 24px;">
                    <label>Destination Account</label>
                    <select id="transferClientSelect"></select>
                </div>
                <button class="btn-primary" style="width: 100%;" onclick="executeTransfer()">Execute Transfer</button>
            </div>
        </div>
    </div>

    <div class="modal-overlay" id="dnCnModal">
        <div class="modal-content" style="width: 450px;">
            <div class="modal-header">
                <h3>Issue Credit / Debit Note</h3>
                <button class="close-btn" onclick="document.getElementById('dnCnModal').style.display='none'">×</button>
            </div>
            <div class="modal-body">
                <div class="form-group" style="margin-bottom: 12px;">
                    <label>Note Type</label>
                    <select id="noteType" onchange="updateNoteUI()" style="font-weight:bold;">
                        <option value="CN">Credit Note (Reduces Due Amount)</option>
                        <option value="DN">Debit Note (Increases Due Amount)</option>
                    </select>
                </div>
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 12px;">
                    <div class="form-group" style="margin-bottom: 0;">
                        <label>Document Number</label>
                        <input type="text" id="noteNo" placeholder="e.g., CN-2026-001">
                    </div>
                    <div class="form-group" style="margin-bottom: 0;">
                        <label>Date Issued</label>
                        <input type="date" id="noteDate">
                    </div>
                </div>
                <div class="form-group" style="margin-bottom: 12px;">
                    <label>Apply Against Invoice</label>
                    <select id="noteInvSelect"></select>
                </div>
                <div class="form-group" style="margin-bottom: 12px;">
                    <label>Amount (₹)</label>
                    <input type="number" id="noteAmt" placeholder="0.00" style="font-size: 1.1rem; font-weight: bold;">
                </div>
                <div class="form-group" style="margin-bottom: 24px;">
                    <label>Reason / Remarks</label>
                    <input type="text" id="noteReason" placeholder="e.g., Material damage, Rate difference...">
                </div>
                <button class="btn-success" style="width: 100%; border: none;" id="btnSaveNote" onclick="executeIssueNote()">Issue Note</button>
            </div>
        </div>
    </div>

    <div class="modal-overlay" id="columnModal">
        <div class="modal-content">
            <div class="modal-header">
                <h3>Layout Configuration</h3>
                <button class="close-btn" onclick="closeColumnManager()">×</button>
            </div>
            <div class="modal-body" id="columnList" style="padding:16px;"></div>

            <div style="padding:16px; background:#f8fafc; border-top:1px solid var(--border);">
                <h4 style="margin:0 0 10px 0; font-size:0.85rem; color:var(--text-dark);">+ Add Custom Column</h4>
                <div style="display:flex; gap:8px; align-items:center;">
                    <input type="text" id="newColName" placeholder="Col Name" style="width:120px; height:32px; font-size:0.75rem;">
                    <select id="newColType" style="width:100px; height:32px; font-size:0.75rem;" onchange="document.getElementById('newColFormula').style.display = this.value === 'calc' ? 'block' : 'none'">
                        <option value="text">Text Field</option>
                        <option value="calc">Calculated</option>
                    </select>
                    <input type="text" id="newColFormula" placeholder="e.g. basic * 0.1" style="display:none; flex:1; height:32px; font-size:0.75rem;">
                    <button class="btn-primary btn-sm" style="height:32px;" onclick="addCustomColumn()">Add</button>
                </div>
                <div style="font-size:0.65rem; color:var(--text-muted); margin-top:6px;">Calculated vars: basic, gst, gross, advance, tds, retention, netPayable, realized, balance</div>
            </div>

            <div style="padding: 16px 20px; border-top: 1px solid var(--border); background: #fff; text-align: right; display: flex; justify-content: space-between; align-items: center;">
                <p style="font-size: 0.75rem; color: var(--text-muted); margin: 0; font-weight: 500;">Drag the ⋮⋮ handle to reorder.</p>
                <button class="btn-primary btn-sm" onclick="closeColumnManager()">Apply Configuration</button>
            </div>
        </div>
    </div>

    <div class="modal-overlay" id="dispatchColumnModal">
        <div class="modal-content" style="width: 560px;">
            <div class="modal-header">
                <h3>Dispatch Table Layout</h3>
                <button class="close-btn" onclick="closeDispatchColumnManager()">×</button>
            </div>
            <div class="modal-body" style="padding:16px;">
                <h4 style="margin: 0 0 8px 0; font-size:0.82rem; color:var(--text-dark);">Summary Columns</h4>
                <div id="dispatchSummaryColumnList" style="display:grid; grid-template-columns:1fr 1fr; gap:8px; margin-bottom:14px;"></div>
                <h4 style="margin: 0 0 8px 0; font-size:0.82rem; color:var(--text-dark);">Invoice-Wise Columns</h4>
                <div id="dispatchHistoryColumnList" style="display:grid; grid-template-columns:1fr 1fr; gap:8px; margin-bottom:14px;"></div>
                <div style="display:flex; justify-content:flex-end; gap:10px;">
                    <button class="btn-outline btn-sm" onclick="resetDispatchTablePrefs()">Reset Default</button>
                    <button class="btn-primary btn-sm" onclick="closeDispatchColumnManager()">Apply</button>
                </div>
            </div>
        </div>
    </div>

    <div class="modal-overlay" id="passwordModal">
        <div class="modal-content" style="width: 360px;">
            <div class="modal-header">
                <h3 id="pwdModalTitle" style="font-size:1.05rem;">Update Security Key</h3>
                <button class="close-btn" onclick="closePasswordModal()">×</button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="pwdTargetUserId" value="">
                <div class="form-group" id="currentPwdGroup" style="margin-bottom: 12px; display:none;">
                    <label>Current Password</label>
                    <input type="password" id="currentPwdInput" placeholder="Enter current password...">
                </div>
                <div class="form-group" style="margin-bottom: 20px;">
                    <label>New Access Password</label>
                    <input type="password" id="newPwdInput" placeholder="Enter highly secure password...">
                </div>
                <button class="btn-primary" style="width:100%;" onclick="submitPasswordChange()">Update Identity Key</button>
                <div id="pwdMsg" style="margin-top: 12px; font-size: 0.8rem; font-weight: 600; text-align: center;"></div>
            </div>
        </div>
    </div>

    <div class="modal-overlay" id="accountDetailsModal">
        <div class="modal-content" style="width: 380px;">
            <div class="modal-header">
                <h3 style="font-size:1.05rem;">Account Details</h3>
                <button class="close-btn" onclick="closeAccountDetailsModal()">×</button>
            </div>
            <div class="modal-body">
                <div class="form-group" style="margin-bottom: 12px;">
                    <label>Username</label>
                    <input type="text" id="accDetailUsername" disabled>
                </div>
                <div class="form-group" style="margin-bottom: 12px;">
                    <label>Role</label>
                    <input type="text" id="accDetailRole" disabled>
                </div>
                <div class="form-group" style="margin-bottom: 6px;">
                    <label>User ID</label>
                    <input type="text" id="accDetailUserId" disabled>
                </div>
            </div>
        </div>
    </div>

    <div class="modal-overlay" id="editPaymentModal">
        <div class="modal-content" style="width: 400px;">
            <div class="modal-header">
                <h3>Edit Transaction Record</h3>
                <button class="close-btn" onclick="document.getElementById('editPaymentModal').style.display='none'">×</button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="editPaymentId">
                <div class="form-group" style="margin-bottom: 16px;">
                    <label>Receipt Amount (₹)</label>
                    <input type="number" id="editPaymentAmt" style="font-weight: bold; font-size: 1.1rem; color: var(--brand-primary);">
                    <div style="font-size: 0.65rem; color: var(--text-muted); margin-top: 4px;">*Amount editing is locked for auto-allocations. Use 'Redistribute' instead.</div>
                </div>
                <div class="form-group" style="margin-bottom: 24px;">
                    <label>Transaction Notes / Remarks</label>
                    <input type="text" id="editPaymentNote" placeholder="Update your notes here...">
                </div>
                <button class="btn-primary" style="width: 100%; border: none;" onclick="savePaymentEdit()">Save Changes & Recalculate</button>
            </div>
        </div>
    </div>

    <div id="loginOverlay" class="login-overlay">
        <div class="login-card">
            <div style="text-align: center; margin-bottom: 24px;">
                <img src="data:image/svg+xml;base64," style="height: 56px; margin-bottom: 12px;" alt="Achint Chemicals Logo">
                <h2 style="margin:0; color: var(--text-dark); font-size: 1.4rem; font-weight: 800;">Achint Chemicals</h2>
                <p style="color: var(--brand-secondary); margin: 4px 0 0 0; font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 1px;">Accounts ERP Platform</p>
                <p style="margin:8px 0 0 0; font-size:0.72rem; color:var(--text-muted); font-weight:600;">High Performance Refractories</p>
            </div>
            <div class="form-group" style="margin-bottom: 16px;">
                <label>Secure Username</label>
                <input type="text" id="loginUser" placeholder="Enter username...">
            </div>
            <div class="form-group" style="margin-bottom: 24px;">
                <label>Authentication Key</label>
                <input type="password" id="loginPass" placeholder="Enter password..." onkeypress="if(event.key === 'Enter') performLogin()">
            </div>
            <button class="btn-primary" style="width: 100%;" onclick="performLogin()">Secure Sign In</button>
            <div id="loginError" style="color: var(--danger); margin-top: 16px; font-size: 0.8rem; font-weight: bold; text-align: center;"></div>
        </div>
    </div>
    <aside class="sidebar" id="mainSidebar">
        <div class="sidebar-header">
            <img src="data:image/svg+xml;base64," alt="Achint Logo">
            <div class="brand-details">
                <h2>ACHINT</h2>
                <p>ERP Portal</p>
            </div>
            <button class="hamburger" onclick="toggleSidebar()">☰</button>
        </div>
        <div class="nav-menu" id="clientNavList"></div>
    </aside>

    <main class="main-content">
        <header class="topbar">
            <div style="display: flex; align-items: center; gap: 24px;">
                <button id="btnTopBack" class="btn-outline btn-sm" style="display: none; padding: 0 12px; height: 30px; font-weight: 700; color: var(--text-dark); border-color: var(--border-dark); align-items: center; gap: 6px; background: #f8fafc;" onclick="goBack()" title="Return to Dashboard">
                    <span style="font-size: 1.1rem; line-height: 1;">←</span> Back
                </button>
                <h1 id="topbarTitle" style="margin: 0; font-size: 1.2rem; font-weight: 700; color: var(--text-dark); letter-spacing: -0.5px;">Client Portfolio</h1>
                <div id="clientActions" style="display:none; gap: 8px;">
                    <button class="btn-outline btn-sm" id="btnEditClient" onclick="editCurrentClient()">Rename</button>
                    <button class="btn-outline btn-sm" id="btnToggleClientStatus" onclick="toggleClientActive()"></button>
                    <button class="btn-outline btn-sm text-danger" id="btnDelClient" onclick="deleteCurrentClient()">Delete</button>
                </div>
            </div>

            <div class="user-menu-container" id="userMenuTop" style="display: none;">
                <button class="btn-outline btn-sm" id="btnFxRate" onclick="setExchangeRate()" title="Set Exchange Rate" style="border-color: var(--border-dark); color: var(--text-dark); font-weight: 600;">FX 1 USD = ₹<span id="exRateDisplay">83.00</span></button>
                <button class="btn-primary btn-sm" onclick="toggleDisplayCurrency()" id="btnDisplayCur" style="width:100px;">View in USD</button>
                <div class="user-menu-dropdown" id="topUserMenuWrap">
                    <button class="user-icon-btn" id="btnUserMenu" onclick="toggleUserMenu()" title="User Menu">
                        <span id="topUserInitial">U</span>
                    </button>
                    <div class="user-dropdown-panel" id="topUserDropdown" style="display:none;">
                        <div class="user-menu-meta">
                            <div class="user-greeting" id="topGreeting"></div>
                        </div>
                        <button class="user-dropdown-item" onclick="openAccountDetailsModal()">Account Details</button>
                        <button class="user-dropdown-item" onclick="openPasswordModal('self')">Change Password</button>
                        <button class="user-dropdown-item danger" onclick="performLogout()">Logout</button>
                    </div>
                </div>
            </div>
        </header>

        <div class="scroll-area">
            <div id="landingView">
                <div class="portfolio-header">
                    <div>
                        <h3 class="section-title" id="landingSectionTitle" style="border:none; padding:0;">Active Accounts Directory</h3>
                        <div style="display:flex; gap:12px; align-items:center; margin-top: -12px;">
                            <input type="text" id="dashSearch" placeholder="Search accounts..." style="width:240px;" oninput="debounceByKey('dashSearch', renderLandingPage, 120)">
                            <select id="dashSort" style="width:180px;" onchange="renderLandingPage()">
                                <option value="az">Sort: A-Z</option>
                                <option value="pendingDesc">Highest Pending</option>
                                <option value="unallocatedDesc">Highest Unallocated</option>
                            </select>
                        </div>
                    </div>
                    <div class="client-form" id="addClientSection">
                        <div class="form-group">
                            <input type="text" id="newClientName" placeholder="Enter new plant or contractor name...">
                        </div>
                        <button type="button" class="btn-primary" onclick="addClient()">+ Establish Account</button>
                    </div>
                </div>
                <div class="client-grid" id="clientGrid"></div>
            </div>

            <div id="logisticsLandingView" style="display: none;">
                <header style="margin-bottom: 24px;">
                    <h2 id="logisticsBoardTitle" style="margin: 0; color: var(--text-dark);">Dispatch Operations Console</h2>
                    <p id="logisticsBoardSubcopy" style="margin: 4px 0 0 0; color: var(--text-muted); font-size: 0.9rem;">Dispatch-only workspace for statement tracking and shipment progress.</p>
                </header>

                <div class="dispatch-ui-section-label">Operations Snapshot</div>
                <div class="kpi-row" style="grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); margin-bottom: 16px;">
                    <div class="kpi-card blue">
                        <div class="kpi-label">Dispatched Trucks</div>
                        <div class="kpi-value" id="lgDispatchedTrucks">0</div>
                    </div>
                    <div class="kpi-card red">
                        <div class="kpi-label">Statements Pending</div>
                        <div class="kpi-value" id="lgStmtPending">0</div>
                    </div>
                    <div class="kpi-card green">
                        <div class="kpi-label">Dispatched Today</div>
                        <div class="kpi-value" id="lgDispatchedToday">0</div>
                    </div>
                    <div class="kpi-card purple">
                        <div class="kpi-label">Pending Qty</div>
                        <div class="kpi-value" id="lgPendingQty">0</div>
                    </div>
                </div>

                <div class="dispatch-ui-section-label">Statement Filters</div>
                <div class="filter-bar" style="margin-bottom: 12px;">
                    <input type="text" id="logisticsDispatchSearch" placeholder="Search by client or PO..." style="max-width: 320px;" oninput="debounceByKey('logisticsDispatchSearch', renderGlobalDispatchBoard, 120)">
                    <select id="logisticsDispatchStatus" style="width: 180px;" onchange="renderGlobalDispatchBoard()">
                        <option value="">All Statements</option>
                        <option value="pending">Pending Only</option>
                        <option value="cleared">Cleared Only</option>
                    </select>
                    <button class="btn-outline btn-sm" onclick="renderGlobalDispatchBoard()">Refresh</button>
                    <button class="btn-outline btn-sm" onclick="openLogisticsClientDirectoryView()">All Clients</button>
                </div>
                <div class="filter-bar" style="margin-bottom: 12px;">
                    <input type="text" id="logisticsClientQuickSearch" placeholder="Quick client find..." style="max-width: 280px;" oninput="renderGlobalDispatchBoard()">
                </div>

                <div class="dispatch-ui-section-label">Dispatch Summary Board</div>
                <div class="client-grid" id="logisticsClientGrid" style="margin-bottom: 14px;"></div>

                <div class="card" style="padding: 0; overflow-y: auto; max-height: 48vh; border: 1px solid var(--border-dark);">
                    <table style="width: 100%; border-collapse: collapse; font-size: 0.9rem;">
                        <thead style="background: #1e293b; color: #fff; position: sticky; top: 0; z-index: 10;">
                            <tr>
                                <th style="padding: 14px 16px; text-align: left;">Client</th>
                                <th style="padding: 14px 16px; text-align: left;">PO Number</th>
                                <th style="padding: 14px 16px; text-align: right;">Materials</th>
                                <th style="padding: 14px 16px; text-align: right;">Ordered</th>
                                <th style="padding: 14px 16px; text-align: right; color: #38bdf8;">Dispatched</th>
                                <th style="padding: 14px 16px; text-align: right; color: #4ade80;">Inspected</th>
                                <th style="padding: 14px 16px; text-align: right; color: #f87171;">Pending</th>
                                <th style="padding: 14px 16px; text-align: center;">Completion</th>
                                <th style="padding: 14px 16px; text-align: center;">Statement</th>
                            </tr>
                        </thead>
                        <tbody id="globalDispatchBody">
                        </tbody>
                    </table>
                </div>

                <div class="dispatch-ui-section-label">Statement Detail</div>
                <div class="card" style="margin-top: 14px;">
                    <div style="display:flex; justify-content:space-between; align-items:center; gap:12px; flex-wrap:wrap;">
                        <h3 style="margin:0; border:none; padding:0;">Dispatch Statement Detail</h3>
                        <div style="display:flex; align-items:center; gap:10px; flex-wrap:wrap;">
                            <div id="logisticsStatementMeta" style="font-size:0.82rem; color:var(--text-muted);">Select a statement from the dashboard to view line-level dispatch details.</div>
                            <button class="btn-outline btn-sm" onclick="exportSelectedLogisticsDispatchExcel()">Export Dispatch Excel</button>
                        </div>
                    </div>
                    <div style="margin-top: 10px; overflow:auto; max-height: 26vh; border: 1px solid var(--border); border-radius: 8px;">
                        <table style="width: 100%; border-collapse: collapse; font-size: 0.84rem;">
                            <thead style="background: #334155; color: #fff; position: sticky; top: 0;">
                                <tr>
                                    <th style="padding: 10px 12px; text-align: left;">Material Description</th>
                                    <th style="padding: 10px 12px; text-align: center;">UoM</th>
                                    <th style="padding: 10px 12px; text-align: right;">Ordered</th>
                                    <th style="padding: 10px 12px; text-align: right;">Dispatched</th>
                                    <th style="padding: 10px 12px; text-align: right;">Inspected</th>
                                    <th style="padding: 10px 12px; text-align: right;">Pending</th>
                                </tr>
                            </thead>
                            <tbody id="logisticsStatementSummaryBody">
                                <tr><td colspan="6" style="padding:18px; text-align:center; color:var(--text-muted);">No statement selected.</td></tr>
                            </tbody>
                        </table>
                    </div>
                    <div style="margin-top: 12px; overflow:auto; max-height: 24vh; border: 1px solid var(--border); border-radius: 8px;">
                        <table style="width: 100%; border-collapse: collapse; font-size: 0.82rem;">
                            <thead style="background: #0f172a; color: #fff; position: sticky; top: 0;">
                                <tr>
                                    <th style="padding: 9px 10px; text-align: left;">Invoice</th>
                                    <th style="padding: 9px 10px; text-align: left;">Date</th>
                                    <th style="padding: 9px 10px; text-align: left;">Material</th>
                                    <th style="padding: 9px 10px; text-align: right;">Dispatched Qty</th>
                                    <th style="padding: 9px 10px; text-align: right;">Inspected Qty</th>
                                </tr>
                            </thead>
                            <tbody id="logisticsStatementInvoiceBody">
                                <tr><td colspan="5" style="padding:16px; text-align:center; color:var(--text-muted);">Invoice-wise dispatch rows will appear here.</td></tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div id="logisticsClientDirectoryView" style="display:none;">
                <header style="margin-bottom: 18px; display:flex; justify-content:space-between; align-items:center; gap:12px; flex-wrap:wrap;">
                    <div>
                        <h2 style="margin:0; color:var(--text-dark);">All Clients Dispatch Directory</h2>
                        <p style="margin:4px 0 0 0; color:var(--text-muted); font-size:0.9rem;">Open a client-specific page to view dispatch summaries and PO statements.</p>
                    </div>
                    <button class="btn-outline btn-sm" onclick="loadLogisticsPortal()">Refresh Directory</button>
                </header>
                <div class="card" style="padding:0; overflow:auto; max-height:70vh; border:1px solid var(--border-dark);">
                    <table style="width:100%; border-collapse:collapse; font-size:0.9rem;">
                        <thead style="background:#1e293b; color:#fff; position:sticky; top:0; z-index:10;">
                            <tr>
                                <th style="padding:12px 14px; text-align:left;">Client</th>
                                <th style="padding:12px 14px; text-align:right;">Statements</th>
                                <th style="padding:12px 14px; text-align:right;">Ordered Qty</th>
                                <th style="padding:12px 14px; text-align:right;">Dispatched Qty</th>
                                <th style="padding:12px 14px; text-align:right;">Pending Qty</th>
                                <th style="padding:12px 14px; text-align:center;">Completion</th>
                                <th style="padding:12px 14px; text-align:center;">Client Page</th>
                            </tr>
                        </thead>
                        <tbody id="logisticsClientDirectoryBody">
                            <tr><td colspan="7" style="padding:18px; text-align:center; color:var(--text-muted);">Loading clients dispatch data...</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <div id="logisticsClientPageView" style="display:none;">
                <header style="margin-bottom: 24px; display:flex; justify-content:flex-start; align-items:center; gap:16px; flex-wrap:wrap;">
                    <button class="btn-outline btn-sm" id="logisticsClientPageBackBtn" onclick="goBackFromClientDispatchPage()" title="Back to ledger" style="display:inline-flex; align-items:center; gap:6px; font-weight:700;">← Back</button>
                    <div style="flex:1 1 auto; min-width:240px;">
                        <h2 id="logisticsClientPageTitle" style="margin:0; color:var(--text-dark);">Client Dispatch Page</h2>
                        <p id="logisticsClientPageSubcopy" style="margin: 4px 0 0 0; color: var(--text-muted); font-size: 0.9rem;">PO-wise dispatch summary and complete statement drill-down for the selected client.</p>
                    </div>
                </header>

                <div class="dispatch-ui-section-label">Client Snapshot</div>
                <div class="kpi-row" style="grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); margin-bottom: 16px;">
                    <div class="kpi-card blue">
                        <div class="kpi-label">Client Statements</div>
                        <div class="kpi-value" id="lgClientStmtTotal">0</div>
                    </div>
                    <div class="kpi-card red">
                        <div class="kpi-label">Statements Pending</div>
                        <div class="kpi-value" id="lgClientStmtPending">0</div>
                    </div>
                    <div class="kpi-card green">
                        <div class="kpi-label">Dispatch Completion</div>
                        <div class="kpi-value" id="lgClientCompletion">0.0%</div>
                    </div>
                    <div class="kpi-card purple">
                        <div class="kpi-label">Client Pending Qty</div>
                        <div class="kpi-value" id="lgClientPendingQty">0</div>
                    </div>
                </div>

                <div class="dispatch-ui-section-label">PO Dispatch Summary</div>
                <div class="filter-bar" style="margin-bottom: 12px;">
                    <input type="text" id="logisticsClientPoSearch" placeholder="Global search in PO table..." style="min-width: 260px;" oninput="debounceByKey('logisticsClientPoSearch', renderLogisticsClientPageBoard, 120)">
                    <input type="text" id="logisticsClientPoNoFilter" placeholder="Filter PO Number..." style="width: 180px;" oninput="debounceByKey('logisticsClientPoNoFilter', renderLogisticsClientPageBoard, 120)">
                    <input type="date" id="logisticsClientDateFilter" style="width: 170px;" onchange="renderLogisticsClientPageBoard()">
                    <select id="logisticsClientStatusFilter" style="width: 180px;" onchange="renderLogisticsClientPageBoard()">
                        <option value="">All Status</option>
                        <option value="pending">Pending</option>
                        <option value="completed">Completed</option>
                        <option value="partial">Partial</option>
                    </select>
                    <select id="logisticsClientSortBy" style="width: 180px;" onchange="renderLogisticsClientPageBoard()">
                        <option value="date_desc">Date (Newest)</option>
                        <option value="date_asc">Date (Oldest)</option>
                        <option value="po_asc">PO Number (A-Z)</option>
                        <option value="pending_desc">Pending % (High-Low)</option>
                        <option value="dispatched_desc">Dispatched % (High-Low)</option>
                    </select>
                </div>
                <div class="card" style="padding: 0; overflow-y: auto; max-height: 44vh; border: 1px solid var(--border-dark);">
                    <table style="width: 100%; border-collapse: collapse; font-size: 0.9rem;">
                        <thead style="background: #1e293b; color: #fff; position: sticky; top: 0; z-index: 10;">
                            <tr>
                                <th style="padding: 14px 16px; text-align: left;">PO Number</th>
                                <th style="padding: 14px 16px; text-align: left;">Date</th>
                                <th style="padding: 14px 16px; text-align: right;">No. of Items</th>
                                <th style="padding: 14px 16px; text-align: center;">Dispatch Status</th>
                                <th style="padding: 14px 16px; text-align: right; color: #f87171;">Pending %</th>
                                <th style="padding: 14px 16px; text-align: right; color: #38bdf8;">Dispatched %</th>
                                <th style="padding: 14px 16px; text-align: center;">Statement</th>
                            </tr>
                        </thead>
                        <tbody id="logisticsClientPageBody">
                            <tr><td colspan="7" style="padding:18px; text-align:center; color:var(--text-muted);">Loading client dispatch summary...</td></tr>
                        </tbody>
                    </table>
                </div>

                
            </div>

            <div id="clientView">
                <div class="ledger-top-actions" style="display: flex; justify-content: flex-end; gap: 10px; margin-bottom: 16px;">
                    <button class="btn-outline" onclick="openPoDetailsPage()" style="font-size: 0.9rem; padding: 0 20px;">Open PO Details</button>
                    <button class="btn-primary" onclick="openDispatchStatementEntry(currentClient)" style="font-size: 0.9rem; padding: 0 20px; box-shadow: var(--shadow-md);">Open Dispatch Statement</button>
                </div>
                <div class="ledger-section-head">Performance Snapshot</div>
                <div class="kpi-row ledger-kpi-row" style="grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));">
                    <div class="kpi-card blue">
                        <div class="kpi-label">Net Billed</div>
                        <div class="kpi-value" id="dashTotalInvoiced">₹0.00</div>
                    </div>
                    <div class="kpi-card green">
                        <div class="kpi-label">Cash Realized</div>
                        <div class="kpi-value" id="dashTotalReceived">₹0.00</div>
                    </div>
                    <div class="kpi-card red">
                        <div class="kpi-label">Outstanding</div>
                        <div class="kpi-value" id="dashTotalOutstanding">₹0.00</div>
                    </div>
                    <div class="kpi-card purple">
                        <div class="kpi-label">Collection Ratio</div>
                        <div class="kpi-value" id="dashCollectionRate">0.0%</div>
                        <div class="kpi-subvalue" id="dashCollectionMeta">Realized vs billed</div>
                    </div>
                </div>

                <div class="ledger-section-head">Operations Entry</div>
                <div id="dataEntrySection" class="split-layout ledger-entry-grid">
                    <div class="card" id="invoiceFormCard" style="margin-bottom: 0;">
                        <h3 class="section-title" id="formTitle">Log New Dispatch / Invoice</h3>
                        <input type="hidden" id="editMode" value="false">

                        <div class="form-grid">
                            <div class="form-group col-span-3" id="dropZone" style="padding: 16px; text-align: center;">
                                <label style="cursor: pointer; color: var(--brand-primary); font-weight: 700; font-size: 0.95rem; display: block; width: 100%; margin:0;">
                                    📄 Click or Drag PDFs Here to Queue
                                    <input type="file" id="pdfUploadInput" accept=".pdf" multiple style="display: none;" onchange="handlePDFUpload(event)">
                                </label>
                                <div id="uploadStatus" style="font-size: 0.75rem; color: var(--text-muted); margin-top: 6px; font-weight: 500;">Supports standard Tally/ERP generated PDFs</div>

                                <div id="stagingArea" style="display: none; margin-top: 12px; padding-top: 12px; border-top: 1px solid var(--border-dark);">
                                    <div style="font-size: 0.85rem; font-weight: 600; color: var(--text-dark); margin-bottom: 10px;">
                                        Files Queued: <span id="stagedCount" style="color: var(--brand-secondary); font-size: 1.1rem; font-weight: 800;">0</span>
                                    </div>
                                    <div style="display: flex; gap: 10px; justify-content: center;">
                                        <button type="button" class="btn-outline btn-sm text-danger" onclick="clearStagedPDFs()">Clear Queue</button>
                                        <button type="button" class="btn-success btn-sm" onclick="processStagedPDFs()">Process All Queued PDFs</button>
                                    </div>
                                </div>
                            </div>

                            <div class="form-group">
                                <label style="display: flex; justify-content: space-between; align-items: center;">
                                    PO Number
                                    <button type="button" class="btn-outline btn-sm" style="padding: 0 8px; height: 22px; font-size: 0.65rem;" onclick="openPoTermsModal()">Terms</button>
                                </label>
                                <div style="display: flex; gap: 8px;">
                                    <select id="poNoSelect" style="flex: 1; font-weight: 600;" onchange="handlePoSelectChange()">
                                        <option value="">-- Select PO --</option>
                                    </select>
                                    <input type="text" id="poNo" placeholder="Enter New PO..." style="display: none; flex: 1;" onkeyup="autoCalculateTerms()" onchange="autoCalculateTerms()">
                                    <button type="button" id="btnCancelNewPo" class="btn-outline text-danger" style="display: none; padding: 0 10px; font-weight: bold;" onclick="cancelNewPoInput()" title="Cancel New PO">✖</button>
                                </div>
                            </div>
                            <div class="form-group">
                                <label>Sub-Entity / Unit</label>
                                <input type="text" id="subEntity" placeholder="Optional (e.g. Unit-1)">
                            </div>
                            <div class="form-group">
                                <label>Invoice Number</label>
                                <input type="text" id="invNo" placeholder="Required">
                            </div>
                            <div class="form-group">
                                <label>LR Number (Dispatch)</label>
                                <input type="text" id="lrNo" placeholder="Lorry Receipt">
                            </div>
                            <div class="form-group">
                                <label>Invoice Date</label>
                                <input type="date" id="invDate">
                            </div>
                            <div class="form-group">
                                <label>Payment Due Date</label>
                                <input type="date" id="dueDate">
                            </div>

                            <div class="form-group">
                                <label>Basic Value</label>
                                <input type="number" id="basicVal" placeholder="0.00" onkeyup="autoCalculateTerms()" onchange="autoCalculateTerms()">
                            </div>
                            <div class="form-group" style="display:none;">
                                <label>Advance Adjusted</label>
                                <input type="number" id="advanceVal" placeholder="0.00" value="0">
                            </div>
                            <div class="form-group">
                                <label>TDS Ded.</label>
                                <input type="number" id="tdsVal" placeholder="0.00" value="0">
                            </div>

                            <div class="form-group">
                                <label>Retention / SD</label>
                                <input type="number" id="retentionVal" placeholder="0.00" value="0">
                            </div>

                            <div class="form-group">
                                <label>Entry Currency & Rate</label>
                                <div style="display: flex; gap: 8px;">
                                    <select id="entryCurrency" style="flex: 1;" onchange="document.getElementById('entryRate').disabled = this.value === 'INR'; document.getElementById('entryRate').value = this.value === 'INR' ? 1 : exchangeRate; autoCalculateTerms();">
                                        <option value="INR">₹ INR</option>
                                        <option value="USD">$ USD</option>
                                    </select>
                                    <input type="number" id="entryRate" placeholder="Rate" value="1" disabled style="flex: 1;" onkeyup="autoCalculateTerms()" onchange="autoCalculateTerms()" title="Custom Exchange Rate">
                                </div>
                            </div>
                            <div class="form-group" style="display: flex; flex-direction: column; justify-content: flex-end; gap: 12px; padding-bottom: 8px;">
                                <label style="cursor:pointer; display:flex; align-items:center; gap:8px; margin:0; color:var(--text-dark);">
                                    <input type="checkbox" id="applyGst" checked style="width:16px; height:16px; accent-color:var(--brand-primary);" onchange="autoCalculateTerms()">
                                    Apply 18% GST
                                </label>
                                <label style="cursor:pointer; display:flex; align-items:center; gap:8px; margin:0; color:var(--text-dark);">
                                    <input type="checkbox" id="applyTds" style="width:16px; height:16px; accent-color:var(--brand-primary);" onchange="autoCalculateTerms()">
                                    Auto-Deduct 0.1% TDS
                                </label>
                            </div>
                        </div>

                        <div id="customFieldsContainer" class="form-grid" style="margin-top: 12px;"></div>

                        <div style="margin-top: 20px; display: flex; gap: 12px;">
                            <button type="button" class="btn-primary" id="saveBtn" style="flex: 1;" onclick="saveInvoice()">Save Invoice</button>
                            <button type="button" class="btn-outline" id="cancelBtn" style="display: none;" onclick="cancelEdit()">Cancel Edit</button>
                        </div>
                    </div>

                    <div class="card" style="margin-bottom: 0;">
                        <h3 class="section-title" style="display: flex; justify-content: space-between; align-items: center;">
                            <span id="paymentSectionTitle">Record Payment Receipt</span>
                            <div style="display:flex; gap:8px;">
                                <button type="button" class="btn-outline btn-sm" onclick="openExcessPoApplet()" style="font-weight: 600; font-size: 0.75rem;">PO Excess Applet</button>
                                <button type="button" class="btn-outline btn-sm" onclick="openPaymentHistory()" style="font-weight: 600; font-size: 0.75rem;">Ledger History</button>
                            </div>
                        </h3>
                        <div class="form-group" style="margin-bottom: 16px;">
                            <label>Amount Received (Bank / RTGS)</label>
                            <div style="display:flex; gap: 8px;">
                                <select id="payCurrency" style="width: 90px; font-weight: bold; height: auto; background: #f0fdf4; border-color: #6ee7b7;" onchange="document.getElementById('payRate').disabled = this.value === 'INR'; document.getElementById('payRate').value = this.value === 'INR' ? 1 : exchangeRate;">
                                    <option value="INR">₹ INR</option>
                                    <option value="USD">$ USD</option>
                                </select>
                                <input type="number" id="payRate" placeholder="Rate" value="1" disabled style="width: 80px; height: auto; background: #f0fdf4; border-color: #6ee7b7;" title="Bank Exchange Rate">
                                <input type="number" id="targetPaymentVal" placeholder="0.00" style="flex: 1; font-size: 1.25rem; font-weight: 700; color: var(--success); padding: 12px; background: #f0fdf4; border-color: #6ee7b7; height: auto;">
                            </div>
                        </div>

                        <div class="form-group" style="margin-bottom: 16px;">
                            <label>Transaction Remarks / Notes</label>
                            <input type="text" id="paymentNote" placeholder="Optional notes for this receipt..." style="background: #f8fafc;">
                        </div>

                        <div style="display:flex; flex-wrap:wrap; gap: 16px; margin-bottom: 12px; background: #f8fafc; padding: 10px 14px; border: 1px solid var(--border); border-radius: var(--radius-md);">
                            <span style="font-size:0.75rem; font-weight:700; color:var(--text-muted);">AUTO-ALLOCATE:</span>
                            <label style="margin:0; display:flex; align-items:center; gap:6px; cursor:pointer;" title="Automatically pulls from PO advance pool according to PO terms">
                                <input type="checkbox" id="optApplyAdv" checked style="width:14px; height:14px; accent-color:var(--brand-primary);" onchange="updateCheckboxes()"> Apply PO Advance
                            </label>
                            <label style="margin:0; display:flex; align-items:center; gap:6px; cursor:pointer;" title="Strictly auto-fill the GST portion">
                                <input type="checkbox" id="optOnlyGst" style="width:14px; height:14px; accent-color:var(--brand-primary);" onchange="if(this.checked) document.getElementById('optHoldGst').checked = false; updateCheckboxes();"> Only GST
                            </label>
                            <span style="border-left: 1px solid var(--border-dark); margin: 0 4px;"></span>
                            <span style="font-size:0.75rem; font-weight:700; color:var(--text-muted);">HOLDS:</span>
                            <label style="margin:0; display:flex; align-items:center; gap:6px; cursor:pointer;">
                                <input type="checkbox" id="optHoldRet" checked style="width:14px; height:14px; accent-color:var(--brand-secondary);" onchange="updateCheckboxes()"> Hold Retention
                            </label>
                            <label style="margin:0; display:flex; align-items:center; gap:6px; cursor:pointer;">
                                <input type="checkbox" id="optHoldGst" style="width:14px; height:14px; accent-color:var(--brand-secondary);" onchange="if(this.checked) document.getElementById('optOnlyGst').checked = false; updateCheckboxes();"> Hold GST
                            </label>
                        </div>

                        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 6px;">
                            <label style="margin: 0;">Select invoices to allocate:</label>
                            <div style="display:flex; align-items:center; gap:8px;">
                                <button type="button" class="btn-outline btn-sm" style="height: 28px; font-size: 0.72rem;" onclick="refreshInvoiceAllocationList()">Refresh Invoices</button>
                            <label style="margin: 0; display: flex; align-items: center; gap: 6px; cursor: pointer; font-size: 0.75rem; font-weight: 700; color: var(--brand-primary);">
                                <input type="checkbox" id="selectAllPayments" style="width: 14px; height: 14px; accent-color: var(--brand-primary); margin: 0;" onchange="toggleAllPaymentCheckboxes(this)"> Select All
                            </label>
                            </div>
                        </div>
                        <div class="checkbox-list" id="invoiceCheckboxes"></div>

                        <div style="margin-top: 20px; display: flex; flex-direction: column; gap: 12px;">
                            <div style="display:flex; gap:12px;">
                                <button type="button" class="btn-success" style="flex: 1.2; white-space: nowrap; font-size: 0.9rem;" onclick="applyTargetedPayment()">Post & Allocate Receipt</button>
                            </div>
                            <div style="display:flex; gap:12px;">
                                <button type="button" class="btn-outline" style="flex: 1.2; border-color: var(--brand-primary); color: var(--brand-primary); white-space: nowrap;" onclick="addAdvanceToPO()">Add Direct PO Advance</button>
                                <button type="button" class="btn-outline" style="flex: 1; white-space: nowrap;" onclick="openPoBalancesModal()">PO Advance Wallet</button>
                            </div>

                            <div id="unallocatedUI" style="display:none; margin-top: 16px; padding: 14px; background: #faf5ff; border: 1px dashed #a855f7; border-radius: var(--radius-md);">
                                <div style="font-size: 0.8rem; font-weight: 700; color: #7e22ce; margin-bottom: 10px; display: flex; justify-content: space-between;">
                                    <span>Unallocated Receipts Available:</span>
                                    <span id="lblUnallocatedBal" style="font-size: 1rem;">₹0.00</span>
                                </div>
                                <div style="display:flex; gap:10px;">
                                    <button type="button" class="btn-outline" style="flex:1; border-color: #9333ea; color: #9333ea; font-size: 0.8rem;" onclick="applyUnallocatedToInvoices()">Allocate to Invoices</button>
                                    <button type="button" class="btn-outline" style="flex:1; border-color: #9333ea; color: #9333ea; font-size: 0.8rem;" onclick="moveUnallocatedToPO()">Move to PO Wallet</button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card ledger-records-shell" style="padding: 0; overflow: visible; display: flex; flex-direction: column; border: 1px solid var(--border);">
                    <div style="padding: 20px 24px; border-bottom: 1px solid var(--border); display: flex; justify-content: space-between; align-items: center; background: #fff;">
                        <h3 class="section-title" id="tableHeaderTitle" style="margin: 0; border: none; padding: 0; color: var(--text-dark);">Ledger Records</h3>
                        <div style="display: flex; gap: 10px; align-items:center; position:relative;">
                            <button type="button" class="btn-outline btn-sm" onclick="openNoteModal()" style="border-color: var(--brand-primary); color: var(--brand-primary); font-weight: bold;">Issue DN/CN</button>
                            <button type="button" class="btn-outline btn-sm" id="ledgerOptionsBtn" onclick="toggleLedgerOptionsMenu(event)" title="Ledger actions" style="width:34px; min-width:34px; font-size:1rem; font-weight:800; line-height:1;">⋮</button>
                            <div id="ledgerOptionsMenu" onclick="event.stopPropagation()" style="display:none; position:absolute; top:38px; right:0; min-width:220px; background:#fff; border:1px solid var(--border-dark); border-radius:10px; box-shadow:var(--shadow-lg); padding:10px; z-index:40;">
                                <div style="display:flex; flex-direction:column; gap:8px;">
                                    <select id="ledgerDensity" class="btn-outline btn-sm" style="height:30px; width:100%;" onchange="setLedgerDensity(this.value)">
                                        <option value="comfortable">Comfortable</option>
                                        <option value="compact">Compact</option>
                                    </select>
                                    <label class="btn-outline btn-sm" style="display:flex; align-items:center; gap:6px; cursor:pointer; justify-content:flex-start;">
                                        <input type="checkbox" id="ledgerWrapToggle" onchange="toggleLedgerWrap(this.checked)">
                                        Wrap Text
                                    </label>
                                    <select id="layoutPresetSelect" class="btn-outline btn-sm" style="height:30px; width:100%;" onchange="applySavedLayout(this.value)">
                                        <option value="">Layout Presets</option>
                                        <option value="Finance View">Finance View</option>
                                        <option value="Logistics View">Logistics View</option>
                                        <option value="Audit View">Audit View</option>
                                    </select>
                                    <button type="button" class="btn-outline btn-sm" onclick="saveCurrentLayout(); closeLedgerOptionsMenu();">Save Layout</button>
                                    <button type="button" class="btn-outline btn-sm text-danger" onclick="executeBulkDelete(); closeLedgerOptionsMenu();" style="border-color: var(--danger); background: #fef2f2;">Delete Selected</button>
                                    <button type="button" class="btn-outline btn-sm" onclick="openBulkEditModal(); closeLedgerOptionsMenu();">Edit Selected</button>
                                    <button type="button" class="btn-outline btn-sm" onclick="openTransferModal(); closeLedgerOptionsMenu();">Transfer Selected</button>
                                    <button type="button" class="btn-outline btn-sm" onclick="openColumnManager(); closeLedgerOptionsMenu();">Columns</button>
                                    <button type="button" class="btn-outline btn-sm" onclick="exportLedgerCheckedExcel(); closeLedgerOptionsMenu();" style="font-weight: 600;">Export Checked Excel</button>
                                    <button type="button" class="btn-outline btn-sm" onclick="exportToCSV(); closeLedgerOptionsMenu();" style="font-weight: 600;">Export Checked</button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div id="selectionAggregates" class="selection-aggregates-sticky" style="display:none; padding: 12px 24px; background: #f0fdf4; border-bottom: 1px solid #6ee7b7; flex-wrap: wrap; gap: 16px; justify-content: space-between; align-items: center;">
                        <div style="display: flex; align-items: center; gap: 20px;">
                            <span style="font-weight:700; color:#047857; font-size: 0.8rem;">Selected: <span id="aggCount">0</span></span>
                            <div style="display:flex; gap:16px; font-weight:800; color:#064e3b; font-size:0.85rem; padding-left: 16px; border-left: 2px solid #a7f3d0;">
                                <span>Gross: <span id="aggGross">₹0.00</span></span>
                                <span>Received: <span id="aggPaid">₹0.00</span></span>
                                <span style="color:#b91c1c;">Balance: <span id="aggBal">₹0.00</span></span>
                            </div>
                        </div>
                        <div style="display:flex; align-items: center; gap: 8px; background: #fff; padding: 4px 12px; border-radius: var(--radius-md); border: 1px solid #6ee7b7;">
                            <span style="font-size:0.7rem; font-weight:700; color:#047857;">CUSTOM CALC:</span>
                            <select id="dynAggFunc" style="width: 80px; height: 26px; padding: 0 4px; font-size: 0.75rem;" onchange="updateAggregates()">
                                <option value="SUM">SUM</option>
                                <option value="AVG">AVG</option>
                                <option value="MAX">MAX</option>
                                <option value="MIN">MIN</option>
                            </select>
                            <select id="dynAggCol" style="width: 110px; height: 26px; padding: 0 4px; font-size: 0.75rem;" onchange="updateAggregates()">
                                <option value="basic">Basic Value</option>
                                <option value="gst">GST</option>
                                <option value="total">Gross Total</option>
                                <option value="tds">TDS</option>
                                <option value="retention">Retention</option>
                                <option value="realized">Realized</option>
                                <option value="balance">Balance</option>
                            </select>
                            <span style="font-weight: 800; color: var(--brand-primary); font-size: 0.9rem; min-width: 80px; text-align: right;" id="dynAggResult">₹0.00</span>
                        </div>
                    </div>

                    <div class="filter-bar table-toolbar-sticky" style="border-radius: 0; border-left: none; border-right: none; box-shadow: none; background: #f8fafc; margin-bottom: 0; padding: 12px 24px;">
                        <select id="fltClient" class="filter-control" onchange="updatePOFilterDropdown(); triggerUpdate();" style="display:none; font-weight: 600; width: 160px;">
                            <option value="">All Clients</option>
                        </select>
                        <div class="multi-select-container">
                            <div class="multi-select-box" onclick="toggleMultiSelect('poSelectOptions')">
                                <span id="poSelectLabel" style="color:var(--text-dark);">Filter by POs...</span> <span style="color: var(--text-muted); font-size:0.7rem;">▼</span>
                            </div>
                            <div class="multi-select-options" id="poSelectOptions"></div>
                        </div>
                        <div class="multi-select-container">
                            <div class="multi-select-box" onclick="toggleMultiSelect('subSelectOptions')">
                                <span id="subSelectLabel" style="color:var(--text-dark);">Sub-Entities...</span> <span style="color: var(--text-muted); font-size:0.7rem;">▼</span>
                            </div>
                            <div class="multi-select-options" id="subSelectOptions"></div>
                        </div>
                        <div class="multi-select-container">
                            <div class="multi-select-box" onclick="toggleMultiSelect('projectSelectOptions')">
                                <span id="projectSelectLabel" style="color:var(--text-dark);">Projects...</span> <span style="color: var(--text-muted); font-size:0.7rem;">▼</span>
                            </div>
                            <div class="multi-select-options" id="projectSelectOptions"></div>
                        </div>
                        <div class="multi-select-container">
                            <div class="multi-select-box" onclick="toggleMultiSelect('fySelectOptions')">
                                <span id="fySelectLabel" style="color:var(--text-dark);">Financial Years...</span> <span style="color: var(--text-muted); font-size:0.7rem;">▼</span>
                            </div>
                            <div class="multi-select-options" id="fySelectOptions"></div>
                        </div>
                        <label class="btn-outline btn-sm" style="display:flex; align-items:center; gap:6px; cursor:pointer;">
                            <input type="checkbox" id="hideCompletedPoToggle" onchange="triggerUpdate()">
                            Hide Completed POs
                        </label>
                        <select id="fltStatus" class="filter-control" style="width:160px;" onchange="triggerUpdate()">
                            <option value="">All Statuses</option>
                            <option value="PENDING">Pending Only</option>
                            <option value="CLEARED">Cleared Only</option>
                            <option value="OVERDUE">Overdue Only</option>
                        </select>
                        <div class="filter-date-group">
                            <span style="color:var(--text-muted); font-size:0.75rem; font-weight:700;">FROM:</span>
                            <input type="date" id="fltStart" onchange="triggerUpdate()">
                        </div>
                        <div class="filter-date-group">
                            <span style="color:var(--text-muted); font-size:0.75rem; font-weight:700;">TO:</span>
                            <input type="date" id="fltEnd" onchange="triggerUpdate()">
                        </div>
                        <div class="search-box">
                            <input type="text" id="fltSearch" placeholder="Search entries..." oninput="debounceByKey('fltSearch', triggerUpdate, 120)">
                        </div>
                        <button class="btn-outline btn-sm" onclick="resetFilters()">Clear</button>
                    </div>

                    <div class="table-wrapper" style="border: none; border-radius: 0; box-shadow: none;">
                        <table>
                            <thead id="dynamicTableHeader"></thead>
                            <tbody id="invoiceTableBody"></tbody>
                            <tfoot id="invoiceTableFoot" style="background: #f8fafc; font-weight: 800; position: sticky; bottom: 0; box-shadow: 0 -2px 5px rgba(0,0,0,0.05); z-index: 10;"></tfoot>
                        </table>
                    </div>
                </div>
            </div>

            <div id="poDetailsView" style="display:none;">
                <div class="portfolio-header">
                    <div>
                        <h3 class="section-title" style="border:none; padding:0;">PO Details Register</h3>
                        <p id="poDetailsSubtitle" style="margin: 0; color: var(--text-muted); font-size: 0.82rem; font-weight: 500;">PO-level operational and financial snapshots.</p>
                    </div>
                    <div style="display:flex; gap:10px;">
                        <button class="btn-outline btn-sm" onclick="renderPoDetailsTable()">Refresh</button>
                        <button class="btn-outline btn-sm" onclick="openClient(currentClient)">Back to Ledger</button>
                    </div>
                </div>
                <div class="card" style="padding:0;">
                    <div class="filter-bar" style="border-radius:0; border-left:none; border-right:none; margin-bottom:0; box-shadow:none;">
                        <select id="poFilterColumn" class="filter-control" onchange="renderPoDetailsTable()">
                            <option value="poNo">PO Number</option>
                            <option value="projectName">Project</option>
                            <option value="contactPerson">Contact Person</option>
                            <option value="lastDispatchedDate">Last Dispatched Date</option>
                            <option value="totalBilled">Total Billed</option>
                            <option value="totalReceived">Total Received</option>
                            <option value="totalBalance">Total Balance</option>
                            <option value="paymentTerms">Payment Terms</option>
                            <option value="status">Status</option>
                        </select>
                        <input id="poFilterValue" class="filter-control" placeholder="Enter filter value..." oninput="renderPoDetailsTable()" />
                        <select id="poFilterStatusValue" class="filter-control" onchange="renderPoDetailsTable()">
                            <option value="">Select Status</option>
                            <option value="OPEN">Open</option>
                            <option value="COMPLETED">Completed</option>
                        </select>
                    </div>
                    <div class="table-wrapper" style="border:none; border-radius:0; box-shadow:none;">
                        <table>
                            <thead>
                                <tr>
                                    <th>PO Number</th>
                                    <th>Project</th>
                                    <th>Contact Person</th>
                                    <th>Last Dispatched Date</th>
                                    <th style="text-align:right;">Total Billed</th>
                                    <th style="text-align:right;">Total Received</th>
                                    <th style="text-align:right;">Total Balance</th>
                                    <th>Payment Terms</th>
                                    <th>Status</th>
                                    <th style="text-align:center;">Action</th>
                                </tr>
                            </thead>
                            <tbody id="poDetailsTableBody">
                                <tr><td colspan="10" style="text-align:center; padding: 24px; color: var(--text-muted);">Open a client and click "Open PO Details".</td></tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div id="reportsView">
                <div class="portfolio-header">
                    <div>
                        <h3 class="section-title" style="border:none; padding:0;">Executive Analytics</h3>
                        <p style="margin: 0; color: var(--text-muted); font-size: 0.8rem; font-weight: 500;">Generate financial insights based on specific timeframes or clients.</p>
                    </div>
                    <div class="filter-bar" style="margin-bottom: 0; padding: 12px 20px;">
                        <select id="repClient" class="filter-control" style="width: 200px;" onchange="generateReports()">
                            <option value="">All Clients / Global</option>
                        </select>
                        <div class="filter-date-group">
                            <span style="color:var(--text-muted); font-size:0.75rem; font-weight:700;">FROM:</span>
                            <input type="date" id="repStart" onchange="generateReports()">
                        </div>
                        <div class="filter-date-group">
                            <span style="color:var(--text-muted); font-size:0.75rem; font-weight:700;">TO:</span>
                            <input type="date" id="repEnd" onchange="generateReports()">
                        </div>
                        <button class="btn-primary btn-sm" onclick="generateReports()">Update Dash</button>
                        <button class="btn-outline btn-sm" onclick="document.getElementById('repClient').value=''; document.getElementById('repStart').value=''; document.getElementById('repEnd').value=''; generateReports();">Clear Filters</button>
                    </div>
                </div>
                <div class="kpi-row" id="repKpis"></div>
                <div class="chart-grid">
                    <div class="chart-container full-width">
                        <canvas id="trendChart"></canvas>
                    </div>
                    <div class="chart-container">
                        <canvas id="revenueChart"></canvas>
                    </div>
                    <div class="chart-container">
                        <canvas id="statusChart"></canvas>
                    </div>
                </div>
                <div class="card" style="margin-top: 24px;">
                    <h3 class="section-title">Custom Data Modeling</h3>
                    <div class="filter-bar" style="background: #f8fafc; box-shadow: none; border-color: var(--border);">
                        <div class="form-group" style="margin-bottom:0; width: 140px;">
                            <label style="font-size:0.7rem;">Chart Type</label>
                            <select id="ccType" class="filter-control">
                                <option value="bar">Bar Chart</option>
                                <option value="line">Line Chart</option>
                                <option value="pie">Pie Chart</option>
                            </select>
                        </div>
                        <div class="form-group" style="margin-bottom:0; width: 160px;">
                            <label style="font-size:0.7rem;">Metric to Analyze</label>
                            <select id="ccMetric" class="filter-control">
                                <option value="netPayable">Net Billed</option>
                                <option value="paid">Cash Realized</option>
                                <option value="balance">Outstanding Balance</option>
                                <option value="advance">Advances Used</option>
                            </select>
                        </div>
                        <div class="form-group" style="margin-bottom:0; width: 140px;">
                            <label style="font-size:0.7rem;">Group Data By</label>
                            <select id="ccGroupBy" class="filter-control">
                                <option value="client">Client</option>
                                <option value="month">Month</option>
                                <option value="po">PO Number</option>
                            </select>
                        </div>
                        <div class="form-group" style="margin-bottom:0; width: 200px;">
                            <label style="font-size:0.7rem;">Target Clients</label>
                            <div class="multi-select-container">
                                <div class="multi-select-box" onclick="toggleMultiSelect('ccSelectOptions')">
                                    <span id="ccSelectLabel" style="color:var(--text-dark);">All Clients...</span> <span style="color: var(--text-muted); font-size:0.7rem;">▼</span>
                                </div>
                                <div class="multi-select-options" id="ccSelectOptions"></div>
                            </div>
                        </div>
                        <div style="display:flex; gap:8px; align-items:flex-end; margin-left:auto;">
                            <button class="btn-outline btn-sm" onclick="clearCustomChartFilters()">Clear</button>
                            <button class="btn-primary btn-sm" onclick="buildCustomChart()">Generate Model</button>
                        </div>
                    </div>
                    <div class="chart-container full-width" style="display:none; border: none; box-shadow: none;" id="customChartWrapper">
                        <canvas id="customChartCanvas"></canvas>
                    </div>
                </div>
            </div>

            <div id="dispatchView" style="display: none;">
                <header style="display: flex; justify-content: flex-start; align-items: center; gap: 16px; margin-bottom: 24px; flex-wrap: wrap;">
                    <button class="btn-outline btn-sm" id="dispatchViewBackBtn" onclick="goBackFromDispatchReconciliation()" title="Back to Client Dispatch Dashboard" style="display:inline-flex; align-items:center; gap:6px; font-weight:700;">← Back</button>
                    <div style="flex:1 1 auto; min-width:240px;">
                        <h2 id="dispatchHeaderTitle" style="margin: 0; color: var(--text-dark);">Dispatch & Fulfillment Tracking</h2>
                        <p id="dispatchHeaderSubcopy" style="margin: 4px 0 0 0; color: var(--text-muted); font-size: 0.85rem;">Statement-first dispatch view with quick reconciliation and drill-down.</p>
                    </div>
                </header>



                <div class="dispatch-ui-section-label">Dispatch Snapshot</div>
                <div class="dispatch-snapshot">
                    <div class="dispatch-stat"><div class="dispatch-stat-label">Bricks Ordered</div><div class="dispatch-stat-value" id="dispatchStatBricksOrdered">0</div></div>
                    <div class="dispatch-stat"><div class="dispatch-stat-label">Bricks Dispatched</div><div class="dispatch-stat-value" id="dispatchStatBricksDispatched">0</div></div>
                    <div class="dispatch-stat"><div class="dispatch-stat-label">Bricks Pending</div><div class="dispatch-stat-value" id="dispatchStatBricksPending">0</div></div>
                    <div class="dispatch-stat"><div class="dispatch-stat-label">Castables/Mortars Ordered</div><div class="dispatch-stat-value" id="dispatchStatCastOrdered">0</div></div>
                    <div class="dispatch-stat"><div class="dispatch-stat-label">Castables/Mortars Dispatched</div><div class="dispatch-stat-value" id="dispatchStatCastDispatched">0</div></div>
                    <div class="dispatch-stat"><div class="dispatch-stat-label">Castables/Mortars Pending</div><div class="dispatch-stat-value" id="dispatchStatCastPending">0</div></div>
                    <div class="dispatch-stat"><div class="dispatch-stat-label">Invoices Covered</div><div class="dispatch-stat-value" id="dispatchStatInvoices">0</div></div>
                </div>

                <div class="dispatch-ui-section-label">Controls & Actions</div>
                <div class="dispatch-toolbar">
                    <div class="dispatch-toolbar-stack">
                        <div class="dispatch-toolbar-row primary">
                            <div class="dispatch-toolbar-group">
                                <span class="dispatch-toolbar-label">PO</span>
                                <select id="dispatchPoSelect" onchange="renderDispatchReconciliation()">
                                    <option value="">-- Select Purchase Order --</option>
                                </select>
                                <button class="btn-outline btn-sm" onclick="stepDispatchPo(-1)">← Previous</button>
                                <button class="btn-outline btn-sm" onclick="stepDispatchPo(1)">Next →</button>
                            </div>
                            <div class="dispatch-toolbar-group">
                                <span class="dispatch-toolbar-label">Search</span>
                                <input type="text" id="dispatchSearch" placeholder="Invoice / LR / material..." oninput="debounceByKey('dispatchSearch', renderDispatchReconciliation, 120)">
                            </div>
                            <div class="dispatch-toolbar-group">
                                <span class="dispatch-toolbar-label">Table</span>
                                <button class="btn-outline btn-sm" onclick="renderDispatchReconciliation()">Refresh</button>
                                <button class="btn-outline btn-sm" onclick="openDispatchColumnManager()">Columns</button>
                                <button class="btn-outline btn-sm" onclick="exportCurrentDispatchExcel()">Export Excel</button>
                            </div>
                        </div>

                        <div class="dispatch-toolbar-row">
                            <div class="dispatch-toolbar-group">
                                <span class="dispatch-toolbar-label">Entries</span>
                                <button class="btn-outline btn-sm" onclick="addManualBaselineItem()">Add PO Item</button>
                                <button class="btn-outline btn-sm" onclick="addDispatchAgainstInvoiceManual()">Add Against Invoice</button>
                                <button class="btn-outline btn-sm" onclick="addManualDispatchNewEntry()">Add New Entry</button>
                            </div>
                            <div class="dispatch-toolbar-group">
                                <span class="dispatch-toolbar-label">AI</span>
                                <button class="btn-primary btn-sm" onclick="document.getElementById('dispatchInvoiceUploadInput').click()">Add Dispatch Invoice</button>
                                <input type="file" id="dispatchInvoiceUploadInput" accept=".pdf" multiple style="display:none;" onchange="handleDispatchInvoiceUpload(event)">
                                <button class="btn-primary btn-sm" onclick="document.getElementById('poPdfUploadInput').click()">Extract PO PDF</button>
                                <input type="file" id="poPdfUploadInput" accept=".pdf" style="display: none;" onchange="handlePOUpload(event)">
                            </div>
                            <div class="dispatch-toolbar-group">
                                <span class="dispatch-toolbar-label">Aggregate</span>
                                <select id="dispatchAggMetric" style="width: 170px;" onchange="renderDispatchReconciliation()">
                                    <option value="dispatched">Metric: Dispatched</option>
                                    <option value="ordered">Metric: Ordered</option>
                                    <option value="inspected">Metric: Inspected</option>
                                    <option value="pending">Metric: Pending</option>
                                </select>
                                <select id="dispatchAggFn" style="width: 140px;" onchange="renderDispatchReconciliation()">
                                    <option value="sum">SUM</option>
                                    <option value="avg">AVG</option>
                                    <option value="min">MIN</option>
                                    <option value="max">MAX</option>
                                    <option value="count">COUNT</option>
                                </select>
                                <span class="status-pill" id="dispatchAggResult" style="background:#eef2ff; color:#1e3a8a; border:1px solid #c7d2fe;">Agg: -</span>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="dispatch-section-head">
                    <h3 style="color: var(--brand-primary);">Unified Dispatch Reconciliation</h3>
                    <span class="status-pill" id="dispatchSummaryHint" style="background:#e2e8f0; color:#334155; border:1px solid #cbd5e1;">Select a PO</span>
                </div>
                <div class="dispatch-filter-quickbar">
                    <div class="hint">Use PO + Search + Aggregate controls above to narrow results quickly. Quantity columns are on the right; horizontal scroll is enabled.</div>
                    <div class="actions">
                        <span class="dispatch-size-control" title="Drag table column or row edges to resize">Spreadsheet Resize: Drag column/row edges</span>
                        <button class="btn-outline btn-sm" onclick="document.getElementById('dispatchSearch').value=''; renderDispatchReconciliation();">Clear Search</button>
                        <button class="btn-outline btn-sm" onclick="resetDispatchSpreadsheetSizing()">Reset Size</button>
                        <button class="btn-outline btn-sm" onclick="renderDispatchReconciliation()">Refresh Table</button>
                    </div>
                </div>
                <div class="dispatch-formula-bar">
                    <span class="dispatch-formula-label">fx</span>
                    <input id="dispatchFormulaInput" type="text" placeholder="Select a cell to view/edit value">
                </div>
                <div id="dispatchAgGrid" class="ag-theme-alpine"></div>
                <div style="margin-bottom: 20px;">
                    <table id="dispatchUnifiedTable" class="dispatch-table" style="font-size: 0.8rem;">
                        <thead id="dispatchUnifiedHead" style="background: #f8fafc; position: static; top: auto; z-index: auto; box-shadow: none;">
                            <tr>
                                <th style="padding: 12px 16px; text-align: left; border-bottom: 1px solid var(--border-dark);">S. No.</th>
                                <th style="padding: 12px 16px; text-align: left; border-bottom: 1px solid var(--border-dark);">Bill No.</th>
                                <th style="padding: 12px 16px; text-align: left; border-bottom: 1px solid var(--border-dark);">Dated</th>
                                <th style="padding: 12px 16px; text-align: left; border-bottom: 1px solid var(--border-dark);">L.R. No.</th>
                                <th style="padding: 12px 16px; text-align: right; border-bottom: 1px solid var(--border-dark);">Bill Value</th>
                                <th style="padding: 12px 16px; text-align: center; border-bottom: 1px solid var(--border-dark);">Action</th>
                            </tr>
                        </thead>
                        <tbody id="dispatchUnifiedBody"></tbody>
                    </table>
                </div>
                <div id="dispatchContextMenu" class="dispatch-context-menu" style="display:none;">
                    <button type="button" onclick="dispatchContextInsertRow()">Insert Row</button>
                    <button type="button" onclick="dispatchContextDeleteRow()">Delete Row</button>
                    <button type="button" onclick="dispatchContextFormatCell()">Format Cells</button>
                </div>
            </div>

            <div id="adminView">
                <div class="split-layout">
                    <div class="card" style="margin-bottom: 0;">
                        <h3 class="section-title">Provision New Access</h3>
                        <div class="form-group" style="margin-bottom: 12px;">
                            <label>Network Username</label>
                            <input type="text" id="newUsername" placeholder="e.g., dlm_manager">
                        </div>
                        <div class="form-group" style="margin-bottom: 12px;">
                            <label>Initial Password</label>
                            <input type="text" id="newPassword" placeholder="Enter secure key...">
                        </div>
                        <div class="form-group" style="margin-bottom: 20px;">
                            <label>Security Clearance Level</label>
                            <select id="newUserRole">
                                <option value="user">Standard Operations (Data Entry Only)</option>
                                <option value="logistics">Logistics Manager (Dispatch & Fulfillment Only)</option>
                                <option value="admin">System Administrator (Full Read/Write/Delete)</option>
                            </select>
                        </div>
                        <button class="btn-primary" style="width: 100%;" onclick="createUser()">Create Identity</button>
                        <div id="adminMsg" style="margin-top: 12px; font-weight: 600; font-size: 0.8rem; text-align: center;"></div>
                    </div>
                    <div class="card" style="margin-bottom: 0;">
                        <h3 class="section-title">Legacy Import Status</h3>
                        <div id="legacyImportStatus" style="display:flex; flex-direction:column; gap:8px; font-size:0.82rem; color:var(--text-muted);">
                            <div>Last import status is not available.</div>
                        </div>
                    </div>
                    <div class="card" style="margin-bottom: 0; padding: 0; overflow: hidden;">
                        <h3 class="section-title" style="margin: 24px 24px 12px 24px; border:none;">Active Network Identities</h3>
                        <div class="table-wrapper" style="border: none; box-shadow: none; border-radius: 0;">
                            <table style="min-width: 100%;">
                                <thead>
                                    <tr>
                                        <th style="text-align: left; background: transparent;">Username</th>
                                        <th style="text-align: center; background: transparent;">Clearance</th>
                                        <th style="text-align: center; background: transparent;">Action</th>
                                    </tr>
                                </thead>
                                <tbody id="userTableBody"></tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </main>
    <script>
        function escJs(str) {
            if (str == null) return '';
            return String(str)
                .replace(/\\/g, '\\\\')
                .replace(/'/g, "\\'")
                .replace(/"/g, '\\"')
                .replace(/</g, '\\x3C')
                .replace(/>/g, '\\x3E');
        }

        function escHtml(str) {
            if (str == null) return '';
            return String(str)
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#39;');
        }

        // Backward compatible alias used in JS-string interpolation contexts.
        function esc(str) { return escJs(str); }

        let appletResolver = null;
        function customApplet({ title = "System Alert", message = "", type = "alert", placeholder = "", dangerMatch = "" }) {
            return new Promise((resolve) => {
                appletResolver = resolve;
                const overlay = document.getElementById('customAppletOverlay');
                const titleEl = document.getElementById('appletTitle');
                const msgEl = document.getElementById('appletMessage');
                const inputContainer = document.getElementById('appletInputContainer');
                const inputEl = document.getElementById('appletInput');
                const btnCancel = document.getElementById('appletCancel');
                const btnConfirm = document.getElementById('appletConfirm');

                titleEl.innerText = title;
                msgEl.textContent = String(message ?? '');
                inputEl.value = type === 'prompt' ? placeholder : '';
                inputEl.placeholder = placeholder;

                btnConfirm.style.backgroundColor = 'var(--brand-primary)';
                btnConfirm.style.color = '#fff';

                if (type === 'alert') {
                    inputContainer.style.display = 'none';
                    btnCancel.style.display = 'none';
                    btnConfirm.innerText = 'OK';
                } else if (type === 'confirm') {
                    inputContainer.style.display = 'none';
                    btnCancel.style.display = 'inline-flex';
                    btnConfirm.innerText = 'Yes, Confirm';
                } else if (type === 'prompt' || type === 'dangerPrompt') {
                    inputContainer.style.display = 'block';
                    btnCancel.style.display = 'inline-flex';
                    if (type === 'dangerPrompt') {
                        btnConfirm.innerText = 'DELETE';
                        btnConfirm.style.backgroundColor = 'var(--danger)';
                        inputEl.value = '';
                    } else {
                        btnConfirm.innerText = 'Submit';
                    }
                }

                btnCancel.onclick = () => { overlay.style.display = 'none'; appletResolver(null); };
                btnConfirm.onclick = () => {
                    if (type === 'alert' || type === 'confirm') {
                        overlay.style.display = 'none';
                        appletResolver(type === 'alert' ? true : true);
                    } else {
                        const val = inputEl.value.trim();
                        if (type === 'dangerPrompt' && val !== dangerMatch) {
                            msgEl.textContent = `Text does not match. Please type exactly: ${dangerMatch}`;
                            return;
                        }
                        overlay.style.display = 'none';
                        appletResolver(val);
                    }
                };

                document.getElementById('appletCloseBtn').onclick = () => { overlay.style.display = 'none'; appletResolver(type === 'confirm' ? false : null); };
                overlay.style.display = 'flex';
                if (type === 'prompt' || type === 'dangerPrompt') setTimeout(() => inputEl.focus(), 50);
            });
        }

        let appData = {};
        let currentClient = null;
        let clientAccordionOpen = true;
        let currentSort = { col: 'invDate', asc: false };
        let inlineEditId = null;
        let displayCurrency = 'INR';
        let exchangeRate = 83.0;
        let userColumns = [];
        const dispatchViewState = { selectedPoByClient: {} };
        const logisticsPortalState = {
            activeClient: '',
            selectedClient: '',
            selectedPoNo: '',
            visibleRows: [],
            clientPageClient: '',
            visibleClientRows: [],
            filteredClientRows: [],
            selectedClientRowIndex: -1,
            selectedStatementTarget: null,
            selectedStatementCache: null,
            clientSummaries: {}
        };
        let renderUpdateRaf = null;
        const debounceTimers = {};
        let poAdvancePoolCache = {};
        const inFlightOps = {};
        const dispatchResizeState = { colWidths: {}, rowHeights: {} };
        const dispatchGridState = {
            gridApi: null,
            materialByField: {},
            currentPoNo: '',
            formattedCells: new Set(),
            layoutByPo: {}
        };
        const dispatchSheetState = {
            sortKey: '',
            sortAsc: true,
            filterBillNo: '',
            filterDated: '',
            filterTruckNo: '',
            activeCell: null,
            contextInvoiceNo: '',
            contextCellEl: null
        };

        function debounceByKey(key, fn, delay = 120) {
            if (debounceTimers[key]) clearTimeout(debounceTimers[key]);
            debounceTimers[key] = setTimeout(() => {
                delete debounceTimers[key];
                fn();
            }, delay);
        }

        async function withInFlight(opKey, runner) {
            if (inFlightOps[opKey]) {
                return null;
            }
            inFlightOps[opKey] = true;
            try {
                return await runner();
            } finally {
                inFlightOps[opKey] = false;
            }
        }

        function getColStorageKey() {
            if (!currentClient || currentClient === 'ALL' || currentClient === 'ADMIN' || currentClient === 'REPORTS') return 'refractoryColsConfig_GLOBAL';
            return 'refractoryColsConfig_' + currentClient;
        }

        const DEFAULT_DISPATCH_TABLE_PREFS = {
            summaryVisibility: { material: true, uom: true, ordered: true, dispatched: true, inspected: true, pending: true },
            historyVisibility: { date: true, invoice: true, material: true, lr: true, bill: true, dispatched: true, action: true },
            summaryOrder: ['material', 'uom', 'ordered', 'dispatched', 'inspected', 'pending'],
            historyOrder: ['date', 'invoice', 'material', 'lr', 'bill', 'dispatched', 'action']
        };

        function getDispatchPrefsKey() { return 'dispatchTablePrefs_v1'; }

        function getDispatchTablePrefs() {
            try {
                const raw = localStorage.getItem(getDispatchPrefsKey());
                if (!raw) return JSON.parse(JSON.stringify(DEFAULT_DISPATCH_TABLE_PREFS));
                const parsed = JSON.parse(raw);
                return {
                    summaryVisibility: { ...DEFAULT_DISPATCH_TABLE_PREFS.summaryVisibility, ...(parsed.summaryVisibility || parsed.summary || {}) },
                    historyVisibility: { ...DEFAULT_DISPATCH_TABLE_PREFS.historyVisibility, ...(parsed.historyVisibility || parsed.history || {}) },
                    summaryOrder: Array.isArray(parsed.summaryOrder) ? parsed.summaryOrder.filter(k => DEFAULT_DISPATCH_TABLE_PREFS.summaryOrder.includes(k)) : [...DEFAULT_DISPATCH_TABLE_PREFS.summaryOrder],
                    historyOrder: Array.isArray(parsed.historyOrder) ? parsed.historyOrder.filter(k => DEFAULT_DISPATCH_TABLE_PREFS.historyOrder.includes(k)) : [...DEFAULT_DISPATCH_TABLE_PREFS.historyOrder]
                };
            } catch {
                return JSON.parse(JSON.stringify(DEFAULT_DISPATCH_TABLE_PREFS));
            }
        }

        function saveDispatchTablePrefs(prefs) {
            localStorage.setItem(getDispatchPrefsKey(), JSON.stringify(prefs));
        }

        function getVisibleDispatchCols(section) {
            const prefs = getDispatchTablePrefs();
            const order = section === 'history' ? prefs.historyOrder : prefs.summaryOrder;
            const map = section === 'history' ? prefs.historyVisibility : prefs.summaryVisibility;
            const keys = order.filter(k => map[k]);
            if (!keys.length) return section === 'history' ? [...DEFAULT_DISPATCH_TABLE_PREFS.historyOrder] : [...DEFAULT_DISPATCH_TABLE_PREFS.summaryOrder];
            return keys;
        }

        function openDispatchColumnManager() {
            const prefs = getDispatchTablePrefs();
            const summaryHost = document.getElementById('dispatchSummaryColumnList');
            const historyHost = document.getElementById('dispatchHistoryColumnList');
            if (!summaryHost || !historyHost) return;
            const summaryLabels = { material: 'Material Description', uom: 'UOM', ordered: 'Ordered Qty', dispatched: 'Dispatched Qty', inspected: 'Inspected Qty', pending: 'Pending Qty' };
            const historyLabels = { date: 'Date', invoice: 'Invoice No.', material: 'Material Description', lr: 'LR No.', bill: 'Bill Value', dispatched: 'Dispatched Qty', action: 'Action' };
            summaryHost.innerHTML = prefs.summaryOrder.map((k, idx) => `<label draggable="true" ondragstart="dispatchColDragStart(event,'summary',${idx})" ondragover="dispatchColDragOver(event)" ondrop="dispatchColDrop(event,'summary',${idx})" style="display:flex; gap:8px; align-items:center; margin:0; border:1px solid var(--border); border-radius:8px; padding:6px 8px; background:#fff;"><span style="cursor:move; color:var(--text-muted);">⋮⋮</span><input type="checkbox" ${prefs.summaryVisibility[k] ? 'checked' : ''} onchange="toggleDispatchColumn('summary','${k}',this.checked)"> ${summaryLabels[k]}</label>`).join('');
            historyHost.innerHTML = prefs.historyOrder.map((k, idx) => `<label draggable="true" ondragstart="dispatchColDragStart(event,'history',${idx})" ondragover="dispatchColDragOver(event)" ondrop="dispatchColDrop(event,'history',${idx})" style="display:flex; gap:8px; align-items:center; margin:0; border:1px solid var(--border); border-radius:8px; padding:6px 8px; background:#fff;"><span style="cursor:move; color:var(--text-muted);">⋮⋮</span><input type="checkbox" ${prefs.historyVisibility[k] ? 'checked' : ''} onchange="toggleDispatchColumn('history','${k}',this.checked)"> ${historyLabels[k]}</label>`).join('');
            document.getElementById('dispatchColumnModal').style.display = 'flex';
        }

        function closeDispatchColumnManager() {
            document.getElementById('dispatchColumnModal').style.display = 'none';
            if (document.getElementById('dispatchView').style.display !== 'none') renderDispatchReconciliation();
        }

        function toggleDispatchColumn(section, key, checked) {
            const prefs = getDispatchTablePrefs();
            const target = section === 'history' ? 'historyVisibility' : 'summaryVisibility';
            prefs[target][key] = !!checked;
            saveDispatchTablePrefs(prefs);
        }

        let dispatchDragIndex = null;
        function dispatchColDragStart(e, section, index) {
            dispatchDragIndex = { section, index };
            e.dataTransfer.effectAllowed = "move";
        }
        function dispatchColDragOver(e) { e.preventDefault(); }
        function dispatchColDrop(e, section, targetIndex) {
            e.preventDefault();
            if (!dispatchDragIndex || dispatchDragIndex.section !== section || dispatchDragIndex.index === targetIndex) return;
            const prefs = getDispatchTablePrefs();
            const orderKey = section === 'history' ? 'historyOrder' : 'summaryOrder';
            const moved = prefs[orderKey].splice(dispatchDragIndex.index, 1)[0];
            prefs[orderKey].splice(targetIndex, 0, moved);
            saveDispatchTablePrefs(prefs);
            openDispatchColumnManager();
        }

        function resetDispatchTablePrefs() {
            saveDispatchTablePrefs(JSON.parse(JSON.stringify(DEFAULT_DISPATCH_TABLE_PREFS)));
            openDispatchColumnManager();
        }

        function getLedgerPrefsKey() { return 'ledgerTablePrefs_v1'; }

        function getLedgerTablePrefs() {
            try {
                const raw = localStorage.getItem(getLedgerPrefsKey());
                const parsed = raw ? JSON.parse(raw) : {};
                return { density: parsed.density || 'comfortable', wrap: !!parsed.wrap };
            } catch {
                return { density: 'comfortable', wrap: false };
            }
        }

        function applyLedgerTablePrefs() {
            const prefs = getLedgerTablePrefs();
            document.body.classList.toggle('ledger-compact', prefs.density === 'compact');
            document.body.classList.toggle('ledger-nowrap', !prefs.wrap);
            const densityEl = document.getElementById('ledgerDensity');
            const wrapEl = document.getElementById('ledgerWrapToggle');
            if (densityEl) densityEl.value = prefs.density;
            if (wrapEl) wrapEl.checked = prefs.wrap;
        }

        function setLedgerDensity(value) {
            const prefs = getLedgerTablePrefs();
            prefs.density = value === 'compact' ? 'compact' : 'comfortable';
            localStorage.setItem(getLedgerPrefsKey(), JSON.stringify(prefs));
            applyLedgerTablePrefs();
        }

        function toggleLedgerWrap(checked) {
            const prefs = getLedgerTablePrefs();
            prefs.wrap = !!checked;
            localStorage.setItem(getLedgerPrefsKey(), JSON.stringify(prefs));
            applyLedgerTablePrefs();
        }

        function getSavedLayoutsKey() { return 'namedLayouts_v1'; }
        function getSavedLayouts() {
            try { return JSON.parse(localStorage.getItem(getSavedLayoutsKey()) || '{}'); } catch { return {}; }
        }

        function refreshLayoutOptions() {
            const sel = document.getElementById('layoutPresetSelect');
            if (!sel) return;
            const base = ['','Finance View','Logistics View','Audit View'];
            const saved = Object.keys(getSavedLayouts()).sort();
            const all = [...base, ...saved.filter(n => !base.includes(n))];
            sel.innerHTML = all.map(v => v ? `<option value="${esc(v)}">${esc(v)}</option>` : '<option value="">Layout Presets</option>').join('');
        }

        function applySavedLayout(layoutName) {
            if (!layoutName) return;
            const builtins = {
                "Finance View": {
                    ledgerDensity: 'comfortable',
                    ledgerWrap: false,
                    ledgerHidden: ['paymentBreakdown'],
                    dispatch: { summaryVisibility: { material: true, uom: true, ordered: true, dispatched: true, inspected: true, pending: true }, historyVisibility: { date: true, invoice: true, material: true, lr: true, bill: true, dispatched: true, action: true } }
                },
                "Logistics View": {
                    ledgerDensity: 'compact',
                    ledgerWrap: true,
                    ledgerHidden: ['tds', 'retention', 'paymentBreakdown'],
                    dispatch: { summaryVisibility: { material: true, uom: true, ordered: true, dispatched: true, inspected: true, pending: true }, historyVisibility: { date: true, invoice: true, material: true, lr: true, bill: false, dispatched: true, action: true } }
                },
                "Audit View": {
                    ledgerDensity: 'comfortable',
                    ledgerWrap: true,
                    ledgerHidden: [],
                    dispatch: { summaryVisibility: { material: true, uom: true, ordered: true, dispatched: true, inspected: true, pending: true }, historyVisibility: { date: true, invoice: true, material: true, lr: true, bill: true, dispatched: true, action: true } }
                }
            };
            const saved = getSavedLayouts();
            const config = saved[layoutName] || builtins[layoutName];
            if (!config) return;

            userColumns = userColumns.map(c => ({ ...c, visible: c.type === 'core' && (c.id === 'invNo' || c.id === 'actions') ? true : !((config.ledgerHidden || []).includes(c.id)) }));
            localStorage.setItem(getColStorageKey(), JSON.stringify(userColumns));
            localStorage.setItem(getLedgerPrefsKey(), JSON.stringify({ density: config.ledgerDensity || 'comfortable', wrap: !!config.ledgerWrap }));
            applyLedgerTablePrefs();

            if (config.dispatch) {
                const prefs = getDispatchTablePrefs();
                prefs.summaryVisibility = { ...prefs.summaryVisibility, ...(config.dispatch.summaryVisibility || {}) };
                prefs.historyVisibility = { ...prefs.historyVisibility, ...(config.dispatch.historyVisibility || {}) };
                saveDispatchTablePrefs(prefs);
            }
            triggerUpdate();
            if (document.getElementById('dispatchView').style.display !== 'none') renderDispatchReconciliation();
        }

        async function saveCurrentLayout() {
            const name = await customApplet({ title: "Save Layout", message: "Enter layout name:", type: "prompt", placeholder: "My Team View" });
            if (!name || !name.trim()) return;
            const layouts = getSavedLayouts();
            const ledgerPrefs = getLedgerTablePrefs();
            const hidden = userColumns.filter(c => !c.visible).map(c => c.id);
            layouts[name.trim()] = {
                ledgerDensity: ledgerPrefs.density,
                ledgerWrap: ledgerPrefs.wrap,
                ledgerHidden: hidden,
                dispatch: getDispatchTablePrefs()
            };
            localStorage.setItem(getSavedLayoutsKey(), JSON.stringify(layouts));
            const sel = document.getElementById('layoutPresetSelect');
            if (sel && !Array.from(sel.options).some(o => o.value === name.trim())) {
                sel.innerHTML += `<option value="${esc(name.trim())}">${esc(name.trim())}</option>`;
            }
            await customApplet({ title: "Saved", message: `Layout "${name.trim()}" saved.` });
        }

        function loadUserColumns() {
            try {
                const savedCols = localStorage.getItem(getColStorageKey());
                userColumns = savedCols ? JSON.parse(savedCols) : JSON.parse(JSON.stringify(defaultColumns));
            } catch (e) { userColumns = JSON.parse(JSON.stringify(defaultColumns)); }

            defaultColumns.forEach(dc => {
                if (!userColumns.find(uc => uc.id === dc.id)) userColumns.splice(defaultColumns.findIndex(d => d.id === dc.id), 0, dc);
            });

            if (appData._settings && appData._settings.customColumns) {
                appData._settings.customColumns.forEach(cc => {
                    if (!userColumns.find(uc => uc.id === cc.id)) {
                        userColumns.push({ id: cc.id, label: cc.label, visible: true, isCustom: true, type: cc.type, formula: cc.formula });
                    }
                });
            }

            let retCol = userColumns.find(c => c.id === 'retention');
            if (retCol) retCol.label = 'Retention Due';
            let balCol = userColumns.find(c => c.id === 'balance');
            if (balCol) balCol.label = 'Total Due';
            let realCol = userColumns.find(c => c.id === 'realized');
            if (realCol) realCol.label = 'Payment Received';

            userColumns = userColumns.filter(c => c.id !== 'netPayable');
        }

        const defaultColumns = [
            { id: 'clientName', label: 'Client', visible: true, type: 'core' },
            { id: 'subEntity', label: 'Sub-Entity', visible: true, type: 'core' },
            { id: 'poNo', label: 'PO No.', visible: true, type: 'core' },
            { id: 'invNo', label: 'Inv No.', visible: true, type: 'core' },
            { id: 'invDate', label: 'Inv Date', visible: true, type: 'core' },
            { id: 'status', label: 'Status / Due', visible: true, type: 'core' },
            { id: 'lrNo', label: 'LR No.', visible: false, type: 'core' },
            { id: 'basic', label: 'Basic', visible: true, type: 'core' },
            { id: 'gst', label: 'GST', visible: true, type: 'core' },
            { id: 'gross', label: 'Gross Total', visible: true, type: 'core' },
            { id: 'advance', label: 'Advance Adj.', visible: true, type: 'core' },
            { id: 'tds', label: 'TDS', visible: true, type: 'core' },
            { id: 'retention', label: 'Retention Due', visible: true, type: 'core' },
            { id: 'realized', label: 'Payment Received', visible: true, type: 'core' },
            { id: 'balance', label: 'Total Due', visible: true, type: 'core' },
            { id: 'paymentBreakdown', label: 'Payment Log', visible: true, type: 'core' },
            { id: 'actions', label: 'Actions', visible: true, type: 'core' }
        ];

        window.onload = function () {
            const token = sessionStorage.getItem('erp_token');
            if (!token) {
                document.getElementById('loginOverlay').style.display = 'flex';
                return;
            }
            loadSecuredData(token);
        };

        function closeUserMenu(reason = 'unknown') {
            const panel = document.getElementById('topUserDropdown');
            const wrap = document.getElementById('topUserMenuWrap');
            if (panel) {
                panel.style.display = 'none';
                panel.style.left = '';
                panel.style.top = '';
                panel.style.right = '';
                panel.style.position = '';
                if (wrap && panel.parentElement !== wrap) {
                    wrap.appendChild(panel);
                }
            }
        }

        function toggleUserMenu() {
            const panel = document.getElementById('topUserDropdown');
            const wrap = document.getElementById('topUserMenuWrap');
            const btn = document.getElementById('btnUserMenu');
            if (!panel) return;
            const shouldOpen = (panel.style.display === 'none' || !panel.style.display);
            panel.style.display = shouldOpen ? 'flex' : 'none';
            if (shouldOpen) {
                if (panel.parentElement !== document.body) document.body.appendChild(panel);
                panel.style.position = 'fixed';
                const btnRect = btn ? btn.getBoundingClientRect() : { right: window.innerWidth - 12, bottom: 44 };
                const panelRect = panel.getBoundingClientRect();
                const left = Math.max(8, Math.min(window.innerWidth - panelRect.width - 8, btnRect.right - panelRect.width));
                const top = Math.max(8, btnRect.bottom + 8);
                panel.style.right = 'auto';
                panel.style.left = `${left}px`;
                panel.style.top = `${top}px`;
            } else if (wrap && panel.parentElement !== wrap) {
                wrap.appendChild(panel);
                panel.style.position = '';
            }
        }

        document.addEventListener('click', function (e) {
            if (!e.target.closest('.multi-select-container')) {
                document.querySelectorAll('.multi-select-options').forEach(el => el.classList.remove('show'));
            }
            if (!e.target.closest('#topUserMenuWrap')) {
                if (e.target.closest('#topUserDropdown')) return;
                closeUserMenu('document-outside-click');
            }
            if (!e.target.closest('#ledgerOptionsMenu') && !e.target.closest('#ledgerOptionsBtn')) {
                closeLedgerOptionsMenu();
            }
        });

        document.addEventListener('keydown', function (e) {
            // QoL: "/" focuses dispatch search when dispatch view is open.
            if (e.key === '/' && !e.ctrlKey && !e.metaKey && !e.altKey) {
                const activeTag = (document.activeElement && document.activeElement.tagName) ? document.activeElement.tagName.toLowerCase() : '';
                if (activeTag === 'input' || activeTag === 'textarea') return;
                const dispatchView = document.getElementById('dispatchView');
                const dispatchSearch = document.getElementById('dispatchSearch');
                if (dispatchView && dispatchSearch && dispatchView.style.display !== 'none') {
                    e.preventDefault();
                    dispatchSearch.focus();
                }
            }
        });

        function getVal(val) {
            val = parseFloat(val) || 0;
            return displayCurrency === 'USD' ? (val / exchangeRate) : val;
        }

        function formatCur(val) {
            let v = getVal(val);
            if (displayCurrency === 'USD') return '$' + v.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
            return '₹' + v.toLocaleString('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
        }

        function formatNum(val, digits = 2) {
            const n = Number(val) || 0;
            return n.toLocaleString('en-IN', { minimumFractionDigits: digits, maximumFractionDigits: digits });
        }

        function normalizeDispatchDesc(text) {
            return String(text || '')
                .toUpperCase()
                .replace(/[\r\n\t]+/g, ' ')
                .replace(/[^A-Z0-9 ]+/g, ' ')
                .replace(/\s+/g, ' ')
                .trim();
        }

        function normalizeClientLookupName(text) {
            return String(text || '')
                .toUpperCase()
                .replace(/PVT\.?|PRIVATE/g, '')
                .replace(/LTD\.?|LIMITED/g, '')
                .replace(/&/g, 'AND')
                .replace(/[^A-Z0-9 ]+/g, ' ')
                .replace(/\s+/g, ' ')
                .trim();
        }

        function autoMatchClientByExtractedName(rawName) {
            const norm = normalizeClientLookupName(rawName);
            if (!norm) return null;
            const clients = Object.keys(appData || {}).filter(k => k && k !== '_settings');
            const exact = clients.find(c => normalizeClientLookupName(c) === norm);
            if (exact) return exact;
            // Token-overlap fallback (handles minor naming differences).
            const rawTokens = norm.split(' ').filter(t => t && t.length >= 3);
            if (!rawTokens.length) return null;
            let best = null;
            let bestScore = 0;
            clients.forEach(c => {
                const candNorm = normalizeClientLookupName(c);
                if (!candNorm) return;
                const candTokens = new Set(candNorm.split(' ').filter(Boolean));
                let overlap = 0;
                rawTokens.forEach(t => { if (candTokens.has(t)) overlap += 1; });
                const score = overlap / Math.max(rawTokens.length, candTokens.size);
                if (score > bestScore && score >= 0.6) {
                    bestScore = score;
                    best = c;
                }
            });
            return best;
        }

        function autoMatchPoForClient(clientName, rawPoNo) {
            if (!clientName || !appData[clientName]) return null;
            const target = String(rawPoNo || '').trim().toUpperCase();
            if (!target) return null;
            const known = new Set();
            Object.keys(appData[clientName].poTerms || {}).forEach(p => known.add(String(p).toUpperCase()));
            (appData[clientName].invoices || []).forEach(inv => {
                if (inv.poNo && inv.poNo !== 'UNASSIGNED') known.add(String(inv.poNo).toUpperCase());
            });
            if (known.has(target)) {
                // Return the canonical original-cased version.
                const orig = Array.from(known).find(k => k === target);
                if (orig) {
                    // Find originally-cased
                    const fromTerms = Object.keys(appData[clientName].poTerms || {}).find(p => String(p).toUpperCase() === target);
                    if (fromTerms) return fromTerms;
                    const fromInv = (appData[clientName].invoices || []).find(inv => String(inv.poNo || '').toUpperCase() === target);
                    if (fromInv) return fromInv.poNo;
                }
            }
            return null;
        }

        function getDispatchDescriptionCandidates(clientName, poNo) {
            const out = [];
            if (!clientName || !poNo || !appData[clientName]) return out;

            const poTerms = appData[clientName].poTerms || {};
            const baselineItems = (poTerms[poNo] && poTerms[poNo].baselineItems) ? poTerms[poNo].baselineItems : [];
            baselineItems.forEach(item => {
                if (item && item.description) out.push(String(item.description));
            });

            const invoices = appData[clientName].invoices || [];
            invoices
                .filter(inv => inv.poNo === poNo && !inv.isNote && Array.isArray(inv.dispatchItems))
                .forEach(inv => {
                    inv.dispatchItems.forEach(item => {
                        if (item && item.description) out.push(String(item.description));
                    });
                });

            const uniq = [];
            const seen = new Set();
            out.forEach(v => {
                const key = normalizeDispatchDesc(v);
                if (!key || seen.has(key)) return;
                seen.add(key);
                uniq.push(v);
            });
            return uniq;
        }

        function getDispatchAliasMappings(clientName, poNo) {
            const out = [];
            if (!clientName || !poNo || !appData[clientName]) return out;
            const poTerms = appData[clientName].poTerms || {};
            const baselineItems = (poTerms[poNo] && poTerms[poNo].baselineItems) ? poTerms[poNo].baselineItems : [];
            baselineItems.forEach(item => {
                const alias = String(item?.dispatch_alias || '').trim();
                const target = String(item?.description || '').trim();
                if (!alias || !target) return;
                out.push({
                    alias,
                    alias_norm: normalizeDispatchDesc(alias),
                    target
                });
            });
            return out.filter(x => x.alias_norm);
        }

        function resolveDispatchAlias(rawDesc, aliasMappings) {
            const normRaw = normalizeDispatchDesc(rawDesc);
            if (!normRaw || !aliasMappings.length) return null;
            const exact = aliasMappings.find(m => m.alias_norm === normRaw);
            if (exact) return exact.target;
            const best = findBestDispatchDescriptionMatch(rawDesc, aliasMappings.map(m => m.alias));
            if (!best) return null;
            const mapped = aliasMappings.find(m => m.alias === best);
            return mapped ? mapped.target : null;
        }

        function findBestDispatchDescriptionMatch(rawDesc, candidates) {
            const normRaw = normalizeDispatchDesc(rawDesc);
            if (!normRaw || !candidates.length) return null;

            let exact = candidates.find(c => normalizeDispatchDesc(c) === normRaw);
            if (exact) return exact;

            let best = null;
            let bestScore = 0;
            const rawTokens = normRaw.split(' ').filter(Boolean);
            const rawSet = new Set(rawTokens);

            candidates.forEach(candidate => {
                const normCand = normalizeDispatchDesc(candidate);
                if (!normCand) return;

                if (normCand.includes(normRaw) || normRaw.includes(normCand)) {
                    const score = Math.min(normRaw.length, normCand.length) / Math.max(normRaw.length, normCand.length);
                    if (score > bestScore) { bestScore = score; best = candidate; }
                    return;
                }

                const candTokens = normCand.split(' ').filter(Boolean);
                if (!candTokens.length) return;
                let common = 0;
                candTokens.forEach(t => { if (rawSet.has(t)) common++; });
                const tokenScore = common / Math.max(1, Math.min(rawTokens.length, candTokens.length));
                if (tokenScore > bestScore) { bestScore = tokenScore; best = candidate; }
            });

            return bestScore >= 0.75 ? best : null;
        }

        function canonicalizeExtractedDispatchItems(items, clientName, poNo) {
            const list = Array.isArray(items) ? items : [];
            if (!clientName || !poNo || !list.length) return list;
            const candidates = getDispatchDescriptionCandidates(clientName, poNo);
            const aliasMappings = getDispatchAliasMappings(clientName, poNo);
            if (!candidates.length && !aliasMappings.length) return list;

            return list.map(item => {
                const rawDesc = item.description || '';
                const aliasTarget = resolveDispatchAlias(rawDesc, aliasMappings);
                if (aliasTarget) return { ...item, description: aliasTarget };
                const matched = findBestDispatchDescriptionMatch(rawDesc, candidates);
                if (!matched) return item;
                return { ...item, description: matched };
            });
        }

        async function setExchangeRate() {
            if (!currentClient || !appData[currentClient] || currentClient === 'ALL') return;
            let r = await customApplet({ title: "Set Exchange Rate", message: "Enter Exchange Rate (1 USD = X INR):", type: "prompt", placeholder: exchangeRate.toString() });
            if (r && !isNaN(parseFloat(r))) {
                exchangeRate = parseFloat(r);
                appData[currentClient].exchange_rate = exchangeRate;
                document.getElementById('exRateDisplay').innerText = exchangeRate.toFixed(2);
                await saveClientCurrencyPrefs();
                triggerUpdate();
                if (currentClient === null) renderLandingPage();
            }
        }

        async function toggleDisplayCurrency() {
            if (!currentClient || !appData[currentClient] || currentClient === 'ALL') return;
            displayCurrency = displayCurrency === 'INR' ? 'USD' : 'INR';
            appData[currentClient].display_currency = displayCurrency;
            document.getElementById('btnDisplayCur').innerText = displayCurrency === 'INR' ? 'View in USD' : 'View in INR';
            await saveClientCurrencyPrefs();
            triggerUpdate();
            if (currentClient === null) renderLandingPage();
        }

        async function saveClientCurrencyPrefs() {
            if (!currentClient || !appData[currentClient] || currentClient === 'ALL') return;
            const token = sessionStorage.getItem('erp_token');
            const clientObj = appData[currentClient];
            try {
                await fetch(`/api/clients/${clientObj.sql_id}/currency`, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
                    body: JSON.stringify({
                        displayCurrency: clientObj.display_currency || displayCurrency,
                        exchangeRate: clientObj.exchange_rate || exchangeRate
                    })
                });
            } catch (e) {
                console.error('Failed to save client currency preferences', e);
            }
        }

        function evalMathExpression(expr) {
            const tokens = expr.match(/(\d+(\.\d+)?)|[()+\-*/]/g);
            if (!tokens || tokens.join('') !== expr.replace(/\s+/g, '')) throw new Error('Invalid expression');
            const values = [];
            const ops = [];
            const precedence = (op) => (op === '+' || op === '-') ? 1 : 2;
            const applyTopOp = () => {
                const op = ops.pop();
                const b = Number(values.pop());
                const a = Number(values.pop());
                if ([a, b].some(Number.isNaN)) throw new Error('Invalid operands');
                if (op === '+') values.push(a + b);
                else if (op === '-') values.push(a - b);
                else if (op === '*') values.push(a * b);
                else if (op === '/') values.push(b === 0 ? NaN : a / b);
            };
            for (let i = 0; i < tokens.length; i++) {
                const t = tokens[i];
                if (/^\d+(\.\d+)?$/.test(t)) {
                    values.push(parseFloat(t));
                } else if (t === '(') {
                    ops.push(t);
                } else if (t === ')') {
                    while (ops.length && ops[ops.length - 1] !== '(') applyTopOp();
                    if (!ops.length) throw new Error('Mismatched parentheses');
                    ops.pop();
                } else {
                    while (ops.length && ops[ops.length - 1] !== '(' && precedence(ops[ops.length - 1]) >= precedence(t)) applyTopOp();
                    ops.push(t);
                }
            }
            while (ops.length) {
                if (ops[ops.length - 1] === '(') throw new Error('Mismatched parentheses');
                applyTopOp();
            }
            if (values.length !== 1) throw new Error('Malformed expression');
            return values[0];
        }

        function evalFormula(formula, inv) {
            try {
                let parsed = formula
                    .replace(/\bbasic\b/g, inv.basic || 0)
                    .replace(/\bgst\b/g, inv.gst || 0)
                    .replace(/\bgross\b/g, inv.total || 0)
                    .replace(/\badvance\b/g, inv.advance || 0)
                    .replace(/\btds\b/g, inv.tds || 0)
                    .replace(/\bretention\b/g, inv.retention || 0)
                    .replace(/\bnetPayable\b/g, inv.netPayable || 0)
                    .replace(/\brealized\b/g, inv.paid || 0)
                    .replace(/\bbalance\b/g, inv.balance || 0);
                if (!/^[\d+\-*/().\s]+$/.test(parsed)) return 'ERR';
                const result = evalMathExpression(parsed);
                return Number.isFinite(result) ? formatCur(result) : '-';
            } catch (e) { return 'ERR'; }
        }

        function renderCustomFormFields() {
            const cont = document.getElementById('customFieldsContainer');
            if (!cont) return;
            cont.innerHTML = '';
            if (appData._settings && appData._settings.customColumns) {
                appData._settings.customColumns.forEach(cc => {
                    if (cc.type === 'text') {
                        cont.innerHTML += `<div class="form-group"><label>${esc(cc.label)}</label><input type="text" id="custom_field_${cc.id}" placeholder="..."></div>`;
                    }
                });
            }
        }

        function toggleSidebar() { document.getElementById('mainSidebar').classList.toggle('collapsed'); }
        function toggleLedgerOptionsMenu(event) {
            if (event) event.stopPropagation();
            const menu = document.getElementById('ledgerOptionsMenu');
            if (!menu) return;
            menu.style.display = menu.style.display === 'block' ? 'none' : 'block';
        }
        function closeLedgerOptionsMenu() {
            const menu = document.getElementById('ledgerOptionsMenu');
            if (menu) menu.style.display = 'none';
        }
        function toggleClientAccordion() {
            clientAccordionOpen = !clientAccordionOpen;
            document.getElementById('clientNavListContainer').classList.toggle('hidden', !clientAccordionOpen);
            document.getElementById('clientAccordionChevron').innerText = clientAccordionOpen ? '▼' : '▶';
        }
        function toggleMultiSelect(id) {
            const el = document.getElementById(id);
            if (!el) return;
            el.classList.toggle('show');
        }
        function getMultiSelectValues(id) { return Array.from(document.querySelectorAll(`#${id} input[type="checkbox"]:checked`)).map(cb => cb.value); }
        function updateMultiSelectLabel(containerId, labelId, defaultText) {
            const label = document.getElementById(labelId);
            const container = document.getElementById(containerId);

            // Safety shield: Stop if elements aren't on the screen yet
            if (!label || !container) return;

            const checkboxes = container.querySelectorAll('input[type="checkbox"]');
            if (checkboxes.length === 0) {
                label.innerText = defaultText;
                return;
            }

            let selectedCount = 0;
            let firstSelected = '';

            checkboxes.forEach(chk => {
                if (chk.checked) {
                    selectedCount++;
                    if (!firstSelected) firstSelected = chk.value;
                }
            });

            if (selectedCount === 0 || selectedCount === checkboxes.length) {
                label.innerText = defaultText;
            } else if (selectedCount === 1) {
                label.innerText = firstSelected;
            } else {
                label.innerText = `${selectedCount} Selected`;
            }
        }

        async function performLogin() {
            const user = document.getElementById('loginUser').value.trim();
            const pass = document.getElementById('loginPass').value.trim();
            const errDiv = document.getElementById('loginError');
            if (!user || !pass) return errDiv.innerText = "Username and password required.";

            try {
                const response = await fetch('/api/login', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ username: user, password: pass }) });
                const data = await response.json();
                if (response.ok) {
                    sessionStorage.setItem('erp_token', data.token);
                    sessionStorage.setItem('erp_role', data.role);
                    sessionStorage.setItem('erp_username', data.username);
                    document.getElementById('loginOverlay').style.display = 'none';
                    loadSecuredData(data.token);
                } else { errDiv.innerText = data.error || "Authorization denied."; }
            } catch (e) { errDiv.innerText = "Cannot connect to central server."; }
        }

        function performLogout() {
            sessionStorage.removeItem('erp_token');
            sessionStorage.removeItem('erp_role');
            sessionStorage.removeItem('erp_username');
            document.body.setAttribute('data-role', 'user');
            location.reload();
        }

        function applyRoleDashboardEmphasis(role) {
            const activeRole = (role || 'user').toLowerCase();
            document.body.setAttribute('data-role', activeRole);
            const dashSort = document.getElementById('dashSort');
            if (activeRole === 'admin' && dashSort && dashSort.value === 'az') {
                dashSort.value = 'pendingDesc';
            }
            applyRoleSectionCopy();
        }

        function applyRoleSectionCopy() {
            const role = (sessionStorage.getItem('erp_role') || 'user').toLowerCase();
            const landingTitle = document.getElementById('landingSectionTitle');
            const logisticsTitle = document.getElementById('logisticsBoardTitle');
            const logisticsSubcopy = document.getElementById('logisticsBoardSubcopy');
            const dispatchTitle = document.getElementById('dispatchHeaderTitle');
            const dispatchSubcopy = document.getElementById('dispatchHeaderSubcopy');
            const formTitle = document.getElementById('formTitle');
            const paymentTitle = document.getElementById('paymentSectionTitle');
            const editMode = document.getElementById('editMode');
            const isEditing = editMode && editMode.value === "true";

            if (landingTitle) {
                landingTitle.innerText = role === 'admin' ? 'Financial Command Accounts' : 'Active Accounts Directory';
            }
            if (logisticsTitle) {
                logisticsTitle.innerText = role === 'logistics' ? 'Dispatch Command Board' : 'Master Production & Dispatch Board';
            }
            if (logisticsSubcopy) {
                logisticsSubcopy.innerText = role === 'logistics'
                    ? 'Dispatch-first command view for pending quantity, completion, and PO-level action.'
                    : 'Statement-level view of dispatch progress across all active Purchase Orders.';
            }
            if (dispatchTitle) {
                dispatchTitle.innerText = role === 'admin' ? 'Dispatch Reconciliation (Finance Oversight)' : 'Dispatch & Fulfillment Tracking';
            }
            if (dispatchSubcopy) {
                dispatchSubcopy.innerText = role === 'admin'
                    ? 'Cross-check dispatch quantities against invoice value exposure and pending recovery.'
                    : 'Statement-first dispatch view with quick reconciliation and drill-down.';
            }
            if (!isEditing && formTitle) {
                formTitle.innerText = role === 'admin' ? 'Log Invoice / Billing Entry' : 'Log New Dispatch / Invoice';
            }
            if (paymentTitle) {
                paymentTitle.innerText = role === 'admin' ? 'Record Priority Collection Receipt' : 'Record Payment Receipt';
            }
        }

        async function loadSecuredData() {
            const token = sessionStorage.getItem('erp_token');
            if (!token) return;
            const role = (sessionStorage.getItem('erp_role') || '').toLowerCase();

            try {
                if (role === 'logistics') {
                    document.getElementById('userMenuTop').style.display = 'flex';
                    const topGreeting = document.getElementById('topGreeting');
                    const topInitial = document.getElementById('topUserInitial');
                    const usernameLabel = sessionStorage.getItem('erp_username') || 'User';
                    if (topGreeting) topGreeting.innerText = `${usernameLabel} (LOGISTICS)`;
                    if (topInitial) topInitial.innerText = usernameLabel.charAt(0).toUpperCase();
                    const fxBtn = document.getElementById('btnFxRate');
                    const curBtn = document.getElementById('btnDisplayCur');
                    if (fxBtn) fxBtn.style.display = 'none';
                    if (curBtn) curBtn.style.display = 'none';
                    await loadLogisticsPortal();
                    return;
                }

                // 1. Fetch Clients
                const clientRes = await fetch('/api/clients', { headers: { 'Authorization': 'Bearer ' + token } });
                if (!clientRes.ok) {
                    if (clientRes.status === 401 || clientRes.status === 403) throw new Error("401");
                    throw new Error("Failed to load clients");
                }
                const sqlClients = await clientRes.json();
                const clientNameById = {};
                sqlClients.forEach(c => { clientNameById[c.id] = c.name; });

                // Preserve settings, reset client data
                const settings = appData['_settings'] || { customColumns: [] };
                appData = { _settings: settings };

                sqlClients.forEach(c => {
                    appData[c.name] = {
                        sql_id: c.id,
                        active: c.active !== false,
                        excess: c.excess_funds || 0,
                        unallocated: c.excess_funds || 0,
                        display_currency: c.display_currency || 'INR',
                        exchange_rate: c.exchange_rate || 83.0,
                        invoices: [],
                        paymentHistory: [],
                        poTerms: {}
                    };
                });

                // 2. Fetch Purchase Orders
                const poRes = await fetch('/api/purchase-orders', { headers: { 'Authorization': 'Bearer ' + token } });
                if (poRes.ok) {
                    const sqlPOs = await poRes.json();
                    sqlPOs.forEach(po => {
                        const cName = clientNameById[po.client_id];
                        if (cName && appData[cName]) {
                            appData[cName].poTerms[po.po_no] = {
                                adv: po.adv_pct || 0,
                                ret: po.ret_pct || 0,
                                base: po.ret_base || 'basic',
                                tdsEnabled: po.tds_enabled || false,
                                tdsRate: po.tds_rate || 0,
                                tdsThreshold: po.tds_threshold || 0,
                                projectName: po.project_name || '',
                                contactPerson: po.contact_person || '',
                                isCompleted: !!po.is_completed,
                                isHidden: !!po.is_hidden,
                                completedAt: po.completed_at || null,
                                baselineItems: (po.baseline_items || []).map(item => ({
                                    description: item.description || '',
                                    ordered_qty: Number(item.ordered_qty || 0),
                                    inspected_qty: Number(item.inspected_qty || 0),
                                    uom: item.uom || 'Nos',
                                    material_type: item.material_type || null,
                                    dispatch_alias: item.dispatch_alias || null,
                                    dispatch_rate: Number(item.dispatch_rate || 0)
                                }))
                            };
                        }
                    });
                }

                // 3. Fetch Invoices
                const invRes = await fetch('/api/invoices', { headers: { 'Authorization': 'Bearer ' + token } });
                if (invRes.ok) {
                    const sqlInvs = await invRes.json();
                    sqlInvs.forEach(inv => {
                        const cName = clientNameById[inv.client_id];
                        if (cName && appData[cName]) {
                            appData[cName].invoices.push(inv);
                        }
                    });
                }

                // 4. Fetch Payments
                const payRes = await fetch('/api/payments', { headers: { 'Authorization': 'Bearer ' + token } });
                if (payRes.ok) {
                    const sqlPays = await payRes.json();
                    sqlPays.forEach(pay => {
                        const cName = clientNameById[pay.client_id];
                        if (cName && appData[cName]) {
                            appData[cName].paymentHistory.push(pay);
                        }
                    });
                }

                // 5. Finalize Boot
                // The frontend reads refreshed ledger math from the backend.
                updateSidebarNav();

                // UNHIDE THE TOP RIGHT USER MENU AFTER LOGIN
                document.getElementById('userMenuTop').style.display = 'flex';
                const topGreeting = document.getElementById('topGreeting');
                const topInitial = document.getElementById('topUserInitial');
                const roleLabel = (sessionStorage.getItem('erp_role') || 'user').toUpperCase();
                const usernameLabel = sessionStorage.getItem('erp_username') || 'User';
                if (topGreeting) topGreeting.innerText = `${usernameLabel} (${roleLabel})`;
                if (topInitial) topInitial.innerText = usernameLabel.charAt(0).toUpperCase();
                applyLedgerTablePrefs();
                refreshLayoutOptions();

                // Route user based on their role
                const sessionRole = (sessionStorage.getItem('erp_role') || '').toLowerCase();
                applyRoleDashboardEmphasis(sessionRole);
                if (sessionRole === 'logistics') {
                    document.getElementById('logisticsLandingView').style.display = 'block';
                    document.getElementById('topbarTitle').innerText = 'Logistics Dashboard';
                    renderGlobalDispatchBoard();
                } else {
                    document.getElementById('landingView').style.display = 'block';
                    document.getElementById('topbarTitle').innerText = 'Portfolio Dashboard';
                    renderLandingPage();
                }

            } catch (e) {
                console.error("Initialization Error:", e);
                if (e.message.includes("401") || e.message.includes("403") || e.message.includes("Failed to load")) {
                    sessionStorage.removeItem('erp_token');
                    window.location.reload();
                }
            }
        }

        async function silentDataRefresh() {
            const token = sessionStorage.getItem('erp_token');
            if (!token) return;

            try {
                const role = (sessionStorage.getItem('erp_role') || '').toLowerCase();
                // Fetch perfectly calculated mathematical truth from Python
                const [clientRes, poRes, invRes, payRes] = await Promise.all([
                    fetch('/api/clients', { headers: { 'Authorization': 'Bearer ' + token } }),
                    role === 'logistics'
                        ? Promise.resolve({ ok: true, json: async () => [] })
                        : fetch('/api/purchase-orders', { headers: { 'Authorization': 'Bearer ' + token } }),
                    fetch('/api/invoices', { headers: { 'Authorization': 'Bearer ' + token } }),
                    fetch('/api/payments', { headers: { 'Authorization': 'Bearer ' + token } })
                ]);

                if (clientRes.ok && poRes.ok && invRes.ok && payRes.ok) {
                    const clients = await clientRes.json();
                    const pos = await poRes.json();
                    const invs = await invRes.json();
                    const pays = await payRes.json();

                    // 1. Wipe old frontend memory
                    Object.keys(appData).forEach(k => {
                        if (k !== '_settings') {
                            appData[k].invoices = [];
                            appData[k].paymentHistory = [];
                            appData[k].poTerms = {};
                        }
                    });

                    // 2. Map accurate Unallocated Funds
                    const clientsArr = Array.isArray(clients) ? clients : (clients.clients || []);
                    const clientNameById = {};
                    clientsArr.forEach(c => { clientNameById[c.id] = c.name; });
                    clientsArr.forEach(c => {
                        if (appData[c.name]) {
                            appData[c.name].unallocated = c.excess_funds || 0;
                            appData[c.name].excess = c.excess_funds || 0;
                            appData[c.name].display_currency = c.display_currency || appData[c.name].display_currency || 'INR';
                            appData[c.name].exchange_rate = c.exchange_rate || appData[c.name].exchange_rate || 83.0;
                        }
                    });

                    // 3. Refresh PO baseline/material columns; dispatch matrix depends on this.
                    pos.forEach(po => {
                        const cName = clientNameById[po.client_id];
                        if (cName && appData[cName]) {
                            appData[cName].poTerms[po.po_no] = {
                                adv: po.adv_pct || 0,
                                ret: po.ret_pct || 0,
                                base: po.ret_base || 'basic',
                                tdsEnabled: po.tds_enabled || false,
                                tdsRate: po.tds_rate || 0,
                                tdsThreshold: po.tds_threshold || 0,
                                projectName: po.project_name || '',
                                contactPerson: po.contact_person || '',
                                isCompleted: !!po.is_completed,
                                isHidden: !!po.is_hidden,
                                completedAt: po.completed_at || null,
                                baselineItems: (po.baseline_items || []).map(item => ({
                                    description: item.description || '',
                                    ordered_qty: Number(item.ordered_qty || 0),
                                    inspected_qty: Number(item.inspected_qty || 0),
                                    uom: item.uom || 'Nos',
                                    material_type: item.material_type || null,
                                    dispatch_alias: item.dispatch_alias || null,
                                    dispatch_rate: Number(item.dispatch_rate || 0)
                                }))
                            };
                        }
                    });

                    // 4. Map perfectly linked Invoices & PO Numbers
                    invs.forEach(inv => {
                        const cName = clientNameById[inv.client_id];
                        if (cName && appData[cName]) appData[cName].invoices.push(inv);
                    });

                    // 5. Map perfectly calculated Payments
                    pays.forEach(pay => {
                        const cName = clientNameById[pay.client_id];
                        if (cName && appData[cName]) appData[cName].paymentHistory.push(pay);
                    });
                }
            } catch (e) {
                console.error("Silent refresh failed:", e);
            }
        }

        async function refreshCurrentDispatchContext() {
            const selectedPo = (document.getElementById('dispatchPoSelect')?.value || '').trim();
            const role = (sessionStorage.getItem('erp_role') || '').toLowerCase();
            if (role === 'logistics' && currentClient) {
                const payload = await fetchLogisticsClientDispatchWorkspace(currentClient);
                applyLogisticsWorkspaceData(payload);
                openDispatchTracking(currentClient);
            } else {
                await silentDataRefresh();
            }
            if (selectedPo) {
                const poSelect = document.getElementById('dispatchPoSelect');
                if (poSelect) {
                    const options = Array.from(poSelect.options).map(o => o.value);
                    if (options.includes(selectedPo)) poSelect.value = selectedPo;
                }
            }
            renderDispatchReconciliation();
        }

        async function saveSettings() {
            const token = sessionStorage.getItem('erp_token');
            try {
                await fetch('/api/settings', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
                    body: JSON.stringify(appData._settings)
                });
            } catch (e) { console.error("Settings save failed", e); }
        }

        function openPasswordModal(targetId, username = null) {
            document.getElementById('passwordModal').style.display = 'flex';
            document.getElementById('currentPwdInput').value = '';
            document.getElementById('newPwdInput').value = '';
            document.getElementById('pwdMsg').innerText = '';
            document.getElementById('pwdTargetUserId').value = targetId;
            document.getElementById('currentPwdGroup').style.display = targetId === 'self' ? 'block' : 'none';
            document.getElementById('pwdModalTitle').innerText = targetId === 'self' ? 'Update Security Key' : `Reset Key: ${username}`;
            closeUserMenu();
        }
        function closePasswordModal() { document.getElementById('passwordModal').style.display = 'none'; }

        async function openAccountDetailsModal() {
            const token = sessionStorage.getItem('erp_token');
            closeUserMenu();
            try {
                const response = await fetch('/api/users/me', { headers: { 'Authorization': 'Bearer ' + token } });
                const data = await response.json().catch(() => ({}));
                if (!response.ok) return await customApplet({ title: "Error", message: data.detail || "Failed to fetch account details." });
                document.getElementById('accDetailUsername').value = data.username || '';
                document.getElementById('accDetailRole').value = data.role || '';
                document.getElementById('accDetailUserId').value = data.id || '';
                document.getElementById('accountDetailsModal').style.display = 'flex';
            } catch (e) {
                await customApplet({ title: "Network Error", message: "Unable to fetch account details." });
            }
        }

        function closeAccountDetailsModal() { document.getElementById('accountDetailsModal').style.display = 'none'; }

        async function submitPasswordChange() {
            const targetId = document.getElementById('pwdTargetUserId').value;
            const currentPwd = document.getElementById('currentPwdInput').value.trim();
            const newPwd = document.getElementById('newPwdInput').value.trim();
            const msg = document.getElementById('pwdMsg');
            const token = sessionStorage.getItem('erp_token');
            if (!newPwd) { msg.style.color = 'var(--danger)'; msg.innerText = 'Key cannot be empty.'; return; }
            if (targetId === 'self' && !currentPwd) { msg.style.color = 'var(--danger)'; msg.innerText = 'Current password is required.'; return; }

            let endpoint = targetId === 'self' ? '/api/users/change-password' : `/api/users/${targetId}/password`;
            let method = targetId === 'self' ? 'POST' : 'PUT';
            let body = targetId === 'self' ? { currentPassword: currentPwd, newPassword: newPwd } : { newPassword: newPwd };

            try {
                const response = await fetch(endpoint, { method: method, headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token }, body: JSON.stringify(body) });
                const payload = await response.json().catch(() => ({}));
                if (response.ok) {
                    msg.style.color = 'var(--success)'; msg.innerText = 'Security key updated successfully!';
                    setTimeout(closePasswordModal, 1500);
                } else { msg.style.color = 'var(--danger)'; msg.innerText = payload.detail || 'Failed to update key.'; }
            } catch (e) { msg.style.color = 'var(--danger)'; msg.innerText = 'Server error.'; }
        }

        async function fetchUsers() {
            const token = sessionStorage.getItem('erp_token');
            const tbody = document.getElementById('userTableBody');
            try {
                const response = await fetch('/api/users', { headers: { 'Authorization': 'Bearer ' + token } });
                const users = await response.json();
                const rows = [];
                users.forEach(u => {
                    let rolePill = u.role === 'admin' ? '<span class="status-pill pill-admin">SysAdmin</span>' : '<span class="status-pill pill-user">Operator</span>';
                    rows.push(`<tr><td style="text-align: left; font-weight: 600;">${esc(u.username)}</td><td style="text-align: center;">${rolePill}</td><td style="text-align: center;"><button class="btn-outline btn-sm" style="height:26px;" onclick="openPasswordModal(${u.id}, '${esc(u.username)}')">Reset Key</button> <button class="btn-outline btn-sm text-danger" style="height:26px;" onclick="deleteUser(${u.id})">Revoke</button></td></tr>`);
                });
                tbody.innerHTML = rows.join('');
            } catch (e) { tbody.innerHTML = '<tr><td colspan="3" style="text-align:center; color:red;">Directory fetch failed.</td></tr>'; }
        }

        async function fetchLegacyImportStatus() {
            const token = sessionStorage.getItem('erp_token');
            const host = document.getElementById('legacyImportStatus');
            if (!host) return;
            host.innerHTML = '<div>Loading latest import metadata...</div>';
            try {
                const response = await fetch('/api/admin/legacy-import-status', { headers: { 'Authorization': 'Bearer ' + token } });
                const payload = await response.json().catch(() => ({}));
                if (!response.ok) {
                    host.innerHTML = `<div style="color:var(--danger);">Unable to read import status: ${escHtml(payload.detail || 'Request failed')}</div>`;
                    return;
                }
                if (!payload.available || !payload.status) {
                    host.innerHTML = '<div>No legacy import report has been recorded yet.</div>';
                    return;
                }
                const status = payload.status || {};
                const counts = status.counts || {};
                const success = status.success === true;
                const stamp = status.completed_at || status.started_at || '-';
                const source = status.source_db || '-';
                host.innerHTML = `
                    <div><span class="status-pill ${success ? 'pill-user' : 'pill-inactive'}">${success ? 'SUCCESS' : 'FAILED'}</span></div>
                    <div><strong>Completed:</strong> ${escHtml(String(stamp))}</div>
                    <div><strong>Source DB:</strong> ${escHtml(String(source))}</div>
                    <div><strong>Clients Imported:</strong> ${counts.clients ? counts.clients.inserted : 0}</div>
                    <div><strong>Invoices Imported:</strong> ${counts.invoices ? counts.invoices.inserted : 0}</div>
                    <div><strong>Payments Imported:</strong> ${counts.payments ? counts.payments.inserted : 0}</div>
                `;
            } catch (e) {
                host.innerHTML = '<div style="color:var(--danger);">Unable to fetch import status.</div>';
            }
        }

        async function createUser() {
            const token = sessionStorage.getItem('erp_token');
            const u = document.getElementById('newUsername').value.trim();
            const p = document.getElementById('newPassword').value.trim();
            const r = document.getElementById('newUserRole').value;
            const msg = document.getElementById('adminMsg');
            if (!u || !p) { msg.style.color = "var(--danger)"; msg.innerText = "Identity parameters missing."; return; }
            try {
                const response = await fetch('/api/users', { method: 'POST', headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token }, body: JSON.stringify({ username: u, password: p, role: r }) });
                const payload = await response.json().catch(() => ({}));
                if (response.ok) { msg.style.color = "var(--success)"; msg.innerText = `Identity provisioned.`; document.getElementById('newUsername').value = ''; document.getElementById('newPassword').value = ''; fetchUsers(); }
                else { msg.style.color = "var(--danger)"; msg.innerText = payload.detail || "Provisioning failed."; }
            } catch (e) { msg.style.color = "var(--danger)"; msg.innerText = "Server error."; }
        }

        async function deleteUser(id) {
            let conf = await customApplet({ title: "Revoke Access", message: "Are you sure you want to permanently revoke this identity?", type: "confirm" });
            if (!conf) return;
            const token = sessionStorage.getItem('erp_token');
            const response = await fetch('/api/users/' + id, { method: 'DELETE', headers: { 'Authorization': 'Bearer ' + token } });
            if (response.ok) fetchUsers(); else await customApplet({ title: "Error", message: "Revocation failed." });
        }

        function updateSidebarNav() {
            const nav = document.getElementById('clientNavList');
            const role = sessionStorage.getItem('erp_role');
            const isLogistics = role === 'logistics';

            let navHtml = '';
            if (isLogistics) {
                const inClientPage = document.getElementById('logisticsClientPageView')?.style.display !== 'none';
                const inDirectory = document.getElementById('logisticsClientDirectoryView')?.style.display !== 'none';
                navHtml += `
                    <div class="nav-item ${!inClientPage && !inDirectory ? 'active' : ''}" onclick="openLogisticsStatementsView()">
                        <span class="nav-icon">◫</span>
                        <span class="nav-text">Dispatch Dashboard</span>
                    </div>
                    <div class="nav-item ${inDirectory ? 'active' : ''}" onclick="openLogisticsClientDirectoryView()">
                        <span class="nav-icon">▦</span>
                        <span class="nav-text">All Clients</span>
                    </div>
                `;
                const clientNames = Object.keys(logisticsPortalState.clientSummaries || {}).sort();
                if (clientNames.length) {
                    navHtml += `<div style="margin:10px 0 6px 2px; font-size:0.7rem; letter-spacing:0.8px; color:rgba(255,255,255,0.65); font-weight:700;">CLIENT PAGES</div>`;
                    clientNames.forEach((client) => {
                        const isActive = inClientPage && logisticsPortalState.clientPageClient === client;
                        navHtml += `
                            <div class="nav-item sub-nav-item ${isActive ? 'active' : ''}" onclick="openLogisticsClientPage('${esc(client)}')">
                                <span class="nav-icon" style="font-weight: 800; font-size: 0.95rem; color: #fff;">${escHtml(client.charAt(0).toUpperCase())}</span>
                                <span class="nav-text" style="white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 150px;">${escHtml(client)}</span>
                            </div>
                        `;
                    });
                }
                nav.innerHTML = navHtml;
                return;
            }

            // Only show financial dashboards to non-logistics users
            navHtml += `
                <div class="nav-item ${currentClient === null ? 'active' : ''}" onclick="goBack()"><span class="nav-icon">⌂</span> <span class="nav-text">Portfolio Dashboard</span></div>
                <div class="nav-item ${currentClient === 'ALL' ? 'active' : ''}" onclick="openGlobalLedger()"><span class="nav-icon">▤</span> <span class="nav-text">Global Master Ledger</span></div>
                <div class="nav-item ${currentClient === 'REPORTS' ? 'active' : ''}" onclick="openReportsPanel()"><span class="nav-icon">◔</span> <span class="nav-text">Analytics & Reports</span></div>
            `;

            if (role === 'admin') navHtml += `<div class="nav-item ${currentClient === 'ADMIN' ? 'active' : ''}" onclick="openAdminPanel()" style="margin-top: 12px; border-top: 1px solid rgba(255,255,255,0.05); padding-top: 16px;"><span class="nav-icon">⚙</span> <span class="nav-text">Identity Access Mgt.</span></div>`;

            let accHeader = "Client Accounts";
            const accHeaderIcon = '◉';
            navHtml += `<div class="client-accordion-header" onclick="toggleClientAccordion()"><span style="display:flex; align-items:center;"><span class="nav-icon" style="margin-right:12px; font-size:0.75rem;">${accHeaderIcon}</span><span class="nav-text">${accHeader}</span></span><span id="clientAccordionChevron" class="chevron">${clientAccordionOpen ? '▼' : '▶'}</span></div><div id="clientNavListContainer" class="client-accordion-content ${clientAccordionOpen ? '' : 'hidden'}"></div>`;
            nav.innerHTML = navHtml;

            const clientContainer = document.getElementById('clientNavListContainer');
            const clientRows = [];

            Object.keys(appData).filter(k => k !== '_settings').sort().forEach(client => {
                let activeStr = appData[client].active === false ? ' <span class="status-pill pill-inactive" style="margin-left:8px; border:none;">SUSPENDED</span>' : '';
                let monogram = client.charAt(0).toUpperCase();

                    // ADMIN/USER VIEW: Shows Ledger Link Only (Dispatch moved to internal page button)
                    let pendingCount = appData[client].invoices.filter(i => i.balance > 0).length;
                    let badgeHtml = pendingCount > 0 ? `<span class="nav-badge">${pendingCount}</span>` : '';

                clientRows.push(`
                        <div class="nav-item sub-nav-item ${currentClient === client && document.getElementById('clientView').style.display !== 'none' ? 'active' : ''}" onclick="openClient('${esc(client)}')">
                            <span class="nav-icon" style="font-weight: 800; font-size: 0.95rem; color: #fff;">${monogram}</span>
                        <span class="nav-text" style="white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 120px;">${escHtml(client)}${activeStr}</span>${badgeHtml}
                        </div>
                `);
            });
            clientContainer.innerHTML = clientRows.join('');
        }

        function hideAllViews() {
            ['landingView', 'clientView', 'adminView', 'reportsView', 'dispatchView', 'poDetailsView', 'logisticsLandingView', 'logisticsClientDirectoryView', 'logisticsClientPageView'].forEach(id => {
                let el = document.getElementById(id);
                if (el) el.style.display = 'none';
            });
            let backBtn = document.getElementById('btnTopBack');
            if (backBtn) backBtn.style.display = 'inline-flex';
        }

        function renderLandingPage() {
            hideAllViews();
            let backBtn = document.getElementById('btnTopBack');
            if (backBtn) backBtn.style.display = 'none';
            const actionsEl = document.getElementById('clientActions');
            if (actionsEl) actionsEl.style.display = 'none';

            if (currentClient === null) resetFilters(false);
            document.getElementById('landingView').style.display = 'block';
            document.getElementById('topbarTitle').innerText = "Industrial Portfolio Dashboard";
            applyRoleSectionCopy();

            const grid = document.getElementById('clientGrid');
            const cards = [];

            let clientsList = Object.keys(appData).filter(k => k !== '_settings');
            let searchQ = document.getElementById('dashSearch').value.toLowerCase().trim();
            if (searchQ) clientsList = clientsList.filter(c => c.toLowerCase().includes(searchQ));

            let sortQ = document.getElementById('dashSort').value;
            clientsList.sort((a, b) => {
                if (sortQ === 'az') return a.localeCompare(b);
                let aOut = 0, bOut = 0, aEx = appData[a].excess || 0, bEx = appData[b].excess || 0;
                appData[a].invoices.forEach(i => aOut += i.balance);
                appData[b].invoices.forEach(i => bOut += i.balance);
                if (sortQ === 'pendingDesc') return bOut - aOut;
                if (sortQ === 'unallocatedDesc') return bEx - aEx;
            });

            clientsList.forEach(clientName => {
                let clientData = appData[clientName];
                let totalOut = 0;
                clientData.invoices.forEach(inv => totalOut += inv.balance);
                let statusBanner = clientData.active === false ? `<div style="background:var(--danger); color:white; font-size:0.7rem; font-weight:bold; text-align:center; padding:4px; letter-spacing: 1px;">ACCOUNT SUSPENDED</div>` : '';

                cards.push(`
                                            <div class="card client-card" onclick="openClient('${esc(clientName)}')">
                                                ${statusBanner}
                                                <div style="padding: 20px 24px;">
                                                    <h3 style="border:none; margin-bottom:8px; padding:0;">${clientName} <span style="color:var(--brand-primary); font-size:1.2rem;">→</span></h3>
                                                    <div class="meta">Total Ledger Entries: ${clientData.invoices.length}</div>
                                                    <div class="stats">
                                                        <div class="stat-group">
                                                            <span class="stat-label">Pending Receivable</span>
                                                            <span class="stat-val danger">${formatCur(totalOut)}</span>
                                                        </div>
                                                        <div class="stat-group" style="text-align: right;">
                                                            <span class="stat-label">Unallocated Funds</span>
                                                            <span class="stat-val accent">${formatCur(clientData.excess || 0)}</span>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        `);
            });
            if (clientsList.length === 0) {
                grid.innerHTML = '<p style="color:var(--text-muted); grid-column: 1 / -1; padding: 20px;">No matching accounts found.</p>';
            } else {
                grid.innerHTML = cards.join('');
            }
            updateSidebarNav();
        }

        function openAdminPanel() { currentClient = 'ADMIN'; hideAllViews(); resetFilters(false); const actionsEl = document.getElementById('clientActions'); if (actionsEl) actionsEl.style.display = 'none'; document.getElementById('adminView').style.display = 'block'; document.getElementById('topbarTitle').innerText = "Identity & Security Administration"; updateSidebarNav(); fetchUsers(); fetchLegacyImportStatus(); }

        async function addClient() {
            const name = document.getElementById('newClientName').value.trim();
            if (!name) return await customApplet({ title: "Validation Error", message: "Account name is required." });
            if (appData[name] || name === '_settings') return await customApplet({ title: "Validation Error", message: "Account already exists." });

            const token = sessionStorage.getItem('erp_token');
            try {
                // Route directly to the new SQLAlchemy endpoint
                const response = await fetch('/api/clients', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
                    body: JSON.stringify({ name: name })
                });

                const responseData = await response.json();
                if (!response.ok) return await customApplet({ title: "Validation Error", message: responseData.detail || "Database error." });

                // Update local UI state
                appData[name] = { sql_id: responseData.id, invoices: [], excess: 0, active: true, poTerms: {}, paymentHistory: [] };
                document.getElementById('newClientName').value = '';

                renderLandingPage();
                // All client state persists via backend API + refresh only.
                // The database is now the true source of authority for Clients!
            } catch (e) {
                await customApplet({ title: "Network Error", message: "Failed to reach the SQL server." });
            }
        }

        async function editCurrentClient() {
            let newName = await customApplet({ title: "Rename Account", message: "Enter new name for industrial account:", type: "prompt", placeholder: currentClient });
            if (!newName || newName.trim() === "" || newName.trim() === currentClient || newName === '_settings') return;
            if (appData[newName.trim()]) return await customApplet({ title: "Validation Error", message: "Account already exists." });
            appData[newName.trim()] = appData[currentClient];
            delete appData[currentClient];
            currentClient = newName.trim();
            document.getElementById('topbarTitle').innerText = `Account Ledger: ${currentClient}`;
            document.getElementById('tableHeaderTitle').innerText = `${currentClient} - Detailed Records`;
            updateSidebarNav();
        }

        async function toggleClientActive() {
            if (!appData[currentClient]) return;
            let isAct = appData[currentClient].active !== false;
            if (isAct) {
                let conf = await customApplet({ title: "Suspend Account", message: `Suspend ${currentClient}?<br>This will lock the account into Read-Only mode.`, type: "confirm" });
                if (!conf) return;
            }
            appData[currentClient].active = !isAct;
            openClient(currentClient);
        }

        async function deleteCurrentClient() {
            let check = await customApplet({
                title: "CRITICAL WARNING",
                message: `This will permanently delete '${currentClient}' and ALL associated invoices, POs, and payments from the database.<br><br>Type <b>DELETE</b> to confirm.`,
                type: "dangerPrompt",
                dangerMatch: "DELETE"
            });
            if (check !== 'DELETE') return;

            const clientObj = appData[currentClient];
            const token = sessionStorage.getItem('erp_token');

            try {
                const response = await fetch(`/api/clients/${clientObj.sql_id}`, {
                    method: 'DELETE',
                    headers: { 'Authorization': 'Bearer ' + token }
                });

                if (!response.ok) throw new Error("Failed to delete client from database.");

                delete appData[currentClient];
                goBack();
            } catch (e) {
                await customApplet({ title: "Database Error", message: e.message });
            }
        }

        function openClient(name) {
            currentClient = name;
            displayCurrency = (appData[name]?.display_currency || 'INR').toUpperCase();
            exchangeRate = parseFloat(appData[name]?.exchange_rate || 83.0) || 83.0;
            const exRateEl = document.getElementById('exRateDisplay');
            if (exRateEl) exRateEl.innerText = exchangeRate.toFixed(2);
            const btnDisplayCur = document.getElementById('btnDisplayCur');
            if (btnDisplayCur) btnDisplayCur.innerText = displayCurrency === 'INR' ? 'View in USD' : 'View in INR';
            loadUserColumns();
            hideAllViews(); resetFilters(false);
            document.getElementById('clientView').style.display = 'block';

            const isAdmin = sessionStorage.getItem('erp_role') === 'admin';
            const isActive = appData[name] && appData[name].active !== false;

            if (isAdmin) {
                const actionsEl = document.getElementById('clientActions');
                if (actionsEl) actionsEl.style.display = 'flex';
                let tBtn = document.getElementById('btnToggleClientStatus');
                if (tBtn) {
                tBtn.innerHTML = isActive ? "⏸️ Suspend" : "▶️ Reactivate";
                tBtn.style.color = isActive ? "var(--warning)" : "var(--success)";
                tBtn.style.borderColor = isActive ? "var(--warning)" : "var(--success)";
                }
            } else {
                const actionsEl = document.getElementById('clientActions');
                if (actionsEl) actionsEl.style.display = 'none';
            }

            document.getElementById('dataEntrySection').style.display = isActive ? 'grid' : 'none';
            let titleAddon = isActive ? '' : ' <span class="status-pill pill-inactive" style="margin-left:12px; vertical-align:middle; border:none;">READ-ONLY</span>';
            document.getElementById('topbarTitle').innerHTML = `Account Ledger: ${escHtml(name)}${titleAddon}`;
            document.getElementById('tableHeaderTitle').innerText = `${name} - Detailed Records`;
            document.getElementById('fltClient').style.display = 'none';
            populatePoDropdown();
            applyRoleSectionCopy();

            cancelEdit(); updateSidebarNav(); triggerUpdate();
        }

        function openGlobalLedger() {
            currentClient = 'ALL';
            loadUserColumns();
            hideAllViews(); resetFilters(false);
            document.getElementById('clientView').style.display = 'block';
            const actionsEl = document.getElementById('clientActions');
            if (actionsEl) actionsEl.style.display = 'none';
            document.getElementById('dataEntrySection').style.display = 'none';
            document.getElementById('topbarTitle').innerText = `Global Master Ledger`;
            document.getElementById('tableHeaderTitle').innerText = `Consolidated Operations Records`;
            document.getElementById('fltClient').style.display = 'block';
            applyRoleSectionCopy();
            updateClientFilterDropdown(); updateSidebarNav(); triggerUpdate();
        }

        function parseNumberFilterValue(id) {
            const el = document.getElementById(id);
            if (!el || el.value === '') return null;
            const parsed = parseFloat(el.value);
            return Number.isFinite(parsed) ? parsed : null;
        }

        function getPoDetailRowsForClient(clientName) {
            const clientData = appData[clientName] || {};
            const poTerms = clientData.poTerms || {};
            const invoices = Array.isArray(clientData.invoices) ? clientData.invoices : [];
            const poSet = new Set(Object.keys(poTerms));
            invoices.forEach(inv => {
                if (inv.poNo && inv.poNo !== 'UNASSIGNED') poSet.add(inv.poNo);
            });
            const poList = Array.from(poSet).sort();
            return poList.map(poNo => {
                const term = poTerms[poNo] || {};
                const poInvoices = invoices.filter(inv => inv.poNo === poNo && !inv.isNote);
                let totalBilled = 0;
                let totalReceived = 0;
                let totalBalance = 0;
                let lastDispatchedDate = '';
                poInvoices.forEach(inv => {
                    totalBilled += parseFloat(inv.netPayable || 0);
                    totalReceived += parseFloat(inv.paid || 0);
                    totalBalance += parseFloat(inv.balance || 0);
                    if (inv.invDate && (!lastDispatchedDate || inv.invDate > lastDispatchedDate)) {
                        lastDispatchedDate = inv.invDate;
                    }
                });
                const paymentTerms = `Adv ${term.adv || 0}% | Ret ${term.ret || 0}% (${term.base || 'total'}) | TDS ${term.tdsEnabled ? `${term.tdsRate || 0}%>${formatCur(term.tdsThreshold || 0)}` : 'OFF'}`;
                return {
                    poNo,
                    projectName: term.projectName || '',
                    contactPerson: term.contactPerson || '',
                    lastDispatchedDate,
                    totalBilled,
                    totalReceived,
                    totalBalance,
                    paymentTerms,
                    isCompleted: !!term.isCompleted
                };
            });
        }

        function openPoDetailsPage() {
            if (!currentClient || currentClient === 'ALL' || currentClient === 'ADMIN' || currentClient === 'REPORTS') {
                customApplet({ title: 'Open Client First', message: 'Please open a specific client ledger before opening PO details.' });
                return;
            }
            hideAllViews();
            document.getElementById('poDetailsView').style.display = 'block';
            document.getElementById('topbarTitle').innerText = `PO Details: ${currentClient}`;
            const subtitle = document.getElementById('poDetailsSubtitle');
            if (subtitle) subtitle.innerText = `All Purchase Orders and their latest dispatch/financial summary for ${currentClient}.`;
            renderPoDetailsTable();
        }

        function renderPoDetailsTable() {
            const tbody = document.getElementById('poDetailsTableBody');
            if (!tbody || !currentClient || !appData[currentClient]) return;
            const rows = getPoDetailRowsForClient(currentClient);
            const filterColumn = (document.getElementById('poFilterColumn')?.value || 'poNo').trim();
            const filterValue = (document.getElementById('poFilterValue')?.value || '').trim();
            const statusValue = (document.getElementById('poFilterStatusValue')?.value || '').toUpperCase().trim();

            const filtered = rows.filter(r => {
                const rowStatus = r.isCompleted ? 'COMPLETED' : 'OPEN';
                if (filterColumn === 'status') {
                    if (!statusValue) return true;
                    return rowStatus === statusValue;
                }
                if (!filterValue) return true;
                if (filterColumn === 'totalBilled' || filterColumn === 'totalReceived' || filterColumn === 'totalBalance') {
                    const numericVal = parseFloat(filterValue);
                    if (!Number.isFinite(numericVal)) return true;
                    const source = filterColumn === 'totalBilled' ? r.totalBilled : (filterColumn === 'totalReceived' ? r.totalReceived : r.totalBalance);
                    return Number(source || 0) === numericVal;
                }
                const sourceValue = filterColumn === 'lastDispatchedDate'
                    ? (r.lastDispatchedDate || '')
                    : (filterColumn === 'poNo'
                        ? (r.poNo || '')
                        : (filterColumn === 'projectName'
                            ? (r.projectName || '')
                            : (filterColumn === 'contactPerson'
                                ? (r.contactPerson || '')
                                : (filterColumn === 'paymentTerms' ? (r.paymentTerms || '') : ''))));
                if (filterColumn === 'lastDispatchedDate') {
                    return sourceValue === filterValue;
                }
                if (filterColumn === 'status') {
                    return rowStatus.includes(filterValue.toUpperCase());
                }
                return String(sourceValue).toLowerCase().includes(filterValue.toLowerCase());
                return true;
            });

            if (!filtered.length) {
                tbody.innerHTML = `<tr><td colspan="10" style="text-align:center; padding: 28px; color: var(--text-muted);">No PO rows match current filters.</td></tr>`;
                return;
            }
            tbody.innerHTML = filtered.map(r => `
                <tr>
                    <td>${escHtml(r.poNo)}</td>
                    <td>${escHtml(r.projectName || '-')}</td>
                    <td>${escHtml(r.contactPerson || '-')}</td>
                    <td>${escHtml(r.lastDispatchedDate || '-')}</td>
                    <td style="text-align:right;">${formatCur(r.totalBilled)}</td>
                    <td style="text-align:right;">${formatCur(r.totalReceived)}</td>
                    <td style="text-align:right; color:${r.totalBalance > 0 ? 'var(--danger)' : 'var(--success)'};">${formatCur(r.totalBalance)}</td>
                    <td>${escHtml(r.paymentTerms)}</td>
                    <td>${r.isCompleted ? '<span class="status-pill pill-success">COMPLETED</span>' : '<span class="status-pill pill-admin">OPEN</span>'}</td>
                    <td style="text-align:center;">
                        <button class="btn-outline btn-sm" onclick="editPoFromDetails('${esc(r.poNo)}')">Edit PO</button>
                    </td>
                </tr>
            `).join('');
        }

        function editPoFromDetails(poNo) {
            if (!poNo || !currentClient || !appData[currentClient]) return;
            openPoTermsModal();
            editPoTerm(poNo);
            const formPo = document.getElementById('newTermPo');
            if (formPo) formPo.focus();
        }

        function goBack() {
            const role = sessionStorage.getItem('erp_role');
            if (role === 'logistics') {
            currentClient = null;
            updateSidebarNav();
            hideAllViews();
                const actionsEl = document.getElementById('clientActions');
                if (actionsEl) actionsEl.style.display = 'none';
                openLogisticsStatementsView();
                applyRoleSectionCopy();
                return;
            }

            const dispatchVisible = document.getElementById('dispatchView')?.style.display !== 'none';
            const poDetailsVisible = document.getElementById('poDetailsView')?.style.display !== 'none';
            if ((dispatchVisible || poDetailsVisible) && currentClient && currentClient !== 'ALL' && currentClient !== 'ADMIN' && currentClient !== 'REPORTS') {
                openClient(currentClient);
                return;
            }

            currentClient = null;
            updateSidebarNav();
            hideAllViews();
            const actionsEl = document.getElementById('clientActions');
            if (actionsEl) actionsEl.style.display = 'none';
                document.getElementById('landingView').style.display = 'block';
                document.getElementById('topbarTitle').innerText = 'Portfolio Dashboard';
                renderLandingPage();
            applyRoleSectionCopy();
        }

        async function loadLogisticsPortal() {
            currentClient = null;
            hideAllViews();
            updateSidebarNav();
            const actionsEl = document.getElementById('clientActions');
            if (actionsEl) actionsEl.style.display = 'none';
            const backBtn = document.getElementById('btnTopBack');
            if (backBtn) backBtn.style.display = 'none';
            applyRoleDashboardEmphasis('logistics');
            await openLogisticsStatementsView();
        }

        function openLogisticsStatementsView() {
            hideAllViews();
            const backBtn = document.getElementById('btnTopBack');
            if (backBtn) backBtn.style.display = 'none';
            logisticsPortalState.activeClient = '';
            logisticsPortalState.selectedClient = '';
            logisticsPortalState.selectedPoNo = '';
            const searchEl = document.getElementById('logisticsDispatchSearch');
            const statusEl = document.getElementById('logisticsDispatchStatus');
            const clientSearchEl = document.getElementById('logisticsClientQuickSearch');
            if (searchEl) searchEl.value = '';
            if (statusEl) statusEl.value = '';
            if (clientSearchEl) clientSearchEl.value = '';
            document.getElementById('logisticsLandingView').style.display = 'block';
            document.getElementById('topbarTitle').innerText = logisticsPortalState.activeClient ? `Dispatch: ${logisticsPortalState.activeClient}` : 'Logistics Dashboard';
            renderGlobalDispatchBoard(false);
        }

        async function openLogisticsClientDirectoryView() {
            hideAllViews();
            const backBtn = document.getElementById('btnTopBack');
            if (backBtn) backBtn.style.display = 'none';
            logisticsPortalState.activeClient = '';
            logisticsPortalState.selectedClient = '';
            logisticsPortalState.selectedPoNo = '';
            document.getElementById('logisticsClientDirectoryView').style.display = 'block';
            document.getElementById('topbarTitle').innerText = 'All Clients Dispatch Directory';
            const tbody = document.getElementById('logisticsClientDirectoryBody');
            if (!tbody) return;
            if (Array.isArray(logisticsPortalState.visibleRows) && logisticsPortalState.visibleRows.length) {
                renderLogisticsClientDirectory(logisticsPortalState.visibleRows);
            }
            tbody.innerHTML = '<tr><td colspan="7" style="padding:18px; text-align:center; color:var(--text-muted);">Loading clients dispatch data...</td></tr>';
            try {
                const searchEl = document.getElementById('logisticsDispatchSearch');
                const statusEl = document.getElementById('logisticsDispatchStatus');
                const prevSearch = searchEl ? searchEl.value : '';
                const prevStatus = statusEl ? statusEl.value : '';
                if (searchEl) searchEl.value = '';
                if (statusEl) statusEl.value = '';
                const payload = await fetchLogisticsDispatchSummary(false);
                const rows = Array.isArray(payload.rows) ? payload.rows : [];
                logisticsPortalState.visibleRows = rows;
                renderLogisticsClientDirectory(rows);
                if (searchEl) searchEl.value = prevSearch;
                if (statusEl) statusEl.value = prevStatus;
            } catch (err) {
                tbody.innerHTML = '<tr><td colspan="7" style="padding:18px; text-align:center; color:var(--danger);">Failed to load client-wise dispatch data.</td></tr>';
            }
        }

        function renderLogisticsClientDirectory(rows) {
            const tbody = document.getElementById('logisticsClientDirectoryBody');
            if (!tbody) return;
            const list = Array.isArray(rows) ? rows : [];
            if (!list.length) {
                tbody.innerHTML = '<tr><td colspan="7" style="padding:18px; text-align:center; color:var(--text-muted);">No client dispatch records found.</td></tr>';
                return;
            }
            const byClient = {};
            list.forEach((row) => {
                const key = (row.client || 'Unknown').trim() || 'Unknown';
                if (!byClient[key]) byClient[key] = { client: key, statements: 0, ordered: 0, dispatched: 0, pending: 0 };
                byClient[key].statements += 1;
                byClient[key].ordered += Number(row.ordered_qty || 0);
                byClient[key].dispatched += Number(row.dispatched_qty || 0);
                byClient[key].pending += Number(row.pending_qty || 0);
            });
            const clients = Object.values(byClient).sort((a, b) => b.pending - a.pending);
            tbody.innerHTML = clients.map((row) => {
                const completion = row.ordered > 0 ? (Math.min(row.dispatched, row.ordered) / row.ordered) * 100 : 0;
                const completionColor = row.pending <= 0.0001 ? 'var(--success)' : (completion >= 70 ? '#0ea5e9' : 'var(--danger)');
                return `
                    <tr style="border-bottom: 1px solid var(--border); background:#fff;">
                        <td style="padding:12px 14px; font-weight:700; color:var(--brand-primary);">${escHtml(row.client)}</td>
                        <td style="padding:12px 14px; text-align:right;">${formatNum(row.statements, 0)}</td>
                        <td style="padding:12px 14px; text-align:right;">${formatNum(row.ordered, 2)}</td>
                        <td style="padding:12px 14px; text-align:right; color:#0ea5e9; font-weight:700;">${formatNum(row.dispatched, 2)}</td>
                        <td style="padding:12px 14px; text-align:right; color:var(--danger); font-weight:800;">${formatNum(row.pending, 2)}</td>
                        <td style="padding:12px 14px; text-align:center; color:${completionColor}; font-weight:800;">${completion.toFixed(1)}%</td>
                        <td style="padding:12px 14px; text-align:center;">
                            <button class="btn-outline btn-sm" onclick="openLogisticsClientPage('${esc(row.client)}')">Open Client Page</button>
                        </td>
                    </tr>
                `;
            }).join('');
        }

        function openLogisticsClientPage(clientName) {
            logisticsPortalState.selectedClient = '';
            logisticsPortalState.selectedPoNo = '';
            logisticsPortalState.clientPageClient = clientName || '';
            updateSidebarNav();
            openLogisticsClientPageView();
        }

        async function openLogisticsClientPageView() {
            hideAllViews();
            const backBtn = document.getElementById('btnTopBack');
            if (backBtn) backBtn.style.display = 'none';
            document.getElementById('logisticsClientPageView').style.display = 'block';
            const clientName = logisticsPortalState.clientPageClient || 'Client';
            const role = (sessionStorage.getItem('erp_role') || '').toLowerCase();
            const pageBackBtn = document.getElementById('logisticsClientPageBackBtn');
            if (pageBackBtn) pageBackBtn.innerHTML = role === 'logistics' ? '← Back to All Clients' : '← Back to Ledger';
            document.getElementById('topbarTitle').innerText = `Client Dispatch: ${clientName}`;
            document.getElementById('logisticsClientPageTitle').innerText = `${clientName} - Dispatch Summary`;
            document.getElementById('logisticsClientPageSubcopy').innerText = `PO-wise dispatch summary and full statement drill-down for ${clientName}.`;
            await renderLogisticsClientPageBoard();
        }

        function goBackFromClientDispatchPage() {
            const role = (sessionStorage.getItem('erp_role') || '').toLowerCase();
            if (role === 'logistics') return openLogisticsClientDirectoryView();
            if (logisticsPortalState.clientPageClient) return openClient(logisticsPortalState.clientPageClient);
            return goBack();
        }

        function goBackFromDispatchReconciliation() {
            const role = (sessionStorage.getItem('erp_role') || '').toLowerCase();
            const clientName = (currentClient && currentClient !== 'ALL' && currentClient !== 'ADMIN' && currentClient !== 'REPORTS') ? currentClient : (logisticsPortalState.clientPageClient || '');
            if (role === 'logistics') {
                if (clientName) return openLogisticsClientPage(clientName);
                return openLogisticsClientDirectoryView();
            }
            if (clientName) {
                logisticsPortalState.clientPageClient = clientName;
                logisticsPortalState.selectedClientRowIndex = -1;
                return openLogisticsClientPageView();
            }
            return goBack();
        }

        async function renderLogisticsClientPageBoard() {
            const clientName = (logisticsPortalState.clientPageClient || '').trim();
            const tbody = document.getElementById('logisticsClientPageBody');
            if (!clientName || !tbody) return;
            tbody.innerHTML = '<tr><td colspan="7" style="padding:18px; text-align:center; color:var(--text-muted);">Loading client dispatch summary...</td></tr>';
            try {
                const token = sessionStorage.getItem('erp_token');
                const params = new URLSearchParams();
                params.set('sort_by', 'pending_qty');
                params.set('sort_dir', 'desc');
                const res = await fetch(`/api/logistics/dispatch-summary?${params.toString()}`, { headers: { 'Authorization': 'Bearer ' + token } });
                if (!res.ok) throw new Error('Failed to load dispatch summary');
                const payload = await res.json();
                const allRows = Array.isArray(payload.rows) ? payload.rows : [];
                const rows = allRows.filter(r => (r.client || '').toLowerCase() === clientName.toLowerCase()).map((r) => ({ ...r }));
                logisticsPortalState.visibleClientRows = rows;

                const globalSearch = (document.getElementById('logisticsClientPoSearch')?.value || '').trim().toLowerCase();
                const poNoFilter = (document.getElementById('logisticsClientPoNoFilter')?.value || '').trim().toLowerCase();
                const dateFilter = (document.getElementById('logisticsClientDateFilter')?.value || '').trim();
                const statusFilter = (document.getElementById('logisticsClientStatusFilter')?.value || '').trim();
                const sortBy = (document.getElementById('logisticsClientSortBy')?.value || 'date_desc').trim();

                let filteredRows = rows.filter((row) => {
                    const poNo = String(row.po_no || '').toLowerCase();
                    const date = String(row.last_invoice_date || row.invoice_date || '');
                    const items = Number(row.material_lines || 0);
                    const ordered = Number(row.ordered_qty || 0);
                    const dispatched = Number(row.dispatched_qty || 0);
                    const pending = Number(row.pending_qty || 0);
                    const dispatchedPct = ordered > 0 ? Math.min(100, (Math.min(dispatched, ordered) / ordered) * 100) : 0;
                    const pendingPct = ordered > 0 ? Math.max(0, (pending / ordered) * 100) : 0;
                    let status = 'pending';
                    if (pending <= 0.0001) status = 'completed';
                    else if (dispatched > 0.0001) status = 'partial';
                    const composite = `${row.po_no || ''} ${date} ${items} ${status} ${pendingPct.toFixed(2)} ${dispatchedPct.toFixed(2)}`.toLowerCase();
                    if (globalSearch && !composite.includes(globalSearch)) return false;
                    if (poNoFilter && !poNo.includes(poNoFilter)) return false;
                    if (dateFilter && String(date).slice(0, 10) !== dateFilter) return false;
                    if (statusFilter && status !== statusFilter) return false;
                    row._status = status;
                    row._pendingPct = pendingPct;
                    row._dispatchedPct = dispatchedPct;
                    row._rowDate = date ? String(date).slice(0, 10) : '-';
                    return true;
                });

                filteredRows.sort((a, b) => {
                    if (sortBy === 'date_asc' || sortBy === 'date_desc') {
                        const av = String(a._rowDate || '');
                        const bv = String(b._rowDate || '');
                        return sortBy === 'date_asc' ? av.localeCompare(bv) : bv.localeCompare(av);
                    }
                    if (sortBy === 'po_asc') return String(a.po_no || '').localeCompare(String(b.po_no || ''));
                    if (sortBy === 'pending_desc') return Number(b._pendingPct || 0) - Number(a._pendingPct || 0);
                    if (sortBy === 'dispatched_desc') return Number(b._dispatchedPct || 0) - Number(a._dispatchedPct || 0);
                    return 0;
                });
                logisticsPortalState.filteredClientRows = filteredRows;

                let ordered = 0;
                let dispatched = 0;
                let pending = 0;
                let pendingStatements = 0;
                filteredRows.forEach(row => {
                    ordered += Number(row.ordered_qty || 0);
                    dispatched += Number(row.dispatched_qty || 0);
                    const pend = Number(row.pending_qty || 0);
                    pending += pend;
                    if (pend > 0.0001) pendingStatements += 1;
                });
                const completionPct = ordered > 0 ? (Math.min(dispatched, ordered) / ordered) * 100 : 0;
                document.getElementById('lgClientStmtTotal').innerText = formatNum(filteredRows.length, 0);
                document.getElementById('lgClientStmtPending').innerText = formatNum(pendingStatements, 0);
                document.getElementById('lgClientCompletion').innerText = `${completionPct.toFixed(1)}%`;
                document.getElementById('lgClientPendingQty').innerText = formatNum(pending, 2);

                if (!filteredRows.length) {
                    tbody.innerHTML = '<tr><td colspan="7" style="padding:18px; text-align:center; color:var(--text-muted);">No PO statements found for this client/filter combination.</td></tr>';
                    updateClientStatementStepButtons();
                    return;
                }

                tbody.innerHTML = filteredRows.map((row) => {
                    const rowIndex = logisticsPortalState.filteredClientRows.indexOf(row);
                    const pendingQty = Number(row.pending_qty || 0);
                    const status = row._status || 'pending';
                    const statusLabel = status === 'completed' ? 'Completed' : (status === 'partial' ? 'Partial' : 'Pending');
                    const statusColor = status === 'completed' ? 'var(--success)' : (status === 'partial' ? '#0ea5e9' : 'var(--danger)');
                    const meta = [row.project_name || '', row.contact_person || ''].filter(Boolean).join(' • ');
                    return `
                        <tr style="border-bottom: 1px solid var(--border); background: #fff;">
                            <td style="padding: 12px 16px; font-weight: 600;">${escHtml(row.po_no || '')}${meta ? `<div style="font-size:0.72rem; color:var(--text-muted); font-weight:600; margin-top:2px;">${escHtml(meta)}</div>` : ''}</td>
                            <td style="padding: 12px 16px;">${escHtml(row._rowDate || '-')}</td>
                            <td style="padding: 12px 16px; text-align: right;">${formatNum(row.material_lines || 0, 0)}</td>
                            <td style="padding: 12px 16px; text-align: center; font-weight: 800; color:${statusColor};">${statusLabel}</td>
                            <td style="padding: 12px 16px; text-align: right; font-weight: 800; color: var(--danger);">${Number(row._pendingPct || 0).toFixed(1)}%</td>
                            <td style="padding: 12px 16px; text-align: right; font-weight: 800; color: #0ea5e9;">${Number(row._dispatchedPct || 0).toFixed(1)}%</td>
                            <td style="padding: 12px 16px; text-align: center;"><button class="btn-outline btn-sm" data-row-index="${rowIndex}" onclick="openClientPageDispatchStatementFromButton(this)">Open Statement</button></td>
                                </tr>
                            `;
                }).join('');
                if (logisticsPortalState.selectedClientRowIndex < 0 || !logisticsPortalState.filteredClientRows[logisticsPortalState.selectedClientRowIndex]) {
                    logisticsPortalState.selectedClientRowIndex = 0;
                }
                updateClientStatementStepButtons();
            } catch (err) {
                tbody.innerHTML = '<tr><td colspan="7" style="padding:18px; text-align:center; color:var(--danger);">Failed to load client dispatch summary.</td></tr>';
            }
        }

        function openLogisticsClientPageStatementFromButton(btn) {
            if (!btn) return;
            const idx = Number(btn.getAttribute('data-row-index'));
            if (Number.isNaN(idx) || !logisticsPortalState.filteredClientRows[idx]) return;
            logisticsPortalState.selectedClientRowIndex = idx;
            const row = logisticsPortalState.filteredClientRows[idx];
            openLogisticsStatement(row.client || '', row.po_no || '', {
                metaId: 'logisticsClientStatementMeta',
                summaryBodyId: 'logisticsClientStatementSummaryBody',
                invoiceBodyId: 'logisticsClientStatementInvoiceBody'
            });
        }

        async function openClientPageDispatchStatementFromButton(btn) {
            if (!btn) return;
            const idx = Number(btn.getAttribute('data-row-index'));
            if (Number.isNaN(idx) || !logisticsPortalState.filteredClientRows[idx]) return;
            logisticsPortalState.selectedClientRowIndex = idx;
            const row = logisticsPortalState.filteredClientRows[idx];
            return openDispatchStatementByClientPo(row.client || '', row.po_no || '');
        }

        async function openDispatchStatementByClientPo(clientName, poNo) {
            const role = (sessionStorage.getItem('erp_role') || '').toLowerCase();
            const client = (clientName || '').trim();
            const po = (poNo || '').trim();
            if (!client) return;

            if (role === 'logistics') {
                // Logistics loads secured dispatch workspace and then selects PO in the dedicated dispatch page.
                return openLogisticsDispatchWorkspace(client, po);
            }

            if (!appData[client]) {
                return customApplet({ title: "Unavailable", message: "Client dispatch context is not loaded yet. Please refresh and try again." });
            }
            openDispatchTracking(client);
            if (po) {
                const poSelect = document.getElementById('dispatchPoSelect');
                if (poSelect) {
                    const options = Array.from(poSelect.options).map(o => o.value);
                    if (options.includes(po)) {
                        poSelect.value = po;
                        renderDispatchReconciliation();
                    }
                }
            }
        }

        function updateClientStatementStepButtons() {
            const prevBtn = document.getElementById('logisticsClientPrevPoBtn');
            const nextBtn = document.getElementById('logisticsClientNextPoBtn');
            const idx = Number(logisticsPortalState.selectedClientRowIndex || 0);
            const total = Array.isArray(logisticsPortalState.filteredClientRows) ? logisticsPortalState.filteredClientRows.length : 0;
            if (prevBtn) prevBtn.disabled = !(idx > 0);
            if (nextBtn) nextBtn.disabled = !(idx >= 0 && idx < total - 1);
        }

        function stepClientStatementPo(direction) {
            const dir = Number(direction || 0);
            if (!dir) return;
            const total = Array.isArray(logisticsPortalState.filteredClientRows) ? logisticsPortalState.filteredClientRows.length : 0;
            if (!total) return;
            let nextIndex = Number(logisticsPortalState.selectedClientRowIndex || 0) + (dir > 0 ? 1 : -1);
            nextIndex = Math.max(0, Math.min(total - 1, nextIndex));
            if (nextIndex === logisticsPortalState.selectedClientRowIndex) return;
            logisticsPortalState.selectedClientRowIndex = nextIndex;
            const row = logisticsPortalState.filteredClientRows[nextIndex];
            if (!row) return;
            openDispatchStatementByClientPo(row.client || '', row.po_no || '');
        }

        function rerenderSelectedClientStatement() {
            if (!logisticsPortalState.selectedStatementCache || !logisticsPortalState.selectedStatementTarget) return;
            renderLogisticsStatementFromCache(logisticsPortalState.selectedStatementCache, logisticsPortalState.selectedStatementTarget);
        }

        async function openLogisticsStatement(clientName, poNo, target = {}) {
            logisticsPortalState.selectedClient = clientName || '';
            logisticsPortalState.selectedPoNo = poNo || '';
            const metaId = target.metaId || 'logisticsStatementMeta';
            const summaryBodyId = target.summaryBodyId || 'logisticsStatementSummaryBody';
            const invoiceBodyId = target.invoiceBodyId || 'logisticsStatementInvoiceBody';
            const summaryBody = document.getElementById(summaryBodyId);
            const invoiceBody = document.getElementById(invoiceBodyId);
            const metaEl = document.getElementById(metaId);
            if (!clientName || !poNo) return;
            if (!summaryBody || !invoiceBody || !metaEl) return;
            summaryBody.innerHTML = '<tr><td colspan="6" style="padding:16px; text-align:center; color:var(--text-muted);">Loading statement details...</td></tr>';
            invoiceBody.innerHTML = '<tr><td colspan="5" style="padding:16px; text-align:center; color:var(--text-muted);">Loading invoice-wise rows...</td></tr>';
            try {
                const token = sessionStorage.getItem('erp_token');
                const params = new URLSearchParams({ client: clientName, po_no: poNo });
                const res = await fetch(`/api/logistics/dispatch-detail?${params.toString()}`, { headers: { 'Authorization': 'Bearer ' + token } });
                if (!res.ok) throw new Error('Failed to load dispatch detail');
                const payload = await res.json();
                logisticsPortalState.selectedStatementCache = payload;
                logisticsPortalState.selectedStatementTarget = { metaId, summaryBodyId, invoiceBodyId };
                renderLogisticsStatementFromCache(payload, logisticsPortalState.selectedStatementTarget);
                updateClientStatementStepButtons();
            } catch (err) {
                metaEl.innerText = 'Failed to load dispatch statement detail.';
                summaryBody.innerHTML = '<tr><td colspan="6" style="padding:16px; text-align:center; color:var(--danger);">Unable to load statement summary.</td></tr>';
                invoiceBody.innerHTML = '<tr><td colspan="5" style="padding:16px; text-align:center; color:var(--danger);">Unable to load invoice-wise rows.</td></tr>';
            }
        }

        function renderLogisticsStatementFromCache(payload, target) {
            const overview = payload?.overview || {};
            const summaryRowsRaw = Array.isArray(payload?.summary_rows) ? payload.summary_rows : [];
            const invoiceRowsRaw = Array.isArray(payload?.invoice_rows) ? payload.invoice_rows : [];
            const metaEl = document.getElementById(target.metaId || 'logisticsStatementMeta');
            const summaryBody = document.getElementById(target.summaryBodyId || 'logisticsStatementSummaryBody');
            const invoiceBody = document.getElementById(target.invoiceBodyId || 'logisticsStatementInvoiceBody');
            if (!metaEl || !summaryBody || !invoiceBody) return;

            const itemFilter = (document.getElementById('logisticsDetailItemFilter')?.value || '').trim().toLowerCase();
            const invoiceFilter = (document.getElementById('logisticsDetailInvoiceFilter')?.value || '').trim().toLowerCase();
            const vehicleFilter = (document.getElementById('logisticsDetailVehicleFilter')?.value || '').trim().toLowerCase();
            const minQty = Number(parseFloat((document.getElementById('logisticsDetailMinQtyFilter')?.value || '').trim() || '0')) || 0;

            const filteredSummary = summaryRowsRaw.filter((row) => {
                const desc = String(row.description || '').toLowerCase();
                const qty = Number(row.dispatched_qty || 0);
                return (!itemFilter || desc.includes(itemFilter)) && qty >= minQty;
            });
            const filteredInvoiceRows = invoiceRowsRaw.filter((row) => {
                const desc = String(row.description || '').toLowerCase();
                const inv = String(row.invoice_no || '').toLowerCase();
                const vehicle = String(row.lr_no || row.vehicle_no || '').toLowerCase();
                const qty = Number(row.dispatched_qty || 0);
                return (!itemFilter || desc.includes(itemFilter))
                    && (!invoiceFilter || inv.includes(invoiceFilter))
                    && (!vehicleFilter || vehicle.includes(vehicleFilter))
                    && qty >= minQty;
            });

            const metaBits = [
                `${escHtml(overview.client || '')} - ${escHtml(overview.po_no || '')}`,
                `Completion: ${Number(overview.completion_pct || 0).toFixed(1)}%`,
                (overview.project_name || '').trim(),
                (overview.contact_person || '').trim()
            ].filter(Boolean);
            metaEl.innerHTML = metaBits.join(' | ');

            if (!filteredSummary.length) {
                summaryBody.innerHTML = '<tr><td colspan="6" style="padding:16px; text-align:center; color:var(--text-muted);">No summary rows match current filters.</td></tr>';
            } else {
                summaryBody.innerHTML = filteredSummary.map(row => `
                    <tr style="border-bottom: 1px solid var(--border);">
                        <td style="padding: 10px 12px; font-weight:600;">${escHtml(row.description || '')}</td>
                        <td style="padding: 10px 12px; text-align:center;">${escHtml(row.uom || '')}</td>
                        <td style="padding: 10px 12px; text-align:right;">${formatNum(row.ordered_qty || 0, 2)}</td>
                        <td style="padding: 10px 12px; text-align:right; color:#0ea5e9; font-weight:700;">${formatNum(row.dispatched_qty || 0, 2)}</td>
                        <td style="padding: 10px 12px; text-align:right; color:var(--success); font-weight:700;">${formatNum(row.inspected_qty || 0, 2)}</td>
                        <td style="padding: 10px 12px; text-align:right; color:var(--danger); font-weight:800;">${formatNum(row.pending_qty || 0, 2)}</td>
                    </tr>
                `).join('');
            }
            if (!filteredInvoiceRows.length) {
                invoiceBody.innerHTML = '<tr><td colspan="5" style="padding:16px; text-align:center; color:var(--text-muted);">No invoice-wise rows match current filters.</td></tr>';
            } else {
                invoiceBody.innerHTML = filteredInvoiceRows.map(row => `
                    <tr style="border-bottom: 1px solid var(--border);">
                        <td style="padding: 8px 10px; font-weight:600;">${escHtml(row.invoice_no || '')}</td>
                        <td style="padding: 8px 10px;">${escHtml(row.invoice_date || '-')}</td>
                        <td style="padding: 8px 10px;">${escHtml(row.description || '')}</td>
                        <td style="padding: 8px 10px; text-align:right; color:#0ea5e9; font-weight:700;">${formatNum(row.dispatched_qty || 0, 2)}</td>
                        <td style="padding: 8px 10px; text-align:right; color:var(--success); font-weight:700;">${formatNum(row.inspected_qty || 0, 2)}</td>
                    </tr>
                `).join('');
            }
        }

        function openLogisticsStatementFromButton(btn) {
            if (!btn) return;
            const idx = Number(btn.getAttribute('data-row-index'));
            if (!Number.isNaN(idx) && logisticsPortalState.visibleRows[idx]) {
                const row = logisticsPortalState.visibleRows[idx];
                openLogisticsStatement(row.client || '', row.po_no || '');
                return;
            }
            const clientName = btn.getAttribute('data-client') || '';
            const poNo = btn.getAttribute('data-po') || '';
            openLogisticsStatement(clientName, poNo);
        }

        async function fetchLogisticsClientDispatchWorkspace(clientName) {
            const token = sessionStorage.getItem('erp_token');
            if (!token) throw new Error('Missing auth token');
            const params = new URLSearchParams({ client: clientName || '' });
            const response = await fetch(`/api/logistics/client-dispatch-workspace?${params.toString()}`, {
                headers: { 'Authorization': 'Bearer ' + token }
            });
            if (!response.ok) throw new Error('Failed to load client dispatch workspace');
            return response.json();
        }

        function applyLogisticsWorkspaceData(payload) {
            const client = payload?.client || {};
            const clientName = client.name || '';
            if (!clientName) throw new Error('Missing client name');
            const poTerms = {};
            (payload?.po_terms || []).forEach((po) => {
                poTerms[po.po_no] = {
                    adv: 0,
                    ret: 0,
                    base: 'total',
                    tdsEnabled: false,
                    tdsRate: 0,
                    tdsThreshold: 0,
                    projectName: po.project_name || '',
                    contactPerson: po.contact_person || '',
                    isCompleted: !!po.is_completed,
                    isHidden: !!po.is_hidden,
                    completedAt: po.completed_at || null,
                    baselineItems: (po.baseline_items || []).map(item => ({
                        description: item.description || '',
                        ordered_qty: Number(item.ordered_qty || 0),
                        inspected_qty: Number(item.inspected_qty || 0),
                        uom: item.uom || 'Nos',
                        material_type: item.material_type || null,
                        dispatch_alias: item.dispatch_alias || null,
                        dispatch_rate: Number(item.dispatch_rate || 0)
                    }))
                };
            });
            const invoices = (payload?.invoices || []).map((inv) => ({
                id: inv.invoice_no || inv.id || '',
                poNo: inv.po_no || 'UNASSIGNED',
                subEntity: inv.sub_entity || '',
                lrNo: inv.lr_no || '',
                invDate: inv.inv_date || null,
                dueDate: inv.due_date || null,
                total: Number(inv.total || 0),
                basic: 0,
                gst: 0,
                advance: 0,
                tds: 0,
                retention: 0,
                netPayable: 0,
                paid: 0,
                balance: 0,
                isNote: false,
                dispatchItems: (inv.dispatch_items || []).map((item) => ({
                    id: item.id,
                    description: item.description || '',
                    qty: Number(item.qty || 0),
                    inspected_qty: Number(item.inspected_qty || 0),
                    uom: item.uom || 'Nos',
                    rate_per_uom: Number(item.rate_per_uom || 0)
                }))
            }));
            appData[clientName] = {
                sql_id: client.id,
                active: client.active !== false,
                excess: 0,
                unallocated: 0,
                display_currency: 'INR',
                exchange_rate: 1,
                invoices,
                paymentHistory: [],
                poTerms
            };
            return clientName;
        }

        function applyDispatchRoleVisibility() {
            const isLogistics = (sessionStorage.getItem('erp_role') || '').toLowerCase() === 'logistics';
            const dataEntrySection = document.getElementById('dataEntrySection');
            if (dataEntrySection) {
                dataEntrySection.style.display = isLogistics ? 'grid' : dataEntrySection.style.display;
            }
            const financialFieldIds = ['advanceVal', 'tdsVal', 'retentionVal', 'entryCurrency', 'entryRate', 'applyGst'];
            financialFieldIds.forEach((id) => {
                const el = document.getElementById(id);
                if (!el) return;
                const wrapper = el.closest('.form-group') || el.parentElement;
                if (wrapper) wrapper.style.display = isLogistics ? 'none' : '';
            });
        }

        async function openLogisticsDispatchWorkspace(clientName, poNo = '') {
            const name = (clientName || '').trim();
            if (!name) return;
            try {
                const payload = await fetchLogisticsClientDispatchWorkspace(name);
                const loadedClient = applyLogisticsWorkspaceData(payload);
                openDispatchTracking(loadedClient);
                applyDispatchRoleVisibility();
                if (poNo) {
                    const poSelect = document.getElementById('dispatchPoSelect');
                    if (poSelect) {
                        const options = Array.from(poSelect.options).map(o => o.value);
                        if (options.includes(poNo)) {
                            poSelect.value = poNo;
                            renderDispatchReconciliation();
                        }
                    }
                }
            } catch (err) {
                customApplet({ title: 'Load Error', message: 'Could not open dispatch workspace for this client.' });
            }
        }

        async function openLogisticsDispatchWorkspaceFromButton(btn) {
            if (!btn) return;
            const idx = Number(btn.getAttribute('data-row-index'));
            if (!Number.isNaN(idx) && logisticsPortalState.visibleRows[idx]) {
                const row = logisticsPortalState.visibleRows[idx];
                return openLogisticsDispatchWorkspace(row.client || '', row.po_no || '');
            }
            const clientName = btn.getAttribute('data-client') || '';
            const poNo = btn.getAttribute('data-po') || '';
            return openLogisticsDispatchWorkspace(clientName, poNo);
        }

        async function openLogisticsDispatchWorkspaceFromClientPageButton(btn) {
            if (!btn) return;
            const idx = Number(btn.getAttribute('data-row-index'));
            if (Number.isNaN(idx) || !logisticsPortalState.visibleClientRows[idx]) return;
            const row = logisticsPortalState.visibleClientRows[idx];
            return openLogisticsDispatchWorkspace(row.client || '', row.po_no || '');
        }

        async function fetchLogisticsDispatchSummary(useCurrentFilters = true) {
            const token = sessionStorage.getItem('erp_token');
            if (!token) throw new Error('Missing auth token');
            const params = new URLSearchParams();
            const searchEl = document.getElementById('logisticsDispatchSearch');
            const statusEl = document.getElementById('logisticsDispatchStatus');
            const searchText = useCurrentFilters ? (searchEl ? searchEl.value : '').trim() : '';
            const statusVal = useCurrentFilters ? (statusEl ? statusEl.value : '').trim() : '';
            if (searchText) params.set('search', searchText);
            if (statusVal) params.set('status', statusVal);
            params.set('sort_by', 'pending_qty');
            params.set('sort_dir', 'desc');
            const response = await fetch(`/api/logistics/dispatch-summary?${params.toString()}`, {
                headers: { 'Authorization': 'Bearer ' + token }
            });
            if (!response.ok) {
                throw new Error('Failed to load dispatch summary');
            }
            return response.json();
        }

        async function renderGlobalDispatchBoard(useCurrentFilters = true) {
            const tbody = document.getElementById('globalDispatchBody');
            const clientGrid = document.getElementById('logisticsClientGrid');
            const boardTitle = document.getElementById('logisticsBoardTitle');
            const boardSubcopy = document.getElementById('logisticsBoardSubcopy');
            const activeClient = (logisticsPortalState.activeClient || '').trim();
            if (boardTitle) boardTitle.innerText = activeClient ? `${activeClient} Logistics Dashboard` : 'Logistics Dashboard';
            if (boardSubcopy) {
                boardSubcopy.innerText = activeClient
                    ? 'PO-level dispatch summary for this client. Open any PO to inspect complete statement lines.'
                    : 'Dispatch-only workspace for statement tracking and shipment progress.';
            }
            document.getElementById('topbarTitle').innerText = activeClient ? `Dispatch: ${activeClient}` : 'Logistics Dashboard';
            if (tbody) {
                tbody.innerHTML = '<tr><td colspan="9" style="text-align: center; padding: 24px; color: var(--text-muted);">Loading dispatch summary...</td></tr>';
            }
            try {
                let payload = await fetchLogisticsDispatchSummary(useCurrentFilters);
                let overview = payload.overview || {};
                let rows = Array.isArray(payload.rows) ? payload.rows : [];
                if (!rows.length && useCurrentFilters) {
                    payload = await fetchLogisticsDispatchSummary(false);
                    overview = payload.overview || {};
                    rows = Array.isArray(payload.rows) ? payload.rows : [];
                }
                if (activeClient) {
                    rows = rows.filter(r => (r.client || '').toLowerCase() === activeClient.toLowerCase());
                }
                logisticsPortalState.visibleRows = rows;
                const summaries = {};
                rows.forEach((row) => {
                    const key = (row.client || 'Unknown').trim() || 'Unknown';
                    if (!summaries[key]) summaries[key] = { client: key, statements: 0, ordered: 0, dispatched: 0, pending: 0 };
                    summaries[key].statements += 1;
                    summaries[key].ordered += Number(row.ordered_qty || 0);
                    summaries[key].dispatched += Number(row.dispatched_qty || 0);
                    summaries[key].pending += Number(row.pending_qty || 0);
                });
                logisticsPortalState.clientSummaries = summaries;
                const clientQuickSearch = (document.getElementById('logisticsClientQuickSearch')?.value || '').trim().toLowerCase();
                if (clientGrid) {
                    const cards = Object.values(summaries)
                    .filter(s => !clientQuickSearch || (s.client || '').toLowerCase().includes(clientQuickSearch))
                    .sort((a, b) => b.pending - a.pending).map((s) => {
                        const completion = s.ordered > 0 ? (Math.min(s.dispatched, s.ordered) / s.ordered) * 100 : 0;
                        return `
                            <div class="card client-card" onclick="openLogisticsClientPage('${esc(s.client)}')">
                                <div style="padding: 18px 20px;">
                                    <h3 style="border:none; margin-bottom:8px; padding:0;">${escHtml(s.client)} <span style="color:var(--brand-primary); font-size:1.1rem;">→</span></h3>
                                    <div class="meta">Statements: ${formatNum(s.statements, 0)}</div>
                                    <div class="stats">
                                        <div class="stat-group">
                                            <span class="stat-label">Pending Qty</span>
                                            <span class="stat-val danger">${formatNum(s.pending, 2)}</span>
                                        </div>
                                        <div class="stat-group" style="text-align: right;">
                                            <span class="stat-label">Completion</span>
                                            <span class="stat-val accent">${completion.toFixed(1)}%</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        `;
                    });
                    clientGrid.innerHTML = cards.length ? cards.join('') : '<p style="color:var(--text-muted); grid-column: 1 / -1; padding: 12px;">No clients found for current filters.</p>';
                }
                updateSidebarNav();

                const todayIso = new Date().toISOString().slice(0, 10);
                const dispatchedTodayCount = rows.filter(row => String(row.last_invoice_date || row.invoice_date || '').slice(0, 10) === todayIso).length;
                const dispatchedTrucksCount = rows.filter(row => Number(row.dispatched_qty || 0) > 0).length;
                if (activeClient) {
                    let ordered = 0;
                    let dispatched = 0;
                    let pending = 0;
                    let pendingStatements = 0;
                    rows.forEach(row => {
                        ordered += Number(row.ordered_qty || 0);
                        dispatched += Number(row.dispatched_qty || 0);
                        const pend = Number(row.pending_qty || 0);
                        pending += pend;
                        if (pend > 0.0001) pendingStatements += 1;
                    });
                    const completionPct = ordered > 0 ? (Math.min(dispatched, ordered) / ordered) * 100 : 0;
                    document.getElementById('lgDispatchedTrucks').innerText = formatNum(dispatchedTrucksCount, 0);
                    document.getElementById('lgStmtPending').innerText = formatNum(pendingStatements, 0);
                    document.getElementById('lgDispatchedToday').innerText = formatNum(dispatchedTodayCount, 0);
                    document.getElementById('lgPendingQty').innerText = formatNum(pending || 0, 2);
                } else {
                    document.getElementById('lgDispatchedTrucks').innerText = formatNum(dispatchedTrucksCount || 0, 0);
                    document.getElementById('lgStmtPending').innerText = formatNum(overview.pending_statements || 0, 0);
                    document.getElementById('lgDispatchedToday').innerText = formatNum(dispatchedTodayCount || 0, 0);
                    document.getElementById('lgPendingQty').innerText = formatNum(overview.total_pending_qty || 0, 2);
                }

                if (!rows.length) {
                    tbody.innerHTML = '<tr><td colspan="9" style="text-align: center; padding: 40px; color: var(--text-muted); font-size: 1.0rem;">No dispatch statements match the selected filters.</td></tr>';
                    return;
                }

                const rowsHtml = [];
                rows.forEach(row => {
                    const rowIndex = logisticsPortalState.visibleRows.indexOf(row);
                    const pendingQty = Number(row.pending_qty || 0);
                    const completion = Number(row.completion || 0);
                    const completionColor = pendingQty <= 0.0001 ? 'var(--success)' : (completion >= 70 ? '#0ea5e9' : 'var(--danger)');
                    const meta = [row.project_name || '', row.contact_person || ''].filter(Boolean).join(' • ');
                    rowsHtml.push(`
                        <tr style="border-bottom: 1px solid var(--border); background: #fff;">
                            <td style="padding: 12px 16px; font-weight: bold; color: var(--brand-primary);">${escHtml(row.client || '')}</td>
                            <td style="padding: 12px 16px; font-weight: 600;">${escHtml(row.po_no || '')}${meta ? `<div style="font-size:0.72rem; color:var(--text-muted); font-weight:600; margin-top:2px;">${escHtml(meta)}</div>` : ''}</td>
                            <td style="padding: 12px 16px; text-align: right;">${formatNum(row.material_lines || 0, 0)}</td>
                            <td style="padding: 12px 16px; text-align: right;">${formatNum(row.ordered_qty || 0, 2)}</td>
                            <td style="padding: 12px 16px; text-align: right; font-weight: 700; color: #0ea5e9;">${formatNum(row.dispatched_qty || 0, 2)}</td>
                            <td style="padding: 12px 16px; text-align: right; font-weight: 700; color: var(--success);">${formatNum(row.inspected_qty || 0, 2)}</td>
                            <td style="padding: 12px 16px; text-align: right; font-weight: 800; color: var(--danger);">${formatNum(pendingQty, 2)}</td>
                            <td style="padding: 12px 16px; text-align: center; font-weight: 800; color: ${completionColor};">${completion.toFixed(1)}%</td>
                            <td style="padding: 12px 16px; text-align: center;">
                                <button class="btn-outline btn-sm" data-row-index="${rowIndex}" data-client="${escHtml(row.client || '')}" data-po="${escHtml(row.po_no || '')}" onclick="openLogisticsDispatchWorkspaceFromButton(this)" title="Open dispatch workspace">Open Workspace</button>
                            </td>
                        </tr>
                    `);
                });
                tbody.innerHTML = rowsHtml.join('');
                if (!logisticsPortalState.selectedClient && rows[0]) {
                    openLogisticsStatement(rows[0].client || '', rows[0].po_no || '');
                }
            } catch (err) {
                console.error('Dispatch summary load failed:', err);
                tbody.innerHTML = '<tr><td colspan="9" style="text-align: center; padding: 40px; color: var(--danger); font-size: 1.0rem;">Failed to load dispatch summary from server.</td></tr>';
                if (clientGrid) clientGrid.innerHTML = '';
            }
        }

        function handlePoSelectChange() {
            const sel = document.getElementById('poNoSelect');
            const inp = document.getElementById('poNo');
            const btn = document.getElementById('btnCancelNewPo');

            if (sel.value === 'ADD_NEW') {
                sel.style.display = 'none';
                inp.style.display = 'block';
                btn.style.display = 'block';
                inp.value = '';
                inp.focus();
            } else {
                inp.value = sel.value;
                autoCalculateTerms();
            }
        }

        function populatePoDropdown(selectedPo = '') {
            const sel = document.getElementById('poNoSelect');
            if (!sel || !currentClient || !appData[currentClient]) return;
            const poSet = new Set();
            Object.keys(appData[currentClient].poTerms || {}).forEach(po => {
                if (po && po !== 'UNASSIGNED') poSet.add(po);
            });
            (appData[currentClient].invoices || []).forEach(inv => {
                const poNo = String(inv.poNo || '').trim();
                if (poNo && poNo !== 'UNASSIGNED') poSet.add(poNo);
            });
            const poList = Array.from(poSet).sort((a, b) => a.localeCompare(b));
            sel.innerHTML = '<option value="">-- Select PO --</option>';
            poList.forEach(po => {
                sel.innerHTML += `<option value="${esc(po)}">${escHtml(po)}</option>`;
            });
            sel.innerHTML += '<option value="ADD_NEW">+ Add New PO</option>';
            if (selectedPo && poList.includes(selectedPo)) {
                sel.value = selectedPo;
                const inp = document.getElementById('poNo');
                if (inp) inp.value = selectedPo;
            }
        }

        function cancelNewPoInput() {
            const sel = document.getElementById('poNoSelect');
            const inp = document.getElementById('poNo');
            const btn = document.getElementById('btnCancelNewPo');

            inp.style.display = 'none';
            btn.style.display = 'none';
            sel.style.display = 'block';
            sel.value = '';
            inp.value = '';
            autoCalculateTerms();
        }

        // --- PO TERMS MANAGER WITH RETROACTIVE RECALCULATION & 50L LOGIC ---
        function openPoTermsModal() {
            if (!currentClient || currentClient === 'ALL') return alert("Please open a specific client account first.");
            document.getElementById('poTermsModal').style.display = 'flex';
            renderPoTermsTable();
        }

        function renderPoTermsTable() {
            const tbody = document.getElementById('poTermsTableBody');
            tbody.innerHTML = '';
            if (!appData[currentClient].poTerms) appData[currentClient].poTerms = {};

            const terms = appData[currentClient].poTerms;
            for (const [po, data] of Object.entries(terms)) {
                let tdsStr = data.tdsEnabled
                    ? `<span class="status-pill pill-danger">ON: ${data.tdsRate}% > ${formatCur(data.tdsThreshold)}</span>`
                    : `<span class="status-pill pill-user">OFF</span>`;
                const metaStr = [data.projectName || '', data.contactPerson || ''].filter(Boolean).join(' • ') || '-';
                const completionBadge = data.isCompleted ? `<span class="status-pill pill-success" style="margin-left:6px;">COMPLETED</span>` : '';

                tbody.innerHTML += `
                                            <tr style="border-bottom: 1px solid var(--border);">
                                                <td style="padding: 12px 16px; font-weight: 600;">${esc(po)} ${completionBadge}</td>
                                                <td style="padding: 12px 16px;">${escHtml(metaStr)}</td>
                                                <td style="padding: 12px 16px; text-align: center;">Adv: ${data.adv}%<br>Ret: ${data.ret}%</td>
                                                <td style="padding: 12px 16px; text-align: center;">${tdsStr}</td>
                                                <td style="padding: 12px 16px; text-align: center; white-space: nowrap;">
                                                    <button class="btn-outline btn-sm" style="border: none; margin-right: 4px;" onclick="editPoTerm('${esc(po)}')">✏️ Edit</button>
                                                    <button class="btn-outline btn-sm" style="border: none; margin-right: 4px;" onclick="togglePoCompletion('${esc(po)}', ${data.isCompleted ? 'false' : 'true'})">${data.isCompleted ? '↺ Reopen' : '✓ Complete'}</button>
                                                    <button class="btn-outline btn-sm text-danger" style="border: none;" onclick="deletePoTerm('${esc(po)}')">🗑️ Remove</button>
                                                </td>
                                            </tr>
                                        `;
            }
            if (Object.keys(terms).length === 0) {
                tbody.innerHTML = `<tr><td colspan="5" style="text-align:center; padding: 20px; color:var(--text-muted); font-size:0.8rem;">No PO terms defined yet.</td></tr>`;
            }
        }

        function editPoTerm(po) {
            const terms = appData[currentClient].poTerms[po];
            if (!terms) return;

            document.getElementById('newTermPo').value = po;
            document.getElementById('newTermAdv').value = terms.adv;
            document.getElementById('newTermRet').value = terms.ret;
            document.getElementById('newTermBase').value = terms.base || 'total';
            document.getElementById('newTermProjectName').value = terms.projectName || '';
            document.getElementById('newTermContactPerson').value = terms.contactPerson || '';

            let tdsEnabled = terms.tdsEnabled !== undefined ? terms.tdsEnabled : true;
            document.getElementById('newTermTdsEnabled').checked = tdsEnabled;
            document.getElementById('tdsConfigGrid').style.opacity = tdsEnabled ? '1' : '0.4';
            document.getElementById('tdsConfigGrid').style.pointerEvents = tdsEnabled ? 'auto' : 'none';

            document.getElementById('newTermTdsRate').value = terms.tdsRate !== undefined ? terms.tdsRate : 0.1;
            document.getElementById('newTermTdsBase').value = terms.tdsBase || 'basic';
            document.getElementById('newTermTdsThreshold').value = terms.tdsThreshold !== undefined ? terms.tdsThreshold : 5000000;
            document.getElementById('newTermPoBasic').value = terms.poBasic || 0;

            document.getElementById('newTermAdv').focus();
        }

        async function togglePoCompletion(poNo, targetCompleted) {
            const token = sessionStorage.getItem('erp_token');
            try {
                const response = await fetch(`/api/purchase-orders/${encodeURIComponent(poNo)}/status`, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
                    body: JSON.stringify({ is_completed: !!targetCompleted, is_hidden: false })
                });
                const result = await response.json().catch(() => ({}));
                if (!response.ok) throw new Error(result.detail || 'Failed to update PO status.');
                if (appData[currentClient] && appData[currentClient].poTerms && appData[currentClient].poTerms[poNo]) {
                    appData[currentClient].poTerms[poNo].isCompleted = !!targetCompleted;
                }
                await silentDataRefresh();
                renderPoTermsTable();
                updatePOFilterDropdown();
                triggerUpdate();
            } catch (e) {
                await customApplet({ title: 'Error', message: escHtml(e.message || 'Unable to update PO state.') });
            }
        }

        async function addPoTerm() {
            const po = document.getElementById('newTermPo').value.trim();
            const adv = parseFloat(document.getElementById('newTermAdv').value) || 0;
            const ret = parseFloat(document.getElementById('newTermRet').value) || 0;
            const base = document.getElementById('newTermBase').value;
            const projectName = document.getElementById('newTermProjectName').value.trim();
            const contactPerson = document.getElementById('newTermContactPerson').value.trim();

            const tdsEnabled = document.getElementById('newTermTdsEnabled').checked;
            const tdsRate = parseFloat(document.getElementById('newTermTdsRate').value) || 0;
            const tdsBase = document.getElementById('newTermTdsBase').value;

            const tdsThresholdInput = document.getElementById('newTermTdsThreshold').value;
            const poBasicInput = document.getElementById('newTermPoBasic').value;
            const tdsThreshold = tdsThresholdInput === '' ? 0 : (parseFloat(tdsThresholdInput) || 0);
            const poBasic = poBasicInput === '' ? 0 : (parseFloat(poBasicInput) || 0);

            if (!po) return await customApplet({ title: "Validation Error", message: "PO Number is required." });

            let dynamicTdsRate = 0;
            if (tdsEnabled) {
                if (poBasic === 0 && tdsThreshold === 0) {
                    dynamicTdsRate = tdsRate / 100;
                } else if (poBasic > tdsThreshold) {
                    let excess = poBasic - tdsThreshold;
                    dynamicTdsRate = (excess * (tdsRate / 100)) / poBasic;
                }
            }

            const clientObj = appData[currentClient];
            const token = sessionStorage.getItem('erp_token');
            const existingTerms = appData[currentClient].poTerms[po] || {};
            const existingBaselineItems = Array.isArray(existingTerms.baselineItems) ? existingTerms.baselineItems : [];
            try {
                // Route directly to the new SQLAlchemy endpoint
                const response = await fetch('/api/purchase-orders', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
                    body: JSON.stringify({
                        client_id: clientObj.sql_id,
                        po_no: po,
                        project_name: projectName || null,
                        contact_person: contactPerson || null,
                        adv_pct: adv,
                        ret_pct: ret,
                        ret_base: base,
                        tds_enabled: tdsEnabled,
                        tds_rate: tdsRate,
                        tds_threshold: tdsThreshold,
                        baseline_items: existingBaselineItems
                    })
                });

                const responseData = await response.json();
                if (!response.ok) throw new Error(responseData.detail || "Failed to save to database");

                // Update local UI state for immediate rendering
                appData[currentClient].poTerms[po] = {
                    sql_id: responseData.po_id,
                    adv, ret, base,
                    projectName,
                    contactPerson,
                    isCompleted: existingTerms.isCompleted || false,
                    poBasic, tdsEnabled, tdsRate, tdsBase, tdsThreshold, dynamicTdsRate, baselineItems: existingBaselineItems
                };

                document.getElementById('newTermPo').value = '';
                document.getElementById('newTermAdv').value = '';
                document.getElementById('newTermRet').value = '';
                document.getElementById('newTermProjectName').value = '';
                document.getElementById('newTermContactPerson').value = '';
                document.getElementById('newTermPoBasic').value = '';

                await silentDataRefresh();
                renderPoTermsTable();
                triggerUpdate();
                // Database remains the single source of truth.
                autoCalculateTerms();

                await customApplet({ title: "Terms Configured", message: `Terms successfully saved to database for PO: ${po}.<br><br>All historical and future invoices mapped to this PO have been retroactively calculated.` });
            } catch (e) {
                await customApplet({ title: "Database Error", message: e.message });
            }
        }

        async function deletePoTerm(po) {
            if (!await customApplet({ title: "Remove Terms", message: `Delete payment terms for PO ${po}?`, type: "confirm" })) return;
            const token = sessionStorage.getItem('erp_token');
            try {
                const response = await fetch(`/api/purchase-orders/${encodeURIComponent(po)}`, {
                    method: 'DELETE',
                    headers: { 'Authorization': 'Bearer ' + token }
                });
                const result = await response.json().catch(() => ({}));
                if (!response.ok) throw new Error(result.detail || "Failed to delete PO terms from database.");
                await silentDataRefresh();
            renderPoTermsTable();
            triggerUpdate();
            } catch (e) {
                await customApplet({ title: "Database Error", message: e.message });
            }
        }

        function autoCalculateTerms() {
            if (!currentClient || currentClient === 'ALL') return;
            const poNo = document.getElementById('poNo').value.trim();
            const terms = appData[currentClient].poTerms ? appData[currentClient].poTerms[poNo] : null;

            const basic = parseFloat(document.getElementById('basicVal').value) || 0;
            const applyGst = document.getElementById('applyGst').checked;
            const total = basic + (applyGst ? basic * 0.18 : 0);

            let tdsInput = document.getElementById('tdsVal');

            if (terms) {
                if (terms.tdsEnabled) {
                    let baseAmtForTds = terms.tdsBase === 'total' ? total : basic;
                    tdsInput.value = (baseAmtForTds * (terms.dynamicTdsRate || 0)).toFixed(2);
                } else {
                    tdsInput.value = '0.00';
                }
            } else {
                if (document.getElementById('applyTds') && document.getElementById('applyTds').checked) {
                    tdsInput.value = (basic * 0.001).toFixed(2);
                } else {
                    tdsInput.value = '0.00';
                }
            }

            if (!terms) {
                document.getElementById('retentionVal').value = '0';
                return;
            }
            const baseAmt = terms.base === 'basic' ? basic : total;
            if (terms.ret > 0) document.getElementById('retentionVal').value = (baseAmt * (terms.ret / 100)).toFixed(2);
        }

        // --- DATA ENTRY & INLINE EDITING ---
        

        function editInvoice(id) {
            if (currentClient === 'ALL') return;
            const inv = appData[currentClient].invoices.find(i => i.id === id);
            if (!inv) return;

            let poVal = inv.poNo === 'UNASSIGNED' ? '' : inv.poNo;
            document.getElementById('poNo').value = poVal;

            let sel = document.getElementById('poNoSelect');
            if (sel) {
                populatePoDropdown();
                sel.value = poVal;
                if (poVal && sel.value !== poVal) {
                    sel.style.display = 'none';
                    document.getElementById('poNo').style.display = 'block';
                    document.getElementById('btnCancelNewPo').style.display = 'block';
                } else {
                    sel.style.display = 'block';
                    document.getElementById('poNo').style.display = 'none';
                    document.getElementById('btnCancelNewPo').style.display = 'none';
                }
            }

            document.getElementById('subEntity').value = inv.subEntity || '';
            document.getElementById('invNo').value = inv.id;
            document.getElementById('invNo').disabled = true;
            document.getElementById('lrNo').value = inv.lrNo || '';
            document.getElementById('invDate').value = inv.invDate || '';
            document.getElementById('dueDate').value = inv.dueDate || '';

            document.getElementById('entryCurrency').value = inv.entryCur || 'INR';
            document.getElementById('entryRate').value = inv.entryRate || 1;
            document.getElementById('entryRate').disabled = (inv.entryCur || 'INR') === 'INR';
            document.getElementById('applyGst').checked = inv.gst > 0;
            if (document.getElementById('applyTds')) document.getElementById('applyTds').checked = Number(inv.tds || 0) > 0;

            document.getElementById('basicVal').value = inv.basic;
            document.getElementById('advanceVal').value = inv.advance;
            document.getElementById('tdsVal').value = inv.tds;
            document.getElementById('retentionVal').value = inv.retention;

            appData._settings.customColumns.forEach(cc => {
                if (cc.type === 'text') {
                    let el = document.getElementById('custom_field_' + cc.id);
                    if (el && inv.customFields) el.value = inv.customFields[cc.id] || '';
                }
            });

            document.getElementById('editMode').value = "true";
            document.getElementById('formTitle').innerText = "Edit Existing Record";
            document.getElementById('saveBtn').innerText = "Update Ledger Entry";
            document.getElementById('cancelBtn').style.display = "flex";

            inlineEditId = id;
            triggerUpdate();
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        async function saveInlineEdit(id) {
            try {
                let inv = appData[currentClient].invoices.find(i => i.id === id);
                if (!inv) return;

                const getVal = (elId, fallback) => document.getElementById(elId) ? document.getElementById(elId).value.trim() : fallback;
                const getFloat = (elId, fallback) => {
                    const el = document.getElementById(elId);
                    return el && el.value ? (parseFloat(el.value) || 0) : fallback;
                };

                const poNo = getVal('inl_po', inv.poNo);
                const subEntity = getVal('inl_sub', inv.subEntity || '');
                const lrNo = getVal('inl_lr', inv.lrNo || '');
                const invDate = getVal('inl_date', inv.invDate || '');
                const dueDate = getVal('inl_due', inv.dueDate || '');

                const basic = getFloat('inl_basic', inv.basic || 0);
                let advance = inv.advance || 0;
                const tds = getFloat('inl_tds', inv.tds || 0);
                let retention = getFloat('inl_ret', inv.retention || 0);

                if (basic <= 0) return await customApplet({ title: "Validation Error", message: "Basic Value must be greater than zero." });

                const gst = inv.gst > 0 ? basic * 0.18 : 0;
                const total = basic + gst;

                if (inv.poNo !== poNo && advance > 0 && inv.poNo !== 'UNASSIGNED') {
                    advance = 0;
                    customApplet({ title: "PO Changed", message: `The PO number was updated. The previously applied advance has been refunded to the ${inv.poNo} pool.` });
                }

                const terms = appData[currentClient].poTerms ? appData[currentClient].poTerms[poNo] : null;
                if (terms) {
                    let baseAmt = terms.base === 'basic' ? basic : total;
                    retention = baseAmt * (terms.ret / 100);
                } else if (poNo !== inv.poNo) {
                    retention = 0;
                }

                const netPayable = total - advance - tds;
                const balance = Math.max(0, netPayable - (inv.paid || 0));

                // --- STRICT RELATIONAL API CALL ---
                const token = sessionStorage.getItem('erp_token');
                const clientObj = appData[currentClient];

                const payload = {
                    client_id: clientObj.sql_id,
                    po_no: poNo || 'UNASSIGNED',
                    invoice_no: id,
                    sub_entity: subEntity,
                    lr_no: lrNo,
                    inv_date: invDate || null,
                    due_date: dueDate || null,
                    basic: basic,
                    gst: gst,
                    total: total,
                    advance_adj: advance,
                    tds_ded: tds,
                    retention_held: retention,
                    net_payable: netPayable,
                    paid: inv.paid || 0,
                    balance: balance,
                    is_note: inv.isNote || false
                };

                const response = await fetch(`/api/invoices/${encodeURIComponent(id)}`, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
                    body: JSON.stringify(payload)
                });

                if (!response.ok) {
                    const result = await response.json().catch(() => ({}));
                    throw new Error(result.detail || "Failed to update record in database.");
                }

                // Map back to UI
                inv.poNo = poNo || 'UNASSIGNED';
                inv.subEntity = subEntity;
                inv.lrNo = lrNo; inv.invDate = invDate; inv.dueDate = dueDate;
                inv.basic = basic; inv.gst = gst; inv.total = total;
                inv.advance = advance; inv.tds = tds; inv.retention = retention;

                inv.isManualOverride = true;
                inv.netPayable = netPayable;
                inv.balance = balance;

                if (appData._settings && appData._settings.customColumns) {
                    appData._settings.customColumns.forEach(cc => {
                        if (cc.type === 'text') {
                            let el = document.getElementById('inl_cust_' + cc.id);
                            if (el && !inv.customFields) inv.customFields = {};
                            if (el) inv.customFields[cc.id] = el.value;
                        }
                    });
                }

                await silentDataRefresh();
                cancelEdit();
                updatePOFilterDropdown();

            } catch (err) {
                console.error("Inline Save Error:", err);
                await customApplet({ title: "Database Error", message: err.message });
            }
        }

        async function deleteInvoice(id) {
            return withInFlight(`deleteInvoice:${id}`, async () => {
            if (currentClient === 'ALL') return;
            const inv = appData[currentClient].invoices.find(i => i.id === id);
            if (!inv) return;

            let conf = await customApplet({ title: "Delete Invoice", message: "Permanently delete Invoice " + id + " from the database?", type: "confirm" });
            if (!conf) return;

            const token = sessionStorage.getItem('erp_token');
            try {
                const response = await fetch(`/api/invoices/${encodeURIComponent(id)}`, {
                    method: 'DELETE',
                    headers: { 'Authorization': 'Bearer ' + token }
                });

                if (!response.ok) throw new Error("Failed to delete record from SQL database.");

                if (inv.paid > 0) {
                    await customApplet({ title: "Funds Refunded", message: formatCur(inv.paid) + " has been mathematically refunded to your Excess Funds." });
                }

                    await silentDataRefresh();
                    triggerUpdate();
            } catch (e) {
                await customApplet({ title: "Deletion Error", message: e.message });
            }
            });
        }

        function cancelEdit() {
            clearInvoiceForm();
            document.getElementById('invNo').disabled = false;
            document.getElementById('editMode').value = "false";
            applyRoleSectionCopy();
            document.getElementById('saveBtn').innerText = "Save Invoice";
            document.getElementById('cancelBtn').style.display = "none";

            if (inlineEditId !== null) {
                inlineEditId = null;
                triggerUpdate();
            }
        }

        function clearInvoiceForm() {
            ['poNo', 'subEntity', 'invNo', 'lrNo', 'invDate', 'dueDate', 'basicVal', 'advanceVal', 'tdsVal', 'retentionVal'].forEach(id => {
                let el = document.getElementById(id);
                if (el) el.value = (id === 'advanceVal' || id === 'tdsVal' || id === 'retentionVal') ? '0' : '';
            });
            document.getElementById('entryCurrency').value = 'INR';
            document.getElementById('entryRate').value = '1';
            document.getElementById('entryRate').disabled = true;
            document.getElementById('applyGst').checked = true;
            if (document.getElementById('applyTds')) document.getElementById('applyTds').checked = false;
            appData._settings.customColumns.forEach(cc => {
                if (cc.type === 'text') {
                    let el = document.getElementById('custom_field_' + cc.id);
                    if (el) el.value = '';
                }
            });

            let sel = document.getElementById('poNoSelect');
            if (sel) {
                sel.style.display = 'block';
                sel.value = '';
                document.getElementById('poNo').style.display = 'none';
                if (document.getElementById('btnCancelNewPo')) document.getElementById('btnCancelNewPo').style.display = 'none';
            }
        }

        function updateCheckboxes() {
            const boxList = document.getElementById('invoiceCheckboxes');
            if (!boxList) return;
            if (!currentClient || currentClient === 'ALL' || currentClient === 'REPORTS' || currentClient === 'ADMIN' || !appData[currentClient]) {
                boxList.innerHTML = '<div style="padding:16px; color:var(--text-muted); font-size:0.8rem; font-weight:500;">Open a specific client account to allocate receipts.</div>';
                return;
            }
            if (!Array.isArray(appData[currentClient].invoices)) {
                boxList.innerHTML = '<div style="padding:16px; color:var(--text-muted); font-size:0.8rem; font-weight:500;">No invoices available for allocation.</div>';
                return;
            }

            let savedState = {};
            document.querySelectorAll('.payment-check').forEach(chk => {
                let inp = document.getElementById('pay_input_' + chk.value);
                let oldSuggested = parseFloat(chk.getAttribute('data-suggested')) || 0;
                let oldSuggestedCur = displayCurrency === 'USD' ? (oldSuggested / exchangeRate) : oldSuggested;
                let currentVal = inp && inp.value ? parseFloat(inp.value) : 0;
                let isAutoFilled = Math.abs(currentVal - oldSuggestedCur) < 0.01;

                if (chk.checked || (inp && inp.value)) {
                    savedState[chk.value] = { checked: chk.checked, val: inp ? inp.value : '', isAutoFilled: isAutoFilled };
                }
            });

            boxList.innerHTML = '';
            let hasPending = false;
            const today = new Date().toISOString().split('T')[0];
            const holdRet = document.getElementById('optHoldRet') ? document.getElementById('optHoldRet').checked : false;
            const holdGst = document.getElementById('optHoldGst') ? document.getElementById('optHoldGst').checked : false;
            const onlyGst = document.getElementById('optOnlyGst') ? document.getElementById('optOnlyGst').checked : false;

            // Payment allocation list should always show pending invoices for the opened client,
            // independent of ledger table filters (status/date/search/etc).
            let pendingInvoices = appData[currentClient].invoices.filter(inv => !inv.isNote && inv.balance > 0);
            const selectedLedgerPos = getMultiSelectValues('poSelectOptions');
            const selectedProjects = getMultiSelectValues('projectSelectOptions');
            const hasPoFilter = selectedLedgerPos.length > 0;
            const hasProjectFilter = selectedProjects.length > 0;
            if (!hasPoFilter && !hasProjectFilter) {
                pendingInvoices = [];
            } else {
                pendingInvoices = pendingInvoices.filter(inv => {
                    const poMatch = hasPoFilter ? selectedLedgerPos.includes(inv.poNo) : false;
                    const poMeta = (((appData[currentClient] || {}).poTerms || {})[inv.poNo]) || {};
                    const projectMatch = hasProjectFilter ? (!!poMeta.projectName && selectedProjects.includes(poMeta.projectName)) : false;
                    if (hasPoFilter && hasProjectFilter) return poMatch || projectMatch;
                    if (hasPoFilter) return poMatch;
                    return projectMatch;
                });
            }
            pendingInvoices.sort((a, b) => {
                let dateA = a.invDate ? new Date(a.invDate) : new Date('9999-12-31');
                let dateB = b.invDate ? new Date(b.invDate) : new Date('9999-12-31');
                return dateA - dateB;
            });

            if (pendingInvoices.length > 0) hasPending = true;

            pendingInvoices.forEach(inv => {
                let targetBal = 0;
                if (holdRet) targetBal += (inv.retention || 0);
                if (holdGst) targetBal += (inv.gst || 0);

                let projectedAdv = 0;
                if (!onlyGst && document.getElementById('optApplyAdv') && document.getElementById('optApplyAdv').checked) {
                    const poNo = inv.poNo;
                    if (poNo && poNo !== 'UNASSIGNED' && appData[currentClient].poTerms && appData[currentClient].poTerms[poNo]) {
                        const terms = appData[currentClient].poTerms[poNo];
                        const pool = getPoAdvancePool(currentClient);
                        let availablePool = pool[poNo] || 0;
                        if (terms.adv > 0 && availablePool > 0) {
                            const baseAmt = terms.base === 'basic' ? inv.basic : inv.total;
                            const maxAllowed = baseAmt * (terms.adv / 100);
                            const shortfall = maxAllowed - (inv.advance || 0);
                            if (shortfall > 0) projectedAdv = Math.min(shortfall, availablePool, inv.balance);
                        }
                    }
                }

                let suggestedAmt = 0;
                if (onlyGst) {
                    suggestedAmt = Math.min(inv.gst || 0, inv.balance);
                } else {
                    suggestedAmt = Math.max(0, inv.balance - targetBal - projectedAdv);
                }

                let isChecked = ''; let fillVal = '';
                if (savedState[inv.id]) {
                    if (savedState[inv.id].checked) {
                        if (savedState[inv.id].isAutoFilled) {
                            let v = displayCurrency === 'USD' ? (suggestedAmt / exchangeRate) : suggestedAmt;
                            fillVal = v > 0 ? v.toFixed(2) : '';
                            isChecked = v > 0 ? 'checked' : '';
                        } else {
                            fillVal = savedState[inv.id].val;
                            isChecked = 'checked';
                        }
                    } else { fillVal = savedState[inv.id].val; }
                }

                let subTag = inv.subEntity ? `<span style="color:var(--brand-primary);font-weight:800;">${inv.subEntity}</span> | ` : '';
                boxList.innerHTML += `
                                            <div class="checkbox-item" style="display:flex; justify-content:space-between; align-items:center; padding: 6px 10px; border-bottom: 1px solid transparent;">
                                                <div style="display:flex; align-items:center; gap:10px; flex:1;">
                                                    <input type="checkbox" class="payment-check" value="${inv.id}" id="chk_${inv.id}" data-suggested="${suggestedAmt}" ${isChecked} onchange="toggleInvoicePayment('${esc(inv.id)}', ${suggestedAmt}); checkMasterPaymentSelect();">
                                                    <label for="chk_${inv.id}" style="margin:0; cursor:pointer; width:100%; display:flex; align-items:center;">
                                                        <strong style="color:var(--text-dark);">${inv.id}</strong>
                                                        <span style="color:var(--text-muted); font-size:0.75rem; margin-left:8px;">(${subTag}${inv.invDate || '-'} | Bal: ${formatCur(inv.balance)} | Ret: ${formatCur(inv.retention || 0)} | GST: ${formatCur(inv.gst || 0)})</span>
                                                    </label>
                                                </div>
                                                <input type="number" class="specific-pay-input" id="pay_input_${inv.id}" data-inv-id="${inv.id}" value="${fillVal}" placeholder="Amount" style="width:100px; height:28px; padding:4px 8px; text-align:right; font-weight:600; color:var(--brand-primary); font-size:0.8rem; border-color:var(--border-dark);" onkeyup="checkInvoicePayment('${esc(inv.id)}')" onchange="checkInvoicePayment('${esc(inv.id)}')">
                                           </div>`;
            });
            if (!hasPending) boxList.innerHTML = '<div style="padding:16px; color:var(--text-muted); font-size:0.8rem; font-weight:500;">No pending invoices match current filters.</div>';
        }

        async function refreshInvoiceAllocationList() {
            if (!currentClient || currentClient === 'ALL' || currentClient === 'REPORTS' || currentClient === 'ADMIN') {
                await customApplet({ title: "Open Client Account", message: "Please open a specific client account first." });
                return;
            }
            await silentDataRefresh();
            updateCheckboxes();
            triggerUpdate();
        }

        function toggleInvoicePayment(id, suggestedAmt) {
            const chk = document.getElementById('chk_' + id);
            const inp = document.getElementById('pay_input_' + id);
            if (chk.checked) {
                if (!inp.value || parseFloat(inp.value) === 0) {
                    let v = displayCurrency === 'USD' ? (suggestedAmt / exchangeRate) : suggestedAmt;
                    inp.value = v.toFixed(2);
                }
            } else {
                inp.value = '';
            }
        }

        function checkInvoicePayment(id) {
            const chk = document.getElementById('chk_' + id);
            const inp = document.getElementById('pay_input_' + id);
            if (parseFloat(inp.value) > 0) chk.checked = true;
            else chk.checked = false;
        }

        function toggleAllPaymentCheckboxes(master) {
            document.querySelectorAll('.payment-check').forEach(chk => {
                if (chk.checked !== master.checked) {
                    chk.checked = master.checked;
                    let suggestedAmt = parseFloat(chk.getAttribute('data-suggested')) || 0;
                    toggleInvoicePayment(chk.value, suggestedAmt);
                }
            });
        }

        function checkMasterPaymentSelect() {
            const checkboxes = document.querySelectorAll('.payment-check');
            const master = document.getElementById('selectAllPayments');
            if (!master || checkboxes.length === 0) return;
            master.checked = Array.from(checkboxes).every(c => c.checked);
        }

        function openPoBalancesModal() {
            if (!currentClient || currentClient === 'ALL') return alert("Please open a specific client account first.");
            const tbody = document.getElementById('poBalancesTableBody');
            tbody.innerHTML = '';

            let pool = getPoAdvancePool(currentClient);
            let hasBalances = false;

            for (let po in pool) {
                if (pool[po] > 0) {
                    hasBalances = true;
                    tbody.innerHTML += `
                                                <tr style="border-bottom: 1px solid var(--border);">
                                                    <td style="padding: 12px 16px; font-weight: 600;">${esc(po)}</td>
                                                    <td style="padding: 12px 16px; text-align: right; color: var(--success); font-weight: 800; font-size: 1.05rem;">${formatCur(pool[po])}</td>
                                                    <td style="padding: 12px 16px; text-align: center;"><button class="btn-outline btn-sm text-danger" style="border:none;" onclick="removePoAdvanceBalance('${esc(po)}')">🗑️ Write-off</button></td>
                                                </tr>`;
                }
            }
            if (!hasBalances) tbody.innerHTML = `<tr><td colspan="3" style="text-align:center; padding: 30px; color:var(--text-muted); font-size:0.85rem; font-weight:500;">No unused PO advances available.</td></tr>`;
            document.getElementById('poBalancesModal').style.display = 'flex';
        }

        async function removePoAdvanceBalance(poNo) {
            const pool = getPoAdvancePool(currentClient);
            let currentBal = pool[poNo] || 0;
            if (!currentBal || currentBal <= 0) return;

            let conf = await customApplet({ title: "Write Off Advance", message: `Are you sure you want to write off the remaining <b>${formatCur(currentBal)}</b> advance for PO ${poNo}?`, type: "confirm" });
            if (!conf) return;

            const token = sessionStorage.getItem('erp_token');
            const clientObj = appData[currentClient];
            const payload = {
                client_id: clientObj.sql_id,
                id: Date.now().toString(),
                date: new Date().toISOString().split('T')[0],
                amount: 0,
                note: 'Cleared by user',
                mode: 'cascade',
                targets: [],
                hold_ret: false,
                hold_gst: false,
                only_gst: false,
                apply_adv: true,
                advance_only: true,
                fund_source: 'receipt',
                po_no: poNo,
                clear_po_pool: true
            };
            try {
                const response = await fetch('/api/payments/allocate', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
                    body: JSON.stringify(payload)
                });
                const result = await response.json().catch(() => ({}));
                if (!response.ok) throw new Error(result.detail || 'Failed to clear PO advance balance.');
                await silentDataRefresh();
            } catch (err) {
                return await customApplet({ title: "Error", message: escHtml(err.message || 'Failed to clear balance.') });
            }

            triggerUpdate();
            openPoBalancesModal();
            await customApplet({ title: "Balance Cleared", message: `The remaining advance for PO ${poNo} has been written off successfully.` });
        }

        function getSelectedLedgerPoFilterSet() {
            const selected = getMultiSelectValues('poSelectOptions') || [];
            if (!selected.length) return null;
            return new Set(selected.map(v => String(v || '').trim()).filter(Boolean));
        }

        function paymentLogMatchesPoFilter(log, poFilterSet, invoicePoById) {
            if (!poFilterSet) return true;
            const allocs = Array.isArray(log.allocations) ? log.allocations : [];
            if (!allocs.length) return false;
            return allocs.some(a => {
                const poFromAlloc = String(a.po || '').trim();
                if (poFromAlloc && poFilterSet.has(poFromAlloc)) return true;
                const invId = String(a.invId || a.id || '').trim();
                const poFromInvoice = invId ? String(invoicePoById[invId] || '').trim() : '';
                return poFromInvoice ? poFilterSet.has(poFromInvoice) : false;
            });
        }

        function openPaymentHistory() {
            if (!currentClient || currentClient === 'ALL') return alert("Please open a specific client account first.");
            const tbody = document.getElementById('paymentHistoryTableBody');
            tbody.innerHTML = '';

            if (!appData[currentClient].paymentHistory) appData[currentClient].paymentHistory = [];
            const poFilterSet = getSelectedLedgerPoFilterSet();
            const invoicePoById = {};
            (appData[currentClient].invoices || []).forEach(inv => {
                invoicePoById[String(inv.id || '')] = String(inv.poNo || '');
            });
            const history = [...appData[currentClient].paymentHistory]
                .reverse()
                .filter(log => paymentLogMatchesPoFilter(log, poFilterSet, invoicePoById));
            history.forEach(log => {
                let typeBadge = '';
                if (log.type === 'RECEIPT') typeBadge = '<span class="status-pill pill-success">Bank Receipt</span>';
                else if (log.type === 'WALLET_APPLIED') typeBadge = '<span class="status-pill pill-admin">Wallet Applied</span>';
                else if (log.type === 'ADVANCE_APPLIED') typeBadge = '<span class="status-pill pill-user" style="background:#fffbeb; color:#d97706; border-color:#fcd34d;">Advance Applied</span>';
                else if (log.type === 'UNALLOCATED_APPLIED') typeBadge = '<span class="status-pill pill-admin" style="background:#f3e8ff; color:#7e22ce; border-color:#d8b4fe;">Unalloc. Applied</span>';
                else if (log.type === 'NOTE_APPLIED') typeBadge = '<span class="status-pill" style="background:#e0e7ff; color:#4338ca; border:1px solid #a5b4fc;">Note Allocated</span>';

                let noteDisplay = log.note ? `<br><span style="color:var(--brand-primary); font-size:0.7rem; font-weight:600;">✎ Note: ${esc(log.note)}</span>` : '';

                let traceHtml = `<div style="font-size:0.75rem; color:var(--text-main); margin-top: 4px; padding-left: 8px; border-left: 2px solid var(--border-dark);">`;
                if (log.allocations && log.allocations.length > 0) {
                    log.allocations.forEach(a => {
                        if (a.type === 'invoice') traceHtml += `<div>↳ Settled Inv <span style="font-weight:bold;">${a.id}</span>: <span style="color:var(--success);">+${formatCur(a.amount)}</span></div>`;
                        if (a.type === 'po_advance') traceHtml += `<div>↳ Parked in PO Pool <span style="font-weight:bold;">${a.po}</span>: <span style="color:var(--warning);">+${formatCur(a.amount)}</span></div>`;
                        if (a.type === 'po_advance_applied') traceHtml += `<div>↳ Pulled from PO <span style="font-weight:bold;">${a.po}</span> → Inv <span style="font-weight:bold;">${a.invId}</span>: <span style="color:var(--warning);">+${formatCur(a.amount)}</span></div>`;
                        if (a.type === 'note_allocation') {
                            let color = a.noteType === 'CN' ? '#10b981' : '#ef4444';
                            let sign = a.noteType === 'CN' ? '-' : '+';
                            traceHtml += `<div>↳ Mapped ${a.noteType} <span style="font-weight:bold;">${a.noteId}</span> to Inv <span style="font-weight:bold;">${a.invId}</span>: <span style="color:${color};">${sign}${formatCur(a.amount)}</span></div>`;
                        }
                    });
                } else {
                    traceHtml += `<div>↳ Unallocated Hold / No Assignments</div>`;
                }
                traceHtml += `</div>`;
                let editBtn = `<button class="btn-outline btn-sm" style="border:none; color:var(--warning); margin-right:4px;" onclick="openEditPaymentModal('${log.id}')" title="Edit Amount/Notes">✏️</button>`;
                let redistBtn = `<button class="btn-outline btn-sm" style="border:none; color:var(--brand-primary); margin-right:4px;" onclick="redistributePayment('${log.id}')" title="Redistribute Payment">🔄</button>`;
                let delBtn = `<button class="btn-outline btn-sm text-danger" style="border:none;" onclick="deletePaymentHistory('${log.id}')" title="Reverse Transaction">🗑️ Reverse</button>`;

                tbody.innerHTML += `
                                <tr style="border-bottom: 1px solid var(--border);">
                                    <td style="padding: 12px 16px; font-weight: 600; vertical-align: top;">${esc(log.date)}<br><span style="font-size:0.65rem; color:var(--text-muted); font-weight:normal;">ID: ${log.id}</span></td>
                                    <td style="padding: 12px 16px; vertical-align: top;">${typeBadge}</td>
                                    <td style="padding: 12px 16px; font-weight: 800; color: var(--text-dark); text-align: right; vertical-align: top;">${formatCur(log.amount)}</td>
                                    <td style="padding: 12px 16px; font-size: 0.8rem; white-space: normal; vertical-align: top;">${esc(log.details)}${noteDisplay}${traceHtml}</td>
                                    <td style="padding: 12px 16px; text-align: center; white-space: nowrap; vertical-align: top;">${editBtn}${redistBtn}${delBtn}</td>
                                </tr>
                            `;
            });
            if (history.length === 0) {
                const msg = poFilterSet ? 'No transactions found for selected PO filter.' : 'No transactions recorded yet.';
                tbody.innerHTML = `<tr><td colspan="5" style="text-align:center; padding: 20px; color:var(--text-muted); font-size:0.8rem;">${msg}</td></tr>`;
            }
            document.getElementById('paymentHistoryModal').style.display = 'flex';
        }

        function openExcessPoApplet() {
            if (!currentClient || currentClient === 'ALL') return customApplet({ title: "Open Client Account", message: "Please open a specific client account first." });
            const sel = document.getElementById('poExcessFilter');
            if (!sel) return;
            const pool = getPoAdvancePool(currentClient);
            const poSet = new Set(Object.keys(pool || {}).filter(po => Number(pool[po] || 0) > 0.000001));
            (appData[currentClient].paymentHistory || []).forEach(log => {
                (log.allocations || []).forEach(a => {
                    if ((a.type === 'po_advance' || a.type === 'po_advance_applied') && a.po) poSet.add(String(a.po));
                });
            });
            const prev = sel.value || '';
            sel.innerHTML = '<option value="">All PO Excess Entries</option>';
            Array.from(poSet).sort((a, b) => a.localeCompare(b)).forEach(po => {
                sel.innerHTML += `<option value="${esc(po)}">${escHtml(po)}</option>`;
            });
            if (prev && Array.from(poSet).includes(prev)) sel.value = prev;
            renderExcessPoAppletRows();
            document.getElementById('poExcessAppletModal').style.display = 'flex';
        }

        function renderExcessPoAppletRows() {
            const tbody = document.getElementById('poExcessAppletBody');
            if (!tbody || !currentClient || !appData[currentClient]) return;
            const selectedPo = (document.getElementById('poExcessFilter')?.value || '').trim();
            tbody.innerHTML = '';
            const rows = [];
            (appData[currentClient].paymentHistory || []).forEach(log => {
                const allocs = Array.isArray(log.allocations) ? log.allocations : [];
                allocs.forEach(a => {
                    if (!(a.type === 'po_advance' || a.type === 'po_advance_applied')) return;
                    const po = String(a.po || '').trim();
                    if (!po) return;
                    if (selectedPo && po !== selectedPo) return;
                    rows.push({
                        paymentId: log.id,
                        date: log.date || '-',
                        po,
                        amount: Number(a.amount || 0),
                        allocType: a.type,
                        payType: log.type || '-',
                        details: log.details || '',
                        note: log.note || ''
                    });
                });
            });
            rows.sort((a, b) => String(b.date || '').localeCompare(String(a.date || '')));
            if (!rows.length) {
                tbody.innerHTML = '<tr><td colspan="6" style="text-align:center; padding:20px; color:var(--text-muted);">No PO excess payment history found for this filter.</td></tr>';
                return;
            }
            rows.forEach(r => {
                const kind = r.allocType === 'po_advance' ? 'Excess Parked' : 'Excess Applied';
                const color = r.allocType === 'po_advance' ? 'var(--success)' : 'var(--warning)';
                tbody.innerHTML += `
                    <tr style="border-bottom:1px solid var(--border);">
                        <td style="padding:12px 16px; font-weight:600;">${escHtml(r.date)}<br><span style="font-size:0.65rem; color:var(--text-muted);">ID: ${escHtml(r.paymentId)}</span></td>
                        <td style="padding:12px 16px; font-weight:700;">${escHtml(r.po)}</td>
                        <td style="padding:12px 16px;"><span class="status-pill" style="background:#f8fafc; color:#334155; border:1px solid #cbd5e1;">${kind}</span></td>
                        <td style="padding:12px 16px; text-align:right; font-weight:800; color:${color};">${formatCur(r.amount)}</td>
                        <td style="padding:12px 16px; font-size:0.8rem;">${escHtml(r.details || '-')} ${r.note ? `<br><span style="color:var(--brand-primary);">✎ ${escHtml(r.note)}</span>` : ''}</td>
                        <td style="padding:12px 16px; text-align:center;"><button class="btn-outline btn-sm text-danger" style="border:none;" onclick="deletePaymentHistory('${esc(r.paymentId)}')" title="Delete payment record altogether">🗑️ Delete</button></td>
                    </tr>
                `;
            });
        }

        async function deletePaymentHistory(historyId) {
            return withInFlight(`deletePaymentHistory:${historyId}`, async () => {
            let conf = await customApplet({
                title: "Reverse Transaction",
                message: "Are you sure you want to delete this transaction record?<br><br>All affected invoice balances and PO advances will be automatically recalculated in the database.",
                type: "confirm"
            });
            if (!conf) return;

            const token = sessionStorage.getItem('erp_token');
            try {
                const response = await fetch(`/api/payments/${historyId}`, {
                    method: 'DELETE',
                    headers: { 'Authorization': 'Bearer ' + token }
                });

                if (!response.ok) {
                    const errorData = await response.json();
                        throw new Error(errorData.detail || "Failed to delete transaction from database.");
                    }
                await customApplet({ title: "Transaction Reversed", message: "The transaction was successfully deleted from the SQL database and ledger balances have been restored." });
                    await silentDataRefresh();
                if (document.getElementById('paymentHistoryModal')?.style.display === 'flex') openPaymentHistory();
                if (document.getElementById('poExcessAppletModal')?.style.display === 'flex') renderExcessPoAppletRows();
                triggerUpdate();

            } catch (e) {
                console.error("Payment Deletion Error:", e);
                await customApplet({ title: "Database Error", message: e.message });
            }
            });
        }

        async function redistributePayment(historyId) {
            return withInFlight(`redistributePayment:${historyId}`, async () => {
            let conf = await customApplet({
                title: "Redistribute Payment",
                message: "Do you want to redistribute this payment?<br><br>This will instantly detach the funds from their current invoices so you can re-allocate them across your newly updated ledger.",
                type: "confirm"
            });
            if (!conf) return;

                const token = sessionStorage.getItem('erp_token');
                let log = null;
                try {
                    const response = await fetch(`/api/payments/${historyId}/redistribute`, {
                        method: 'POST',
                        headers: { 'Authorization': 'Bearer ' + token }
                    });
                    const result = await response.json().catch(() => ({}));
                    if (!response.ok) {
                        throw new Error(result.detail || 'Failed to redistribute transaction from database.');
                    }
                    log = result.payment || null;
                    await silentDataRefresh();
                    triggerUpdate();
                } catch (e) {
                    console.error("Payment Redistribute Error:", e);
                    return await customApplet({ title: "Database Error", message: e.message });
                }

                if (!log) return;
            document.getElementById('paymentHistoryModal').style.display = 'none';

            if (log.type === 'RECEIPT') {
                document.getElementById('targetPaymentVal').value = log.amount;
                if (document.getElementById('paymentNote')) document.getElementById('paymentNote').value = log.note || '';
                    triggerUpdate();
                window.scrollTo({ top: 0, behavior: 'smooth' });
                await customApplet({
                    title: "Ready to Redistribute",
                        message: `The bank receipt of ${formatCur(log.amount)} has been loaded back into the input box.<br><br>You can now check the updated invoices and click 'Post & Allocate Receipt'.`
                });
            } else if (log.type === 'UNALLOCATED_APPLIED') {
                    triggerUpdate();
                window.scrollTo({ top: 0, behavior: 'smooth' });
                await customApplet({
                    title: "Ready to Redistribute",
                        message: `The ${formatCur(log.amount)} has been returned to your Unallocated pool.<br><br>Click 'Allocate to Invoices' under the purple Unallocated section to redistribute.`
                });
            } else if (log.type === 'ADVANCE_APPLIED') {
                    triggerUpdate();
                await customApplet({
                    title: "Ready to Redistribute",
                        message: `The ${formatCur(log.amount)} advance has been returned to the PO Advance pool.<br><br>Click 'Apply PO Advances' to redistribute.`
                });
            } else {
                    triggerUpdate();
            }
            });
        }

        async function addAdvanceToPO() {
            let paymentStr = document.getElementById('targetPaymentVal').value;
            let paymentNote = document.getElementById('paymentNote') ? document.getElementById('paymentNote').value.trim() : '';
            let payRate = parseFloat(document.getElementById('payRate') ? document.getElementById('payRate').value : 1) || 1;

            if (!paymentStr) return await customApplet({ title: "Validation Error", message: "Enter a receipt amount first." });
            let payment = parseFloat(paymentStr) * payRate;
            if (payment <= 0) return await customApplet({ title: "Validation Error", message: "Enter a valid receipt amount." });

            let poNo = await customApplet({ title: "Link Advance to PO", message: "Enter the specific PO Number for this advance:", type: "prompt", placeholder: "PO Number..." });
            if (!poNo || !poNo.trim()) return;
            poNo = poNo.trim();

            const token = sessionStorage.getItem('erp_token');
            const clientObj = appData[currentClient];
            const payload = {
                client_id: clientObj.sql_id,
                id: Date.now().toString(),
                date: new Date().toISOString().split('T')[0],
                amount: payment,
                note: paymentNote,
                mode: 'cascade',
                targets: [],
                hold_ret: false,
                hold_gst: false,
                only_gst: false,
                apply_adv: true,
                advance_only: false,
                fund_source: 'receipt',
                move_to_po: poNo,
                po_no: poNo
            };

            let autoMapped = 0;
            try {
                const response = await fetch('/api/payments/allocate', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
                    body: JSON.stringify(payload)
                });
                const result = await response.json().catch(() => ({}));
                if (!response.ok) throw new Error(result.detail || 'Failed to record PO advance.');
                autoMapped = result.po_advance_applied || 0;
                await silentDataRefresh();
            } catch (err) {
                return await customApplet({ title: "Error", message: escHtml(err.message || 'Failed to record PO advance.') });
            }

            document.querySelectorAll('.payment-check').forEach(c => c.checked = false);
            document.querySelectorAll('.specific-pay-input').forEach(i => i.value = '');
            if (document.getElementById('selectAllPayments')) document.getElementById('selectAllPayments').checked = false;
            if (document.getElementById('targetPaymentVal')) document.getElementById('targetPaymentVal').value = '';
            if (document.getElementById('paymentNote')) document.getElementById('paymentNote').value = '';

            triggerUpdate();

            let msg = `Successfully recorded ${formatCur(payment)} advance against PO: ${poNo}.`;
            if (autoMapped > 0) {
                msg += `<br><br><span style="color:var(--success); font-weight:bold;">Auto-Mapped:</span> ${formatCur(autoMapped)} was instantly cascaded into pending invoices for this PO!`;
            }
            await customApplet({ title: "Advance Recorded", message: msg });
        }

        function getPoAdvancePool(clientName) {
            const cached = poAdvancePoolCache[clientName];
            if (cached && cached.historyRef === appData[clientName]?.paymentHistory) {
                return cached.pool;
            }
            const pool = {};
            if (!appData[clientName] || !Array.isArray(appData[clientName].paymentHistory)) return pool;
            appData[clientName].paymentHistory.forEach(log => {
                if (!Array.isArray(log.allocations)) return;
                log.allocations.forEach(a => {
                    if (!a.po) return;
                    if (a.type === 'po_advance') pool[a.po] = (pool[a.po] || 0) + (a.amount || 0);
                    if (a.type === 'po_advance_applied') pool[a.po] = (pool[a.po] || 0) - (a.amount || 0);
                });
            });
            Object.keys(pool).forEach(po => { if (pool[po] < 0) pool[po] = 0; });
            poAdvancePoolCache[clientName] = { historyRef: appData[clientName].paymentHistory, pool };
            return pool;
        }

        async function applyTargetedPayment() {
            const token = sessionStorage.getItem('erp_token');
            const clientObj = appData[currentClient];
            let paymentStr = document.getElementById('targetPaymentVal').value;
            let paymentNote = document.getElementById('paymentNote') ? document.getElementById('paymentNote').value.trim() : '';
            const checkboxes = document.querySelectorAll('.payment-check:checked');
            const specificInputs = [];

            checkboxes.forEach(chk => {
                const inp = document.getElementById('pay_input_' + chk.value);
                if (inp) specificInputs.push(inp);
            });

            let payRate = parseFloat(document.getElementById('payRate') ? document.getElementById('payRate').value : 1) || 1;
            let totalSpecific = 0;
            specificInputs.forEach(inp => totalSpecific += (parseFloat(inp.value) || 0) * payRate);

            let originalPayment = 0;
            let useCascade = false;

            if (specificInputs.length > 0) {
                useCascade = false;
                if (paymentStr) {
                    originalPayment = parseFloat(paymentStr) * payRate;
                    if (totalSpecific > originalPayment) {
                        let conf = await customApplet({ title: "Short Payment Detected", message: `The allocated amounts (${formatCur(totalSpecific)}) exceed the bank receipt (${formatCur(originalPayment)}).<br><br>Proportionally distribute the receipt across selected invoices?`, type: "confirm" });
                        if (!conf) return;

                        let remainingToAllocate = originalPayment;
                        for (let i = 0; i < specificInputs.length; i++) {
                            let inp = specificInputs[i];
                            let suggested = (parseFloat(inp.value) || 0) * payRate;

                            let actual = 0;
                            if (i === specificInputs.length - 1) {
                                actual = remainingToAllocate;
                            } else {
                                actual = (suggested / totalSpecific) * originalPayment;
                                actual = Math.round(actual * 100) / 100;
                            }

                            inp.value = (document.getElementById('entryCurrency')?.value === 'USD' ? (actual / exchangeRate) : actual).toFixed(2);
                            remainingToAllocate -= actual;
                        }
                        totalSpecific = originalPayment;
                    }
                } else {
                    originalPayment = totalSpecific;
                }
            } else {
                if (paymentStr) {
                    originalPayment = parseFloat(paymentStr) * payRate;
                    useCascade = true;
                } else {
                    return await customApplet({ title: "Validation Error", message: "Enter a receipt amount or specify allocations using the checkboxes." });
                }
            }

            let holdRet = document.getElementById('optHoldRet').checked;
            let holdGst = document.getElementById('optHoldGst').checked;
            let applyAdv = document.getElementById('optApplyAdv') ? document.getElementById('optApplyAdv').checked : false;
            let onlyGst = document.getElementById('optOnlyGst') ? document.getElementById('optOnlyGst').checked : false;
            const targets = [];
            for (let inp of specificInputs) {
                let amt = (parseFloat(inp.value) || 0) * payRate;
                if (amt <= 0) continue;
                let invId = inp.getAttribute('data-inv-id');
                if (invId) targets.push({ inv_id: invId, amount: amt });
            }

            if (originalPayment <= 0) {
                return await customApplet({ title: "Validation Error", message: "Receipt amount must be greater than zero." });
            }

            const payload = {
                client_id: clientObj.sql_id,
                id: Date.now().toString(),
                date: new Date().toISOString().split('T')[0],
                amount: originalPayment,
                note: paymentNote,
                mode: useCascade ? 'cascade' : 'targeted',
                targets,
                hold_ret: holdRet,
                hold_gst: holdGst,
                only_gst: onlyGst,
                apply_adv: applyAdv,
                excess_action: "park"
            };

            if (useCascade === false && originalPayment > totalSpecific) {
                const choice = await customApplet({
                    title: "Excess Receipt Detected",
                    message: `Allocated amount is ${formatCur(totalSpecific)} against receipt ${formatCur(originalPayment)}.<br><br>Park excess in Unallocated Register?<br>Select Cancel to allocate excess to pending invoices.`,
                    type: "confirm"
                });
                payload.excess_action = choice ? "park" : "allocate_pending";
            }

            try {
                const response = await fetch('/api/payments/allocate', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
                    body: JSON.stringify(payload)
                });
                const result = await response.json().catch(() => ({}));
                if (!response.ok) {
                    throw new Error(result.detail || 'Failed to allocate payment.');
                }

                await silentDataRefresh();
                triggerUpdate();

                if ((result.allocation_count || 0) === 0 && (result.advance_allocation_count || 0) === 0) {
                    await customApplet({ title: "No Action Taken", message: "No eligible invoices found for the selected allocation options." });
                } else if ((result.remaining || 0) > 0 || (result.po_advance_applied || 0) > 0) {
                    let msg = `Applied ${formatCur(result.allocated || 0)} to invoices.`;
                    if ((result.po_advance_applied || 0) > 0) {
                        msg += `<br><br><b>PO Advances Auto-Mapped:</b> ${formatCur(result.po_advance_applied || 0)}.`;
                    }
                    if ((result.remaining || 0) > 0) {
                        msg += `<br><br><b>Notice:</b> Remaining ${formatCur(result.remaining || 0)} is now in Unallocated pool.`;
                    }
                    await customApplet({ title: "Allocation Complete", message: msg });
                    } else {
                    await customApplet({ title: "Payment Applied", message: "Allocations successfully applied." });
                    }
            } catch (err) {
                await customApplet({ title: "Error", message: escHtml(err.message || 'Allocation failed.') });
            }

            document.querySelectorAll('.payment-check').forEach(c => c.checked = false);
            document.querySelectorAll('.specific-pay-input').forEach(i => i.value = '');
            if (document.getElementById('selectAllPayments')) document.getElementById('selectAllPayments').checked = false;
            if (document.getElementById('targetPaymentVal')) document.getElementById('targetPaymentVal').value = '';
            if (document.getElementById('paymentNote')) document.getElementById('paymentNote').value = '';
        }

        async function moveUnallocatedToPO() {
            let unalloc = appData[currentClient].unallocated || 0;
            if (unalloc <= 0) return await customApplet({ title: "Error", message: "No unallocated funds available." });

            let paymentNote = document.getElementById('paymentNote') ? document.getElementById('paymentNote').value.trim() : '';

            let poNo = await customApplet({ title: "Move to PO Advance", message: `Available: ${formatCur(unalloc)}<br><br>Enter the destination PO Number:`, type: "prompt", placeholder: "PO Number..." });
            if (!poNo || !poNo.trim()) return;
            poNo = poNo.trim();

            let amtStr = await customApplet({ title: "Move to PO Advance", message: `Available: ${formatCur(unalloc)}<br><br>Enter amount to move to PO ${poNo}:`, type: "prompt", placeholder: unalloc.toString() });
            if (!amtStr) return;
            let amt = parseFloat(amtStr);
            if (isNaN(amt) || amt <= 0 || amt > unalloc) return await customApplet({ title: "Error", message: "Invalid amount entered." });

            const token = sessionStorage.getItem('erp_token');
            const clientObj = appData[currentClient];
            const payload = {
                client_id: clientObj.sql_id,
                id: Date.now().toString(),
                date: new Date().toISOString().split('T')[0],
                amount: amt,
                note: paymentNote,
                mode: 'cascade',
                targets: [],
                hold_ret: false,
                hold_gst: false,
                only_gst: false,
                apply_adv: false,
                advance_only: false,
                fund_source: 'unallocated',
                move_to_po: poNo
            };
            try {
                const response = await fetch('/api/payments/allocate', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
                    body: JSON.stringify(payload)
                });
                const result = await response.json().catch(() => ({}));
                if (!response.ok) throw new Error(result.detail || 'Failed to move unallocated funds to PO.');
                await silentDataRefresh();
            } catch (err) {
                return await customApplet({ title: "Error", message: escHtml(err.message || 'Failed to move funds.') });
            }

            if (document.getElementById('paymentNote')) document.getElementById('paymentNote').value = '';
            await customApplet({ title: "Funds Moved", message: `Successfully moved ${formatCur(amt)} to PO ${poNo}.` });
            triggerUpdate();
        }

        async function applyUnallocatedToInvoices() {
            let unalloc = appData[currentClient].unallocated || 0;
            if (unalloc <= 0) return await customApplet({ title: "Error", message: "No unallocated funds available." });

            let paymentNote = document.getElementById('paymentNote') ? document.getElementById('paymentNote').value.trim() : '';
            const checkboxes = document.querySelectorAll('.payment-check:checked');
            const clientInvoices = appData[currentClient].invoices || [];
            let holdRet = document.getElementById('optHoldRet').checked;
            let holdGst = document.getElementById('optHoldGst').checked;
            let onlyGst = document.getElementById('optOnlyGst') ? document.getElementById('optOnlyGst').checked : false;
            let targetInvoices = [];
            if (checkboxes.length === 0) {
                let conf = await customApplet({ title: "Auto-Allocate Unallocated", message: `Auto-allocate ${formatCur(unalloc)} from Unallocated pool to all pending invoices (FIFO)?`, type: "confirm" });
                if (!conf) return;
                targetInvoices = clientInvoices.filter(i => i.balance > 0).sort((a, b) => new Date(a.invDate || '9999-12-31') - new Date(b.invDate || '9999-12-31'));
            } else {
                let conf = await customApplet({ title: "Allocate Unallocated", message: `Cascade up to ${formatCur(unalloc)} from Unallocated pool across the selected invoices?`, type: "confirm" });
                if (!conf) return;
                checkboxes.forEach(chk => {
                    let inv = clientInvoices.find(i => i.id === chk.value);
                    if (inv) targetInvoices.push(inv);
                });
            }
            const targets = targetInvoices.map(inv => ({ inv_id: inv.id, amount: 0 }));
            const token = sessionStorage.getItem('erp_token');
            const clientObj = appData[currentClient];
            const payload = {
                client_id: clientObj.sql_id,
                id: Date.now().toString(),
                date: new Date().toISOString().split('T')[0],
                amount: unalloc,
                note: paymentNote,
                mode: checkboxes.length > 0 ? 'targeted' : 'cascade',
                targets,
                hold_ret: holdRet,
                hold_gst: holdGst,
                only_gst: onlyGst,
                apply_adv: false,
                advance_only: false,
                fund_source: 'unallocated'
            };

            try {
                const response = await fetch('/api/payments/allocate', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
                    body: JSON.stringify(payload)
                });
                const result = await response.json().catch(() => ({}));
                if (!response.ok) throw new Error(result.detail || 'Failed to allocate unallocated funds.');
                await silentDataRefresh();

                if ((result.allocation_count || 0) === 0) {
                    await customApplet({ title: "Notice", message: "No eligible invoices found or holds restrict allocation." });
                } else {
                    const consumed = result.unallocated_consumed || 0;
                    await customApplet({ title: "Success", message: `Allocated ${formatCur(consumed)} from Unallocated pool.` });
                }
            } catch (err) {
                return await customApplet({ title: "Error", message: escHtml(err.message || 'Allocation failed.') });
            }

            document.querySelectorAll('.payment-check').forEach(c => c.checked = false);
            document.querySelectorAll('.specific-pay-input').forEach(i => i.value = '');
            if (document.getElementById('selectAllPayments')) document.getElementById('selectAllPayments').checked = false;
            if (document.getElementById('targetPaymentVal')) document.getElementById('targetPaymentVal').value = '';
            if (document.getElementById('paymentNote')) document.getElementById('paymentNote').value = '';

            triggerUpdate();
        }

        

        function getCellHtml(col, inv, today, isGlobal, isAdmin, clientName, clientActive) {
            let balClass = inv.balance <= 0 ? 'text-success' : 'text-danger';
            let isInlineEdit = (inv.id === inlineEditId);
            let inpStyle = "height:28px; padding:2px 6px; font-size:0.75rem; border: 1px solid var(--brand-primary); border-radius: 4px; box-sizing: border-box; background: #fff;";

            // BLANK OUT UNNECESSARY FIELDS FOR CN/DN
            if (inv.isNote && ['subEntity', 'poNo', 'lrNo', 'basic', 'gst', 'tds', 'retention'].includes(col.id)) {
                return `<td style="text-align:center; color:var(--text-muted);">-</td>`;
            }

            if (col.isCustom) {
                if (col.type === 'text') {
                    let val = inv.customFields && inv.customFields[col.id] ? esc(inv.customFields[col.id]) : '';
                    if (isInlineEdit) return `<td><input type="text" id="inl_cust_${col.id}" value="${val}" style="${inpStyle} width:100%;"></td>`;
                    let editAttr = (!isGlobal && isAdmin && clientActive) ? `contenteditable="true" onblur="inlineUpdateCustom('${esc(clientName)}', '${esc(inv.id)}', '${col.id}', this.innerText)" style="background:#f8fafc; border-bottom:1px dashed var(--border-dark);"` : '';
                    return `<td ${editAttr}>${val}</td>`;
                } else if (col.type === 'calc') {
                    return `<td class="fw-bold" style="color:var(--brand-primary); text-align: right;">${evalFormula(col.formula, inv)}</td>`;
                }
            }

            switch (col.id) {
                case 'clientName': return `<td class="fw-bold">${clientName}</td>`;
                case 'subEntity':
                    if (isInlineEdit) return `<td><input type="text" id="inl_sub" value="${esc(inv.subEntity || '')}" style="${inpStyle} width:90px;"></td>`;
                    return `<td><span style="font-weight:600; color:var(--brand-secondary);">${inv.subEntity || '-'}</span></td>`;
                case 'poNo':
                    if (isInlineEdit) return `<td><input type="text" id="inl_po" value="${inv.poNo === 'UNASSIGNED' ? '' : esc(inv.poNo)}" style="${inpStyle} width:90px;"></td>`;
                    let poBadge = '';
                    const poPool = getPoAdvancePool(clientName);
                    if (inv.poNo && inv.poNo !== 'UNASSIGNED' && poPool[inv.poNo] > 0) {
                        let available = poPool[inv.poNo];
                        if (available > 0) {
                            poBadge = `<br><span style="font-size:0.65rem; color:var(--success); font-weight:800; background:#d1fae5; padding:2px 6px; border-radius:4px; display:inline-block; margin-top:4px; border: 1px solid #6ee7b7;">ADV AVAIL: ${formatCur(available)}</span>`;
                        }
                    }
                    return `<td><span style="font-weight:600;">${inv.poNo || '-'}</span>${poBadge}</td>`;
                case 'invNo':
                    let noteBadge = inv.isNote ? ` <span class="status-pill ${inv.noteType === 'CN' ? 'pill-success' : 'pill-danger'}" style="font-size:0.55rem; padding: 2px 4px;">${inv.noteType}</span>` : '';
                    if (inv.isNote && inv.noteTargetInvoice) {
                        return `<td class="fw-bold">${inv.id} against ${inv.noteTargetInvoice}${noteBadge}</td>`;
                    }
                    return `<td class="fw-bold">${inv.id}${noteBadge}</td>`;
                case 'invDate':
                    if (isInlineEdit) return `<td><input type="date" id="inl_date" value="${inv.invDate || ''}" style="${inpStyle} width:110px;"></td>`;
                    return `<td>${inv.invDate || '-'}</td>`;
                case 'status':
                    if (isInlineEdit) return `<td style="text-align: center;"><input type="date" id="inl_due" value="${inv.dueDate || ''}" title="Due Date" style="${inpStyle} width:110px;"></td>`;
                    let dateDisplay = inv.dueDate || '-';
                    if (inv.balance > 0 && inv.dueDate && inv.dueDate < today) dateDisplay = `<span class="status-pill pill-danger" style="margin-bottom:4px;">OVERDUE</span><br><span style="font-size:0.7rem; color:var(--text-muted);">${inv.dueDate}</span>`;
                    else if (inv.balance <= 0) dateDisplay = `<span class="status-pill pill-success">CLEARED</span>`;
                    return `<td style="text-align: center;">${dateDisplay}</td>`;
                case 'lrNo':
                    if (isInlineEdit) return `<td><input type="text" id="inl_lr" value="${esc(inv.lrNo || '')}" style="${inpStyle} width:90px;"></td>`;
                    return `<td style="color:var(--text-muted); font-family:monospace; text-align: left;">${inv.lrNo || '-'}</td>`;
                case 'basic':
                    if (isInlineEdit) return `<td style="text-align: right;"><input type="number" id="inl_basic" value="${inv.basic}" style="${inpStyle} width:80px; text-align:right;"></td>`;
                    return `<td style="text-align: right;">${formatCur(inv.basic)}</td>`;
                case 'gst': return `<td style="text-align: right;">${formatCur(inv.gst)}</td>`;
                case 'gross': return `<td style="text-align: right;" class="fw-bold ${inv.isNote && inv.noteType === 'CN' ? 'text-success' : ''}">${formatCur(inv.total)}</td>`;
                case 'advance':
                    if (isInlineEdit) return `<td style="text-align: right;"><input type="number" id="inl_adv" value="${inv.advance || 0}" style="${inpStyle} width:70px; text-align:right;"></td>`;
                    return `<td style="text-align: right; color: var(--warning); font-weight: 600;">${formatCur(inv.advance || 0)}</td>`;
                case 'tds':
                    if (isInlineEdit) return `<td style="text-align: right;"><input type="number" id="inl_tds" value="${inv.tds}" style="${inpStyle} width:70px; text-align:right;"></td>`;
                    return `<td style="text-align: right;">${formatCur(inv.tds)}</td>`;
                case 'retention':
                    if (isInlineEdit) return `<td style="text-align: right;"><input type="number" id="inl_ret" value="${inv.retention}" style="${inpStyle} width:70px; text-align:right;"></td>`;
                    let retTag = '';
                    if (inv.retention > 0) {
                        if (inv.balance <= 0) {
                            retTag = `<br><span class="status-pill pill-success" style="font-size:0.6rem; padding:2px 4px; margin-top:4px;">PAID</span>`;
                        } else if (inv.balance < inv.retention) {
                            retTag = `<br><span class="status-pill" style="font-size:0.6rem; padding:2px 4px; margin-top:4px; background:#fef3c7; color:#d97706; border:1px solid #fde68a;">PARTIAL</span>`;
                        }
                    }
                    return `<td style="text-align: right;">${formatCur(inv.retention)}${retTag}</td>`;
                case 'realized':
                    let totalRealized = (inv.paid || 0);
                    return `<td class="fw-bold text-success" style="text-align: right;">${formatCur(totalRealized)}</td>`;
                case 'balance': return `<td class="${balClass}" style="text-align: right;">${formatCur(inv.balance)}</td>`;
                case 'paymentBreakdown':
                    let historyHtml = '';
                    if (appData[clientName] && appData[clientName].paymentHistory) {
                        appData[clientName].paymentHistory.forEach(log => {
                            if (log.allocations) {
                                let alloc = log.allocations.find(a => (a.type === 'invoice' && a.id === inv.id) || (a.type === 'po_advance_applied' && a.invId === inv.id) || (a.type === 'note_allocation' && (a.invId === inv.id || a.noteId === inv.id)));
                                if (alloc) {
                                    let typeIcon = alloc.type === 'po_advance_applied' ? '🟡' : (log.type === 'UNALLOCATED_APPLIED' ? '🟣' : (log.type === 'NOTE_APPLIED' ? '📝' : '🟢'));
                                    let displayLabel = log.note ? esc(log.note) : log.date;
                                    if (alloc.type === 'po_advance_applied' && !log.note) displayLabel = 'PO Adv: ' + log.date;
                                    if (alloc.type === 'note_allocation') displayLabel = (alloc.noteType === 'CN' ? 'CN ' : 'DN ') + alloc.noteId;

                                    let amtColor = (alloc.type === 'note_allocation' && alloc.noteType === 'DN') ? 'var(--danger)' : 'var(--success)';
                                    if (inv.isNote && alloc.type === 'note_allocation') amtColor = 'var(--text-muted)'; // Showing note's own consumption
                                    let sign = (alloc.type === 'note_allocation' && alloc.noteType === 'DN' && !inv.isNote) ? '-' : '+';

                                    historyHtml += `<div style="margin-bottom:4px; padding-bottom:4px; border-bottom:1px dashed var(--border-dark); white-space:normal; min-width: 180px; text-align:left; line-height:1.3;">
                                                    <span style="font-size:0.7rem; font-weight:700; color:var(--text-muted);">${typeIcon} ${displayLabel}:</span> <span style="font-weight:700; color:${amtColor};">${sign}${formatCur(alloc.amount)}</span>
                                                </div>`;
                                }
                            }
                        });
                    }
                    if (inv.isNote && inv.noteReason) {
                        historyHtml += `<div style="font-size:0.7rem; color:var(--text-muted); font-style:italic;">Rsn: ${esc(inv.noteReason)}</div>`;
                    }
                    return `<td class="payment-breakdown-cell" style="vertical-align:top;">${historyHtml || '<span style="color:var(--text-muted);">-</span>'}</td>`;
                case 'actions':
                    if (isInlineEdit) {
                        return `<td style="text-align: center; white-space: nowrap;">
                                                <button class="btn-success btn-sm" style="padding:4px 8px; height:auto; min-height: 26px;" onclick="saveInlineEdit('${esc(inv.id)}')">💾 Save</button>
                                                <button class="btn-outline btn-sm text-danger" style="padding:4px 8px; height:auto; min-height: 26px; border-color:var(--danger); margin-left:4px;" onclick="cancelEdit()">✖</button>
                                            </td>`;
                    }
                    let actionBtn = (isGlobal || !isAdmin || !clientActive) ? `<span style="font-size:0.7rem; color:var(--text-muted); font-weight: 700;">LOCKED</span>`
                        : `<button type="button" class="btn-outline btn-sm" style="padding:2px 6px; height:auto;" onclick="editInvoice('${esc(inv.id)}')">✏️</button> <button type="button" class="btn-outline btn-sm text-danger" style="padding:2px 6px; height:auto; margin-left:4px; border-color:var(--danger);" onclick="deleteInvoice('${esc(inv.id)}')">🗑️</button>`;
                    return `<td style="text-align: center; white-space: nowrap;">${actionBtn}</td>`;
                default: return `<td>-</td>`;
            }
        }

        function getInvoiceMetricValue(inv, metricKey) {
            if (!inv) return 0;
            if (metricKey === 'gross') return Number(inv.total || 0);
            if (metricKey === 'realized') return Number(inv.paid || 0);
            if (metricKey === 'netPayable') return Number(inv.netPayable || 0);
            return Number(inv[metricKey] || 0);
        }

        function renderTableAndDashboard() {
            const thead = document.getElementById('dynamicTableHeader');
            const tbody = document.getElementById('invoiceTableBody');
            const isAdmin = sessionStorage.getItem('erp_role') === 'admin';

            thead.innerHTML = '<tr></tr>';
            const headRow = thead.querySelector('tr');
            headRow.innerHTML += `<th style="text-align: center; width: 40px; padding: 14px 10px;"><input type="checkbox" id="selectAllRows" onchange="toggleAllRows(this)" style="cursor:pointer; width:16px; height:16px; accent-color:var(--brand-primary); margin:0;"></th>`;

            let visibleColCount = 1;
            userColumns.forEach(col => {
                if (col.visible) {
                    visibleColCount++;
                    let align = (col.id === 'actions' || col.id === 'status') ? 'text-align: center;' : '';
                    if (['invNo', 'invDate', 'lrNo', 'clientName', 'poNo', 'subEntity'].includes(col.id) || col.type === 'text') align = 'text-align: left;';
                    if (['basic', 'gst', 'gross', 'tds', 'retention', 'realized', 'balance', 'advance'].includes(col.id) || col.type === 'calc') align = 'text-align: right;';

                    let sortArrow = currentSort.col === col.id ? (currentSort.asc ? ' <span style="color:var(--brand-secondary); font-weight:bold;">↑</span>' : ' <span style="color:var(--brand-secondary); font-weight:bold;">↓</span>') : '';
                    headRow.innerHTML += `<th style="${align}" class="sortable-header" title="Click to Sort" onclick="sortTable('${col.id}')">${col.label}${sortArrow}</th>`;
                }
            });

            let tableHTML = '';
            const today = new Date().toISOString().split('T')[0];
            const filters = {
                client: currentClient === 'ALL' ? document.getElementById('fltClient').value : null,
                pos: getMultiSelectValues('poSelectOptions'),
                subs: getMultiSelectValues('subSelectOptions'),
                projects: getMultiSelectValues('projectSelectOptions'),
                fiscalYears: getMultiSelectValues('fySelectOptions'),
                hideCompletedPos: !!document.getElementById('hideCompletedPoToggle')?.checked,
                status: document.getElementById('fltStatus').value,
                start: document.getElementById('fltStart').value,
                end: document.getElementById('fltEnd').value,
                search: document.getElementById('fltSearch').value.toLowerCase().trim()
            };

            let clientsToRender = currentClient === 'ALL' ? Object.keys(appData).filter(k => k !== '_settings').sort() : [currentClient];

            let appletUI = document.getElementById('dataEntryApplets');
            if (appletUI) {
                appletUI.style.display = (currentClient === 'ALL') ? 'none' : '';
            }

            let sumBilled = 0, sumReceived = 0, sumOut = 0;
            let aggBasic = 0, aggGst = 0, aggGross = 0, aggRet = 0, aggDue = 0, aggPaid = 0, aggAdv = 0, aggTds = 0;
            let flatInvoices = [];

            clientsToRender.forEach(client => {
                if (!appData[client] || !appData[client].invoices) return;
                let cActive = appData[client].active !== false;
                appData[client].invoices.forEach(inv => {
                    if (isInvoiceMatchingFilters(inv, client, filters, today)) flatInvoices.push({ ...inv, clientName: client, cActive: cActive });
                });
            });

            flatInvoices.sort((a, b) => {
                let valA = a[currentSort.col]; let valB = b[currentSort.col];

                if (currentSort.col.startsWith('cust_')) {
                    let cc = appData._settings.customColumns.find(c => c.id === currentSort.col);
                    if (cc && cc.type === 'calc') {
                        valA = parseFloat(evalFormula(cc.formula, a).replace(/[^\d.-]/g, '')) || 0;
                        valB = parseFloat(evalFormula(cc.formula, b).replace(/[^\d.-]/g, '')) || 0;
                    } else if (cc && cc.type === 'text') {
                        valA = (a.customFields && a.customFields[cc.id]) ? a.customFields[cc.id] : '';
                        valB = (b.customFields && b.customFields[cc.id]) ? b.customFields[cc.id] : '';
                    }
                } else {
                    if (currentSort.col === 'status') { valA = a.balance === 0 ? 'Z' : (a.dueDate || 'A'); valB = b.balance === 0 ? 'Z' : (b.dueDate || 'A'); }
                    else if (currentSort.col === 'invDate') {
                        valA = new Date(a.invDate || '1970-01-01').getTime();
                        valB = new Date(b.invDate || '1970-01-01').getTime();
                    } else if (['basic', 'gst', 'tds', 'retention', 'advance', 'balance'].includes(currentSort.col)) {
                        valA = parseFloat(a[currentSort.col]) || 0;
                        valB = parseFloat(b[currentSort.col]) || 0;
                    } else if (currentSort.col === 'gross') { valA = parseFloat(a.total) || 0; valB = parseFloat(b.total) || 0; }
                    else if (currentSort.col === 'realized') { valA = (parseFloat(a.paid) || 0) + (parseFloat(a.advance) || 0); valB = (parseFloat(b.paid) || 0) + (parseFloat(b.advance) || 0); }
                }

                if (valA === undefined || valA === null) valA = '';
                if (valB === undefined || valB === null) valB = '';
                if (typeof valA === 'string' && typeof valB === 'string') { valA = valA.toLowerCase(); valB = valB.toLowerCase(); }

                if (valA < valB) return currentSort.asc ? -1 : 1;
                if (valA > valB) return currentSort.asc ? 1 : -1;
                return 0;
            });

            flatInvoices.forEach(inv => {
                const totalPaid = getInvoiceMetricValue(inv, 'realized');
                const netPayable = getInvoiceMetricValue(inv, 'netPayable');
                const basicVal = getInvoiceMetricValue(inv, 'basic');
                const gstVal = getInvoiceMetricValue(inv, 'gst');
                const grossVal = getInvoiceMetricValue(inv, 'gross');
                const advanceVal = getInvoiceMetricValue(inv, 'advance');
                const tdsVal = getInvoiceMetricValue(inv, 'tds');
                const retentionVal = getInvoiceMetricValue(inv, 'retention');
                const balanceVal = getInvoiceMetricValue(inv, 'balance');

                sumBilled += netPayable;
                sumReceived += totalPaid;
                sumOut += balanceVal;
                aggBasic += basicVal;
                aggGst += gstVal;
                aggGross += grossVal;
                aggRet += retentionVal;
                aggDue += balanceVal;
                aggPaid += totalPaid;
                aggAdv += advanceVal;
                aggTds += tdsVal;

                let rowHtml = `<tr><td style="text-align:center;"><input type="checkbox" class="export-row-chk" onchange="updateAggregates()" data-client="${esc(inv.clientName)}" data-id="${esc(inv.id)}"></td>`;
                userColumns.forEach(col => {
                    if (col.visible) {
                        rowHtml += getCellHtml(col, inv, today, currentClient === 'ALL', isAdmin, inv.clientName, inv.cActive);
                    }
                });
                rowHtml += `</tr>`;
                tableHTML += rowHtml;
            });

            if (flatInvoices.length === 0) tableHTML = `<tr><td colspan="${visibleColCount}" style="text-align:center; padding: 40px; color: var(--text-muted); font-size: 0.85rem; font-weight: 500;">No records found matching current filters.</td></tr>`;

            tbody.innerHTML = tableHTML;
            tbody.classList.remove('fade-in'); void tbody.offsetWidth; tbody.classList.add('fade-in');

            const tfoot = document.getElementById('invoiceTableFoot');
            if (flatInvoices.length > 0) {
                let footHtml = '<tr><td style="text-align:center;">-</td>';
                userColumns.forEach(col => {
                    if (col.visible) {
                        if (col.id === 'basic') footHtml += `<td style="color:var(--text-dark); text-align: right; font-weight:800;">${formatCur(aggBasic)}</td>`;
                        else if (col.id === 'gst') footHtml += `<td style="color:var(--text-dark); text-align: right; font-weight:800;">${formatCur(aggGst)}</td>`;
                        else if (col.id === 'gross') footHtml += `<td style="color:var(--text-dark); text-align: right; font-weight:800;">${formatCur(aggGross)}</td>`;
                        else if (col.id === 'advance') footHtml += `<td style="color:var(--warning); text-align: right; font-weight:800;">${formatCur(aggAdv)}</td>`;
                        else if (col.id === 'tds') footHtml += `<td style="color:var(--text-dark); text-align: right; font-weight:800;">${formatCur(aggTds)}</td>`;
                        else if (col.id === 'retention') footHtml += `<td style="color:var(--text-dark); text-align: right; font-weight:800;">${formatCur(aggRet)}</td>`;
                        else if (col.id === 'balance') footHtml += `<td style="color:var(--danger); text-align: right; font-weight:800;">${formatCur(aggDue)}</td>`;
                        else if (col.id === 'realized') footHtml += `<td style="color:var(--success); text-align: right; font-weight:800;">${formatCur(aggPaid)}</td>`;
                        else if (col.id === 'status') footHtml += `<td style="text-align:right; color:var(--text-muted); font-size:0.75rem; text-transform:uppercase; font-weight:800;">PAGE TOTALS:</td>`;
                        else footHtml += `<td></td>`;
                    }
                });
                footHtml += '</tr>';
                tfoot.innerHTML = footHtml;
            } else {
                tfoot.innerHTML = '';
            }

            document.getElementById('dashTotalInvoiced').innerText = formatCur(sumBilled);
            document.getElementById('dashTotalReceived').innerText = formatCur(sumReceived);
            document.getElementById('dashTotalOutstanding').innerText = formatCur(sumOut);
            const collectionRate = sumBilled > 0 ? (sumReceived / sumBilled) * 100 : 0;
            if (document.getElementById('dashCollectionRate')) {
                document.getElementById('dashCollectionRate').innerText = `${collectionRate.toFixed(1)}%`;
            }
            if (document.getElementById('dashCollectionMeta')) {
                document.getElementById('dashCollectionMeta').innerText = `${formatCur(sumReceived)} realized of ${formatCur(sumBilled)}`;
            }

            let unallocUi = document.getElementById('unallocatedUI');
            // SAFETY SHIELD: Only try to read unallocated funds if we are actually inside a specific client's ledger
            if (unallocUi && currentClient && currentClient !== 'ALL' && currentClient !== 'REPORTS' && currentClient !== 'ADMIN' && appData[currentClient]) {
                if (appData[currentClient].unallocated > 0) {
                    unallocUi.style.display = 'block';
                    document.getElementById('lblUnallocatedBal').innerText = formatCur(appData[currentClient].unallocated);
                } else unallocUi.style.display = 'none';
            } else if (unallocUi) {
                unallocUi.style.display = 'none';
            }

            updateAggregates();
        }

        function triggerUpdate() {
            if (renderUpdateRaf !== null) return;
            renderUpdateRaf = requestAnimationFrame(() => {
                renderUpdateRaf = null;
                poAdvancePoolCache = {};
            if (typeof updateAggregates === 'function') {
                updateAggregates();
            }
            if (typeof renderTableAndDashboard === 'function') {
                renderTableAndDashboard();
            }
                if (typeof updateCheckboxes === 'function') {
                    updateCheckboxes();
                }
                
                // Update the multi-select labels to reflect how many boxes are checked
                if (typeof updateMultiSelectLabel === 'function') {
                    updateMultiSelectLabel('poSelectOptions', 'poSelectLabel', 'Filter by POs...');
                    updateMultiSelectLabel('subSelectOptions', 'subSelectLabel', 'Sub-Entities...');
                    updateMultiSelectLabel('projectSelectOptions', 'projectSelectLabel', 'Projects...');
                    updateMultiSelectLabel('fySelectOptions', 'fySelectLabel', 'Financial Years...');
                }
                
                // Cascade available filter options based on currently active filters.
                if (typeof updatePOFilterDropdown === 'function') {
                    updatePOFilterDropdown();
                }
            });
        }

        function updateClientFilterDropdown() {
            const clientSel = document.getElementById('fltClient');
            const currVal = clientSel.value;
            clientSel.innerHTML = '<option value="">All Clients</option>';
            Object.keys(appData).filter(k => k !== '_settings').sort().forEach(c => { clientSel.innerHTML += `<option value="${esc(c)}">${escHtml(c)}</option>`; });
            clientSel.value = currVal || '';
        }

        function getCurrentLedgerFilterState() {
            return {
                client: currentClient === 'ALL' ? (document.getElementById('fltClient')?.value || '') : (currentClient || ''),
                pos: getMultiSelectValues('poSelectOptions'),
                subs: getMultiSelectValues('subSelectOptions'),
                projects: getMultiSelectValues('projectSelectOptions'),
                fiscalYears: getMultiSelectValues('fySelectOptions'),
                hideCompletedPos: !!document.getElementById('hideCompletedPoToggle')?.checked,
                status: document.getElementById('fltStatus')?.value || '',
                start: document.getElementById('fltStart')?.value || '',
                end: document.getElementById('fltEnd')?.value || '',
                search: (document.getElementById('fltSearch')?.value || '').toLowerCase().trim()
            };
        }

        function invoiceMatchesFiltersForOptions(inv, clientName, filters, excludeField, todayDate) {
            if (filters.client && clientName !== filters.client) return false;
            const poMeta = (((appData[clientName] || {}).poTerms || {})[inv.poNo]) || {};
            const projectName = poMeta.projectName || '';

            if (excludeField !== 'pos' && filters.pos && filters.pos.length > 0 && !filters.pos.includes(inv.poNo)) return false;
            if (excludeField !== 'subs' && filters.subs && filters.subs.length > 0 && (!inv.subEntity || !filters.subs.includes(inv.subEntity))) return false;
            if (excludeField !== 'projects' && filters.projects && filters.projects.length > 0 && (!projectName || !filters.projects.includes(projectName))) return false;
            if (excludeField !== 'fiscalYears' && filters.fiscalYears && filters.fiscalYears.length > 0 && (!inv.fiscalYear || !filters.fiscalYears.includes(inv.fiscalYear))) return false;

            if (filters.hideCompletedPos && poMeta.isCompleted) return false;
            if (filters.status) {
                if (filters.status === 'CLEARED' && inv.balance > 0) return false;
                if (filters.status === 'PENDING' && inv.balance === 0) return false;
                if (filters.status === 'OVERDUE' && (inv.balance === 0 || !inv.dueDate || inv.dueDate >= todayDate)) return false;
            }
            if (filters.start && (!inv.invDate || inv.invDate < filters.start)) return false;
            if (filters.end && (!inv.invDate || inv.invDate > filters.end)) return false;
            if (filters.search) {
                const allText = `${clientName} ${inv.subEntity || ''} ${inv.poNo} ${inv.id} ${inv.lrNo || ''} ${inv.basic} ${inv.gst} ${inv.total} ${inv.advance} ${inv.tds} ${inv.retention} ${inv.netPayable} ${inv.paid} ${inv.balance} ${projectName}`.toLowerCase();
                if (!allText.includes(filters.search)) return false;
            }
            return true;
        }

        function updatePOFilterDropdown() {
            const poContainer = document.getElementById('poSelectOptions');
            const currentSelections = getMultiSelectValues('poSelectOptions');
            if (poContainer) poContainer.innerHTML = '';

            const subContainer = document.getElementById('subSelectOptions');
            const currentSubSelections = getMultiSelectValues('subSelectOptions');
            if (subContainer) subContainer.innerHTML = '';
            const projectContainer = document.getElementById('projectSelectOptions');
            const currentProjectSelections = getMultiSelectValues('projectSelectOptions');
            if (projectContainer) projectContainer.innerHTML = '';
            const fyContainer = document.getElementById('fySelectOptions');
            const currentFySelections = getMultiSelectValues('fySelectOptions');
            if (fyContainer) fyContainer.innerHTML = '';

            const filters = getCurrentLedgerFilterState();
            const today = new Date().toISOString().split('T')[0];
            const clientsToProcess = filters.client
                ? [filters.client]
                : (currentClient === 'ALL' ? Object.keys(appData).filter(k => k !== '_settings') : [currentClient]);

            const uniquePOs = new Set();
            const uniqueSubs = new Set();
            const uniqueProjects = new Set();
            const uniqueFys = new Set();

            clientsToProcess.forEach(client => {
                if (!appData[client] || !Array.isArray(appData[client].invoices)) return;
                appData[client].invoices.forEach(inv => {
                    const poMeta = (((appData[client] || {}).poTerms || {})[inv.poNo]) || {};
                    if (invoiceMatchesFiltersForOptions(inv, client, filters, 'pos', today)) uniquePOs.add(inv.poNo);
                    if (invoiceMatchesFiltersForOptions(inv, client, filters, 'subs', today) && inv.subEntity) uniqueSubs.add(inv.subEntity);
                    if (invoiceMatchesFiltersForOptions(inv, client, filters, 'projects', today) && poMeta.projectName) uniqueProjects.add(poMeta.projectName);
                    if (invoiceMatchesFiltersForOptions(inv, client, filters, 'fiscalYears', today) && inv.fiscalYear) uniqueFys.add(inv.fiscalYear);
                });
            });

            if (poContainer) {
                Array.from(uniquePOs).sort().forEach(po => {
                    let isChecked = currentSelections.includes(po) ? 'checked' : '';
                    // CRITICAL FIX: Changed onchange to call triggerUpdate()
                    poContainer.innerHTML += `<label class="multi-option"><input type="checkbox" value="${esc(po)}" ${isChecked} onchange="triggerUpdate()"> ${po}</label>`;
                });
                updateMultiSelectLabel('poSelectOptions', 'poSelectLabel', 'Filter by POs...');
            }

            if (subContainer) {
                Array.from(uniqueSubs).sort().forEach(sub => {
                    let isChecked = currentSubSelections.includes(sub) ? 'checked' : '';
                    // CRITICAL FIX: Changed onchange to call triggerUpdate()
                    subContainer.innerHTML += `<label class="multi-option"><input type="checkbox" value="${esc(sub)}" ${isChecked} onchange="triggerUpdate()"> ${sub}</label>`;
                });
                updateMultiSelectLabel('subSelectOptions', 'subSelectLabel', 'Sub-Entities...');
            }
            if (projectContainer) {
                Array.from(uniqueProjects).sort().forEach(projectName => {
                    let isChecked = currentProjectSelections.includes(projectName) ? 'checked' : '';
                    projectContainer.innerHTML += `<label class="multi-option"><input type="checkbox" value="${esc(projectName)}" ${isChecked} onchange="triggerUpdate()"> ${escHtml(projectName)}</label>`;
                });
                updateMultiSelectLabel('projectSelectOptions', 'projectSelectLabel', 'Projects...');
            }
            if (fyContainer) {
                Array.from(uniqueFys).sort().forEach(fy => {
                    let isChecked = currentFySelections.includes(fy) ? 'checked' : '';
                    fyContainer.innerHTML += `<label class="multi-option"><input type="checkbox" value="${esc(fy)}" ${isChecked} onchange="triggerUpdate()"> ${escHtml(fy)}</label>`;
                });
                updateMultiSelectLabel('fySelectOptions', 'fySelectLabel', 'Financial Years...');
            }
        }

        function isInvoiceMatchingFilters(inv, clientName, filters, todayDate) {
            if (filters.client && clientName !== filters.client) return false;
            const hasPoFilter = Array.isArray(filters.pos) && filters.pos.length > 0;
            const hasProjectFilter = Array.isArray(filters.projects) && filters.projects.length > 0;
            if (!hasPoFilter && !hasProjectFilter) return false;
            const poMatches = hasPoFilter ? filters.pos.includes(inv.poNo) : false;
            const poMeta = (((appData[clientName] || {}).poTerms || {})[inv.poNo]) || {};
            const projectName = poMeta.projectName || '';
            const projectMatches = hasProjectFilter ? (!!projectName && filters.projects.includes(projectName)) : false;
            if (hasPoFilter && hasProjectFilter) {
                if (!(poMatches || projectMatches)) return false;
            } else if (hasPoFilter && !poMatches) {
                return false;
            } else if (hasProjectFilter && !projectMatches) {
                return false;
            }
            if (filters.subs && filters.subs.length > 0 && (!inv.subEntity || !filters.subs.includes(inv.subEntity))) return false;
            if (filters.fiscalYears && filters.fiscalYears.length > 0 && (!inv.fiscalYear || !filters.fiscalYears.includes(inv.fiscalYear))) return false;
            if (filters.hideCompletedPos) {
                const poMeta = (((appData[clientName] || {}).poTerms || {})[inv.poNo]) || {};
                if (poMeta.isCompleted) return false;
            }
            if (filters.status) {
                if (filters.status === 'CLEARED' && inv.balance > 0) return false;
                if (filters.status === 'PENDING' && inv.balance === 0) return false;
                if (filters.status === 'OVERDUE' && (inv.balance === 0 || !inv.dueDate || inv.dueDate >= todayDate)) return false;
            }
            if (filters.start && (!inv.invDate || inv.invDate < filters.start)) return false;
            if (filters.end && (!inv.invDate || inv.invDate > filters.end)) return false;
            if (filters.search) {
                const allText = `${clientName} ${inv.subEntity || ''} ${inv.poNo} ${inv.id} ${inv.lrNo || ''} ${inv.basic} ${inv.gst} ${inv.total} ${inv.advance} ${inv.tds} ${inv.retention} ${inv.netPayable} ${inv.paid} ${inv.balance}`.toLowerCase();
                if (!allText.includes(filters.search)) return false;
            }
            return true;
        }

        function inlineUpdateCustom(client, invId, colId, val) {
            let inv = appData[client].invoices.find(i => i.id === invId);
            if (inv) {
                if (!inv.customFields) inv.customFields = {};
                inv.customFields[colId] = val;
            }
        }

        function resetFilters(hardReset = false) {
            if (currentClient === 'ALL' || hardReset) document.getElementById('fltClient').value = '';
            document.querySelectorAll('#poSelectOptions input[type="checkbox"]').forEach(cb => cb.checked = false);
            updateMultiSelectLabel('poSelectOptions', 'poSelectLabel', 'Filter by POs...');
            document.querySelectorAll('#subSelectOptions input[type="checkbox"]').forEach(cb => cb.checked = false);
            updateMultiSelectLabel('subSelectOptions', 'subSelectLabel', 'Sub-Entities...');
            document.querySelectorAll('#projectSelectOptions input[type="checkbox"]').forEach(cb => cb.checked = false);
            updateMultiSelectLabel('projectSelectOptions', 'projectSelectLabel', 'Projects...');
            document.querySelectorAll('#fySelectOptions input[type="checkbox"]').forEach(cb => cb.checked = false);
            updateMultiSelectLabel('fySelectOptions', 'fySelectLabel', 'Financial Years...');
            if (document.getElementById('hideCompletedPoToggle')) document.getElementById('hideCompletedPoToggle').checked = false;
            document.getElementById('fltStatus').value = '';
            document.getElementById('fltStart').value = '';
            document.getElementById('fltEnd').value = '';
            document.getElementById('fltSearch').value = '';
            if (hardReset) {
                document.getElementById('repClient').value = ''; document.getElementById('repStart').value = ''; document.getElementById('repEnd').value = '';
                clearCustomChartFilters();
            }
            updatePOFilterDropdown(); triggerUpdate();
        }

        function clearCustomChartFilters() {
            document.getElementById('ccType').value = 'bar'; document.getElementById('ccMetric').value = 'netPayable'; document.getElementById('ccGroupBy').value = 'client';
            document.querySelectorAll('#ccSelectOptions input[type="checkbox"]').forEach(cb => cb.checked = false);
            updateMultiSelectLabel('ccSelectOptions', 'ccSelectLabel', 'All Clients...');
            document.getElementById('customChartWrapper').style.display = 'none';
        }

        // --- COL CONFIG, EXPORT, BULK EDIT, TRANSFER, BULK DELETE ---

        function openColumnManager() {
            document.getElementById('columnModal').style.display = 'flex';
            renderColumnManager();
        }

        function closeColumnManager() {
            document.getElementById('columnModal').style.display = 'none';
            triggerUpdate();
        }

        function renderColumnManager() {
            const list = document.getElementById('columnList');
            list.innerHTML = '';
            userColumns.forEach((col, index) => {
                let dragAttr = `draggable="true" ondragstart="colDragStart(event, ${index})" ondragover="colDragOver(event)" ondrop="colDrop(event, ${index})"`;
                let isCoreLock = col.type === 'core' && (col.id === 'invNo' || col.id === 'actions');
                let chk = `<input type="checkbox" id="col_vis_${index}" ${col.visible ? 'checked' : ''} ${isCoreLock ? 'disabled title="Core columns cannot be hidden"' : ''} onchange="toggleColVis(${index})">`;
                let delBtn = col.isCustom ? `<button class="btn-outline btn-sm text-danger" style="border:none; padding:0; height:auto; margin-left:auto;" onclick="deleteCustomColumn('${col.id}')">🗑️ Remove</button>` : `<span style="margin-left:auto; font-size:0.7rem; color:var(--text-muted); text-transform:uppercase; font-weight:700;">Core Config</span>`;

                list.innerHTML += `
                                            <div class="col-drag-item" ${dragAttr} id="col_drag_${index}">
                                                <span class="drag-handle" title="Drag to reorder">⋮⋮</span>
                                                ${chk}
                                                <label for="col_vis_${index}" style="margin:0; cursor:${isCoreLock ? 'not-allowed' : 'pointer'}; font-weight:600; font-size:0.85rem; color:var(--text-dark); flex:1;">${esc(col.label)}</label>
                                                ${delBtn}
                                            </div>
                                        `;
            });
        }

        let dragColIndex = null;
        function colDragStart(e, index) {
            dragColIndex = index;
            e.dataTransfer.effectAllowed = "move";
            setTimeout(() => e.target.classList.add('dragging'), 0);
        }
        function colDragOver(e) {
            e.preventDefault();
            e.dataTransfer.dropEffect = "move";
        }
        function colDrop(e, targetIndex) {
            e.preventDefault();
            document.querySelectorAll('.col-drag-item').forEach(el => el.classList.remove('dragging'));
            if (dragColIndex === null || dragColIndex === targetIndex) return;

            let movedCol = userColumns.splice(dragColIndex, 1)[0];
            userColumns.splice(targetIndex, 0, movedCol);

            localStorage.setItem(getColStorageKey(), JSON.stringify(userColumns));
            renderColumnManager();
            triggerUpdate();
        }

        function toggleColVis(index) {
            userColumns[index].visible = !userColumns[index].visible;
            localStorage.setItem(getColStorageKey(), JSON.stringify(userColumns));
            triggerUpdate();
        }

        function addCustomColumn() {
            const name = document.getElementById('newColName').value.trim();
            const type = document.getElementById('newColType').value;
            const formula = document.getElementById('newColFormula').value.trim();

            if (!name) return customApplet({ title: "Validation Error", message: "Column name is required." });
            if (type === 'calc' && !formula) return customApplet({ title: "Validation Error", message: "Formula is required for calculated columns." });

            let id = 'cust_' + Date.now();
            appData._settings.customColumns.push({ id, label: name, type, formula });
            userColumns.push({ id, label: name, visible: true, isCustom: true, type, formula });

            document.getElementById('newColName').value = '';
            document.getElementById('newColFormula').value = '';

            localStorage.setItem(getColStorageKey(), JSON.stringify(userColumns));
            saveSettings(); renderColumnManager(); triggerUpdate(); renderCustomFormFields();
        }

        function deleteCustomColumn(id) {
            appData._settings.customColumns = appData._settings.customColumns.filter(c => c.id !== id);
            userColumns = userColumns.filter(c => c.id !== id);
            localStorage.setItem(getColStorageKey(), JSON.stringify(userColumns));
            saveSettings(); renderColumnManager(); triggerUpdate(); renderCustomFormFields();
        }

        async function exportDispatchExcel(clientName, poNo) {
            const token = sessionStorage.getItem('erp_token');
            const client = (clientName || '').trim();
            const po = (poNo || '').trim();
            if (!client || !po) {
                customApplet({ title: "Export Error", message: "Please select a valid dispatch statement first." });
                return;
            }

            const url = `/api/dispatch/export-xlsx?client=${encodeURIComponent(client)}&po_no=${encodeURIComponent(po)}`;
            const res = await fetch(url, { headers: { 'Authorization': `Bearer ${token}` } });
            if (!res.ok) {
                let detail = 'Unable to export dispatch excel.';
                try {
                    const err = await res.json();
                    detail = err.detail || detail;
                } catch (_) {}
                throw new Error(detail);
            }

            const blob = await res.blob();
            const href = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = href;
            a.download = `dispatch_${client.replace(/[^a-z0-9._-]/gi, '_')}_${po.replace(/[^a-z0-9._-]/gi, '_')}.xlsx`;
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
            URL.revokeObjectURL(href);
        }

        async function exportCurrentDispatchExcel() {
            const poNo = document.getElementById('dispatchPoSelect')?.value || '';
            try {
                await exportDispatchExcel(currentClient, poNo);
            } catch (err) {
                customApplet({ title: "Export Error", message: err.message || "Export failed." });
            }
        }

        async function exportSelectedLogisticsDispatchExcel() {
            try {
                await exportDispatchExcel(logisticsPortalState.selectedClient, logisticsPortalState.selectedPoNo);
            } catch (err) {
                customApplet({ title: "Export Error", message: err.message || "Export failed." });
            }
        }

        async function exportLedgerCheckedExcel() {
            const checkedBoxes = Array.from(document.querySelectorAll('.export-row-chk:checked'));
            if (checkedBoxes.length === 0) {
                customApplet({ title: "Export Error", message: "Please check at least one ledger row to export." });
                return;
            }
            const token = sessionStorage.getItem('erp_token');
            const invoiceNos = [];
            checkedBoxes.forEach(box => {
                const invId = box.getAttribute('data-id');
                if (invId) invoiceNos.push(invId);
            });
            try {
                const res = await fetch('/api/ledger/export-xlsx', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'Authorization': `Bearer ${token}`
                    },
                    body: JSON.stringify({ invoice_nos: invoiceNos })
                });
                if (!res.ok) {
                    let detail = 'Unable to export financial ledger excel.';
                    try {
                        const err = await res.json();
                        detail = err.detail || detail;
                    } catch (_) {}
                    throw new Error(detail);
                }
                const blob = await res.blob();
                const href = URL.createObjectURL(blob);
                const a = document.createElement('a');
                a.href = href;
                a.download = `financial_ledger_export_${new Date().toISOString().split('T')[0]}.xlsx`;
                document.body.appendChild(a);
                a.click();
                document.body.removeChild(a);
                URL.revokeObjectURL(href);
            } catch (err) {
                customApplet({ title: "Export Error", message: err.message || "Export failed." });
            }
        }

        function exportToCSV() {
            const checkedBoxes = Array.from(document.querySelectorAll('.export-row-chk:checked'));
            if (checkedBoxes.length === 0) return customApplet({ title: "Export Error", message: "Please check the box next to at least one row to export it." });

            let visibleCols = userColumns.filter(c => c.visible && c.id !== 'actions');
            let headers = visibleCols.map(c => `"${c.label}"`).join(',');
            let rows = [headers];

            const today = new Date().toISOString().split('T')[0];

            checkedBoxes.forEach(box => {
                let client = box.getAttribute('data-client');
                let invId = box.getAttribute('data-id');
                let inv = appData[client].invoices.find(i => i.id === invId);
                if (!inv) return;

                let rowData = visibleCols.map(col => {
                    let val = '';
                    if (col.isCustom) {
                        if (col.type === 'text') val = inv.customFields && inv.customFields[col.id] ? inv.customFields[col.id] : '';
                        else if (col.type === 'calc') val = evalFormula(col.formula, inv);
                    } else {
                        switch (col.id) {
                            case 'clientName': val = client; break;
                            case 'subEntity': val = inv.subEntity || ''; break;
                            case 'poNo': val = inv.poNo || ''; break;
                            case 'invNo': val = inv.id; break;
                            case 'invDate': val = inv.invDate || ''; break;
                            case 'status': val = inv.balance === 0 ? 'CLEARED' : (inv.dueDate && inv.dueDate < today ? 'OVERDUE' : 'PENDING'); break;
                            case 'lrNo': val = inv.lrNo || ''; break;
                            case 'basic': val = getVal(inv.basic); break;
                            case 'gst': val = getVal(inv.gst); break;
                            case 'gross': val = getVal(inv.total); break;
                            case 'tds': val = getVal(inv.tds); break;
                            case 'retention': val = getVal(inv.retention); break;
                            case 'advance': val = getVal(inv.advance); break;
                            case 'realized': val = getVal((inv.paid || 0)); break;
                            case 'balance': val = getVal(inv.balance); break;
                            case 'paymentBreakdown': val = 'Ref Ledger History'; break;
                        }
                    }
                    return `"${String(val).replace(/"/g, '""')}"`;
                });
                rows.push(rowData.join(','));
            });

            let csvContent = "data:text/csv;charset=utf-8," + rows.join('\n');
            let encodedUri = encodeURI(csvContent);
            let link = document.createElement("a");
            link.setAttribute("href", encodedUri);
            link.setAttribute("download", `Achint_ERP_Export_${new Date().toISOString().split('T')[0]}.csv`);
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
        }

        function openBulkEditModal() {
            const checkedBoxes = document.querySelectorAll('.export-row-chk:checked');
            if (checkedBoxes.length === 0) return customApplet({ title: "Error", message: "Please check at least one row to edit." });

            ['bulkPoNo', 'bulkSubEntity', 'bulkLrNo', 'bulkInvDate', 'bulkDueDate', 'bulkBasic', 'bulkAdvance', 'bulkTds', 'bulkRet'].forEach(id => {
                let el = document.getElementById(id);
                if (el) el.value = '';
            });
            document.getElementById('bulkEditModal').style.display = 'flex';
        }

        async function executeBulkEdit() {
            const checkedBoxes = Array.from(document.querySelectorAll('.export-row-chk:checked'));
            const token = sessionStorage.getItem('erp_token');

            // Get values from the bulk edit modal
            const bulkData = {
                po_no: document.getElementById('bulkPoNo').value.trim(),
                sub_entity: document.getElementById('bulkSubEntity').value.trim(),
                lr_no: document.getElementById('bulkLrNo').value.trim(),
                inv_date: document.getElementById('bulkInvDate').value,
                due_date: document.getElementById('bulkDueDate').value,
                basic: document.getElementById('bulkBasic').value,
                advance_adj: document.getElementById('bulkAdvance').value,
                tds_ded: document.getElementById('bulkTds').value,
                retention_held: document.getElementById('bulkRet').value
            };

            let count = 0;
            for (let box of checkedBoxes) {
                let client = box.getAttribute('data-client');
                let invId = box.getAttribute('data-id');
                let inv = appData[client].invoices.find(i => i.id === invId);

                if (inv) {
                    // Update only fields that were filled in the modal
                    if (bulkData.po_no) inv.poNo = bulkData.po_no;
                    if (bulkData.sub_entity) inv.subEntity = bulkData.sub_entity;
                    if (bulkData.lr_no) inv.lr_no = bulkData.lr_no;
                    if (bulkData.inv_date) inv.invDate = bulkData.inv_date;
                    if (bulkData.due_date) inv.dueDate = bulkData.due_date;
                    if (bulkData.basic !== '') {
                        inv.basic = parseFloat(bulkData.basic);
                        inv.gst = inv.basic * 0.18;
                        inv.total = inv.basic + inv.gst;
                    }
                    if (bulkData.advance_adj !== '') inv.advance = parseFloat(bulkData.advance_adj);
                    if (bulkData.tds_ded !== '') inv.tds = parseFloat(bulkData.tds_ded);
                    if (bulkData.retention_held !== '') inv.retention = parseFloat(bulkData.retention_held);

                    inv.netPayable = (inv.total || 0) - (inv.advance || 0) - (inv.tds || 0);
                    inv.balance = Math.max(0, inv.netPayable - (inv.paid || 0));

                    // Send to SQL
                    try {
                        await fetch(`/api/invoices/${encodeURIComponent(invId)}`, {
                            method: 'PUT',
                            headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
                            body: JSON.stringify({
                                client_id: appData[client].sql_id,
                                po_no: inv.poNo,
                                invoice_no: inv.id,
                                sub_entity: inv.subEntity,
                                lr_no: inv.lrNo,
                                inv_date: inv.invDate,
                                due_date: inv.dueDate,
                                basic: inv.basic,
                                gst: inv.gst,
                                total: inv.total,
                                advance_adj: inv.advance,
                                tds_ded: inv.tds,
                                retention_held: inv.retention,
                                net_payable: inv.netPayable,
                                paid: inv.paid,
                                balance: inv.balance
                            })
                        });
                        count++;
                    } catch (e) { console.error("Bulk update failed for " + invId); }
                }
            }

            document.getElementById('bulkEditModal').style.display = 'none';
            await silentDataRefresh();
            triggerUpdate();
            await customApplet({ title: "Bulk Edit Complete", message: `Successfully updated ${count} records in the database.` });
        }

        function openTransferModal() {
            const checkedBoxes = document.querySelectorAll('.export-row-chk:checked');
            if (checkedBoxes.length === 0) return customApplet({ title: "Error", message: "Please check at least one row to transfer." });

            let sel = document.getElementById('transferClientSelect');
            sel.innerHTML = '<option value="">-- Select Destination --</option>';
            Object.keys(appData).filter(k => k !== '_settings').sort().forEach(c => {
                if (currentClient === 'ALL' || c !== currentClient) {
                    sel.innerHTML += `<option value="${esc(c)}">${esc(c)}</option>`;
                }
            });

            document.getElementById('transferModal').style.display = 'flex';
        }

        async function executeTransfer() {
            return withInFlight('executeTransfer', async () => {
            const targetClient = document.getElementById('transferClientSelect').value;
            const action = document.getElementById('transferAction').value;
            if (!targetClient) return await customApplet({ title: "Error", message: "Please select a destination account." });

            const checkedBoxes = Array.from(document.querySelectorAll('.export-row-chk:checked'));
                const token = sessionStorage.getItem('erp_token');
                const targetClientSqlId = appData[targetClient].sql_id;
                let successCount = 0;
                let failCount = 0;

                for (let box of checkedBoxes) {
                let invId = box.getAttribute('data-id');
                    try {
                        const response = await fetch(`/api/invoices/${encodeURIComponent(invId)}/transfer`, {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
                            body: JSON.stringify({ new_client_id: targetClientSqlId, action: action })
                        });
                        if (response.ok) successCount++;
                        else failCount++;
                    } catch (e) {
                        failCount++;
                    }
                }

            document.getElementById('transferModal').style.display = 'none';
            document.querySelectorAll('.export-row-chk').forEach(c => c.checked = false);
                await silentDataRefresh();
                triggerUpdate();
                let msg = `Successfully ${action}d ${successCount} records to ${targetClient}.`;
                if (failCount > 0) msg += `<br><br><span style="color:var(--danger)">Warning: ${failCount} records failed to transfer. Please retry.</span>`;
            await customApplet({ title: "Transfer Complete", message: msg });
            });
        }

        async function executeBulkDelete() {
            return withInFlight('executeBulkDelete', async () => {
            const checkedBoxes = Array.from(document.querySelectorAll('.export-row-chk:checked'));
            if (checkedBoxes.length === 0) return;

            let conf = await customApplet({
                title: "Confirm Bulk Deletion",
                message: `Are you sure you want to permanently delete ${checkedBoxes.length} records from the SQL database? This cannot be undone.`,
                type: "confirm"
            });
            if (!conf) return;

            const token = sessionStorage.getItem('erp_token');
            let successCount = 0;
            let failCount = 0;

            for (let box of checkedBoxes) {
                const invId = box.getAttribute('data-id');
                try {
                    const response = await fetch(`/api/invoices/${encodeURIComponent(invId)}`, {
                        method: 'DELETE',
                        headers: { 'Authorization': 'Bearer ' + token }
                    });
                        if (response.ok) successCount++;
                        else failCount++;
                } catch (e) {
                    failCount++;
                    console.error(`Network error during bulk delete for ${invId}:`, e);
                }
            }

                await silentDataRefresh();
            updatePOFilterDropdown();
            triggerUpdate();

            let resultMessage = `Successfully deleted ${successCount} records.`;
            if (failCount > 0) resultMessage += `<br><br><span style="color:var(--danger)">Warning: ${failCount} records could not be deleted. Check console for details.</span>`;

            await customApplet({
                title: "Bulk Action Complete",
                message: resultMessage
                });
            });
        }

        function updateAggregates() {
            const checkedBoxes = Array.from(document.querySelectorAll('.export-row-chk:checked'));
            const aggContainer = document.getElementById('selectionAggregates');
            if (checkedBoxes.length === 0) {
                aggContainer.style.display = 'none';
                return;
            }

            let sumGross = 0, sumPaid = 0, sumBal = 0;

            const func = document.getElementById('dynAggFunc').value;
            const colName = document.getElementById('dynAggCol').value;
            let dynValues = [];

            checkedBoxes.forEach(box => {
                let clientName = box.getAttribute('data-client');
                let invId = box.getAttribute('data-id');
                let inv = appData[clientName].invoices.find(i => i.id === invId);
                if (inv) {
                    const gross = getInvoiceMetricValue(inv, 'gross');
                    const realized = getInvoiceMetricValue(inv, 'realized');
                    const balance = getInvoiceMetricValue(inv, 'balance');
                    sumGross += gross;
                    sumPaid += realized;
                    sumBal += balance;

                    const dynVal = getInvoiceMetricValue(inv, colName);
                    dynValues.push(dynVal);
                }
            });

            document.getElementById('aggCount').innerText = checkedBoxes.length;
            document.getElementById('aggGross').innerText = formatCur(sumGross);
            document.getElementById('aggPaid').innerText = formatCur(sumPaid);
            document.getElementById('aggBal').innerText = formatCur(sumBal);

            let dynResult = 0;
            if (dynValues.length > 0) {
                if (func === 'SUM') dynResult = dynValues.reduce((a, b) => a + b, 0);
                else if (func === 'AVG') dynResult = dynValues.reduce((a, b) => a + b, 0) / dynValues.length;
                else if (func === 'MAX') dynResult = Math.max(...dynValues);
                else if (func === 'MIN') dynResult = Math.min(...dynValues);
            }
            document.getElementById('dynAggResult').innerText = formatCur(dynResult);

            aggContainer.style.display = 'flex';
        }

        function toggleAllRows(masterCheckbox) {
            document.querySelectorAll('.export-row-chk').forEach(cb => cb.checked = masterCheckbox.checked);
            updateAggregates();
        }

        function sortTable(colId) {
            if (currentSort.col === colId) currentSort.asc = !currentSort.asc;
            else { currentSort.col = colId; currentSort.asc = true; }
            triggerUpdate();
        }

        // --- SAFE REPORTING FALLBACKS (CHART.JS DISABLED) ---
        function openReportsPanel() {
            currentClient = 'REPORTS';
            hideAllViews(); resetFilters(false);
            document.getElementById('reportsView').style.display = 'block';
            document.getElementById('topbarTitle').innerText = "Executive Analytics";
            let clientSel = document.getElementById('repClient');
            if (clientSel) {
                let currVal = clientSel.value;
                clientSel.innerHTML = '<option value="">All Clients / Global</option>';
                Object.keys(appData).filter(k => k !== '_settings').sort().forEach(c => {
                    clientSel.innerHTML += `<option value="${esc(c)}">${escHtml(c)}</option>`;
                });
                clientSel.value = currVal || '';
            }
            updateSidebarNav(); generateReports();
        }

        function generateReports() {
            let kpiDiv = document.getElementById('repKpis');
            if (kpiDiv) {
                kpiDiv.innerHTML = '<div class="kpi-card" style="border-left: 4px solid var(--warning); grid-column: span 3;"><div class="kpi-label">System Notice</div><div class="kpi-value" style="font-size:1rem; white-space:normal;">Visual charts are currently disabled due to network firewalls blocking the Chart.js library. Your ledger data is secure and active.</div></div>';
            }
        }

        function buildCustomChart() {
            customApplet({ title: "Notice", message: "Custom charts require the Chart.js library, which is currently blocked by your network." });
        }

        // ==========================================
        // AI PDF EXTRACTION (STAGING QUEUE UPGRADE)
        // ==========================================

        let pendingBulkInvoices = [];
        let stagedFiles = []; // Array to hold files in memory

        const dropZone = document.getElementById('dropZone');
        if (dropZone) {
            dropZone.addEventListener('dragover', (e) => {
                e.preventDefault();
                dropZone.style.borderColor = 'var(--brand-primary)';
                dropZone.style.background = '#e0e7ff';
            });
            dropZone.addEventListener('dragleave', (e) => {
                e.preventDefault();
                dropZone.style.borderColor = 'var(--border-dark)';
                dropZone.style.background = '#f8fafc';
            });
            dropZone.addEventListener('drop', (e) => {
                e.preventDefault();
                dropZone.style.borderColor = 'var(--border-dark)';
                dropZone.style.background = '#f8fafc';
                const files = e.dataTransfer.files;
                if (files.length > 0) stagePDFs(files);
            });
        }

        function handlePDFUpload(event) {
            const files = event.target.files;
            if (files.length > 0) stagePDFs(files);
            event.target.value = ''; // Reset input so you can select from another folder
        }

        // NEW: Load files into memory and rename them dynamically to prevent identical name collision
        function stagePDFs(files) {
            for (let i = 0; i < files.length; i++) {
                let file = files[i];
                if (file.name.toLowerCase().endsWith('.pdf') || file.type === 'application/pdf') {
                    // Create a unique filename so "invoice.pdf" doesn't overwrite another "invoice.pdf"
                    let safeName = `invoice_batch_${Date.now()}_${i}.pdf`;
                    let safeFile = new File([file], safeName, { type: 'application/pdf' });
                    stagedFiles.push(safeFile);
                } else {
                    customApplet({ title: "Skipped File", message: `Skipped ${file.name} (Not a PDF).` });
                }
            }
            renderStagingArea();
        }

        function renderStagingArea() {
            const stagingUI = document.getElementById('stagingArea');
            if (stagedFiles.length > 0) {
                stagingUI.style.display = 'block';
                document.getElementById('stagedCount').innerText = stagedFiles.length;
                document.getElementById('uploadStatus').innerText = "Browse more folders to add files, or click Process when ready.";
            } else {
                stagingUI.style.display = 'none';
                document.getElementById('uploadStatus').innerText = "Supports standard Tally/ERP generated PDFs";
            }
        }

        function clearStagedPDFs() {
            stagedFiles = [];
            renderStagingArea();
        }

        // Build an /api/invoices payload from an AI-extracted invoice for auto-routing.
        function buildAutoInvoicePayload(inv, matchedClient, matchedPo) {
            const clientObj = appData[matchedClient] || {};
            const poNo = matchedPo || (inv.poNo || '').trim() || 'UNASSIGNED';
            const basic = parseFloat(inv.basic || 0) || 0;
            const gst = basic > 0 ? basic * 0.18 : 0;
            const total = basic + gst;
            let tds = 0;
            let retention = 0;
            const terms = (clientObj.poTerms || {})[poNo] || null;
            if (terms) {
                const baseAmt = terms.base === 'basic' ? basic : total;
                retention = baseAmt * ((terms.ret || 0) / 100);
                if (terms.tdsEnabled) {
                    const baseAmtForTds = terms.tdsBase === 'total' ? total : basic;
                    tds = baseAmtForTds * (terms.dynamicTdsRate || 0);
                }
            } else if (basic > 0) {
                tds = basic * 0.001;
            }
            const dispatchItemsRaw = (inv.items || []).map(i => ({
                description: i.desc || i.description || '',
                qty: parseFloat(i.qty) || 0,
                inspected_qty: parseFloat(i.inspected_qty || 0) || 0,
                uom: i.uom || 'Nos',
                rate_per_uom: parseFloat(i.rate_per_uom ?? i.rate ?? i.unitRate ?? 0) || 0
            })).filter(d => d.description && d.qty > 0);
            const dispatchItems = canonicalizeExtractedDispatchItems(dispatchItemsRaw, matchedClient, poNo);
            return {
                client_id: clientObj.sql_id,
                po_no: poNo,
                invoice_no: String(inv.invNo || '').trim(),
                sub_entity: inv.subEntity || null,
                lr_no: inv.lrNo || null,
                inv_date: inv.date || null,
                due_date: null,
                basic,
                gst,
                total,
                advance_adj: 0,
                tds_ded: tds,
                retention_held: retention,
                net_payable: 0,
                paid: 0,
                balance: 0,
                is_note: false,
                dispatch_items: dispatchItems
            };
        }

        async function autoStoreParsedInvoice(parsedItem) {
            const inv = parsedItem.data || {};
            const invNo = String(inv.invNo || '').trim();
            if (!invNo) return { status: 'failed', reason: 'missing_invoice_no' };
            // Try matching by extracted clientName, fall back to currentClient context.
            const extractedClient = String(inv.clientName || inv.client_name || '').trim();
            let matched = autoMatchClientByExtractedName(extractedClient);
            if (!matched && currentClient && currentClient !== 'ALL' && appData[currentClient]) {
                matched = currentClient;
            }
            if (!matched || !appData[matched] || !appData[matched].sql_id) {
                return { status: 'unrouted', reason: 'no_client_match', extractedClient };
            }
            const matchedPo = autoMatchPoForClient(matched, inv.poNo) || (inv.poNo ? String(inv.poNo).trim() : '');
            const payload = buildAutoInvoicePayload(inv, matched, matchedPo);
            const token = sessionStorage.getItem('erp_token');
            try {
                const res = await fetch('/api/invoices', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
                    body: JSON.stringify(payload)
                });
                if (res.ok) return { status: 'saved', client: matched, poNo: payload.po_no, invNo };
                const err = await res.json().catch(() => ({}));
                if (String(err.detail || '').toLowerCase().includes('already exists')) {
                    return { status: 'duplicate', client: matched, poNo: payload.po_no, invNo };
                }
                return { status: 'failed', reason: err.detail || 'save_failed', client: matched, invNo };
            } catch (err) {
                return { status: 'failed', reason: err.message || 'network_error', invNo };
            }
        }

        // NEW: Send the entire queue to the server at once
        async function processStagedPDFs() {
            if (stagedFiles.length === 0) return;
            const haveClientContext = currentClient && currentClient !== 'ALL' && appData[currentClient];

            const formData = new FormData();
            if (haveClientContext) formData.append('clientName', currentClient);
            stagedFiles.forEach(file => {
                formData.append('invoice_pdf', file);
            });

            document.getElementById('uploadStatus').innerText = `⏳ AI is extracting items...`;
            document.getElementById('stagingArea').style.display = 'none';
            const token = sessionStorage.getItem('erp_token');

            try {
                const response = await fetch('/api/upload-invoice', {
                    method: 'POST',
                    headers: { 'Authorization': 'Bearer ' + token },
                    body: formData
                });

                const data = await response.json();
                document.getElementById('uploadStatus').innerText = "Supports standard Tally/ERP generated PDFs";
                stagedFiles = [];
                renderStagingArea();

                if (data.success && Array.isArray(data.results)) {
                    const parsed = [];
                    const failed = [];
                    data.results.forEach((result) => {
                        if (!result || !result.success || !result.raw_data) {
                            failed.push(result?.filename || 'unknown');
                            return;
                        }
                        try {
                            const cleanJson = result.raw_data.replace(/```json/g, '').replace(/```/g, '').trim();
                            const inv = JSON.parse(cleanJson);
                            parsed.push({ filename: result.filename || 'file', data: inv });
                        } catch (e) {
                            failed.push(result.filename || 'unknown');
                        }
                    });

                    if (!parsed.length) {
                        return await customApplet({ title: "AI Parse Error", message: "No valid invoice payload could be extracted." });
                    }

                    // Auto-route invoices whose extracted clientName matches an existing client.
                    const autoSavedSummary = { saved: 0, duplicate: 0, failed: 0, byClient: {} };
                    const unmatched = [];
                    const autoSavedClientSet = new Set();
                    for (const p of parsed) {
                        const inv = p.data || {};
                        const extractedClient = String(inv.clientName || inv.client_name || '').trim();
                        const matched = autoMatchClientByExtractedName(extractedClient);
                        if (!matched) { unmatched.push(p); continue; }
                        const result = await autoStoreParsedInvoice(p);
                        if (result.status === 'saved') {
                            autoSavedSummary.saved += 1;
                            autoSavedSummary.byClient[matched] = (autoSavedSummary.byClient[matched] || 0) + 1;
                            autoSavedClientSet.add(matched);
                        } else if (result.status === 'duplicate') {
                            autoSavedSummary.duplicate += 1;
                            autoSavedClientSet.add(matched);
                        } else if (result.status === 'failed') {
                            autoSavedSummary.failed += 1;
                            unmatched.push(p);
                        } else {
                            unmatched.push(p);
                        }
                    }
                    const autoTouched = autoSavedSummary.saved + autoSavedSummary.duplicate + autoSavedSummary.failed;
                    if (autoTouched > 0) {
                        await silentDataRefresh();
                        updatePOFilterDropdown();
                        triggerUpdate();
                        const lines = [`Auto-routed: ${autoTouched} invoice(s).`];
                        lines.push(`Saved: ${autoSavedSummary.saved}`);
                        if (autoSavedSummary.duplicate) lines.push(`Duplicates skipped: ${autoSavedSummary.duplicate}`);
                        if (autoSavedSummary.failed) lines.push(`Failed: ${autoSavedSummary.failed}`);
                        if (Object.keys(autoSavedSummary.byClient).length) {
                            lines.push('');
                            lines.push('By client:');
                            Object.entries(autoSavedSummary.byClient).forEach(([c, n]) => lines.push(`  • ${c}: ${n}`));
                        }
                        if (unmatched.length) lines.push(`\n${unmatched.length} invoice(s) need manual review.`);
                        await customApplet({ title: "Auto-Storage Complete", message: lines.join('\n') });
                    }

                    if (!unmatched.length) return;

                    // Re-scope downstream review to remaining unmatched parses only.
                    parsed.length = 0;
                    parsed.push(...unmatched);

                    if (!haveClientContext) {
                        return await customApplet({
                            title: "Manual Routing Required",
                            message: `${unmatched.length} invoice(s) could not be auto-matched to a client. Open the relevant client and re-upload these PDFs to review and save them manually.`
                        });
                    }

                    // Single file: keep fast-fill UX.
                    if (parsed.length === 1) {
                        const inv = parsed[0].data;
                    document.getElementById('invNo').value = inv.invNo || '';
                    document.getElementById('subEntity').value = inv.subEntity || '';
                    document.getElementById('lrNo').value = inv.lrNo || '';
                    if (inv.date) document.getElementById('invDate').value = inv.date;
                    document.getElementById('basicVal').value = inv.basic || '';

                    window.lastExtractedItems = (inv.items || []).map(i => ({
                        description: i.desc || i.description,
                        qty: parseFloat(i.qty) || 0,
                        uom: i.uom || 'Nos',
                        rate_per_uom: parseFloat(i.rate_per_uom ?? i.rate ?? i.unitRate ?? 0) || 0
                    }));

                    let poVal = inv.poNo || '';
                    let sel = document.getElementById('poNoSelect');
                    if (sel) {
                        let exists = Array.from(sel.options).some(opt => opt.value === poVal);
                        if (exists && poVal) {
                            sel.value = poVal;
                            document.getElementById('poNo').value = poVal;
                        } else if (poVal) {
                            sel.value = 'ADD_NEW';
                            document.getElementById('poNo').style.display = 'block';
                            document.getElementById('poNo').value = poVal;
                            sel.style.display = 'none';
                            document.getElementById('btnCancelNewPo').style.display = 'block';
                        }
                    }
                        const selectedPo = (document.getElementById('poNo')?.value || poVal || '').trim();
                        if (selectedPo) {
                            window.lastExtractedItems = canonicalizeExtractedDispatchItems(window.lastExtractedItems, currentClient, selectedPo);
                        }
                    autoCalculateTerms();
                        const failNote = failed.length ? `\n\n${failed.length} file(s) could not be parsed.` : '';
                        customApplet({ title: "AI Success", message: `Extracted ${window.lastExtractedItems.length} items.${failNote}` });
                    } else {
                        // Multi file: route to existing bulk review workflow.
                        pendingBulkInvoices = parsed.map(p => ({ filename: p.filename, data: p.data }));
                        renderBulkReviewTable();
                        document.getElementById('bulkReviewModal').style.display = 'flex';
                        let msg = `Parsed ${parsed.length} invoice(s). Review and commit from batch panel.`;
                        if (failed.length) msg += `\n\n${failed.length} file(s) failed to parse.`;
                        customApplet({ title: "Batch AI Extraction Complete", message: msg });
                    }
                }
            } catch (error) {
                console.error("AI Error:", error);
                document.getElementById('uploadStatus').innerText = "Upload failed.";
                stagedFiles = [];
                renderStagingArea();
                await customApplet({ title: "Error", message: "Failed to parse AI response." });
            }
        }

        async function saveInvoice() {
            const role = (sessionStorage.getItem('erp_role') || '').toLowerCase();
            const isLogistics = role === 'logistics';
            let poNo = document.getElementById('poNo').value.trim();
            const selPo = document.getElementById('poNoSelect');

            if (selPo && selPo.style.display !== 'none' && selPo.value && selPo.value !== 'ADD_NEW') {
                poNo = selPo.value.trim();
            }
            poNo = poNo || 'UNASSIGNED';

            const invNo = document.getElementById('invNo').value.trim();
            if (!invNo) return await customApplet({ title: "Validation Error", message: "Invoice No. is mandatory." });

            const subEntity = document.getElementById('subEntity').value.trim();
            const lrNo = document.getElementById('lrNo').value.trim();
            const invDate = document.getElementById('invDate').value;
            const dueDate = document.getElementById('dueDate').value;
            const isEditing = document.getElementById('editMode').value === "true";

            const entryCur = document.getElementById('entryCurrency').value;
            const rate = parseFloat(document.getElementById('entryRate')?.value || 1) || 1;

            const basicRaw = isLogistics ? 0 : (parseFloat(document.getElementById('basicVal').value) || 0);
            const advanceRaw = isLogistics ? 0 : (parseFloat(document.getElementById('advanceVal').value) || 0);
            const tdsRaw = isLogistics ? 0 : (parseFloat(document.getElementById('tdsVal').value) || 0);
            const retentionRaw = isLogistics ? 0 : (parseFloat(document.getElementById('retentionVal').value) || 0);

            if (!isLogistics && basicRaw <= 0) return await customApplet({ title: "Validation Error", message: "Basic Value is mandatory." });

            const basic = basicRaw * rate;
            const advance = advanceRaw * rate;
            const tds = tdsRaw * rate;
            const retention = retentionRaw * rate;
            const applyGst = isLogistics ? false : document.getElementById('applyGst').checked;
            const gst = applyGst ? basic * 0.18 : 0;
            const total = basic + gst;

            // Note: We don't calculate the netPayable or balances here anymore. 
            // The Python SQL backend enforces all the math!

            const token = sessionStorage.getItem('erp_token');
            const clientObj = appData[currentClient];

            const payload = {
                client_id: clientObj.sql_id,
                po_no: poNo,
                invoice_no: invNo,
                sub_entity: subEntity,
                lr_no: lrNo,
                inv_date: invDate || null,
                due_date: dueDate || null,
                basic: basic,
                gst: gst,
                total: total,
                advance_adj: advance,
                tds_ded: tds,
                retention_held: retention,
                net_payable: 0,
                paid: 0,
                balance: 0,
                is_note: false,
                dispatch_items: window.lastExtractedItems || []
            };
            try {
                let endpoint = isEditing ? `/api/invoices/${encodeURIComponent(invNo)}` : '/api/invoices';
                let method = isEditing ? 'PUT' : 'POST';

                const response = await fetch(endpoint, {
                    method: method,
                    headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
                    body: JSON.stringify(payload)
                });
                const saveResult = await response.json().catch(() => ({}));
                if (!response.ok) throw new Error("Database update failed");

                if (isEditing) {
                    cancelEdit();
                } else {
                    clearInvoiceForm();
                }

                // CRITICAL FIX: Silently fetch exact, mathematically perfect balances from Python
                await silentDataRefresh();
                const refreshedInv = (((appData[currentClient] || {}).invoices) || []).find(i => i.id === invNo);
                window.lastExtractedItems = [];
                updatePOFilterDropdown();
                triggerUpdate();

                await customApplet({ title: "Success", message: "Ledger updated and balances calculated securely." });

            } catch (error) {
                console.error("Save error:", error);
                await customApplet({ title: "Database Error", message: "Failed to save invoice." });
            }
        }

        function renderBulkReviewTable() {
            const tbody = document.getElementById('bulkReviewTableBody');
            tbody.innerHTML = '';

            pendingBulkInvoices.forEach((item, index) => {
                const inv = item.data;
                if (!inv) return;

                tbody.innerHTML += `
                                    <tr style="border-bottom: 1px solid var(--border);">
                                        <td style="font-size:0.75rem; color:var(--text-muted); max-width: 150px; overflow: hidden; text-overflow: ellipsis;">${esc(item.filename)}</td>
                                        <td><input type="text" id="bulk_inv_${index}" value="${esc(inv.invNo || '')}" style="width:100px; height: 30px;"></td>
                                        <td><input type="text" id="bulk_sub_${index}" value="${esc(inv.subEntity || '')}" style="width:90px; height: 30px;"></td>
                                        <td><input type="text" id="bulk_po_${index}" value="${esc(inv.poNo || '')}" style="width:110px; height: 30px;"></td>
                                        <td><input type="text" id="bulk_lr_${index}" value="${esc(inv.lrNo || '')}" style="width:90px; height: 30px;"></td>
                                        <td><input type="date" id="bulk_date_${index}" value="${esc(inv.date || '')}" style="width:110px; height: 30px;"></td>
                                        <td><input type="number" id="bulk_basic_${index}" value="${esc(inv.basic || 0)}" style="width:100px; text-align:right; font-weight:bold; color:var(--brand-primary); height: 30px;"></td>
                                        <td style="text-align:center;"><input type="checkbox" id="bulk_gst_${index}" checked style="width:16px; height:16px; accent-color:var(--brand-primary);"></td>
                                        <td style="text-align:center;"><input type="checkbox" id="bulk_tds_${index}" style="width:16px; height:16px; accent-color:var(--brand-primary);"></td>
                                    </tr>
                                `;
            });
        }

        async function commitBulkInvoices() {
            return withInFlight('commitBulkInvoices', async () => {
            let successCount = 0;
            let duplicateCount = 0;
                let failedCount = 0;
                const token = sessionStorage.getItem('erp_token');
                const clientObj = appData[currentClient];

            for (let i = 0; i < pendingBulkInvoices.length; i++) {
                const item = pendingBulkInvoices[i];
                if (!item.data) continue;

                const invNo = document.getElementById(`bulk_inv_${i}`).value.trim();
                const subEntity = document.getElementById(`bulk_sub_${i}`).value.trim();
                const poNo = document.getElementById(`bulk_po_${i}`).value.trim() || 'UNASSIGNED';
                const lrNo = document.getElementById(`bulk_lr_${i}`).value.trim();
                const invDate = document.getElementById(`bulk_date_${i}`).value;
                const basic = parseFloat(document.getElementById(`bulk_basic_${i}`).value) || 0;
                const applyGst = !!document.getElementById(`bulk_gst_${i}`)?.checked;
                const applyTds = !!document.getElementById(`bulk_tds_${i}`)?.checked;

                if (!invNo || basic <= 0) continue;

                const gst = applyGst ? basic * 0.18 : 0;
                const total = basic + gst;
                let tds = 0;
                let retention = 0;

                const terms = appData[currentClient].poTerms ? appData[currentClient].poTerms[poNo] : null;
                if (terms) {
                    let baseAmt = terms.base === 'basic' ? basic : total;
                    retention = baseAmt * (terms.ret / 100);

                    if (applyTds && terms.tdsEnabled) {
                        let baseAmtForTds = terms.tdsBase === 'total' ? total : basic;
                        tds = baseAmtForTds * (terms.dynamicTdsRate || 0);
                    }
                } else {
                    tds = applyTds ? (basic * 0.001) : 0;
                }

                const netPayable = total - tds;
                    let dispatchItems = (item.data.items || []).map((di) => ({
                        description: di.desc || di.description || '',
                        qty: parseFloat(di.qty) || 0,
                        inspected_qty: parseFloat(di.inspected_qty || 0) || 0,
                        uom: di.uom || 'Nos',
                        rate_per_uom: parseFloat(di.rate_per_uom ?? di.rate ?? di.unitRate ?? 0) || 0
                    })).filter((di) => di.description && di.qty > 0);
                    dispatchItems = canonicalizeExtractedDispatchItems(dispatchItems, currentClient, poNo);
                    const payload = {
                        client_id: clientObj.sql_id,
                        po_no: poNo,
                        invoice_no: invNo,
                        sub_entity: subEntity || null,
                        lr_no: lrNo || null,
                        inv_date: invDate || null,
                        due_date: null,
                        basic: basic,
                        gst: gst,
                        total: total,
                        advance_adj: 0,
                        tds_ded: tds,
                        retention_held: retention,
                        net_payable: netPayable,
                        paid: 0,
                        balance: netPayable,
                        is_note: false,
                        note_type: null,
                        note_reason: null,
                        dispatch_items: dispatchItems
                    };

                    try {
                        const response = await fetch('/api/invoices', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
                            body: JSON.stringify(payload)
                        });
                        if (response.ok) successCount++;
                        else if (response.status === 400) duplicateCount++;
                        else failedCount++;
                    } catch (e) {
                        failedCount++;
                    }
            }

            document.getElementById('bulkReviewModal').style.display = 'none';
            pendingBulkInvoices = [];
                await silentDataRefresh();
            updatePOFilterDropdown();
            triggerUpdate();

            let msg = `Successfully mapped and saved ${successCount} invoices to the ledger.`;
            if (duplicateCount > 0) {
                msg += `<br><br><span style="color:var(--warning); font-weight:bold;">Notice:</span> ${duplicateCount} record(s) were skipped because the Invoice Number already exists in this account.`;
            }
                if (failedCount > 0) {
                    msg += `<br><br><span style="color:var(--danger); font-weight:bold;">Warning:</span> ${failedCount} record(s) failed due to server/network issues.`;
                }
            await customApplet({ title: "Batch Commit Successful", message: msg });
            });
        }

        function openNoteModal() {
            if (!currentClient || currentClient === 'ALL') return customApplet({ title: "Error", message: "Please open a specific client account first." });

            document.getElementById('noteNo').value = '';
            document.getElementById('noteDate').value = new Date().toISOString().split('T')[0];
            document.getElementById('noteAmt').value = '';
            document.getElementById('noteReason').value = '';

            const sel = document.getElementById('noteInvSelect');
            sel.innerHTML = '<option value="">-- Leave Unassigned (Account Level) --</option>';
            appData[currentClient].invoices.forEach(inv => {
                if (!inv.isNote && inv.balance !== 0) {
                    sel.innerHTML += `<option value="${esc(inv.id)}">${esc(inv.id)} (Curr Bal: ${formatCur(inv.balance)})</option>`;
                }
            });

            updateNoteUI();
            document.getElementById('dnCnModal').style.display = 'flex';
        }

        function updateNoteUI() {
            const type = document.getElementById('noteType').value;
            const btn = document.getElementById('btnSaveNote');
            if (type === 'CN') {
                btn.innerText = 'Issue Credit Note';
                btn.style.backgroundColor = 'var(--success)';
            } else {
                btn.innerText = 'Issue Debit Note';
                btn.style.backgroundColor = 'var(--danger)';
            }
        }

        async function executeIssueNote() {
            return withInFlight('executeIssueNote', async () => {
            const type = document.getElementById('noteType').value;
            const noteNo = document.getElementById('noteNo').value.trim();
            const date = document.getElementById('noteDate').value;
            const invId = document.getElementById('noteInvSelect').value;
            const amt = parseFloat(document.getElementById('noteAmt').value) || 0;
            const reason = document.getElementById('noteReason').value.trim();

            if (!noteNo) return customApplet({ title: "Validation Error", message: "Document Number is required." });
            if (amt <= 0) return customApplet({ title: "Validation Error", message: "Amount must be greater than 0." });
            if (appData[currentClient].invoices.some(i => i.id === noteNo)) return customApplet({ title: "Validation Error", message: "Document Number already exists." });

                const token = sessionStorage.getItem('erp_token');
                const clientObj = appData[currentClient];
                const payload = {
                    client_id: clientObj.sql_id,
                    note_no: noteNo,
                    date: date || null,
                    note_type: type,
                    amount: amt,
                    reason: reason,
                    target_invoice_id: invId || null
                };
                const response = await fetch('/api/notes/issue', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
                    body: JSON.stringify(payload)
                });
                const result = await response.json().catch(() => ({}));
                if (!response.ok) return customApplet({ title: "Database Error", message: result.detail || "Failed to issue note." });

            document.getElementById('dnCnModal').style.display = 'none';
                await silentDataRefresh();
            triggerUpdate();
                await customApplet({ title: "Note Issued", message: `${type === 'CN' ? 'Credit' : 'Debit'} Note <b>${noteNo}</b> successfully issued and mathematically applied.` });
            });
        }

        function openEditPaymentModal(historyId) {
            let historyList = appData[currentClient].paymentHistory;
            let log = historyList.find(h => h.id == historyId);
            if (!log) return;

            document.getElementById('editPaymentId').value = log.id;
            document.getElementById('editPaymentAmt').value = log.amount;

            // Only allow the raw Amount to be edited if it's a base Bank Receipt.
            // For derived/auto-applied transactions, only the note can be edited.
            document.getElementById('editPaymentAmt').disabled = (log.type !== 'RECEIPT');

            document.getElementById('editPaymentNote').value = log.note || '';

            document.getElementById('editPaymentModal').style.display = 'flex';
        }

        async function savePaymentEdit() {
            return withInFlight('savePaymentEdit', async () => {
            let historyId = document.getElementById('editPaymentId').value;
            let newAmt = parseFloat(document.getElementById('editPaymentAmt').value) || 0;
            let newNote = document.getElementById('editPaymentNote').value.trim();

                let log = appData[currentClient].paymentHistory.find(h => h.id == historyId);
            if (!log) return;

                if (log.type === 'RECEIPT' && newAmt <= 0) return customApplet({ title: "Error", message: "Amount must be greater than zero." });

                const token = sessionStorage.getItem('erp_token');
                const response = await fetch(`/api/payments/${historyId}`, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
                    body: JSON.stringify({ amount: newAmt, note: newNote })
                });
                if (!response.ok) {
                    const result = await response.json().catch(() => ({}));
                    return customApplet({ title: "Database Error", message: result.detail || "Failed to update transaction." });
                }
            document.getElementById('editPaymentModal').style.display = 'none';
                await silentDataRefresh();
            openPaymentHistory();
            triggerUpdate();
                customApplet({ title: "Record Updated", message: "Transaction updated and Python has verified the ledger." });
            });
        }


        async function openDispatchStatementEntry(clientName) {
            const role = (sessionStorage.getItem('erp_role') || '').toLowerCase();
            if (role === 'logistics') {
                return openLogisticsDispatchWorkspace(clientName);
            }
            if (!clientName || !appData[clientName]) {
                return customApplet({ title: "Unavailable", message: "Client dispatch context is not loaded yet. Please refresh and try again." });
            }
            logisticsPortalState.clientPageClient = clientName;
            logisticsPortalState.selectedClientRowIndex = -1;
            await openLogisticsClientPageView();
        }

        function openDispatchTracking(clientName) {
            if (!clientName || !appData[clientName]) {
                customApplet({ title: "Unavailable", message: "Client dispatch context is not loaded yet. Please refresh and try again." });
                return;
            }
            currentClient = clientName;
            hideAllViews();
            document.getElementById('dispatchView').style.display = 'block';

            let isActive = appData[clientName] && appData[clientName].active !== false;
            let titleAddon = isActive ? '' : ' <span class="status-pill pill-inactive" style="margin-left:12px; vertical-align:middle; border:none;">READ-ONLY</span>';
            document.getElementById('topbarTitle').innerHTML = `Fulfillment: ${escHtml(clientName)}${titleAddon}`;

            // Restore the Admin Buttons for this specific client
            const isAdmin = sessionStorage.getItem('erp_role') === 'admin';
            if (isAdmin && appData[clientName]) {
                const actionsEl = document.getElementById('clientActions');
                if (actionsEl) actionsEl.style.display = 'flex';
                let tBtn = document.getElementById('btnToggleClientStatus');
                if (tBtn) {
                tBtn.innerHTML = isActive ? "⏸️ Suspend" : "▶️ Reactivate";
                tBtn.style.color = isActive ? "var(--warning)" : "var(--success)";
                tBtn.style.borderColor = isActive ? "var(--warning)" : "var(--success)";
                }
            } else {
                const actionsEl = document.getElementById('clientActions');
                if (actionsEl) actionsEl.style.display = 'none';
            }

            // Populate PO Dropdown
            const sel = document.getElementById('dispatchPoSelect');
            sel.innerHTML = '<option value="">-- Select Purchase Order --</option>';

            let poSet = new Set();
            if (appData[clientName].poTerms) {
                Object.keys(appData[clientName].poTerms).forEach(po => poSet.add(po));
            }
            appData[clientName].invoices.forEach(inv => {
                if (inv.poNo && inv.poNo !== 'UNASSIGNED') poSet.add(inv.poNo);
            });

            poSet.forEach(po => {
                sel.innerHTML += `<option value="${esc(po)}">${esc(getPoMetaLabel(clientName, po))}</option>`;
            });

            let hasUnassigned = appData[clientName].invoices.some(i => i.poNo === 'UNASSIGNED' && i.dispatchItems && i.dispatchItems.length > 0);
            if (hasUnassigned) {
                sel.innerHTML += `<option value="UNASSIGNED" style="font-weight: bold; color: var(--brand-primary);">UNASSIGNED DISPATCHES</option>`;
            }

            const poOptions = Array.from(sel.options).map(o => o.value).filter(Boolean);
            const rememberedPo = dispatchViewState.selectedPoByClient[clientName];
            if (rememberedPo && poOptions.includes(rememberedPo)) {
                sel.value = rememberedPo;
            } else if (poOptions.length > 0) {
                sel.value = poOptions[0];
                dispatchViewState.selectedPoByClient[clientName] = poOptions[0];
            } else {
            sel.value = '';
            }
            applyRoleSectionCopy();
            applyDispatchRoleVisibility();
            renderDispatchReconciliation();
        }

        function getPoMetaLabel(clientName, poNo) {
            const poData = (((appData[clientName] || {}).poTerms || {})[poNo]) || {};
            const meta = [poData.projectName || '', poData.contactPerson || ''].filter(Boolean).join(' • ');
            return meta ? `${poNo} (${meta})` : poNo;
        }

        function setDispatchSnapshot({
            ordered = 0, dispatched = 0, pending = 0, invoices = 0,
            bricksOrdered = 0, bricksDispatched = 0, bricksPending = 0,
            castOrdered = 0, castDispatched = 0, castPending = 0
        } = {}) {
            const setText = (id, val) => {
                const el = document.getElementById(id);
                if (el) el.innerText = val;
            };
            setText('dispatchStatBricksOrdered', formatNum(bricksOrdered, 2));
            setText('dispatchStatBricksDispatched', formatNum(bricksDispatched, 2));
            setText('dispatchStatBricksPending', formatNum(bricksPending, 2));
            setText('dispatchStatCastOrdered', formatNum(castOrdered, 2));
            setText('dispatchStatCastDispatched', formatNum(castDispatched, 2));
            setText('dispatchStatCastPending', formatNum(castPending, 2));
            setText('dispatchStatInvoices', invoices);
        }

        function stepDispatchPo(direction) {
            const sel = document.getElementById('dispatchPoSelect');
            if (!sel) return;
            const options = Array.from(sel.options).map(o => o.value).filter(Boolean);
            if (!options.length) return;
            const currentIdx = Math.max(0, options.indexOf(sel.value));
            const nextIdx = Math.min(options.length - 1, Math.max(0, currentIdx + direction));
            sel.value = options[nextIdx];
            renderDispatchReconciliation();
        }

        function updateDispatchAggregate(summaryRows) {
            const metricEl = document.getElementById('dispatchAggMetric');
            const fnEl = document.getElementById('dispatchAggFn');
            const outEl = document.getElementById('dispatchAggResult');
            if (!outEl) return;
            const rows = Array.isArray(summaryRows) ? summaryRows : [];
            if (!rows.length) {
                outEl.innerText = 'Agg: -';
                return;
            }
            const metric = metricEl ? metricEl.value : 'dispatched';
            const fn = fnEl ? fnEl.value : 'sum';
            const values = rows.map(r => Number(r[metric] || 0)).filter(v => Number.isFinite(v));
            if (!values.length) {
                outEl.innerText = 'Agg: -';
                return;
            }
            let result = 0;
            if (fn === 'avg') result = values.reduce((a, b) => a + b, 0) / values.length;
            else if (fn === 'min') result = Math.min(...values);
            else if (fn === 'max') result = Math.max(...values);
            else if (fn === 'count') result = values.length;
            else result = values.reduce((a, b) => a + b, 0);

            const label = `${fn.toUpperCase()}(${metric.toUpperCase()})`;
            outEl.innerText = fn === 'count' ? `${label}: ${formatNum(result, 0)}` : `${label}: ${formatNum(result, 2)}`;
        }

        function renderDispatchHeaders(summaryCols, historyCols) {
            const summaryHead = document.getElementById('dispatchSummaryHead');
            const historyHead = document.getElementById('dispatchHistoryHead');
            const role = (sessionStorage.getItem('erp_role') || '').toLowerCase();
            const effectiveHistoryCols = role === 'logistics' ? historyCols.filter(k => k !== 'bill') : historyCols;
            if (summaryHead) {
                const m = {
                    material: 'Material Description',
                    uom: 'UOM',
                    ordered: 'Ordered Qty',
                    dispatched: 'Dispatched Qty',
                    inspected: 'Inspected Qty',
                    pending: 'Pending Qty'
                };
                summaryHead.innerHTML = `<tr>${summaryCols.map(k => `<th style="padding: 12px 16px; text-align: ${k === 'material' ? 'left' : 'right'}; border-bottom: 2px solid var(--border-dark);">${m[k]}</th>`).join('')}</tr>`;
            }
            if (historyHead) {
                const m = {
                    date: 'Date',
                    invoice: 'Invoice No.',
                    material: 'Material Description',
                    lr: 'LR No. (Transport)',
                    bill: 'Bill Value',
                    dispatched: 'Dispatched',
                    action: 'Action'
                };
                historyHead.innerHTML = `<tr>${effectiveHistoryCols.map(k => `<th style="padding: 12px 16px; text-align: ${k === 'material' || k === 'date' || k === 'invoice' || k === 'lr' ? 'left' : (k === 'action' ? 'center' : 'right')}; border-bottom: 1px solid var(--border-dark);">${m[k]}</th>`).join('')}</tr>`;
            }
        }

        function renderDispatchReconciliation() {
            if (window.agGrid && document.getElementById('dispatchAgGrid')) {
                return renderDispatchReconciliationAgGrid();
            }
            const poNo = document.getElementById('dispatchPoSelect').value;
            const unifiedHead = document.getElementById('dispatchUnifiedHead');
            const unifiedTbody = document.getElementById('dispatchUnifiedBody');
            const hint = document.getElementById('dispatchSummaryHint');
            const searchQ = (document.getElementById('dispatchSearch')?.value || '').trim().toLowerCase();
            updateDispatchTableSizing();
            dispatchViewState.selectedPoByClient[currentClient] = poNo;

            if (!poNo) {
                if (unifiedHead) {
                    unifiedHead.innerHTML = `<tr>
                        <th style="padding: 12px 16px; text-align: left; border-bottom: 1px solid var(--border-dark);">S. No.</th>
                        <th style="padding: 12px 16px; text-align: left; border-bottom: 1px solid var(--border-dark);">Bill No.</th>
                        <th style="padding: 12px 16px; text-align: left; border-bottom: 1px solid var(--border-dark);">Dated</th>
                        <th style="padding: 12px 16px; text-align: left; border-bottom: 1px solid var(--border-dark);">L.R. No.</th>
                        <th style="padding: 12px 16px; text-align: right; border-bottom: 1px solid var(--border-dark);">Bill Value</th>
                        <th style="padding: 12px 16px; text-align: center; border-bottom: 1px solid var(--border-dark);">Action</th>
                    </tr>`;
                }
                unifiedTbody.innerHTML = `<tr><td colspan="6" style="text-align: center; padding: 20px; color: var(--text-muted);">Select a PO to view reconciliation.</td></tr>`;
                if (hint) hint.innerText = 'Select a PO';
                setDispatchSnapshot();
                return;
            }

            const terms = appData[currentClient].poTerms[poNo] || {};
            const baselineItems = terms.baselineItems || [];
            const baselineCandidates = baselineItems.map(b => b.description || '');

            const dispatchedMap = {};
            const summaryRowsData = [];
            const invoiceMaterialMap = {};

            const poInvoices = appData[currentClient].invoices.filter(i => i.poNo === poNo && !i.isNote);
            poInvoices.sort((a, b) => new Date(a.invDate || '9999-12-31') - new Date(b.invDate || '9999-12-31'));
            let dispatchLineCount = 0;

            // Build per-invoice and consolidated material maps.
            poInvoices.forEach(inv => {
                invoiceMaterialMap[inv.id] = {};
                if (inv.dispatchItems && inv.dispatchItems.length > 0) {
                    inv.dispatchItems.forEach((item) => {
                        const rowText = `${inv.invDate || ''} ${inv.id || ''} ${item.description || ''} ${inv.lrNo || ''}`.toLowerCase();
                        if (searchQ && !rowText.includes(searchQ)) return;
                        // Use exact normalized dispatch description key to avoid cross-material over-aggregation.
                        // Fuzzy matching can incorrectly merge distinct rows (e.g., 3-3 and 3-4 bricks) into one key.
                        let descKey = normalizeDispatchDesc(item.description || '');
                        if (!dispatchedMap[descKey]) {
                            dispatchedMap[descKey] = { qty: 0, uom: item.uom || 'Nos', rawName: item.description };
                        }
                        dispatchedMap[descKey].qty += (parseFloat(item.qty) || 0);
                        invoiceMaterialMap[inv.id][descKey] = (invoiceMaterialMap[inv.id][descKey] || 0) + (parseFloat(item.qty) || 0);
                        dispatchLineCount += 1;
                    });
                }
            });

            let summaryKeys = new Set([
                ...baselineItems.map(b => normalizeDispatchDesc(b.description)),
                ...Object.keys(dispatchedMap)
            ]);

            let totalOrdered = 0;
            let totalDispatched = 0;
            let totalPending = 0;
            let bricksOrdered = 0;
            let bricksDispatched = 0;
            let bricksPending = 0;
            let castOrdered = 0;
            let castDispatched = 0;
            let castPending = 0;
            summaryKeys.forEach(key => {
                let base = baselineItems.find(b => normalizeDispatchDesc(b.description) === key);
                let disp = dispatchedMap[key] || { qty: 0, uom: base ? base.uom : '-', rawName: key };
                let displayDesc = base ? base.description : disp.rawName;

                let orderedNum = base ? (base.ordered_qty || 0) : 0;
                let inspectedNum = base ? (base.inspected_qty || 0) : 0;

                let pendingQty = base ? Math.max(0, (orderedNum - disp.qty)) : '-';
                totalOrdered += Number(orderedNum || 0);
                totalDispatched += Number(disp.qty || 0);
                if (pendingQty !== '-') totalPending += Number(pendingQty || 0);
                summaryRowsData.push({
                    description: displayDesc,
                    uom: (base ? base.uom : disp.uom) || 'Nos',
                    material_type: (base && base.material_type) ? String(base.material_type) : null,
                    dispatch_alias: (base && base.dispatch_alias) ? String(base.dispatch_alias) : null,
                    dispatch_rate: Number((base && base.dispatch_rate) ? base.dispatch_rate : 0),
                    ordered: Number(orderedNum || 0),
                    dispatched: Number(disp.qty || 0),
                    inspected: Number(inspectedNum || 0),
                    pending: pendingQty === '-' ? 0 : Number(pendingQty || 0)
                });
                const descNorm = normalizeDispatchDesc(displayDesc || '');
                const mt = ((base && base.material_type) ? String(base.material_type).toLowerCase() : '');
                const isBrick = mt ? mt === 'brick' : /\bbrick(s)?\b/.test(descNorm);
                const o = Number(orderedNum || 0);
                const d = Number(disp.qty || 0);
                const p = pendingQty === '-' ? 0 : Number(pendingQty || 0);
                if (isBrick) {
                    bricksOrdered += o; bricksDispatched += d; bricksPending += p;
                } else {
                    castOrdered += o; castDispatched += d; castPending += p;
                }
            });
            const primaryColCount = 6; // S.No, Bill, Dated, LR, Truck, Bill Value
            const actionColIndex = primaryColCount + summaryRowsData.length;
            if (unifiedHead) {
                const sortIcon = (key) => dispatchSheetState.sortKey === key ? (dispatchSheetState.sortAsc ? '▲' : '▼') : '⇅';
                unifiedHead.innerHTML = `
                    <tr>
                        <th class="fixed-col fixed-col-0" rowspan="3" style="${getDispatchColStyle(0, 60)} text-align:left; white-space:nowrap;">S. No.</th>
                        <th class="fixed-col fixed-col-1" rowspan="3" style="${getDispatchColStyle(1, 110)} text-align:left; white-space:nowrap;">Bill No.<button class="header-filter-btn" title="Sort Bill No." onclick="dispatchSortBy('bill_no')">${sortIcon('bill_no')}</button><button class="header-filter-btn" title="Filter Bill No." onclick="dispatchFilterBy('bill_no')">⌄</button></th>
                        <th class="fixed-col fixed-col-2" rowspan="3" style="${getDispatchColStyle(2, 96)} text-align:left; white-space:nowrap;">Dated<button class="header-filter-btn" title="Sort Date" onclick="dispatchSortBy('dated')">${sortIcon('dated')}</button><button class="header-filter-btn" title="Filter Date" onclick="dispatchFilterBy('dated')">⌄</button></th>
                        <th rowspan="3" style="${getDispatchColStyle(3, 96)} text-align:left; white-space:nowrap;">L.R.No.</th>
                        <th rowspan="3" style="${getDispatchColStyle(4, 96)} text-align:left; white-space:nowrap;">Truck No.<button class="header-filter-btn" title="Filter Truck No." onclick="dispatchFilterBy('truck_no')">⌄</button></th>
                        <th rowspan="3" style="${getDispatchColStyle(5, 108)} text-align:right; white-space:nowrap;">Bill Value</th>
                        ${summaryRowsData.map((r, matIdx) => `<th colspan="1" style="${getDispatchColStyle(matIdx + primaryColCount, 140)} text-align:left; min-width:140px; white-space:pre-wrap; overflow-wrap:anywhere; word-break:break-word; vertical-align:top;">
                        <div class="dispatch-material-th-inner">
                            <div class="material-type-row">
                                <select class="dispatch-material-type-select"
                                        title="Set material family for KPI split"
                                        data-po-no="${escHtml(poNo || '')}"
                                        data-description="${escHtml(r.description || '')}"
                                        data-uom="${escHtml(r.uom || 'Nos')}"
                                        onchange="setSummaryMaterialTypeFromSelect(this)">
                                    <option value="" ${!r.material_type ? 'selected' : ''}>Auto</option>
                                    <option value="brick" ${(r.material_type || '').toLowerCase() === 'brick' ? 'selected' : ''}>Brick</option>
                                    <option value="castable_mortar" ${(r.material_type || '').toLowerCase() === 'castable_mortar' ? 'selected' : ''}>Castable/Mortar</option>
                                </select>
                            </div>
                            <div class="material-desc-block">
                                <span contenteditable="true"
                                      data-summary-desc-inline="1"
                                      data-po-no="${escHtml(poNo || '')}"
                                      data-description="${escHtml(r.description || '')}"
                                      data-uom="${escHtml(r.uom || 'Nos')}"
                                      data-original="${escHtml(r.description || '')}"
                                      onkeydown="handleDispatchInlineEditKeydown(event, this)"
                                      onblur="saveSummaryDescriptionInline(this)"
                                      style="display:inline-block; min-width:80px; border-bottom:1px dashed rgba(37,99,235,0.35); outline:none;">${escHtml(r.description).replace(/\n/g, '<br>')}</span>
                                <span style="font-size:0.72rem; color:var(--text-muted);">${escHtml(r.uom || 'Nos')}</span>
                                <button class="btn-outline btn-sm"
                                        style="padding:2px 6px; margin-top:4px;"
                                        title="Set auto-alias for invoice upload matching"
                                        data-po-no="${escHtml(poNo || '')}"
                                        data-description="${escHtml(r.description || '')}"
                                        data-uom="${escHtml(r.uom || 'Nos')}"
                                        data-alias="${escHtml(r.dispatch_alias || '')}"
                                        onclick="setSummaryDispatchAliasFromButton(this)">
                                    Alias: ${escHtml((r.dispatch_alias || 'None'))}
                                </button>
                            </div>
                            <div class="material-remove-row">
                                <button class="dispatch-remove-col-btn"
                                        title="Remove material column"
                                        aria-label="Remove material column"
                                        data-po-no="${escHtml(poNo || '')}"
                                        data-description="${escHtml(r.description || '')}"
                                        data-uom="${escHtml(r.uom || 'Nos')}"
                                        onclick="deleteSummaryColumnFromButton(this)">🗑</button>
                            </div>
                        </div>
                    </th>`).join('')}
                        <th rowspan="3" style="${getDispatchColStyle(actionColIndex, 96)} text-align:center;">Action</th>
                    </tr>
                    <tr>
                        ${summaryRowsData.map((r, matIdx) => `<th style="${getDispatchColStyle(matIdx + primaryColCount, 140)} text-align:right; color:#111827; font-weight:700;">Ordered Qty: ${formatNum(r.ordered || 0, 2)}</th>`).join('')}
                    </tr>
                    <tr>
                        ${summaryRowsData.map((r, matIdx) => `<th style="${getDispatchColStyle(matIdx + primaryColCount, 140)} text-align:right; color:#111827; font-weight:700;">Inspected Qty: ${formatNum(r.inspected || 0, 2)}</th>`).join('')}
                    </tr>`;
            }

            let unifiedHtml = '';

            const filteredInvoices = poInvoices.filter(inv => {
                if (!searchQ) return true;
                const rowText = `${inv.invDate || ''} ${inv.id || ''} ${inv.lrNo || ''} ${inv.truckNo || inv.lrNo || ''}`.toLowerCase();
                return rowText.includes(searchQ) || Object.keys(invoiceMaterialMap[inv.id] || {}).some(k => (k || '').includes(searchQ));
            });

            if (dispatchSheetState.filterBillNo) {
                const target = dispatchSheetState.filterBillNo.toLowerCase();
                filteredInvoices.splice(0, filteredInvoices.length, ...filteredInvoices.filter(inv => String(inv.id || '').toLowerCase().includes(target)));
            }
            if (dispatchSheetState.filterDated) {
                const target = dispatchSheetState.filterDated.toLowerCase();
                filteredInvoices.splice(0, filteredInvoices.length, ...filteredInvoices.filter(inv => String(inv.invDate || '').toLowerCase().includes(target)));
            }
            if (dispatchSheetState.filterTruckNo) {
                const target = dispatchSheetState.filterTruckNo.toLowerCase();
                filteredInvoices.splice(0, filteredInvoices.length, ...filteredInvoices.filter(inv => String(inv.truckNo || inv.lrNo || '').toLowerCase().includes(target)));
            }
            if (dispatchSheetState.sortKey) {
                const key = dispatchSheetState.sortKey;
                const asc = dispatchSheetState.sortAsc ? 1 : -1;
                filteredInvoices.sort((a, b) => {
                    const va = key === 'bill_no' ? String(a.id || '') : (key === 'dated' ? String(a.invDate || '') : String(a.truckNo || ''));
                    const vb = key === 'bill_no' ? String(b.id || '') : (key === 'dated' ? String(b.invDate || '') : String(b.truckNo || ''));
                    if (va < vb) return -1 * asc;
                    if (va > vb) return 1 * asc;
                    return 0;
                });
            }

            filteredInvoices.forEach((inv, idx) => {
                const billNo = esc(inv.id || '-');
                const date = inv.invDate || '';
                const lr = inv.lrNo || '';
                const truck = inv.truckNo || inv.lrNo || '';
                const billVal = Number(inv.total || 0);
                const cells = summaryRowsData.map((r, matIdx) => {
                    const key = normalizeDispatchDesc(r.description || '');
                    const val = Number((invoiceMaterialMap[inv.id] || {})[key] || 0);
                    return `<td style="${getDispatchColStyle(matIdx + primaryColCount, 120)} padding:6px 10px; text-align:right; font-weight:${val > 0 ? '800' : '600'}; color:${val > 0 ? 'var(--brand-primary)' : 'var(--text-muted)'}; background:${val > 0 ? 'rgba(37, 99, 235, 0.08)' : 'transparent'};">
                        <span contenteditable="true"
                              data-dispatch-inline="1"
                              data-invoice-no="${esc(inv.id || '')}"
                              data-description="${esc(r.description || '')}"
                              data-uom="${esc(r.uom || 'Nos')}"
                              data-original="${val}"
                              onkeydown="handleDispatchInlineEditKeydown(event, this)"
                              onblur="saveDispatchInlineCell(this)"
                              style="display:inline-block; min-width:64px; text-align:right; border-bottom:1px dashed rgba(37,99,235,0.35); padding:0 2px; outline:none;">${formatNum(val, 2)}</span>
                    </td>`;
                }).join('');
                unifiedHtml += `<tr data-row-key="invoice_${esc(inv.id || idx)}" data-invoice-no="${esc(inv.id || '')}" style="${getDispatchRowStyle(`invoice_${inv.id || idx}`)} border-bottom:1px solid var(--border);">
                    <td class="fixed-col fixed-col-0" style="${getDispatchColStyle(0, 60)} padding:6px 8px;">${idx + 1}</td>
                    <td class="fixed-col fixed-col-1" style="${getDispatchColStyle(1, 110)} padding:6px 8px; font-weight:700;">${billNo}</td>
                    <td class="fixed-col fixed-col-2" style="${getDispatchColStyle(2, 86)} padding:6px 8px;"><span contenteditable="true" data-invoice-inline="1" data-invoice-no="${esc(inv.id || '')}" data-field="inv_date" data-original="${esc(date)}" onkeydown="handleDispatchInlineEditKeydown(event, this)" onblur="saveDispatchInvoiceInlineCell(this)" style="display:inline-block; min-width:72px; border-bottom:1px dashed rgba(37,99,235,0.35); outline:none;">${esc(date || '')}</span></td>
                    <td class="fixed-col fixed-col-3" style="${getDispatchColStyle(3, 90)} padding:6px 8px; font-family:monospace;"><span contenteditable="true" data-invoice-inline="1" data-invoice-no="${esc(inv.id || '')}" data-field="lr_no" data-original="${esc(lr)}" onkeydown="handleDispatchInlineEditKeydown(event, this)" onblur="saveDispatchInvoiceInlineCell(this)" style="display:inline-block; min-width:76px; border-bottom:1px dashed rgba(37,99,235,0.35); outline:none;">${esc(lr || '')}</span></td>
                    <td class="fixed-col fixed-col-4" style="${getDispatchColStyle(4, 96)} padding:6px 8px; font-family:monospace;"><span contenteditable="true" data-invoice-inline="1" data-invoice-no="${esc(inv.id || '')}" data-field="truck_no" data-original="${esc(truck)}" onkeydown="handleDispatchInlineEditKeydown(event, this)" onblur="saveDispatchInvoiceInlineCell(this)" style="display:inline-block; min-width:76px; border-bottom:1px dashed rgba(37,99,235,0.35); outline:none;">${esc(truck || '')}</span></td>
                    <td class="fixed-col fixed-col-5" style="${getDispatchColStyle(5, 108)} padding:6px 8px; text-align:right; font-weight:700;"><span contenteditable="true" data-invoice-inline="1" data-invoice-no="${esc(inv.id || '')}" data-field="total" data-original="${billVal}" onkeydown="handleDispatchInlineEditKeydown(event, this)" onblur="saveDispatchInvoiceInlineCell(this)" style="display:inline-block; min-width:70px; text-align:right; border-bottom:1px dashed rgba(37,99,235,0.35); outline:none;">${formatNum(billVal, 2)}</span></td>
                    ${cells}
                    <td class="fixed-col fixed-col-6" style="${getDispatchColStyle(actionColIndex, 96)} padding:6px 8px; text-align:center;">
                        <button class="btn-outline btn-sm text-danger" style="height:24px; padding:0 8px;" onclick="deleteDispatchMatrixRow('${encodeURIComponent(inv.id || '')}')">Del Row</button>
                        </td>
                </tr>`;
            });

            const totalDispatchedRow = `<tr class="pinned-footer-row" data-row-key="footer_dispatched" style="${getDispatchRowStyle('footer_dispatched')} background:#f8fafc; border-top:2px solid var(--border-dark);">
                <td class="fixed-col fixed-col-0" colspan="5" style="padding:10px 14px; font-weight:900; color:var(--brand-primary);">TOTAL DESPATCHED QUANTITY (Nos.)</td>
                ${summaryRowsData.map((r, matIdx) => `<td style="${getDispatchColStyle(matIdx + primaryColCount, 120)} padding:6px 10px; text-align:right; font-weight:900; color:var(--brand-primary);">${formatNum(r.dispatched || 0, 2)}</td>`).join('')}
                <td style="${getDispatchColStyle(actionColIndex, 96)} padding:10px 14px;"></td>
            </tr>`;
            const totalBalanceRow = `<tr class="pinned-footer-row balance" data-row-key="footer_balance" style="${getDispatchRowStyle('footer_balance')} background:#fff7ed; border-top:1px solid #fed7aa;">
                <td class="fixed-col fixed-col-0" colspan="5" style="padding:10px 14px; font-weight:900; color:var(--danger);">TOTAL BALANCE QUANTITY (Nos.)</td>
                ${summaryRowsData.map((r, matIdx) => `<td style="${getDispatchColStyle(matIdx + primaryColCount, 120)} padding:6px 10px; text-align:right; font-weight:900; color:var(--danger);">${formatNum(r.pending || 0, 2)}</td>`).join('')}
                <td style="${getDispatchColStyle(actionColIndex, 96)} padding:10px 14px;"></td>
            </tr>`;
            unifiedHtml += totalDispatchedRow + totalBalanceRow;

            unifiedTbody.innerHTML = unifiedHtml || `<tr><td colspan="6" style="text-align:center; padding:20px;">No ordered or dispatched items found.</td></tr>`;
            if (hint) hint.innerText = `PO ${poNo} • ${poInvoices.length} invoices`;
            updateDispatchAggregate(summaryRowsData);
            setDispatchSnapshot({
                ordered: totalOrdered,
                dispatched: totalDispatched,
                pending: totalPending,
                invoices: poInvoices.length,
                bricksOrdered,
                bricksDispatched,
                bricksPending,
                castOrdered,
                castDispatched,
                castPending
            });
            attachDispatchSpreadsheetResizers();
            enhanceDispatchSpreadsheetInteractions();
            requestAnimationFrame(updateDispatchStickyOffsets);
        }

        async function dispatchGridSaveInvoiceInline(invoiceNo, field, value, oldValue) {
            const token = sessionStorage.getItem('erp_token');
            const payload = {};
            if (field === 'inv_date') payload.inv_date = value || null;
            else if (field === 'lr_no') payload.lr_no = value || '';
            else if (field === 'truck_no') payload.lr_no = value || '';
            else if (field === 'total') payload.total = Number(value || 0);
            else return true;
            const response = await fetch(`/api/invoices/${encodeURIComponent(invoiceNo)}/inline`, {
                method: 'PATCH',
                headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
                body: JSON.stringify(payload)
            });
            if (!response.ok) throw new Error((await response.json().catch(() => ({}))).detail || 'Failed to save invoice cell');
            return true;
        }

        async function dispatchGridSaveMaterialCell(invoiceNo, material, qty) {
            const token = sessionStorage.getItem('erp_token');
            const response = await fetch('/api/dispatch-items/upsert-cell', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
                body: JSON.stringify({
                    invoice_no: invoiceNo,
                    description: material.description,
                    uom: material.uom || 'Nos',
                    qty: Number(qty || 0)
                })
            });
            if (!response.ok) throw new Error((await response.json().catch(() => ({}))).detail || 'Failed to save dispatch quantity');
            return true;
        }

        async function dispatchGridSaveMaterialBaseline(poNo, material, metricKey, value) {
            if (!currentClient || !appData[currentClient]) return false;
            const poTerms = appData[currentClient].poTerms || {};
            if (!poTerms[poNo]) poTerms[poNo] = { baselineItems: [] };
            const items = poTerms[poNo].baselineItems || [];
            const norm = normalizeDispatchDesc(material.description || '');
            const uomKey = String(material.uom || 'Nos').trim().toUpperCase();
            let idx = items.findIndex(i => normalizeDispatchDesc(i.description || '') === norm && String(i.uom || 'Nos').trim().toUpperCase() === uomKey);
            if (idx < 0) {
                items.push({
                    description: material.description || '',
                    ordered_qty: 0,
                    inspected_qty: 0,
                    uom: material.uom || 'Nos',
                    material_type: null,
                    dispatch_alias: null,
                    dispatch_rate: 0
                });
                idx = items.length - 1;
            }
            const updated = items.map(i => ({ ...i }));
            if (metricKey === 'ordered') updated[idx].ordered_qty = Math.max(0, Number(value || 0));
            else if (metricKey === 'inspected') updated[idx].inspected_qty = Math.max(0, Number(value || 0));
            else if (metricKey === 'rate') updated[idx].dispatch_rate = Math.max(0, Number(value || 0));
            poTerms[poNo].baselineItems = updated;
            await persistSummaryBaseline(poNo, updated);
            return true;
        }

        function dispatchGridCellStyle(params) {
            const key = `${params.node?.id || params.rowIndex}:${params.column?.getColId?.() || params.colDef?.field || ''}`;
            if (dispatchGridState.formattedCells.has(key)) {
                return { backgroundColor: '#fff7ed', border: '1px solid #fdba74' };
            }
            return null;
        }

        function dispatchGridFormatCell(params) {
            if (!params || !params.node || !params.column) return;
            const key = `${params.node.id}:${params.column.getColId()}`;
            if (dispatchGridState.formattedCells.has(key)) dispatchGridState.formattedCells.delete(key);
            else dispatchGridState.formattedCells.add(key);
            params.api.refreshCells({ force: true });
        }

        function dispatchGridContextMenuItems(params) {
            const row = params?.node?.data || {};
            const invoiceNo = String(row.invoice_no || '').trim();
            return [
                {
                    name: 'Insert Row',
                    action: () => addManualDispatchNewEntry()
                },
                {
                    name: 'Delete Row',
                    disabled: !invoiceNo,
                    action: () => {
                        if (!invoiceNo) return;
                        deleteDispatchMatrixRow(encodeURIComponent(invoiceNo));
                    }
                },
                {
                    name: 'Format Cells',
                    action: () => dispatchGridFormatCell(params)
                },
                'separator',
                'copy',
                'paste'
            ];
        }

        function rememberDispatchGridLayout(poNo, api) {
            if (!poNo || !api?.getColumnState) return;
            const state = api.getColumnState() || [];
            if (!state.length) return;
            const compact = state.map((s) => ({
                colId: s.colId,
                width: s.width,
                pinned: s.pinned || null,
                hide: !!s.hide
            }));
            dispatchGridState.layoutByPo[poNo] = compact;
            const clientKey = String(currentClient || '').trim();
            if (clientKey) {
                const storageKey = `dispatchGridLayout:${clientKey}:${poNo}`;
                try {
                    localStorage.setItem(storageKey, JSON.stringify(compact));
                } catch (_) {
                    // Ignore quota/privacy errors; memory cache still works.
                }
            }
        }

        function restoreDispatchGridLayout(poNo, api) {
            if (!poNo || !api?.applyColumnState) return;
            let saved = dispatchGridState.layoutByPo[poNo];
            if ((!Array.isArray(saved) || !saved.length) && currentClient) {
                const storageKey = `dispatchGridLayout:${currentClient}:${poNo}`;
                try {
                    const raw = localStorage.getItem(storageKey);
                    const parsed = raw ? JSON.parse(raw) : null;
                    if (Array.isArray(parsed) && parsed.length) {
                        saved = parsed;
                        dispatchGridState.layoutByPo[poNo] = parsed;
                    }
                } catch (_) {
                    // Ignore corrupted/unavailable localStorage entries.
                }
            }
            if (!Array.isArray(saved) || !saved.length) return;
            try {
                api.applyColumnState({
                    state: saved,
                    applyOrder: false
                });
            } catch (_) {
                // Ignore mismatches when material column sets change across POs.
            }
        }

        function ensureDispatchAgGrid() {
            if (dispatchGridState.gridApi) return dispatchGridState.gridApi;
            const gridEl = document.getElementById('dispatchAgGrid');
            if (!gridEl || !window.agGrid) return null;
            if (!window.DispatchMaterialGroupHeader) {
                window.DispatchMaterialGroupHeader = class {
                    init(params) {
                        this.params = params;
                        const meta = params?.columnGroup?.getColGroupDef?.()?.headerGroupComponentParams || {};
                        const wrap = document.createElement('div');
                        wrap.style.display = 'flex';
                        wrap.style.flexDirection = 'column';
                        wrap.style.gap = '4px';
                        wrap.style.padding = '2px 0';
                        wrap.style.minWidth = '0';

                        const title = document.createElement('div');
                        title.style.fontWeight = '700';
                        title.style.fontSize = '0.72rem';
                        title.style.whiteSpace = 'normal';
                        title.style.wordBreak = 'break-word';
                        title.style.lineHeight = '1.2';
                        title.textContent = meta.description || params.displayName || 'Material';
                        wrap.appendChild(title);

                        const controls = document.createElement('div');
                        controls.style.display = 'flex';
                        controls.style.alignItems = 'center';
                        controls.style.gap = '4px';

                        const sel = document.createElement('select');
                        sel.style.fontSize = '0.68rem';
                        sel.style.height = '22px';
                        sel.style.minWidth = '132px';
                        sel.style.padding = '0 20px 0 6px';
                        sel.style.border = '1px solid #cbd5e1';
                        sel.style.borderRadius = '6px';
                        sel.style.background = '#ffffff';
                        sel.style.color = '#111827';
                        sel.style.fontWeight = '600';
                        sel.style.lineHeight = '1.2';
                        sel.innerHTML = `
                            <option value="" ${!meta.materialType ? 'selected' : ''}>Auto</option>
                            <option value="brick" ${String(meta.materialType || '').toLowerCase() === 'brick' ? 'selected' : ''}>Brick</option>
                            <option value="castable_mortar" ${String(meta.materialType || '').toLowerCase() === 'castable_mortar' ? 'selected' : ''}>Castable/Mortar</option>
                        `;
                        sel.onchange = () => {
                            setSummaryMaterialType(
                                encodeURIComponent(meta.poNo || ''),
                                encodeURIComponent(meta.description || ''),
                                encodeURIComponent(meta.uom || 'Nos'),
                                sel.value
                            );
                        };
                        controls.appendChild(sel);

                        const del = document.createElement('button');
                        del.type = 'button';
                        del.textContent = '🗑';
                        del.title = 'Delete material column';
                        del.style.border = '1px solid #e5e7eb';
                        del.style.background = '#fff';
                        del.style.borderRadius = '6px';
                        del.style.cursor = 'pointer';
                        del.style.height = '22px';
                        del.style.minWidth = '24px';
                        del.onclick = () => {
                            deleteSummaryColumn(
                                encodeURIComponent(meta.poNo || ''),
                                encodeURIComponent(meta.description || ''),
                                encodeURIComponent(meta.uom || 'Nos')
                            );
                        };
                        controls.appendChild(del);
                        wrap.appendChild(controls);
                        this.eGui = wrap;
                    }
                    getGui() { return this.eGui; }
                };
            }
            const options = {
                defaultColDef: {
                    sortable: true,
                    filter: true,
                    resizable: true,
                    editable: false,
                    wrapHeaderText: true,
                    autoHeaderHeight: true,
                    cellStyle: dispatchGridCellStyle
                },
                animateRows: true,
                rowSelection: 'single',
                suppressColumnVirtualisation: false,
                singleClickEdit: false,
                stopEditingWhenCellsLoseFocus: true,
                groupHeaderHeight: 108,
                headerHeight: 44,
                getContextMenuItems: dispatchGridContextMenuItems,
                onColumnResized: (e) => {
                    if (!e?.finished) return;
                    rememberDispatchGridLayout(dispatchGridState.currentPoNo, e.api);
                },
                components: {
                    DispatchMaterialGroupHeader: window.DispatchMaterialGroupHeader
                },
                getRowStyle: (params) => {
                    const t = params?.data?._rowType;
                    if (t === 'meta_rate') return { background: '#f5f3ff', fontWeight: 700, color: '#5b21b6' };
                    if (t === 'meta_ordered') return { background: '#f8fafc', fontWeight: 700, color: '#111827' };
                    if (t === 'meta_inspected') return { background: '#ecfeff', fontWeight: 700, color: '#0f766e' };
                    if (t === 'summary') return { background: '#f3f4f6', fontWeight: 800, color: '#111827' };
                    return null;
                },
                onCellFocused: (e) => {
                    const formula = document.getElementById('dispatchFormulaInput');
                    if (!formula || !e?.api || e.rowIndex == null || !e.column) return;
                    const row = e.api.getDisplayedRowAtIndex(e.rowIndex)?.data;
                    if (!row) return;
                    const field = e.column.getColDef().field;
                    formula.value = row[field] ?? '';
                },
                onCellValueChanged: async (e) => {
                    if (!e || e.newValue === e.oldValue) return;
                    const invoiceNo = e.data.invoice_no;
                    const field = e.colDef.field;
                    try {
                        if (field && field.startsWith('mat_qty__') && e.data?._rowType === 'invoice') {
                            const material = dispatchGridState.materialByField[field];
                            if (!material) return;
                            await dispatchGridSaveMaterialCell(invoiceNo, material, Number(e.newValue || 0));
                        } else if (field && field.startsWith('mat_qty__') && e.data?._rowType === 'meta_ordered') {
                            const material = dispatchGridState.materialByField[field];
                            if (!material) return;
                            await dispatchGridSaveMaterialBaseline(dispatchGridState.currentPoNo, material, 'ordered', Number(e.newValue || 0));
                        } else if (field && field.startsWith('mat_qty__') && e.data?._rowType === 'meta_inspected') {
                            const material = dispatchGridState.materialByField[field];
                            if (!material) return;
                            await dispatchGridSaveMaterialBaseline(dispatchGridState.currentPoNo, material, 'inspected', Number(e.newValue || 0));
                        } else if (field && field.startsWith('mat_qty__') && e.data?._rowType === 'meta_rate') {
                            const material = dispatchGridState.materialByField[field];
                            if (!material) return;
                            await dispatchGridSaveMaterialBaseline(dispatchGridState.currentPoNo, material, 'rate', Number(e.newValue || 0));
                        } else if (e.data?._rowType === 'invoice' && ['inv_date', 'lr_no', 'truck_no', 'total'].includes(field)) {
                            await dispatchGridSaveInvoiceInline(invoiceNo, field, e.newValue, e.oldValue);
                        } else {
                            return;
                        }
                        await silentDataRefresh();
                        renderDispatchReconciliationAgGrid();
                    } catch (err) {
                        customApplet({ title: "Save Error", message: err.message || "Failed to save cell value." });
                        e.node.setDataValue(field, e.oldValue);
                    }
                }
            };
            dispatchGridState.gridApi = agGrid.createGrid(gridEl, options);
            return dispatchGridState.gridApi;
        }

        function renderDispatchReconciliationAgGrid() {
            const api = ensureDispatchAgGrid();
            if (!api) return;
            const poNo = (document.getElementById('dispatchPoSelect')?.value || '').trim();
            dispatchGridState.currentPoNo = poNo;
            const hint = document.getElementById('dispatchSummaryHint');
            const searchQ = (document.getElementById('dispatchSearch')?.value || '').trim().toLowerCase();
            const oldTable = document.getElementById('dispatchUnifiedTable');
            if (oldTable) oldTable.closest('div').style.display = 'none';
            const formulaInput = document.getElementById('dispatchFormulaInput');
            if (formulaInput && !formulaInput.dataset.boundAg) {
                formulaInput.dataset.boundAg = '1';
                formulaInput.addEventListener('keydown', (e) => {
                    if (e.key !== 'Enter') return;
                    const focused = api.getFocusedCell();
                    if (!focused) return;
                    e.preventDefault();
                    api.startEditingCell({ rowIndex: focused.rowIndex, colKey: focused.column.getColId() });
                    const rowNode = api.getDisplayedRowAtIndex(focused.rowIndex);
                    if (rowNode) rowNode.setDataValue(focused.column.getColId(), formulaInput.value);
                    api.stopEditing();
                });
            }

            if (!poNo || !currentClient || !appData[currentClient]) {
                api.setGridOption('columnDefs', []);
                api.setGridOption('rowData', []);
                api.setGridOption('pinnedBottomRowData', []);
                if (hint) hint.innerText = 'Select a PO';
                setDispatchSnapshot();
                return;
            }

            const terms = appData[currentClient].poTerms[poNo] || {};
            const baselineItems = terms.baselineItems || [];
            const poInvoices = (appData[currentClient].invoices || []).filter(i => i.poNo === poNo && !i.isNote);
            poInvoices.sort((a, b) => new Date(a.invDate || '9999-12-31') - new Date(b.invDate || '9999-12-31'));

            const materialKeys = new Map();
            baselineItems.forEach((b) => {
                const key = normalizeDispatchDesc(b.description || '');
                if (!key) return;
                materialKeys.set(key, {
                    description: b.description || '',
                    uom: b.uom || 'Nos',
                    ordered: Number(b.ordered_qty || 0),
                    inspected: Number(b.inspected_qty || 0),
                    rate: Number(b.dispatch_rate || 0),
                    material_type: b.material_type || null
                });
            });
            poInvoices.forEach((inv) => {
                (inv.dispatchItems || []).forEach((it) => {
                    const key = normalizeDispatchDesc(it.description || '');
                    if (!key) return;
                    if (!materialKeys.has(key)) materialKeys.set(key, {
                        description: it.description || '',
                        uom: it.uom || 'Nos',
                        ordered: 0,
                        inspected: 0,
                        rate: Number(it.rate_per_uom || 0),
                        material_type: null
                    });
                });
            });
            const materialList = Array.from(materialKeys.values());
            dispatchGridState.materialByField = {};

            const rowData = poInvoices
                .filter(inv => {
                    const t = `${inv.id || ''} ${inv.invDate || ''} ${inv.lrNo || ''}`.toLowerCase();
                    return !searchQ || t.includes(searchQ);
                })
                .map((inv, idx) => {
                    const row = {
                        _rowType: 'invoice',
                        sno: idx + 1,
                        invoice_no: inv.id || '',
                        bill_no: inv.id || '',
                        inv_date: inv.invDate || '',
                        lr_no: inv.lrNo || '',
                        truck_no: inv.truckNo || inv.lrNo || '',
                        total: Number(inv.total || 0)
                    };
                    materialList.forEach((m) => {
                        const norm = normalizeDispatchDesc(m.description || '');
                        const key = `mat_qty__${norm}`;
                        const item = (inv.dispatchItems || []).find(d => normalizeDispatchDesc(d.description || '') === normalizeDispatchDesc(m.description || ''));
                        row[key] = Number(item?.qty || 0);
                    });
                    return row;
                });

            const colDefs = [
                { headerName: 'S. No.', field: 'sno', width: 80, pinned: 'left' },
                { headerName: 'Bill No.', field: 'bill_no', width: 130, pinned: 'left', filter: 'agTextColumnFilter' },
                { headerName: 'Dated', field: 'inv_date', width: 120, pinned: 'left', editable: true, filter: 'agTextColumnFilter' },
                { headerName: 'L.R.No.', field: 'lr_no', width: 120, editable: true },
                { headerName: 'Truck No.', field: 'truck_no', width: 120, editable: true, filter: 'agTextColumnFilter' },
                { headerName: 'Bill Value', field: 'total', width: 130, editable: true, valueParser: p => Number(p.newValue || 0), type: 'numericColumn' }
            ];

            materialList.forEach((m) => {
                const norm = normalizeDispatchDesc(m.description || '');
                const qtyField = `mat_qty__${norm}`;
                const materialMeta = { description: m.description, uom: m.uom || 'Nos' };
                dispatchGridState.materialByField[qtyField] = materialMeta;
                colDefs.push({
                    headerName: `${m.description || 'Material'} (${m.uom || 'Nos'})`,
                    headerTooltip: `${m.description || 'Material'} (${m.uom || 'Nos'})`,
                    headerGroupComponent: 'DispatchMaterialGroupHeader',
                    headerGroupComponentParams: {
                        description: m.description || 'Material',
                        uom: m.uom || 'Nos',
                        poNo,
                        materialType: m.material_type || null
                    },
                    marryChildren: true,
                    minWidth: 150,
                    children: [
                        {
                            headerName: '',
                            field: qtyField,
                            width: 150,
                            editable: (p) => ['invoice', 'meta_rate', 'meta_ordered', 'meta_inspected'].includes(p?.data?._rowType),
                            valueParser: p => Number(p.newValue || 0),
                            type: 'numericColumn'
                        }
                    ]
                });
            });

            colDefs.push({
                headerName: 'Action',
                field: 'action',
                width: 110,
                cellRenderer: (p) => {
                    if (p.data?._rowType !== 'invoice') return '';
                    return `<button class="btn-outline btn-sm text-danger" style="height:24px; padding:0 8px;" onclick="deleteDispatchMatrixRow('${encodeURIComponent(p.data.invoice_no || '')}')">Del Row</button>`;
                }
            });

            const pinnedTopRate = { _rowType: 'meta_rate', bill_no: 'Rate / UOM', total: '' };
            const pinnedTopOrdered = { _rowType: 'meta_ordered', bill_no: 'Ordered Qty', total: '' };
            const pinnedTopInspected = { _rowType: 'meta_inspected', bill_no: 'Inspected Qty', total: '' };

            const totalsDispatched = { _rowType: 'summary', bill_no: 'TOTAL DESPATCHED QUANTITY', total: '' };
            const totalsBalance = { _rowType: 'summary', bill_no: 'TOTAL BALANCE QUANTITY', total: '' };
            materialList.forEach((m) => {
                const norm = normalizeDispatchDesc(m.description || '');
                const qtyField = `mat_qty__${norm}`;
                const dispatched = rowData.reduce((s, r) => s + Number(r[qtyField] || 0), 0);
                pinnedTopRate[qtyField] = Number(m.rate || 0);
                pinnedTopOrdered[qtyField] = Number(m.ordered || 0);
                pinnedTopInspected[qtyField] = Number(m.inspected || 0);
                totalsDispatched[qtyField] = dispatched;
                totalsBalance[qtyField] = Math.max(0, Number(m.ordered || 0) - dispatched);
            });

            api.setGridOption('columnDefs', colDefs);
            api.setGridOption('rowData', rowData);
            api.setGridOption('pinnedTopRowData', [pinnedTopRate, pinnedTopOrdered, pinnedTopInspected]);
            api.setGridOption('pinnedBottomRowData', [totalsDispatched, totalsBalance]);
            restoreDispatchGridLayout(poNo, api);
            if (hint) hint.innerText = `PO ${poNo} • ${rowData.length} invoices`;

            const totalOrdered = materialList.reduce((s, m) => s + Number(m.ordered || 0), 0);
            const totalDispatched = materialList.reduce((s, m) => s + Number(totalsDispatched[`mat_qty__${normalizeDispatchDesc(m.description || '')}`] || 0), 0);
            const totalPending = materialList.reduce((s, m) => s + Number(totalsBalance[`mat_qty__${normalizeDispatchDesc(m.description || '')}`] || 0), 0);
            setDispatchSnapshot({
                ordered: totalOrdered,
                dispatched: totalDispatched,
                pending: totalPending,
                invoices: rowData.length
            });
        }

        async function deleteDispatchEntry(invoiceNo, dispatchItemId) {
            return withInFlight(`deleteDispatchEntry:${dispatchItemId}`, async () => {
                if (!dispatchItemId) return await customApplet({ title: "Not Available", message: "This dispatch row cannot be deleted because it has no database id. Refresh data and retry." });
                const conf = await customApplet({
                    title: "Delete Dispatch Entry",
                    message: `Delete dispatch line from invoice ${invoiceNo}? This will remove only this line item from dispatch history.`,
                    type: "confirm"
                });
                if (!conf) return;
                const token = sessionStorage.getItem('erp_token');
                const response = await fetch(`/api/dispatch-items/${dispatchItemId}`, {
                    method: 'DELETE',
                    headers: { 'Authorization': 'Bearer ' + token }
                });
                const result = await response.json().catch(() => ({}));
                if (!response.ok) {
                    return await customApplet({ title: "Database Error", message: result.detail || "Failed to delete dispatch entry." });
                }
                await silentDataRefresh();
                renderDispatchReconciliation();
            });
        }

        async function openInvoiceLineEditor(invoiceNoEnc) {
            const invoiceNo = decodeURIComponent(String(invoiceNoEnc || ''));
            if (!invoiceNo || !currentClient || !appData[currentClient]) return;
            const inv = (appData[currentClient].invoices || []).find(i => i.id === invoiceNo);
            if (!inv || !Array.isArray(inv.dispatchItems) || !inv.dispatchItems.length) {
                return customApplet({ title: "No Dispatch Lines", message: `No editable dispatch lines found for invoice ${invoiceNo}.` });
            }
            const lines = inv.dispatchItems
                .filter(it => it && it.id)
                .map((it, idx) => `${idx + 1}. ${it.description || 'Material'} | Qty: ${formatNum(it.qty || 0, 2)} ${it.uom || 'Nos'}`);
            const pick = await customApplet({
                title: "Select Dispatch Line",
                message: `Enter line number to edit for invoice ${invoiceNo}:\n\n${lines.join('\n')}`,
                type: "prompt",
                placeholder: "1"
            });
            if (pick === null) return;
            const idx = Math.max(1, parseInt(String(pick || '0'), 10)) - 1;
            const item = inv.dispatchItems[idx];
            if (!item || !item.id) return customApplet({ title: "Invalid Selection", message: "Please enter a valid line number." });
            return editDispatchEntry(invoiceNo, item.id, item.description || '', Number(item.qty || 0), Number(item.inspected_qty || 0), item.uom || 'Nos');
        }

        async function saveDispatchInvoiceInlineCell(el) {
            return withInFlight(`saveDispatchInvoiceInline:${el?.getAttribute?.('data-invoice-no') || ''}:${el?.getAttribute?.('data-field') || ''}`, async () => {
            if (!el || !el.getAttribute || !el.getAttribute('data-invoice-inline')) return;
            const invoiceNo = (el.getAttribute('data-invoice-no') || '').trim();
            const field = (el.getAttribute('data-field') || '').trim();
            const original = String(el.getAttribute('data-original') || '');
            let raw = String(el.innerText || '').trim();
            if (!invoiceNo || !field) return;

            const payload = {};
            if (field === 'inv_date') {
                if (raw && !/^\d{4}-\d{2}-\d{2}$/.test(raw)) {
                    el.innerText = original;
                    return customApplet({ title: "Validation Error", message: "Date must be in YYYY-MM-DD format." });
                }
                if (raw === original) return;
                payload.inv_date = raw || null;
            } else if (field === 'lr_no') {
                if (raw === original) return;
                payload.lr_no = raw;
            } else if (field === 'truck_no') {
                if (raw === original) return;
                // Backend schema currently persists transport reference in lr_no.
                payload.lr_no = raw;
            } else if (field === 'total') {
                const parsed = parseFloat(raw.replace(/,/g, ''));
                const orig = parseFloat(original || '0');
                if (!Number.isFinite(parsed) || parsed < 0) {
                    el.innerText = formatNum(orig || 0, 2);
                    return customApplet({ title: "Validation Error", message: "Enter a valid non-negative bill value." });
                }
                const fixed = Number(parsed.toFixed(2));
                if (Math.abs(fixed - (orig || 0)) < 0.000001) return;
                payload.total = fixed;
            } else {
                return;
            }

            const token = sessionStorage.getItem('erp_token');
            try {
                const response = await fetch(`/api/invoices/${encodeURIComponent(invoiceNo)}/inline`, {
                    method: 'PATCH',
                    headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
                    body: JSON.stringify(payload)
                });
                const result = await response.json().catch(() => ({}));
                if (!response.ok) {
                    if (field === 'total') el.innerText = formatNum(parseFloat(original || '0') || 0, 2);
                    else el.innerText = original;
                    return customApplet({ title: "Database Error", message: result.detail || "Failed to save invoice inline change." });
                }
                if (field === 'total') {
                    const val = Number(payload.total || 0);
                    el.setAttribute('data-original', String(val));
                    el.innerText = formatNum(val, 2);
                } else {
                    el.setAttribute('data-original', String(raw || ''));
                }
                await silentDataRefresh();
                renderDispatchReconciliation();
            } catch (_) {
                if (field === 'total') el.innerText = formatNum(parseFloat(original || '0') || 0, 2);
                else el.innerText = original;
            }
            });
        }

        function handleDispatchInlineEditKeydown(event, el) {
            if (event.key === 'Enter') {
                event.preventDefault();
                if (el && el.getAttribute && el.getAttribute('data-summary-desc-inline')) {
                    return saveSummaryDescriptionInline(el);
                }
                el.blur();
            } else if (event.key === 'Escape') {
                event.preventDefault();
                const originalRaw = String(el.getAttribute('data-original') || '');
                if (/^-?\d+(\.\d+)?$/.test(originalRaw)) el.innerText = formatNum(Number(originalRaw), 2);
                else el.innerText = originalRaw;
                el.blur();
            }
        }

        function decodeHtmlEntities(text) {
            const t = document.createElement('textarea');
            t.innerHTML = String(text || '');
            return t.value;
        }

        function updateDispatchTableSizing() {
            const tbl = document.getElementById('dispatchUnifiedTable');
            if (!tbl) return;
            tbl.style.setProperty('--dispatch-col-width', '84px');
            tbl.style.setProperty('--dispatch-row-pad-y', '6px');
            tbl.style.setProperty('--dispatch-table-zoom', '1');
        }

        function updateDispatchStickyOffsets() {
            const tbl = document.getElementById('dispatchUnifiedTable');
            const head = document.getElementById('dispatchUnifiedHead');
            if (!tbl || !head) return;
            const headRow = head.querySelector('tr');
            const headHeight = Math.max(44, Math.ceil((headRow || head).getBoundingClientRect().height || 0));
            const rateRow = tbl.querySelector('.pinned-meta-row-rate');
            const orderedRow = tbl.querySelector('.pinned-meta-row');
            const rateHeight = Math.max(36, Math.ceil(rateRow?.getBoundingClientRect().height || 40));
            const orderedHeight = Math.max(36, Math.ceil(orderedRow?.getBoundingClientRect().height || 40));
            tbl.style.setProperty('--dispatch-sticky-head-top', '0px');
            tbl.style.setProperty('--dispatch-sticky-head-height', `${headHeight}px`);
            tbl.style.setProperty('--dispatch-sticky-meta1-top', `${headHeight}px`);
            tbl.style.setProperty('--dispatch-sticky-meta2-top', `${headHeight + rateHeight}px`);
            tbl.style.setProperty('--dispatch-sticky-meta3-top', `${headHeight + rateHeight + orderedHeight}px`);

            // Dynamically align frozen-left columns after manual column resizing.
            const th0 = head.querySelector('.fixed-col-0');
            const th1 = head.querySelector('.fixed-col-1');
            const w0 = Math.max(40, Math.ceil(th0?.getBoundingClientRect().width || 60));
            const w1 = Math.max(60, Math.ceil(th1?.getBoundingClientRect().width || 96));
            tbl.style.setProperty('--dispatch-fixed-left-1', `${w0}px`);
            tbl.style.setProperty('--dispatch-fixed-left-2', `${w0 + w1}px`);
        }

        function dispatchSortBy(key) {
            if (!key) return;
            if (dispatchSheetState.sortKey === key) dispatchSheetState.sortAsc = !dispatchSheetState.sortAsc;
            else {
                dispatchSheetState.sortKey = key;
                dispatchSheetState.sortAsc = true;
            }
            renderDispatchReconciliation();
        }

        async function dispatchFilterBy(key) {
            const label = key === 'bill_no' ? 'Bill No.' : (key === 'dated' ? 'Dated' : 'Truck No.');
            const seed = key === 'bill_no' ? dispatchSheetState.filterBillNo : (key === 'dated' ? dispatchSheetState.filterDated : dispatchSheetState.filterTruckNo);
            const next = await customApplet({
                title: `Filter ${label}`,
                message: `Enter contains-filter for ${label}. Leave blank to clear.`,
                type: "prompt",
                placeholder: seed || ''
            });
            if (next === null) return;
            const val = String(next || '').trim();
            if (key === 'bill_no') dispatchSheetState.filterBillNo = val;
            else if (key === 'dated') dispatchSheetState.filterDated = val;
            else dispatchSheetState.filterTruckNo = val;
            renderDispatchReconciliation();
        }

        function hideDispatchContextMenu() {
            const menu = document.getElementById('dispatchContextMenu');
            if (menu) menu.style.display = 'none';
        }

        function dispatchContextInsertRow() {
            hideDispatchContextMenu();
            return addManualDispatchNewEntry();
        }

        function dispatchContextDeleteRow() {
            hideDispatchContextMenu();
            if (!dispatchSheetState.contextInvoiceNo) return customApplet({ title: "No Row Selected", message: "Right-click a dispatch row first." });
            return deleteDispatchMatrixRow(encodeURIComponent(dispatchSheetState.contextInvoiceNo));
        }

        function dispatchContextFormatCell() {
            hideDispatchContextMenu();
            if (!dispatchSheetState.contextCellEl) return;
            dispatchSheetState.contextCellEl.classList.toggle('cell-format-highlight');
        }

        function enhanceDispatchSpreadsheetInteractions() {
            const table = document.getElementById('dispatchUnifiedTable');
            const formulaInput = document.getElementById('dispatchFormulaInput');
            if (!table) return;

            const editableCells = Array.from(table.querySelectorAll('[contenteditable="true"]'));
            editableCells.forEach((cell) => {
                if (cell.getAttribute('data-editable-cell') === '1') return;
                cell.setAttribute('data-editable-cell', '1');
                cell.setAttribute('contenteditable', 'false');
                cell.addEventListener('dblclick', () => {
                    cell.setAttribute('contenteditable', 'true');
                    cell.focus();
                    document.execCommand?.('selectAll', false, null);
                    dispatchSheetState.activeCell = cell;
                    if (formulaInput) formulaInput.value = cell.innerText || '';
                });
                cell.addEventListener('focus', () => {
                    dispatchSheetState.activeCell = cell;
                    if (formulaInput) formulaInput.value = cell.innerText || '';
                });
                cell.addEventListener('input', () => {
                    if (formulaInput && dispatchSheetState.activeCell === cell) formulaInput.value = cell.innerText || '';
                });
                cell.addEventListener('blur', () => {
                    cell.setAttribute('contenteditable', 'false');
                });
                cell.addEventListener('contextmenu', (e) => {
                    e.preventDefault();
                    const menu = document.getElementById('dispatchContextMenu');
                    if (!menu) return;
                    dispatchSheetState.contextCellEl = cell;
                    dispatchSheetState.contextInvoiceNo = cell.getAttribute('data-invoice-no') || cell.closest('tr')?.getAttribute('data-invoice-no') || '';
                    menu.style.left = `${e.clientX + 4}px`;
                    menu.style.top = `${e.clientY + 4}px`;
                    menu.style.display = 'block';
                });
            });

            if (formulaInput && !formulaInput.dataset.bound) {
                formulaInput.dataset.bound = '1';
                formulaInput.addEventListener('keydown', (e) => {
                    if (e.key !== 'Enter') return;
                    const active = dispatchSheetState.activeCell;
                    if (!active) return;
                    e.preventDefault();
                    active.setAttribute('contenteditable', 'true');
                    active.innerText = formulaInput.value || '';
                    active.blur();
                });
            }

            if (!table.dataset.contextBound) {
                table.dataset.contextBound = '1';
                table.addEventListener('contextmenu', (e) => {
                    if (e.target.closest('[data-editable-cell="1"]')) return;
                    e.preventDefault();
                    const row = e.target.closest('tr');
                    const menu = document.getElementById('dispatchContextMenu');
                    if (!menu) return;
                    dispatchSheetState.contextCellEl = e.target.closest('td,th') || null;
                    dispatchSheetState.contextInvoiceNo = row?.getAttribute('data-invoice-no') || '';
                    menu.style.left = `${e.clientX + 4}px`;
                    menu.style.top = `${e.clientY + 4}px`;
                    menu.style.display = 'block';
                });
            }
            if (!document.body.dataset.dispatchCtxCloseBound) {
                document.body.dataset.dispatchCtxCloseBound = '1';
                document.addEventListener('click', (e) => {
                    if (!e.target.closest('#dispatchContextMenu')) hideDispatchContextMenu();
                });
            }
        }

        if (!window.__dispatchStickyResizeBound) {
            window.__dispatchStickyResizeBound = true;
            window.addEventListener('resize', () => requestAnimationFrame(updateDispatchStickyOffsets));
        }

        function resetDispatchSpreadsheetSizing() {
            dispatchResizeState.colWidths = {};
            dispatchResizeState.rowHeights = {};
            const poNo = (document.getElementById('dispatchPoSelect')?.value || '').trim();
            if (poNo) delete dispatchGridState.layoutByPo[poNo];
            if (poNo && currentClient) {
                const storageKey = `dispatchGridLayout:${currentClient}:${poNo}`;
                try {
                    localStorage.removeItem(storageKey);
                } catch (_) {
                    // Ignore storage access failures.
                }
            }
            if (dispatchGridState.gridApi?.resetColumnState) {
                dispatchGridState.gridApi.resetColumnState();
            }
            updateDispatchTableSizing();
            renderDispatchReconciliation();
        }

        function getDispatchColStyle(colIndex, fallbackPx) {
            const px = Number(dispatchResizeState.colWidths[colIndex] || fallbackPx || 120);
            return `width:${px}px; min-width:${px}px;`;
        }

        function getDispatchRowStyle(rowKey) {
            const px = Number(dispatchResizeState.rowHeights[rowKey] || 0);
            return px > 0 ? `height:${px}px;` : '';
        }

        function attachDispatchSpreadsheetResizers() {
            const table = document.getElementById('dispatchUnifiedTable');
            if (!table) return;
            const headCells = Array.from(table.querySelectorAll('#dispatchUnifiedHead th'));
            headCells.forEach((th, idx) => {
                if (th.querySelector('.resizer-col')) return;
                th.style.position = th.style.position || 'relative';
                const handle = document.createElement('span');
                handle.className = 'resizer-col';
                handle.title = 'Drag to resize column';
                handle.addEventListener('mousedown', (e) => {
                    e.preventDefault();
                    const startX = e.clientX;
                    const startW = th.getBoundingClientRect().width;
                    const move = (ev) => {
                        const next = Math.max(72, Math.round(startW + (ev.clientX - startX)));
                        dispatchResizeState.colWidths[idx] = next;
                        renderDispatchReconciliation();
                    };
                    const up = () => {
                        window.removeEventListener('mousemove', move);
                        window.removeEventListener('mouseup', up);
                    };
                    window.addEventListener('mousemove', move);
                    window.addEventListener('mouseup', up);
                });
                th.appendChild(handle);
            });

            const rows = Array.from(table.querySelectorAll('#dispatchUnifiedBody tr'));
            rows.forEach((tr) => {
                const rowKey = tr.getAttribute('data-row-key');
                if (!rowKey) return;
                if (tr.querySelector('.resizer-row')) return;
                tr.style.position = tr.style.position || 'relative';
                const handle = document.createElement('span');
                handle.className = 'resizer-row';
                handle.title = 'Drag to resize row';
                handle.addEventListener('mousedown', (e) => {
                    e.preventDefault();
                    const startY = e.clientY;
                    const startH = tr.getBoundingClientRect().height;
                    const move = (ev) => {
                        const next = Math.max(28, Math.round(startH + (ev.clientY - startY)));
                        dispatchResizeState.rowHeights[rowKey] = next;
                        tr.style.height = `${next}px`;
                    };
                    const up = () => {
                        window.removeEventListener('mousemove', move);
                        window.removeEventListener('mouseup', up);
                    };
                    window.addEventListener('mousemove', move);
                    window.addEventListener('mouseup', up);
                });
                tr.appendChild(handle);
            });
        }

        async function saveDispatchInlineCell(el) {
            return withInFlight(`saveDispatchInlineCell:${el?.getAttribute?.('data-invoice-no') || ''}:${el?.getAttribute?.('data-description') || ''}:${el?.getAttribute?.('data-uom') || ''}`, async () => {
            if (!el || !el.getAttribute || !el.getAttribute('data-dispatch-inline')) return;
            const invoiceNo = (el.getAttribute('data-invoice-no') || '').trim();
            const description = decodeHtmlEntities(el.getAttribute('data-description') || '').trim();
            const uom = decodeHtmlEntities(el.getAttribute('data-uom') || 'Nos').trim() || 'Nos';
            const original = Number(el.getAttribute('data-original') || 0);
            const raw = String(el.innerText || '').replace(/,/g, '').trim();
            const parsed = parseFloat(raw);

            if (!Number.isFinite(parsed) || parsed < 0) {
                el.innerText = formatNum(original, 2);
                customApplet({ title: "Validation Error", message: "Enter a valid non-negative quantity." });
                return;
            }
            const nextQty = Number(parsed.toFixed(2));
            if (Math.abs(nextQty - original) < 0.000001) {
                el.innerText = formatNum(original, 2);
                return;
            }

            const token = sessionStorage.getItem('erp_token');
            try {
                const response = await fetch('/api/dispatch-items/upsert-cell', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
                    body: JSON.stringify({
                        invoice_no: invoiceNo,
                        description,
                        uom,
                        qty: nextQty
                    })
                });
                const result = await response.json().catch(() => ({}));
                if (!response.ok) {
                    el.innerText = formatNum(original, 2);
                    return customApplet({ title: "Database Error", message: result.detail || "Failed to save inline dispatch cell." });
                }
                el.setAttribute('data-original', String(nextQty));
                el.innerText = formatNum(nextQty, 2);
                await silentDataRefresh();
                renderDispatchReconciliation();
            } catch (_) {
                el.innerText = formatNum(original, 2);
                customApplet({ title: "Save Error", message: "Unable to save inline value right now." });
            }
            });
        }

        async function persistSummaryBaseline(poNo, items) {
            const poData = appData[currentClient].poTerms[poNo];
            const token = sessionStorage.getItem('erp_token');
            const response = await fetch('/api/purchase-orders', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
                body: JSON.stringify({
                    client_id: appData[currentClient].sql_id,
                    po_no: poNo,
                    project_name: poData.projectName || null,
                    contact_person: poData.contactPerson || null,
                    adv_pct: poData.adv || 0,
                    ret_pct: poData.ret || 0,
                    ret_base: poData.base || 'basic',
                    tds_enabled: poData.tdsEnabled || false,
                    tds_rate: poData.tdsRate || 0,
                    tds_threshold: poData.tdsThreshold || 0,
                    baseline_items: items
                })
            });
            if (!response.ok) {
                const result = await response.json().catch(() => ({}));
                throw new Error(result.detail || "Failed to update summary material.");
            }
        }

        function editSummaryDescriptionCellEncoded(poNoEnc, descEnc, uomEnc) {
            const poNo = decodeURIComponent(String(poNoEnc || ''));
            const desc = decodeURIComponent(String(descEnc || ''));
            const uom = decodeURIComponent(String(uomEnc || 'Nos'));
            return editSummaryDescriptionCell(poNo, desc, uom);
        }

        async function saveSummaryDescriptionInline(el) {
            return withInFlight(`saveSummaryDescriptionInline:${el?.getAttribute?.('data-po-no') || ''}:${el?.getAttribute?.('data-description') || ''}:${el?.getAttribute?.('data-uom') || ''}`, async () => {
            if (!el || !el.getAttribute || !el.getAttribute('data-summary-desc-inline')) return;
            const poNo = (el.getAttribute('data-po-no') || '').trim();
            const currentDesc = decodeHtmlEntities(el.getAttribute('data-description') || '').trim();
            const currentUom = decodeHtmlEntities(el.getAttribute('data-uom') || 'Nos').trim() || 'Nos';
            const original = (el.getAttribute('data-original') || '').trim();
            const nextDesc = String(el.innerText || '').trim();
            if (!poNo) return;
            if (!nextDesc) {
                el.innerText = original;
                return customApplet({ title: "Validation Error", message: "Description is required." });
            }
            if (nextDesc === original) return;

            const token = sessionStorage.getItem('erp_token');
            try {
                const res = await fetch('/api/dispatch-columns/rename', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
                    body: JSON.stringify({
                        po_no: poNo,
                        client_id: appData[currentClient]?.sql_id || null,
                        old_description: currentDesc,
                        old_uom: currentUom,
                        new_description: nextDesc,
                        new_uom: currentUom
                    })
                });
                if (!res.ok) {
                    const err = await res.json().catch(() => ({}));
                    el.innerText = original;
                    return customApplet({ title: "Database Error", message: err.detail || "Failed to update description." });
                }
                const result = await res.json().catch(() => ({}));
                await refreshCurrentDispatchContext();
                const mergedDispatch = Number(result.dispatch_merged || 0);
                const mergedBaseline = Number(result.baseline_merged || 0);
                if (mergedDispatch > 0 || mergedBaseline > 0) {
                    await customApplet({
                        title: "Merged Successfully",
                        message: `Combined ${mergedBaseline + mergedDispatch} duplicate row(s) into "${nextDesc}".`
                    });
                }
            } catch (err) {
                el.innerText = original;
                return customApplet({ title: "Database Error", message: err.message || "Failed to update description." });
            }
            });
        }

        async function editSummaryDescriptionCell(poNo, currentDesc, currentUom) {
            return withInFlight(`editSummaryDesc:${poNo}:${currentDesc}`, async () => {
                if (!poNo) return;
                const targetUom = String(currentUom || 'Nos').trim() || 'Nos';

                const nextDescRaw = await customApplet({
                    title: "Edit Material Description",
                    message: `Update material description for PO ${poNo}:`,
                    type: "prompt",
                    placeholder: currentDesc || ''
                });
                if (nextDescRaw === null) return;
                const nextDesc = String(nextDescRaw || '').trim();
                if (!nextDesc) return await customApplet({ title: "Validation Error", message: "Description is required." });
                if (nextDesc === currentDesc) return;

                const token = sessionStorage.getItem('erp_token');
                try {
                    const res = await fetch('/api/dispatch-columns/rename', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
                        body: JSON.stringify({
                            po_no: poNo,
                            client_id: appData[currentClient]?.sql_id || null,
                            old_description: currentDesc,
                            old_uom: targetUom,
                            new_description: nextDesc,
                            new_uom: targetUom
                        })
                    });
                    if (!res.ok) {
                        const err = await res.json().catch(() => ({}));
                        return customApplet({ title: "Database Error", message: err.detail || "Failed to update summary material." });
                    }
                    const result = await res.json().catch(() => ({}));
                    await refreshCurrentDispatchContext();
                    const mergedDispatch = Number(result.dispatch_merged || 0);
                    const mergedBaseline = Number(result.baseline_merged || 0);
                    if (mergedDispatch > 0 || mergedBaseline > 0) {
                        await customApplet({
                            title: "Merged Successfully",
                            message: `Combined ${mergedBaseline + mergedDispatch} duplicate row(s) into "${nextDesc}".`
                        });
                    }
                } catch (err) {
                    return customApplet({ title: "Database Error", message: err.message || "Failed to update summary material." });
                }
            });
        }

        function editSummaryOrderedCellEncoded(poNoEnc, descEnc, currentOrdered, uomEnc) {
            const poNo = decodeURIComponent(String(poNoEnc || ''));
            const desc = decodeURIComponent(String(descEnc || ''));
            const uom = decodeURIComponent(String(uomEnc || 'Nos'));
            return editSummaryOrderedCell(poNo, desc, Number(currentOrdered || 0), uom);
        }

        async function saveSummaryOrderedInline(el) {
            return withInFlight(`saveSummaryOrderedInline:${el?.getAttribute?.('data-po-no') || ''}:${el?.getAttribute?.('data-description') || ''}:${el?.getAttribute?.('data-uom') || ''}`, async () => {
            if (!el || !el.getAttribute || !el.getAttribute('data-summary-ordered-inline')) return;
            const poNo = (el.getAttribute('data-po-no') || '').trim();
            const currentDesc = decodeHtmlEntities(el.getAttribute('data-description') || '').trim();
            const currentUom = decodeHtmlEntities(el.getAttribute('data-uom') || 'Nos').trim() || 'Nos';
            const original = Number(el.getAttribute('data-original') || 0);
            const parsed = parseFloat(String(el.innerText || '').replace(/,/g, '').trim());
            if (!poNo) return;
            if (!Number.isFinite(parsed) || parsed < 0) {
                el.innerText = formatNum(original, 2);
                return customApplet({ title: "Validation Error", message: "Please enter a valid non-negative ordered quantity." });
            }
            const nextOrdered = Number(parsed.toFixed(2));
            if (Math.abs(nextOrdered - original) < 0.000001) return;
            if (!appData[currentClient].poTerms[poNo]) appData[currentClient].poTerms[poNo] = { baselineItems: [] };
            const items = appData[currentClient].poTerms[poNo].baselineItems || [];
            const oldNorm = normalizeDispatchDesc(currentDesc);
            let idx = items.findIndex(i => normalizeDispatchDesc(i.description || '') === oldNorm && String(i.uom || 'Nos').trim().toUpperCase() === currentUom.toUpperCase());
            if (idx < 0) {
                items.push({ description: currentDesc, ordered_qty: 0, inspected_qty: 0, uom: currentUom, material_type: null, dispatch_alias: null, dispatch_rate: 0 });
                idx = items.length - 1;
            }
            const updatedItems = items.map(it => ({ ...it }));
            updatedItems[idx].ordered_qty = nextOrdered;
            appData[currentClient].poTerms[poNo].baselineItems = updatedItems;
            try {
                await persistSummaryBaseline(poNo, updatedItems);
            } catch (err) {
                el.innerText = formatNum(original, 2);
                return customApplet({ title: "Database Error", message: err.message || "Failed to update ordered quantity." });
            }
            await silentDataRefresh();
            renderDispatchReconciliation();
            });
        }

