            box-shadow: 0 4px 10px rgba(15, 23, 42, 0.11), inset 0 1px 0 rgba(255, 255, 255, 0.6) !important;
            -webkit-backdrop-filter: blur(6px) saturate(1.06);
            backdrop-filter: blur(6px) saturate(1.06);
            will-change: transform;
