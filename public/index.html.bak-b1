        /* =========================================================
           Manufacturing UI Overhaul Layer (safe visual overrides)
           ========================================================= */
        :root {
            --brand-primary: #1f2937;
            --brand-secondary: #f59e0b;
            --brand-hover: #374151;
            --sidebar-bg: #111827;
            --sidebar-text: #d1d5db;
            --sidebar-hover: #1f2937;
            --bg-body: #f3f4f6;
            --bg-surface: #ffffff;
            --text-main: #1f2937;
            --text-muted: #6b7280;
            --text-dark: #111827;
            --border: #d1d5db;
            --border-dark: #9ca3af;
            --shadow-sm: 0 1px 2px rgba(17,24,39,0.08);
            --shadow-md: 0 8px 20px rgba(17,24,39,0.12);
            --shadow-lg: 0 18px 36px rgba(17,24,39,0.16);
        }

        body {
            background:
                linear-gradient(rgba(17,24,39,0.025) 1px, transparent 1px),
                linear-gradient(90deg, rgba(17,24,39,0.025) 1px, transparent 1px),
                var(--bg-body);
            background-size: 18px 18px, 18px 18px, auto;
        }

        .sidebar {
            border-right: 1px solid rgba(245,158,11,0.18);
            box-shadow: 4px 0 18px rgba(0,0,0,0.24);
        }

        .sidebar-header {
            background: linear-gradient(90deg, rgba(245,158,11,0.16), rgba(245,158,11,0.03));
            border-bottom: 1px solid rgba(245,158,11,0.2);
        }

        .topbar {
            background: linear-gradient(180deg, #ffffff 0%, #f9fafb 100%);
            border-bottom: 1px solid #cbd5e1;
            box-shadow: 0 1px 0 rgba(255,255,255,0.9), 0 2px 6px rgba(17,24,39,0.05);
        }

        .topbar h1 {
            font-weight: 800;
            letter-spacing: -0.35px;
        }

        .card {
            border: 1px solid #cbd5e1;
            box-shadow: var(--shadow-sm);
        }

        .card::before {
            height: 4px;
            background: linear-gradient(90deg, #111827 0%, #374151 55%, #f59e0b 100%);
            opacity: 1;
        }

        .kpi-card {
            border-color: #cbd5e1;
            background: linear-gradient(180deg, #ffffff 0%, #f9fafb 100%);
        }

        .kpi-label {
            color: #4b5563;
            letter-spacing: 0.8px;
        }

        .btn-primary {
            background: linear-gradient(180deg, #374151 0%, #1f2937 100%);
            border-color: #111827;
        }

        .btn-primary:hover {
            background: linear-gradient(180deg, #4b5563 0%, #374151 100%);
            box-shadow: 0 7px 14px rgba(17,24,39,0.24);
        }

        .btn-outline {
            background: #ffffff;
            border-color: #9ca3af;
            color: #1f2937;
        }

        .btn-outline:hover {
            background: #f3f4f6;
            border-color: #6b7280;
        }

        input:not([type="checkbox"]), select {
            background: #ffffff;
            border-color: #9ca3af;
            box-shadow: inset 0 1px 2px rgba(17,24,39,0.05);
        }

        input:focus-visible, select:focus-visible, .multi-select-box:focus-visible {
            outline: 2px solid rgba(245,158,11,0.42);
        }

        .table-wrapper table thead th,
        #dispatchView .dispatch-table thead th,
        #reportsView table thead th {
            background: repeating-linear-gradient(
                135deg,
                #e5e7eb 0,
                #e5e7eb 12px,
                #d1d5db 12px,
                #d1d5db 24px
            ) !important;
            color: #111827 !important;
            border-bottom: 2px solid #9ca3af !important;
            text-transform: uppercase;
            font-size: 0.72rem;
            letter-spacing: 0.6px;
        }

        .table-wrapper tbody tr:hover,
        #dispatchView .dispatch-table tbody tr:hover {
            background: #eef2f7 !important;
        }

        td[style*="text-align: right"] {
            font-variant-numeric: tabular-nums;
            font-feature-settings: "tnum" 1;
        }

        .status-pill {
            border-width: 1px;
            font-weight: 700;
        }

        #dispatchView .dispatch-snapshot .dispatch-stat {
            border: 1px solid #d1d5db;
            background: linear-gradient(180deg, #fff 0%, #f9fafb 100%);
        }

        #dispatchView .dispatch-stat-value {
            color: #1f2937;
            font-weight: 800;
        }

        .modal-overlay .modal-content {
            border: 1px solid #cbd5e1;
            box-shadow: 0 26px 46px rgba(17,24,39,0.26);
        }
    </style>
    <style>
