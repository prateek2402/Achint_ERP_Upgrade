            box-shadow: 0 10px 18px rgba(15, 23, 42, 0.10), inset 0 1px 0 rgba(255, 255, 255, 0.55) !important;
            -webkit-backdrop-filter: blur(8px) saturate(1.08);
            backdrop-filter: blur(8px) saturate(1.08);
            contain: paint;
